@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject UserTimeZoneService UserTimeZone
@inject PageTitleService PageTitle
@implements IDisposable

<AuthorizeView>
    <Authorized>
        <div class="layout-container">
            <NavMenu />

            <div class="flex-grow-1 d-flex flex-column min-width-0">
                <!-- Top Navbar -->
                <header class="navbar-top">
                    <div class="d-flex align-items-center">
                        <button class="btn d-md-none border-0 p-1 me-2 text-dark" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebar" aria-controls="sidebar">
                            <i class="bi bi-list fs-3"></i>
                        </button>
                        <h4 class="navbar-top-title">@PageTitle.Title</h4>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <a href="/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                            <i class="bi bi-house-door-fill me-1"></i> Home
                        </a>
                        <a class="btn btn-outline-danger btn-sm rounded-pill px-3" href="/auth/logout">
                            <i class="bi bi-box-arrow-right me-1"></i> Sign Out
                        </a>
                    </div>
                </header>

                <!-- Body Area -->
                <main class="flex-grow-1 p-4 overflow-auto" style="height: calc(100vh - 64px); background-color: var(--surface-bg);">
                    <ImpersonationBanner />
                    @Body
                </main>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        @Body
    </NotAuthorized>
</AuthorizeView>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    protected override void OnInitialized()
    {
        PageTitle.OnTitleChanged += StateHasChanged;
    }

    public void Dispose()
    {
        PageTitle.OnTitleChanged -= StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !UserTimeZone.TimeZoneOffset.HasValue)
        {
            try
            {
                var offset = await JS.InvokeAsync<int>("getBrowserTimezoneOffset");
                UserTimeZone.TimeZoneOffset = offset;
                StateHasChanged();
            }
            catch
            {
                // Silence JS errors during early/non-interactive rendering
            }
        }
    }
}
