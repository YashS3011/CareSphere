@using CareSphere.Modules.Clinical.Services
@using CareSphere.Modules.Laboratory.Services
@using CareSphere.Modules.Pharmacy.Services
@using CareSphere.Modules.Billing.Services
@using CareSphere.Modules.Patients.Services
@using CareSphere.Modules.Ward.Services
@using CareSphere.Modules.Notifications.Services
@using CareSphere.Modules.Admin.Services
@using CareSphere.Modules.Shared.Services
@using CareSphere.Models
@inject IServiceScopeFactory ScopeFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject ITenantContext TenantContext
@implements IDisposable

<div class="dropdown me-3" style="position: relative;">
    <button class="btn btn-link link-dark position-relative p-1 text-decoration-none" @onclick="ToggleDropdown">
        <i class="bi bi-bell fs-5"></i>
        @if (unreadCount > 0)
        {
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem; padding: 0.25em 0.5em;">
                @unreadCount
            </span>
        }
    </button>

    @if (showDropdown)
    {
        <div class="dropdown-menu dropdown-menu-end show shadow-sm p-0 rounded-3" style="position: absolute; right: 0; top: 100%; min-width: 320px; z-index: 1050; max-height: 400px; overflow-y: auto; display: block;">
            <div class="p-2 border-bottom bg-light d-flex justify-content-between align-items-center">
                <span class="fw-bold small text-muted">Notifications</span>
                @if (unreadCount > 0)
                {
                    <span class="badge bg-primary rounded-pill small">@unreadCount New</span>
                }
            </div>
            
            @if (notifications == null || !notifications.Any())
            {
                <div class="p-3 text-center text-muted small">
                    No new notifications
                </div>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var notif in notifications)
                    {
                        <div class="list-group-item list-group-item-action p-2">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="pe-2">
                                    <h6 class="mb-1 fw-bold text-dark fs-7">@notif.Title</h6>
                                    <p class="mb-1 text-muted fs-8">@notif.Message</p>
                                    <small class="text-muted fs-9">@notif.CreatedAt.ToLocalTime().ToString("g")</small>
                                </div>
                                <button class="btn btn-sm btn-outline-secondary border-0 p-1" title="Mark as Read" @onclick="() => MarkAsRead(notif.Id)">
                                    <i class="bi bi-check2"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private List<InAppNotification>? notifications;
    private int unreadCount = 0;
    private bool showDropdown = false;
    private System.Timers.Timer? timer;
    private bool _isDisposed = false;

    // Resolved from auth claims at initialization; no longer passed as hard-coded parameters.
    private string _recipientType = "User";
    private string _recipientId = "00000000-0000-0000-0000-000000000000";

    protected override async Task OnInitializedAsync()
    {
        // Resolve the current user's identity to set RecipientType and RecipientId.
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var role = CurrentUserHelper.GetUserRole(user) ?? string.Empty;
            var doctorId = CurrentUserHelper.GetDoctorId(user);
            var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                         ?? "00000000-0000-0000-0000-000000000000";

            if (role == CareSphereRoles.Doctor && doctorId.HasValue)
            {
                _recipientType = "Doctor";
                _recipientId = doctorId.Value.ToString();
            }
            else if (role == CareSphereRoles.Nurse)
            {
                _recipientType = "Nurse";
                _recipientId = userId;
            }
            else
            {
                _recipientType = "User";
                _recipientId = userId;
            }
        }

        await LoadNotifications();

        // Refresh every 60 seconds
        timer = new System.Timers.Timer(60000);
        timer.Elapsed += async (s, e) => 
        {
            if (_isDisposed) return;
            await InvokeAsync(async () =>
            {
                if (_isDisposed) return;
                await LoadNotifications();
                StateHasChanged();
            });
        };
        timer.Start();
    }

    private async Task LoadNotifications()
    {
        if (_isDisposed) return;
        try
        {
            using (var scope = ScopeFactory.CreateScope())
            {
                // Propagate the tenant context into the child scope so DB query filters work.
                var scopedTenant = scope.ServiceProvider.GetRequiredService<ITenantContext>();
                scopedTenant.SetTenantId(TenantContext.TenantId);

                var notificationService = scope.ServiceProvider.GetRequiredService<ILabNotificationService>();
                unreadCount = await notificationService.GetNotificationCountAsync(_recipientType, _recipientId);
                notifications = await notificationService.GetUnreadNotificationsAsync(_recipientType, _recipientId);
            }
        }
        catch (Exception ex)
        {
            if (!_isDisposed)
            {
                Console.WriteLine($"[NotificationsPanel] Error loading notifications: {ex.Message}");
            }
        }
    }

    private void ToggleDropdown()
    {
        showDropdown = !showDropdown;
    }

    private async Task MarkAsRead(Guid notificationId)
    {
        if (_isDisposed) return;
        try
        {
            using (var scope = ScopeFactory.CreateScope())
            {
                var scopedTenant = scope.ServiceProvider.GetRequiredService<ITenantContext>();
                scopedTenant.SetTenantId(TenantContext.TenantId);

                var notificationService = scope.ServiceProvider.GetRequiredService<ILabNotificationService>();
                await notificationService.MarkNotificationReadAsync(notificationId);
            }
            await LoadNotifications();
            if (unreadCount == 0)
            {
                showDropdown = false;
            }
        }
        catch (Exception ex)
        {
            if (!_isDisposed)
            {
                Console.WriteLine($"[NotificationsPanel] Error marking notification read: {ex.Message}");
            }
        }
    }

    public void Dispose()
    {
        _isDisposed = true;
        if (timer != null)
        {
            timer.Stop();
            timer.Dispose();
        }
    }
}

<style>
    .fs-7 { font-size: 0.85rem !important; }
    .fs-8 { font-size: 0.78rem !important; }
    .fs-9 { font-size: 0.72rem !important; }
</style>
