@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<aside class="sidebar-system offcanvas-md offcanvas-start @(isSidebarCollapsed ? "sidebar-collapsed" : "")" id="sidebar" tabindex="-1">
    <!-- Brand / Header -->
    <div class="sidebar-header">
        <div class="module-icon-badge">
            <i class="bi bi-heart-pulse-fill text-white"></i>
        </div>
        <AuthorizeView Context="userContext">
            <Authorized>
                <span class="sidebar-header-text">@(userContext.User.FindFirst("target_hospital_name")?.Value ?? "CareSphere")</span>
            </Authorized>
        </AuthorizeView>
        <button class="btn btn-sm text-white ms-auto d-none d-md-block" type="button" @onclick="ToggleSidebar">
            <i class="bi bi-list fs-5"></i>
        </button>
    </div>

    <!-- Navigation List -->
    <nav class="sidebar-nav">
        <!-- Dashboard — any authenticated user -->
        <AuthorizeView>
            <Authorized>
                <NavLink class="sidebar-link" href="/dashboard" Match="NavLinkMatch.All" ActiveClass="sidebar-link-active">
                    <i class="bi bi-speedometer2"></i>
                    <span class="sidebar-text">Dashboard</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        <!-- CLINICAL & CORE SECTION -->
        <AuthorizeView>
            <Authorized>
                @if (HasClinicalOrCoreAccess(context.User))
                {
                    <small class="text-muted px-3 mt-3 mb-1 fw-bold text-uppercase d-block" style="font-size: 0.65rem; letter-spacing: 0.05em; opacity: 0.8;">Clinical &amp; Core</small>
                }
            </Authorized>
        </AuthorizeView>

        <!-- Patients -->
        <AuthorizeView Policy="@PolicyNames.Permission_Patients_View">
            <Authorized>
                <NavLink class="sidebar-link" href="/patients" Match="NavLinkMatch.All" ActiveClass="sidebar-link-active">
                    <i class="bi bi-people-fill"></i>
                    <span class="sidebar-text">Patient List</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Patients_Create">
            <Authorized>
                <NavLink class="sidebar-link" href="/patients/create" ActiveClass="sidebar-link-active">
                    <i class="bi bi-person-plus-fill"></i>
                    <span class="sidebar-text">Register Patient</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Patients_Edit">
            <Authorized>
                <NavLink class="sidebar-link" href="/patients/preferences" ActiveClass="sidebar-link-active">
                    <i class="bi bi-sliders"></i>
                    <span class="sidebar-text">Patient Preferences</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        <!-- Appointments -->
        <AuthorizeView Policy="@PolicyNames.Permission_Appointments_View">
            <Authorized>
                <NavLink class="sidebar-link" href="/appointments" Match="NavLinkMatch.All" ActiveClass="sidebar-link-active">
                    <i class="bi bi-calendar-event"></i>
                    <span class="sidebar-text">Appointments</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Appointments_Book">
            <Authorized>
                <NavLink class="sidebar-link" href="/appointments/book" ActiveClass="sidebar-link-active">
                    <i class="bi bi-plus-circle"></i>
                    <span class="sidebar-text">Book Appointment</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_DoctorSchedule_Manage">
            <Authorized>
                <NavLink class="sidebar-link" href="/appointments/schedules" ActiveClass="sidebar-link-active">
                    <i class="bi bi-calendar-week"></i>
                    <span class="sidebar-text">Doctor Schedules</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        <!-- Bed & Ward -->
        <AuthorizeView Policy="@PolicyNames.Permission_Beds_View">
            <Authorized>
                <NavLink class="sidebar-link" href="/beds/dashboard" ActiveClass="sidebar-link-active">
                    <i class="bi bi-hospital"></i>
                    <span class="sidebar-text">Bed Dashboard</span>
                </NavLink>
                <NavLink class="sidebar-link" href="/wards" Match="NavLinkMatch.All" ActiveClass="sidebar-link-active">
                    <i class="bi bi-building"></i>
                    <span class="sidebar-text">Ward List</span>
                </NavLink>
                <NavLink class="sidebar-link" href="/beds" Match="NavLinkMatch.All" ActiveClass="sidebar-link-active">
                    <i class="bi bi-bed"></i>
                    <span class="sidebar-text">Bed List</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Beds_Manage">
            <Authorized>
                <NavLink class="sidebar-link" href="/wards/create" ActiveClass="sidebar-link-active">
                    <i class="bi bi-plus-circle"></i>
                    <span class="sidebar-text">Add Ward</span>
                </NavLink>
                <NavLink class="sidebar-link" href="/beds/create" ActiveClass="sidebar-link-active">
                    <i class="bi bi-plus-circle-fill"></i>
                    <span class="sidebar-text">Add Bed</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_BedAllotment_View">
            <Authorized>
                <NavLink class="sidebar-link" href="/allotments" Match="NavLinkMatch.All" ActiveClass="sidebar-link-active">
                    <i class="bi bi-journal-medical"></i>
                    <span class="sidebar-text">Allotments</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Beds_Allocate">
            <Authorized>
                <NavLink class="sidebar-link" href="/allotments/create" ActiveClass="sidebar-link-active">
                    <i class="bi bi-person-plus"></i>
                    <span class="sidebar-text">New Admission</span>
                </NavLink>
                <NavLink class="sidebar-link" href="/allotments/transfer" ActiveClass="sidebar-link-active">
                    <i class="bi bi-arrow-left-right"></i>
                    <span class="sidebar-text">Transfer Patient</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        <!-- Clinical / Doctor -->
        <AuthorizeView Policy="@PolicyNames.Permission_Queue_View">
            <Authorized>
                @if (doctorId != Guid.Empty)
                {
                    <NavLink class="sidebar-link" href="@($"/doctor/queue/{doctorId}")" Match="NavLinkMatch.All" ActiveClass="sidebar-link-active">
                        <i class="bi bi-clock"></i>
                        <span class="sidebar-text">My Queue</span>
                    </NavLink>
                }
                else
                {
                    <NavLink class="sidebar-link" href="/doctor/queue" Match="NavLinkMatch.All" ActiveClass="sidebar-link-active">
                        <i class="bi bi-clock"></i>
                        <span class="sidebar-text">Doctor Queue</span>
                    </NavLink>
                }
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Encounters_Create">
            <Authorized>
                <NavLink class="sidebar-link" href="/encounter/new" ActiveClass="sidebar-link-active">
                    <i class="bi bi-clipboard-plus"></i>
                    <span class="sidebar-text">New Encounter</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Encounters_View">
            <Authorized>
                <NavLink class="sidebar-link" href="/encounters" Match="NavLinkMatch.All" ActiveClass="sidebar-link-active">
                    <i class="bi bi-clipboard2-pulse"></i>
                    <span class="sidebar-text">Encounters</span>
                </NavLink>
                <NavLink class="sidebar-link" href="/prescriptions" Match="NavLinkMatch.All" ActiveClass="sidebar-link-active">
                    <i class="bi bi-prescription2"></i>
                    <span class="sidebar-text">Prescriptions</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_TeleConsult_Start">
            <Authorized>
                <NavLink class="sidebar-link" href="/teleconsult" Match="NavLinkMatch.All" ActiveClass="sidebar-link-active">
                    <i class="bi bi-camera-video"></i>
                    <span class="sidebar-text">Teleconsult</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        <!-- Nursing -->
        <AuthorizeView Policy="@PolicyNames.Permission_Vitals_View">
            <Authorized>
                <NavLink class="sidebar-link" href="/nursing" Match="NavLinkMatch.All" ActiveClass="sidebar-link-active">
                    <i class="bi bi-heart-pulse"></i>
                    <span class="sidebar-text">Nursing Dashboard</span>
                </NavLink>
                <NavLink class="sidebar-link" href="/nursing/vitals" ActiveClass="sidebar-link-active">
                    <i class="bi bi-activity"></i>
                    <span class="sidebar-text">Vitals</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_NursingNotes_View">
            <Authorized>
                <NavLink class="sidebar-link" href="/nursing/notes" ActiveClass="sidebar-link-active">
                    <i class="bi bi-clipboard-pulse"></i>
                    <span class="sidebar-text">Nursing Notes</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_MedicationAdmin_View">
            <Authorized>
                <NavLink class="sidebar-link" href="/nursing/mar" ActiveClass="sidebar-link-active">
                    <i class="bi bi-capsule"></i>
                    <span class="sidebar-text">MAR</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        <!-- DIAGNOSTIC & SUPPORT SECTION -->
        <AuthorizeView>
            <Authorized>
                @if (HasDiagnosticAccess(context.User))
                {
                    <small class="text-muted px-3 mt-3 mb-1 fw-bold text-uppercase d-block" style="font-size: 0.65rem; letter-spacing: 0.05em; opacity: 0.8;">Diagnostic &amp; Support</small>
                }
            </Authorized>
        </AuthorizeView>

        <!-- Laboratory -->
        <AuthorizeView Policy="@PolicyNames.Permission_Lab_ViewReports">
            <Authorized>
                <NavLink class="sidebar-link" href="/lab/dashboard" Match="NavLinkMatch.All" ActiveClass="sidebar-link-active">
                    <i class="bi bi-droplet"></i>
                    <span class="sidebar-text">Lab Dashboard</span>
                </NavLink>
                <NavLink class="sidebar-link" href="/laboratory/catalog" ActiveClass="sidebar-link-active">
                    <i class="bi bi-list-task"></i>
                    <span class="sidebar-text">Test Catalog</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Lab_OrderTests">
            <Authorized>
                <NavLink class="sidebar-link" href="/laboratory/requisitions" ActiveClass="sidebar-link-active">
                    <i class="bi bi-journal-text"></i>
                    <span class="sidebar-text">Requisitions</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Lab_CollectSample">
            <Authorized>
                <NavLink class="sidebar-link" href="/laboratory/samples" ActiveClass="sidebar-link-active">
                    <i class="bi bi-droplet"></i>
                    <span class="sidebar-text">Sample Collection</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Lab_EnterResults">
            <Authorized>
                <NavLink class="sidebar-link" href="/laboratory/results" ActiveClass="sidebar-link-active">
                    <i class="bi bi-clipboard-data"></i>
                    <span class="sidebar-text">Result Entry</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        <!-- Pharmacy -->
        <AuthorizeView Policy="@PolicyNames.Permission_Pharmacy_ViewStock">
            <Authorized>
                <NavLink class="sidebar-link" href="/pharmacy/dashboard" Match="NavLinkMatch.All" ActiveClass="sidebar-link-active">
                    <i class="bi bi-capsule-pill"></i>
                    <span class="sidebar-text">Pharmacy Dashboard</span>
                </NavLink>
                <NavLink class="sidebar-link" href="/pharmacy/items" ActiveClass="sidebar-link-active">
                    <i class="bi bi-box-seam"></i>
                    <span class="sidebar-text">Drug Catalog</span>
                </NavLink>
                <NavLink class="sidebar-link" href="/pharmacy/stock-ledger" ActiveClass="sidebar-link-active">
                    <i class="bi bi-journal-bookmark"></i>
                    <span class="sidebar-text">Stock Ledger</span>
                </NavLink>
                <NavLink class="sidebar-link" href="/pharmacy/expiry-alerts" ActiveClass="sidebar-link-active">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span class="sidebar-text">Expiry Alerts</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Pharmacy_ManagePO">
            <Authorized>
                <NavLink class="sidebar-link" href="/pharmacy/po" ActiveClass="sidebar-link-active">
                    <i class="bi bi-file-earmark-text"></i>
                    <span class="sidebar-text">Purchase Orders</span>
                </NavLink>
                <NavLink class="sidebar-link" href="/pharmacy/grn" ActiveClass="sidebar-link-active">
                    <i class="bi bi-truck"></i>
                    <span class="sidebar-text">Goods Received</span>
                </NavLink>
                <NavLink class="sidebar-link" href="/pharmacy/suppliers" ActiveClass="sidebar-link-active">
                    <i class="bi bi-people"></i>
                    <span class="sidebar-text">Suppliers</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Pharmacy_Dispense">
            <Authorized>
                <NavLink class="sidebar-link" href="/pharmacy/dispense" ActiveClass="sidebar-link-active">
                    <i class="bi bi-prescription2"></i>
                    <span class="sidebar-text">Dispense Rx</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Pharmacy_OtcSale">
            <Authorized>
                <NavLink class="sidebar-link" href="/pharmacy/otc-sale" ActiveClass="sidebar-link-active">
                    <i class="bi bi-shop"></i>
                    <span class="sidebar-text">OTC POS</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Pharmacy_ManageInventory">
            <Authorized>
                <NavLink class="sidebar-link" href="/pharmacy/controlled-register" ActiveClass="sidebar-link-active">
                    <i class="bi bi-shield-lock"></i>
                    <span class="sidebar-text">CS Register</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        <!-- FINANCE & BILLING SECTION -->
        <AuthorizeView>
            <Authorized>
                @if (HasBillingAccess(context.User))
                {
                    <small class="text-muted px-3 mt-3 mb-1 fw-bold text-uppercase d-block" style="font-size: 0.65rem; letter-spacing: 0.05em; opacity: 0.8;">Finance &amp; Billing</small>
                }
            </Authorized>
        </AuthorizeView>

        <!-- Billing -->
        <AuthorizeView Policy="@PolicyNames.Permission_Billing_View">
            <Authorized>
                <NavLink class="sidebar-link" href="/billing/dashboard" Match="NavLinkMatch.All" ActiveClass="sidebar-link-active">
                    <i class="bi bi-wallet2"></i>
                    <span class="sidebar-text">Billing Dashboard</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Billing_ViewInvoices">
            <Authorized>
                <NavLink class="sidebar-link" href="/billing/invoices" ActiveClass="sidebar-link-active">
                    <i class="bi bi-file-earmark-spreadsheet"></i>
                    <span class="sidebar-text">Invoices</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Payments_Manage">
            <Authorized>
                <NavLink class="sidebar-link" href="/billing/payments" ActiveClass="sidebar-link-active">
                    <i class="bi bi-credit-card"></i>
                    <span class="sidebar-text">Payments</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_InsuranceClaims_View">
            <Authorized>
                <NavLink class="sidebar-link" href="/billing/claims" ActiveClass="sidebar-link-active">
                    <i class="bi bi-shield-check"></i>
                    <span class="sidebar-text">Insurance Claims</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        <!-- SYSTEM & MANAGEMENT SECTION -->
        <AuthorizeView>
            <Authorized>
                @if (HasAdminAccess(context.User))
                {
                    <small class="text-muted px-3 mt-3 mb-1 fw-bold text-uppercase d-block" style="font-size: 0.65rem; letter-spacing: 0.05em; opacity: 0.8;">System &amp; Administration</small>
                }
            </Authorized>
        </AuthorizeView>

        <!-- Notifications -->
        <AuthorizeView Policy="@PolicyNames.Permission_Admin_ManageTenant">
            <Authorized>
                <NavLink class="sidebar-link" href="/notifications/dashboard" Match="NavLinkMatch.All" ActiveClass="sidebar-link-active">
                    <i class="bi bi-bell-fill"></i>
                    <span class="sidebar-text">Notif Dashboard</span>
                </NavLink>
                <NavLink class="sidebar-link" href="/notifications/templates" ActiveClass="sidebar-link-active">
                    <i class="bi bi-file-earmark-text-fill"></i>
                    <span class="sidebar-text">Alert Templates</span>
                </NavLink>
                <NavLink class="sidebar-link" href="/notifications/logs" ActiveClass="sidebar-link-active">
                    <i class="bi bi-clock-history"></i>
                    <span class="sidebar-text">Notification Logs</span>
                </NavLink>
                <NavLink class="sidebar-link" href="/notifications/reminders" ActiveClass="sidebar-link-active">
                    <i class="bi bi-calendar-event"></i>
                    <span class="sidebar-text">Scheduled Reminders</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        <!-- Analytics -->
        <AuthorizeView Policy="@PolicyNames.Permission_Analytics_View">
            <Authorized>
                <NavLink class="sidebar-link" href="/admin/analytics" ActiveClass="sidebar-link-active">
                    <i class="bi bi-graph-up-arrow"></i>
                    <span class="sidebar-text">Analytics</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>

        <!-- Administration -->
        <AuthorizeView Policy="@PolicyNames.Permission_Admin_ManageUsers">
            <Authorized>
                <NavLink class="sidebar-link" href="/admin/users" Match="NavLinkMatch.All" ActiveClass="sidebar-link-active">
                    <i class="bi bi-people"></i>
                    <span class="sidebar-text">Users</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Admin_ManageRoles">
            <Authorized>
                <NavLink class="sidebar-link" href="/admin/roles" ActiveClass="sidebar-link-active">
                    <i class="bi bi-shield-lock"></i>
                    <span class="sidebar-text">Roles &amp; Perms</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Admin_ViewAuditLog">
            <Authorized>
                <NavLink class="sidebar-link" href="/admin/sessions" ActiveClass="sidebar-link-active">
                    <i class="bi bi-person-lines-fill"></i>
                    <span class="sidebar-text">Sessions</span>
                </NavLink>
                <NavLink class="sidebar-link" href="/admin/audit-log" ActiveClass="sidebar-link-active">
                    <i class="bi bi-journal-text"></i>
                    <span class="sidebar-text">Audit Logs</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@PolicyNames.Permission_Admin_ManageTenant">
            <Authorized>
                <NavLink class="sidebar-link" href="/admin/tenant-settings" ActiveClass="sidebar-link-active">
                    <i class="bi bi-gear"></i>
                    <span class="sidebar-text">Tenant Settings</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
    </nav>

    <!-- User profile footer moved to MainLayout top nav -->
</aside>

@code {
    private Guid doctorId = Guid.Empty;
    private bool isSidebarCollapsed = false;

    private void ToggleSidebar()
    {
        isSidebarCollapsed = !isSidebarCollapsed;
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        doctorId = CurrentUserHelper.GetDoctorId(state.User) ?? Guid.Empty;
    }

    private bool HasClinicalOrCoreAccess(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.HasClaim(c => c.Type == CareSphereClaimTypes.Permission && (
            c.Value == CareSpherePermissions.Patients_View ||
            c.Value == CareSpherePermissions.Patients_Create ||
            c.Value == CareSpherePermissions.Patients_Edit ||
            c.Value == CareSpherePermissions.Appointments_View ||
            c.Value == CareSpherePermissions.Appointments_Book ||
            c.Value == CareSpherePermissions.DoctorSchedule_Manage ||
            c.Value == CareSpherePermissions.Beds_View ||
            c.Value == CareSpherePermissions.Beds_Manage ||
            c.Value == CareSpherePermissions.BedAllotment_View ||
            c.Value == CareSpherePermissions.Beds_Allocate ||
            c.Value == CareSpherePermissions.Queue_View ||
            c.Value == CareSpherePermissions.Encounters_Create ||
            c.Value == CareSpherePermissions.Encounters_View ||
            c.Value == CareSpherePermissions.TeleConsult_Start ||
            c.Value == CareSpherePermissions.Vitals_View ||
            c.Value == CareSpherePermissions.NursingNotes_View ||
            c.Value == CareSpherePermissions.MedicationAdmin_View
        ));
    }

    private bool HasDiagnosticAccess(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.HasClaim(c => c.Type == CareSphereClaimTypes.Permission && (
            c.Value == CareSpherePermissions.Lab_ViewReports ||
            c.Value == CareSpherePermissions.Lab_OrderTests ||
            c.Value == CareSpherePermissions.Lab_CollectSample ||
            c.Value == CareSpherePermissions.Lab_EnterResults ||
            c.Value == CareSpherePermissions.Pharmacy_ViewStock ||
            c.Value == CareSpherePermissions.Pharmacy_ManagePO ||
            c.Value == CareSpherePermissions.Pharmacy_Dispense ||
            c.Value == CareSpherePermissions.Pharmacy_OtcSale ||
            c.Value == CareSpherePermissions.Pharmacy_ManageInventory
        ));
    }

    private bool HasBillingAccess(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.HasClaim(c => c.Type == CareSphereClaimTypes.Permission && (
            c.Value == CareSpherePermissions.Billing_ViewInvoices ||
            c.Value == CareSpherePermissions.Payments_Manage ||
            c.Value == CareSpherePermissions.InsuranceClaims_View
        ));
    }

    private bool HasAdminAccess(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.HasClaim(c => c.Type == CareSphereClaimTypes.Permission && (
            c.Value == CareSpherePermissions.Admin_ManageUsers ||
            c.Value == CareSpherePermissions.Admin_ManageRoles ||
            c.Value == CareSpherePermissions.Admin_ViewAuditLog ||
            c.Value == CareSpherePermissions.Admin_ManageTenant ||
            c.Value == CareSpherePermissions.Analytics_View
        ));
    }
}
