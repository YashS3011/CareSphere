@using Microsoft.AspNetCore.Components.Web
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">
    
    <!-- Clean Hospital Style UI - using Bootstrap 5 and Bootstrap Icons via CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="css/sidebar-system.css" />
    <link rel="stylesheet" href="css/role-layouts.css" />

    <link rel="stylesheet" href="@Assets["CareSphere.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    <script>
        window.getBrowserTimezoneOffset = function() {
            return new Date().getTimezoneOffset();
        };

        // Fix Bootstrap Offcanvas lockup on Blazor SPA navigation
        (function() {
            function cleanupOffcanvas() {
                // Remove any Bootstrap offcanvas backdrops
                var backdrops = document.querySelectorAll('.offcanvas-backdrop');
                backdrops.forEach(function(el) {
                    el.remove();
                });
                
                // Reset body styles and classes
                document.body.classList.remove('modal-open');
                document.body.style.overflow = '';
                document.body.style.paddingRight = '';
                
                // Hide any visible sidebar offcanvas
                var sidebar = document.getElementById('sidebar');
                if (sidebar) {
                    sidebar.classList.remove('show');
                }
            }

            // Intercept Blazor navigation
            var pushState = history.pushState;
            var replaceState = history.replaceState;
            
            history.pushState = function() {
                cleanupOffcanvas();
                return pushState.apply(history, arguments);
            };
            
            history.replaceState = function() {
                cleanupOffcanvas();
                return replaceState.apply(history, arguments);
            };

            window.addEventListener('popstate', cleanupOffcanvas);

            // Close offcanvas when a sidebar link is clicked (without preventing default navigation)
            document.addEventListener('click', function(e) {
                var sidebarLink = e.target.closest('.sidebar-link');
                if (sidebarLink) {
                    setTimeout(cleanupOffcanvas, 0);
                }
            });
        })();
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script src="js/billing.js"></script>
    <script src="js/barcodeScanner.js"></script>
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
