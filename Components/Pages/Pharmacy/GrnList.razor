@page "/pharmacy/grn"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Pharmacy_ViewStock)]
@using CareSphere.Models
@using CareSphere.Modules.Clinical.Services
@using CareSphere.Modules.Laboratory.Services
@using CareSphere.Modules.Pharmacy.Services
@using CareSphere.Modules.Billing.Services
@using CareSphere.Modules.Patients.Services
@using CareSphere.Modules.Ward.Services
@using CareSphere.Modules.Notifications.Services
@using CareSphere.Modules.Admin.Services
@using CareSphere.Modules.Shared.Services
@inject IGrnService GrnService
@inject ISupplierService SupplierService
@inject NavigationManager NavigationManager
@inject ITenantContext TenantContext
@rendermode InteractiveServer

<PageTitle>Goods Received Notes - CareSphere</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 text-dark fw-bold"><i class="bi bi-box-arrow-in-down me-2 text-primary"></i>Goods Received Notes (GRN)</h1>
            <p class="text-muted mb-0">Record and post incoming stocks from vendors</p>
        </div>
        <a href="/pharmacy/grn/create" class="btn btn-primary d-flex align-items-center gap-2 px-4 shadow-sm">
            <i class="bi bi-plus-circle"></i> Create GRN Receipt
        </a>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label text-muted small fw-semibold">Supplier</label>
                    <select class="form-select" @bind="SelectedSupplierId" @bind:after="FilterChanged">
                        <option value="">All Suppliers</option>
                        @if (suppliers != null)
                        {
                            @foreach (var supplier in suppliers)
                            {
                                <option value="@supplier.Id">@supplier.SupplierName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label text-muted small fw-semibold">Status</label>
                    <select class="form-select" @bind="SelectedStatus" @bind:after="FilterChanged">
                        <option value="">All Statuses</option>
                        <option value="Draft">Draft</option>
                        <option value="Posted">Posted (Finalized)</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-light w-100" @onclick="ClearFilters">Clear Filters</button>
                </div>
            </div>
        </div>
    </div>

    @if (grns == null)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!grns.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <i class="bi bi-box-arrow-in-down text-muted display-1 mb-3"></i>
            <h4 class="fw-bold">No GRNs Found</h4>
            <p class="text-muted">Create a new Goods Received Note to log stock intake.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-uppercase fs-7 fw-semibold text-muted">
                        <tr>
                            <th class="px-4 py-3">GRN Number</th>
                            <th class="py-3">Supplier Name</th>
                            <th class="py-3">Received Date</th>
                            <th class="py-3">Invoice Number</th>
                            <th class="py-3 text-end">Total Amount</th>
                            <th class="py-3 text-center">Status</th>
                            <th class="px-4 py-3 text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var grn in grns)
                        {
                            var statusBadgeClass = grn.Status == "Posted" 
                                ? "bg-success-subtle text-success border border-success-subtle" 
                                : "bg-light text-dark border";
                            
                            <tr>
                                <td class="px-4 py-3 fw-bold text-dark font-monospace">
                                    <a href="/pharmacy/grn/@grn.Id" class="text-decoration-none">@grn.GrnNumber</a>
                                    @if (grn.PoId.HasValue)
                                    {
                                        <div class="small text-muted font-monospace">PO Ref exists</div>
                                    }
                                </td>
                                <td class="py-3">
                                    <div class="fw-semibold text-dark">@grn.Supplier.SupplierName</div>
                                    <div class="small text-muted">@(grn.Supplier.ContactPerson ?? "—")</div>
                                </td>
                                <td class="py-3 text-secondary">
                                    @grn.ReceivedDate.ToString("yyyy-MM-dd")
                                </td>
                                <td class="py-3 text-secondary">
                                    @(grn.InvoiceNumber ?? "—")
                                </td>
                                <td class="py-3 text-end fw-semibold text-dark">
                                    ₹@grn.TotalAmount.ToString("F2")
                                </td>
                                <td class="py-3 text-center">
                                    <span class="badge rounded-pill @statusBadgeClass px-3 py-2">@grn.Status</span>
                                </td>
                                <td class="px-4 py-3 text-end">
                                    <a href="/pharmacy/grn/@grn.Id" class="btn btn-sm btn-outline-secondary" title="View Details">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (totalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center mt-3">
                <span class="small text-muted">Showing page @currentPage of @totalPages</span>
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <button class="page-item page-link" @onclick="() => NavigateToPage(currentPage - 1)">Previous</button>
                        </li>
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            var pageNumber = i;
                            <li class="page-item @(currentPage == pageNumber ? "active" : "")">
                                <button class="page-link" @onclick="() => NavigateToPage(pageNumber)">@pageNumber</button>
                            </li>
                        }
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <button class="page-item page-link" @onclick="() => NavigateToPage(currentPage + 1)">Next</button>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    }
</div>

@code {
    private List<GoodsReceivedNote>? grns;
    private List<Supplier>? suppliers;

    private string SelectedSupplierId { get; set; } = string.Empty;
    private string SelectedStatus { get; set; } = string.Empty;

    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages = 1;
    private Guid currentTenantId = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        currentTenantId = TenantContext.TenantId;
        suppliers = await SupplierService.GetSuppliersAsync(currentTenantId);
        await LoadGRNs();
    }

    private async Task LoadGRNs()
    {
        Guid? suppId = null;
        if (Guid.TryParse(SelectedSupplierId, out var sGuid))
        {
            suppId = sGuid;
        }

        var totalGrns = await GrnService.GetGrnsCountAsync(currentTenantId, suppId, SelectedStatus);
        totalPages = (int)Math.Ceiling((double)totalGrns / pageSize);
        if (totalPages == 0) totalPages = 1;

        if (currentPage > totalPages) currentPage = totalPages;

        grns = await GrnService.GetGrnsAsync(currentTenantId, suppId, SelectedStatus, currentPage, pageSize);
    }

    private async Task FilterChanged()
    {
        currentPage = 1;
        await LoadGRNs();
    }

    private async Task ClearFilters()
    {
        SelectedSupplierId = string.Empty;
        SelectedStatus = string.Empty;
        currentPage = 1;
        await LoadGRNs();
    }

    private async Task NavigateToPage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
            await LoadGRNs();
        }
    }
}

