@page "/pharmacy/purchase-orders"
@page "/pharmacy/po"

@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Pharmacy_ManagePO)]
@using CareSphere.Models
@using CareSphere.Modules.Clinical.Services
@using CareSphere.Modules.Laboratory.Services
@using CareSphere.Modules.Pharmacy.Services
@using CareSphere.Modules.Billing.Services
@using CareSphere.Modules.Patients.Services
@using CareSphere.Modules.Ward.Services
@using CareSphere.Modules.Notifications.Services
@using CareSphere.Modules.Admin.Services
@using CareSphere.Modules.Shared.Services
@inject IPurchaseOrderService PoService
@inject ISupplierService SupplierService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Purchase Orders - CareSphere</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 text-dark fw-bold"><i class="bi bi-cart4 me-2 text-primary"></i>Purchase Orders</h1>
            <p class="text-muted mb-0">Issue, track, and manage supplier procurement requests</p>
        </div>
        <a href="/pharmacy/purchase-orders/create" class="btn btn-primary d-flex align-items-center gap-2 px-4 shadow-sm">
            <i class="bi bi-plus-circle"></i> Create Purchase Order
        </a>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label text-muted small fw-semibold">Supplier</label>
                    <select class="form-select" @bind="SelectedSupplierId" @bind:after="FilterChanged">
                        <option value="">All Suppliers</option>
                        @if (suppliers != null)
                        {
                            @foreach (var supplier in suppliers)
                            {
                                <option value="@supplier.Id">@supplier.SupplierName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label text-muted small fw-semibold">Status</label>
                    <select class="form-select" @bind="SelectedStatus" @bind:after="FilterChanged">
                        <option value="">All Statuses</option>
                        <option value="Draft">Draft</option>
                        <option value="Sent">Sent</option>
                        <option value="PartiallyReceived">Partially Received</option>
                        <option value="Received">Received</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-light w-100" @onclick="ClearFilters">Clear Filters</button>
                </div>
            </div>
        </div>
    </div>

    @if (purchaseOrders == null)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!purchaseOrders.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <i class="bi bi-cart text-muted display-1 mb-3"></i>
            <h4 class="fw-bold">No Purchase Orders Found</h4>
            <p class="text-muted">Create a new purchase order to start replenishment.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-uppercase fs-7 fw-semibold text-muted">
                        <tr>
                            <th class="px-4 py-3">PO Number</th>
                            <th class="py-3">Supplier Name</th>
                            <th class="py-3">Order Date</th>
                            <th class="py-3">Expected Delivery</th>
                            <th class="py-3 text-end">Total Amount</th>
                            <th class="py-3 text-center">Status</th>
                            <th class="px-4 py-3 text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var po in purchaseOrders)
                        {
                            var statusBadgeClass = GetStatusBadgeClass(po.Status);
                            
                            <tr>
                                <td class="px-4 py-3 fw-bold text-dark font-monospace">
                                    <a href="/pharmacy/purchase-orders/@po.Id" class="text-decoration-none">@po.PoNumber</a>
                                </td>
                                <td class="py-3">
                                    <div class="fw-semibold text-dark">@po.Supplier.SupplierName</div>
                                    <div class="small text-muted">@(po.Supplier.ContactPerson ?? "—")</div>
                                </td>
                                <td class="py-3 text-secondary">
                                    @po.OrderDate.ToString("yyyy-MM-dd HH:mm")
                                </td>
                                <td class="py-3 text-secondary">
                                    @(po.ExpectedDeliveryDate?.ToString("yyyy-MM-dd") ?? "—")
                                </td>
                                <td class="py-3 text-end fw-semibold text-dark">
                                    ₹@po.TotalAmount.ToString("F2")
                                </td>
                                <td class="py-3 text-center">
                                    <span class="badge rounded-pill @statusBadgeClass px-3 py-2">@po.Status</span>
                                </td>
                                <td class="px-4 py-3 text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a href="/pharmacy/purchase-orders/@po.Id" class="btn btn-sm btn-outline-secondary" title="View Details">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                        @if (po.Status == "Draft")
                                        {
                                            <button class="btn btn-sm btn-outline-success" @onclick="() => SendPO(po.Id)" title="Send Order">
                                                <i class="bi bi-send"></i> Send
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (totalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center mt-3">
                <span class="small text-muted">Showing page @currentPage of @totalPages</span>
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <button class="page-item page-link" @onclick="() => NavigateToPage(currentPage - 1)">Previous</button>
                        </li>
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            var pageNumber = i;
                            <li class="page-item @(currentPage == pageNumber ? "active" : "")">
                                <button class="page-link" @onclick="() => NavigateToPage(pageNumber)">@pageNumber</button>
                            </li>
                        }
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <button class="page-item page-link" @onclick="() => NavigateToPage(currentPage + 1)">Next</button>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    }
</div>

@code {
    private List<PurchaseOrder>? purchaseOrders;
    private List<Supplier>? suppliers;

    private string SelectedSupplierId { get; set; } = string.Empty;
    private string SelectedStatus { get; set; } = string.Empty;

    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages = 1;
    private Guid currentTenantId = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        suppliers = await SupplierService.GetSuppliersAsync(currentTenantId);
        await LoadPOs();
    }

    private async Task LoadPOs()
    {
        Guid? suppId = null;
        if (Guid.TryParse(SelectedSupplierId, out var sGuid))
        {
            suppId = sGuid;
        }

        var totalPOs = await PoService.GetPurchaseOrdersCountAsync(currentTenantId, SelectedStatus, suppId);
        totalPages = (int)Math.Ceiling((double)totalPOs / pageSize);
        if (totalPages == 0) totalPages = 1;

        if (currentPage > totalPages) currentPage = totalPages;

        purchaseOrders = await PoService.GetPurchaseOrdersAsync(currentTenantId, SelectedStatus, suppId, currentPage, pageSize);
    }

    private async Task FilterChanged()
    {
        currentPage = 1;
        await LoadPOs();
    }

    private async Task ClearFilters()
    {
        SelectedSupplierId = string.Empty;
        SelectedStatus = string.Empty;
        currentPage = 1;
        await LoadPOs();
    }

    private async Task NavigateToPage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
            await LoadPOs();
        }
    }

    private async Task SendPO(Guid id)
    {
        try
        {
            await PoService.SendPurchaseOrderAsync(id);
            await LoadPOs();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error sending PO: {ex.Message}");
        }
    }

    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Draft" => "bg-light text-dark border",
            "Sent" => "bg-primary-subtle text-primary border border-primary-subtle",
            "PartiallyReceived" => "bg-warning-subtle text-warning border border-warning-subtle",
            "Received" => "bg-success-subtle text-success border border-success-subtle",
            "Cancelled" => "bg-danger-subtle text-danger border border-danger-subtle",
            _ => "bg-secondary text-white"
        };
    }
}

