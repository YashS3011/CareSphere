@page "/pharmacy/suppliers/create"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Pharmacy_ViewStock)]
@using CareSphere.Models
@using CareSphere.Modules.Clinical.Services
@using CareSphere.Modules.Laboratory.Services
@using CareSphere.Modules.Pharmacy.Services
@using CareSphere.Modules.Billing.Services
@using CareSphere.Modules.Patients.Services
@using CareSphere.Modules.Ward.Services
@using CareSphere.Modules.Notifications.Services
@using CareSphere.Modules.Admin.Services
@using CareSphere.Modules.Shared.Services
@inject ISupplierService SupplierService
@inject NavigationManager NavigationManager
@inject ITenantContext TenantContext
@rendermode InteractiveServer

<PageTitle>Add Supplier - CareSphere</PageTitle>

<div class="container py-4">
    <div class="mb-4">
        <a href="/pharmacy/suppliers" class="btn btn-link link-secondary p-0 text-decoration-none mb-2">
            <i class="bi bi-arrow-left"></i> Back to Suppliers
        </a>
        <h1 class="h3 mb-1 text-dark fw-bold">Add New Supplier</h1>
        <p class="text-muted">Register a new pharmaceutical or equipment vendor</p>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <EditForm Model="@supplier" OnValidSubmit="HandleValidSubmit" FormName="createSupplier">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="alert alert-danger mb-4 py-2 small" />

                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-semibold text-muted">Supplier Name *</label>
                                <InputText class="form-control" @bind-Value="supplier.SupplierName" placeholder="e.g. Acme Pharmaceuticals Ltd" />
                                <ValidationMessage For="@(() => supplier.SupplierName)" class="text-danger small" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted">Contact Person</label>
                                <InputText class="form-control" @bind-Value="supplier.ContactPerson" placeholder="e.g. John Doe" />
                                <ValidationMessage For="@(() => supplier.ContactPerson)" class="text-danger small" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted">Phone Number</label>
                                <InputText class="form-control" @bind-Value="supplier.Phone" placeholder="e.g. +91 98765 43210" />
                                <ValidationMessage For="@(() => supplier.Phone)" class="text-danger small" />
                            </div>

                            <div class="col-md-12">
                                <label class="form-label fw-semibold text-muted">Email Address</label>
                                <InputText class="form-control" @bind-Value="supplier.Email" placeholder="e.g. contact@acmepharma.com" />
                                <ValidationMessage For="@(() => supplier.Email)" class="text-danger small" />
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-semibold text-muted">Address</label>
                                <InputTextArea class="form-control" @bind-Value="supplier.Address" rows="3" placeholder="Enter office/warehouse address..." />
                                <ValidationMessage For="@(() => supplier.Address)" class="text-danger small" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted">GST Number</label>
                                <InputText class="form-control" @bind-Value="supplier.GstNumber" placeholder="e.g. 27AAAAA1111A1Z1" />
                                <ValidationMessage For="@(() => supplier.GstNumber)" class="text-danger small" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-muted">Drug License Number</label>
                                <InputText class="form-control" @bind-Value="supplier.LicenseNumber" placeholder="e.g. DL-12345/67" />
                                <ValidationMessage For="@(() => supplier.LicenseNumber)" class="text-danger small" />
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger mt-4 small mb-0 py-2">@errorMessage</div>
                        }

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary px-4 shadow-sm" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                Save Supplier
                            </button>
                            <a href="/pharmacy/suppliers" class="btn btn-light px-4">Cancel</a>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private Supplier supplier = new();
    private bool isSubmitting = false;
    private string errorMessage = string.Empty;

    private async Task HandleValidSubmit()
    {
        try
        {
            isSubmitting = true;
            errorMessage = string.Empty;
            supplier.TenantId = TenantContext.TenantId;

            await SupplierService.CreateSupplierAsync(supplier);
            NavigationManager.NavigateTo("/pharmacy/suppliers");
        }
        catch (Microsoft.AspNetCore.Components.NavigationException)
        {
            throw; // expected Blazor redirect behavior
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to save supplier: {ex.Message}";
            isSubmitting = false;
        }
    }
}

