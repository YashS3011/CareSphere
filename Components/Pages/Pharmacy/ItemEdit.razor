@page "/pharmacy/items/edit/{id:guid}"
@using CareSphere.Models
@using CareSphere.Services
@using CareSphere.Components
@inject IPharmacyItemService ItemService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Edit Pharmacy Item - CareSphere</PageTitle>

<div class="container py-4">
    <div class="mb-4">
        <a href="/pharmacy/items" class="btn btn-link link-secondary p-0 text-decoration-none mb-2">
            <i class="bi bi-arrow-left"></i> Back to Catalog
        </a>
        <h1 class="h3 mb-1 text-dark fw-bold">Edit Pharmacy Item</h1>
        <p class="text-muted">Update catalog details and inventory parameters</p>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    @if (item == null)
                    {
                        <div class="d-flex justify-content-center my-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <EditForm Model="@item" OnValidSubmit="HandleValidSubmit" FormName="editItem">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="alert alert-danger mb-4 py-2 small" />

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold text-muted">Item Code *</label>
                                    <InputText class="form-control" @bind-Value="item.ItemCode" placeholder="e.g. PAR500" />
                                    <ValidationMessage For="@(() => item.ItemCode)" class="text-danger small" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold text-muted">Category *</label>
                                    <InputSelect class="form-select" @bind-Value="item.Category">
                                        <option value="Medicine">Medicine</option>
                                        <option value="Surgical">Surgical</option>
                                        <option value="Consumable">Consumable</option>
                                        <option value="Equipment">Equipment</option>
                                        <option value="Other">Other</option>
                                    </InputSelect>
                                    <ValidationMessage For="@(() => item.Category)" class="text-danger small" />
                                </div>

                                <div class="col-12">
                                    <label class="form-label fw-semibold text-muted">Item Name *</label>
                                    <InputText class="form-control" @bind-Value="item.ItemName" placeholder="e.g. Paracetamol 500mg" />
                                    <ValidationMessage For="@(() => item.ItemName)" class="text-danger small" />
                                </div>

                                <div class="col-12">
                                    <label class="form-label fw-semibold text-muted">Generic Name / Composition</label>
                                    <InputText class="form-control" @bind-Value="item.GenericName" placeholder="e.g. Acetaminophen" />
                                    <ValidationMessage For="@(() => item.GenericName)" class="text-danger small" />
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label fw-semibold text-muted">Form</label>
                                    <InputText class="form-control" @bind-Value="item.Form" placeholder="e.g. Tablet, Capsule, Syrup" />
                                    <ValidationMessage For="@(() => item.Form)" class="text-danger small" />
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label fw-semibold text-muted">Strength</label>
                                    <InputText class="form-control" @bind-Value="item.Strength" placeholder="e.g. 500mg, 10ml" />
                                    <ValidationMessage For="@(() => item.Strength)" class="text-danger small" />
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label fw-semibold text-muted">Unit of Measure *</label>
                                    <InputText class="form-control" @bind-Value="item.Unit" placeholder="e.g. Strip, Box, Vial" />
                                    <ValidationMessage For="@(() => item.Unit)" class="text-danger small" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold text-muted">Barcode</label>
                                    <div class="input-group">
                                        <InputText class="form-control" @bind-Value="item.Barcode" placeholder="Scan or type barcode..." />
                                        <button type="button" class="btn btn-outline-secondary" @onclick="ToggleScanner">
                                            <i class="bi @(showScanner ? "bi-camera-video-off" : "bi-camera")"></i>
                                        </button>
                                    </div>
                                    <ValidationMessage For="@(() => item.Barcode)" class="text-danger small" />
                                    
                                    @if (showScanner)
                                    {
                                        <div class="card mt-2 border border-secondary shadow-sm rounded-3 overflow-hidden">
                                            <div class="card-header bg-light py-2">
                                                <span class="small fw-semibold text-muted"><i class="bi bi-upc-scan me-1"></i> Scan Barcode</span>
                                            </div>
                                            <div class="card-body p-2">
                                                <BarcodeScanner VideoClass="w-100 rounded-3" OnScanned="HandleBarcodeScanned" />
                                            </div>
                                        </div>
                                    }
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold text-muted">Reorder Level *</label>
                                    <InputNumber class="form-control" @bind-Value="item.ReorderLevel" min="0" />
                                    <span class="small text-muted">Trigger alerts when total stock falls below this value.</span>
                                    <ValidationMessage For="@(() => item.ReorderLevel)" class="text-danger small" />
                                </div>

                                <div class="col-md-4 d-flex align-items-center">
                                    <div class="form-check form-switch mt-2">
                                        <InputCheckbox class="form-check-input" @bind-Value="item.RequiresPrescription" id="requiresPrescriptionSwitch" />
                                        <label class="form-check-label fw-semibold text-dark" for="requiresPrescriptionSwitch">Requires Prescription</label>
                                    </div>
                                </div>

                                <div class="col-md-4 d-flex align-items-center">
                                    <div class="form-check form-switch mt-2">
                                        <InputCheckbox class="form-check-input" @bind-Value="item.IsControlled" id="isControlledSwitch" />
                                        <label class="form-check-label fw-semibold text-dark" for="isControlledSwitch">Is Controlled</label>
                                    </div>
                                </div>

                                <div class="col-md-4 d-flex align-items-center">
                                    <div class="form-check form-switch mt-2">
                                        <InputCheckbox class="form-check-input" @bind-Value="item.IsActive" id="isActiveSwitch" />
                                        <label class="form-check-label fw-semibold text-dark" for="isActiveSwitch">Is Active</label>
                                    </div>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <div class="alert alert-danger mt-4 small mb-0 py-2">@errorMessage</div>
                            }

                            <div class="d-flex gap-2 mt-4">
                                <button type="submit" class="btn btn-primary px-4 shadow-sm" disabled="@isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    Save Changes
                                </button>
                                <a href="/pharmacy/items" class="btn btn-light px-4">Cancel</a>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private PharmacyItem? item;
    private bool isSubmitting = false;
    private bool showScanner = false;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        item = await ItemService.GetItemByIdAsync(Id);
        if (item == null)
        {
            errorMessage = "Item not found in catalog.";
        }
    }

    private void ToggleScanner()
    {
        showScanner = !showScanner;
    }

    private void HandleBarcodeScanned(string barcode)
    {
        if (item != null)
        {
            item.Barcode = barcode;
        }
        showScanner = false;
        StateHasChanged();
    }

    private async Task HandleValidSubmit()
    {
        if (item == null) return;

        try
        {
            isSubmitting = true;
            errorMessage = string.Empty;

            await ItemService.UpdateItemAsync(item);
            NavigationManager.NavigateTo("/pharmacy/items");
        }
        catch (Microsoft.AspNetCore.Components.NavigationException)
        {
            throw; // expected Blazor redirect
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to update item: {ex.Message}";
            isSubmitting = false;
        }
    }
}
