@page "/pharmacy/dashboard"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Pharmacy_ViewStock)]
@using CareSphere.Models
@using CareSphere.Services
@using CareSphere.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject IExpiryAlertService AlertService
@inject IPharmacyItemService ItemService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Pharmacy Dashboard - CareSphere</PageTitle>

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 text-dark fw-bold"><i class="bi bi-capsule me-2 text-primary"></i>Pharmacy Dashboard</h1>
            <p class="text-muted mb-0">Overview of pharmacy stock, expiries, dispenses, and OTC sales</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/pharmacy/dispense" class="btn btn-primary shadow-sm"><i class="bi bi-prescription2 me-1"></i> Dispense Rx</a>
            <a href="/pharmacy/otc-sale" class="btn btn-outline-primary shadow-sm"><i class="bi bi-shop me-1"></i> OTC POS</a>
        </div>
    </div>

    @if (loading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading dashboard data...</span>
            </div>
        </div>
    }
    else
    {
        <!-- KPI summary row -->
        <div class="row g-3 mb-4">
            <div class="col-md-6 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-3 bg-white">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-box-seam fs-4"></i>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold uppercase fs-8">Catalog Items</div>
                            <h3 class="fw-bold text-dark mb-0">@totalCatalogItems</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-3 bg-white">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-danger-subtle text-danger d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-exclamation-triangle fs-4"></i>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold uppercase fs-8">Expiring (90d)</div>
                            <h3 class="fw-bold text-danger mb-0">@expiringBatchesCount</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-3 bg-white">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-warning-subtle text-warning-emphasis d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-dash-circle fs-4"></i>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold uppercase fs-8">Low Stock Alerts</div>
                            <h3 class="fw-bold text-warning-emphasis mb-0">@lowStockCount</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-3 bg-white">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-success-subtle text-success d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-currency-rupee fs-4"></i>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold uppercase fs-8">OTC Sales Today</div>
                            <h3 class="fw-bold text-success mb-0">₹@todayOtcSalesAmount.ToString("F0")</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Expiring Batches Table -->
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-header bg-white py-3 px-4 d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold text-dark mb-0"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Near Expiry Batches (90 Days)</h5>
                        <a href="/pharmacy/expiry-alerts" class="btn btn-xs btn-outline-secondary py-0">View All</a>
                    </div>
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 small">
                            <thead class="table-light fs-8 text-uppercase text-muted">
                                <tr>
                                    <th>Item details</th>
                                    <th>Batch #</th>
                                    <th>Exp Date</th>
                                    <th class="text-end">Current Stock</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (expiringSoon == null || !expiringSoon.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">No batches near expiry.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var batch in expiringSoon)
                                    {
                                        var daysRemaining = (batch.ExpiryDate.Date - DateTime.UtcNow.Date).Days;
                                        var daysColor = daysRemaining <= 30 ? "text-danger fw-bold" : "text-warning fw-bold";
                                        
                                        <tr>
                                            <td>
                                                <div class="fw-semibold text-dark">@batch.Item.ItemName</div>
                                                <div class="fs-9 text-muted">Code: @batch.Item.ItemCode</div>
                                            </td>
                                            <td class="font-monospace text-uppercase">@batch.BatchNumber</td>
                                            <td class="@daysColor">
                                                @batch.ExpiryDate.ToString("yyyy-MM-dd")
                                                <span class="fs-9 d-block fw-normal text-muted">(@daysRemaining days left)</span>
                                            </td>
                                            <td class="text-end fw-semibold">
                                                @batch.CurrentStock @batch.Item.Unit
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Low Stock Table -->
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-header bg-white py-3 px-4 d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold text-dark mb-0"><i class="bi bi-dash-circle text-warning-emphasis me-2"></i>Reorder Alert Catalog Items</h5>
                        <a href="/pharmacy/items" class="btn btn-xs btn-outline-secondary py-0">Catalog</a>
                    </div>
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 small">
                            <thead class="table-light fs-8 text-uppercase text-muted">
                                <tr>
                                    <th>Item Details</th>
                                    <th>Category</th>
                                    <th class="text-end">Reorder Level</th>
                                    <th class="text-end">Current Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (lowStockItems == null || !lowStockItems.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">All items have safe stock levels.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var dto in lowStockItems)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold text-dark">@dto.Item.ItemName</div>
                                                <div class="fs-9 text-muted">Code: @dto.Item.ItemCode</div>
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-dark border">@dto.Item.Category</span>
                                            </td>
                                            <td class="text-end text-muted font-monospace">@dto.Item.ReorderLevel</td>
                                            <td class="text-end text-danger fw-bold font-monospace">
                                                @dto.TotalStock @dto.Item.Unit
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool loading = true;
    private int totalCatalogItems = 0;
    private int expiringBatchesCount = 0;
    private int lowStockCount = 0;
    private decimal todayOtcSalesAmount = 0;

    private List<PharmacyBatch>? expiringSoon;
    private List<PharmacyItemStockDto>? lowStockItems;

    private Guid currentTenantId = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            loading = true;

            // Trigger expiry generation automatically
            await AlertService.CheckAndGenerateExpiryAlertsAsync(currentTenantId);

            // Fetch metrics
            totalCatalogItems = await DbContext.PharmacyItems.CountAsync(i => i.TenantId == currentTenantId && i.IsActive);

            var expirationThreshold = DateTime.UtcNow.AddDays(90);
            expiringBatchesCount = await DbContext.PharmacyBatches
                .CountAsync(b => b.TenantId == currentTenantId && b.IsActive && b.CurrentStock > 0 && b.ExpiryDate <= expirationThreshold);

            // Fetch top 10 expiring batches
            expiringSoon = await DbContext.PharmacyBatches
                .Include(b => b.Item)
                .Where(b => b.TenantId == currentTenantId && b.IsActive && b.CurrentStock > 0 && b.ExpiryDate <= expirationThreshold)
                .OrderBy(b => b.ExpiryDate)
                .Take(10)
                .ToListAsync();

            // Fetch low stock items DTO
            lowStockItems = await ItemService.GetLowStockItemsAsync(currentTenantId);
            lowStockCount = lowStockItems.Count;
            lowStockItems = lowStockItems.Take(10).ToList();

            // Fetch today's sales
            var today = DateTime.UtcNow.Date;
            todayOtcSalesAmount = await DbContext.OtcSales
                .Where(s => s.TenantId == currentTenantId && s.SaleDate.Date == today && s.PaymentStatus == "Paid")
                .SumAsync(s => s.TotalAmount);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }
}

