@page "/pharmacy/expiry-alerts"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Pharmacy_ViewStock)]
@using CareSphere.Models
@using CareSphere.Services
@inject IExpiryAlertService AlertService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Expiry Alerts - CareSphere</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 text-dark fw-bold"><i class="bi bi-exclamation-triangle me-2 text-danger"></i>Expiry Alerts</h1>
            <p class="text-muted mb-0">Track batches expiring in 90 days and acknowledge warning actions</p>
        </div>
        <div class="form-check form-switch bg-white shadow-sm border rounded px-3 py-2">
            <input class="form-check-input ms-0 me-2" type="checkbox" id="showAllAlerts" @bind="ShowAllAlerts" @bind:after="ToggleFilter" />
            <label class="form-check-label fw-semibold text-muted" for="showAllAlerts">Show Acknowledged Alerts</label>
        </div>
    </div>

    @if (alerts == null)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-danger" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!alerts.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <i class="bi bi-check2-circle text-success display-1 mb-3"></i>
            <h4 class="fw-bold">All Clear!</h4>
            <p class="text-muted">No active batches are expiring in the next 90 days.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-uppercase fs-7 fw-semibold text-muted">
                        <tr>
                            <th class="px-4 py-3">Item Details</th>
                            <th class="py-3">Batch Number</th>
                            <th class="py-3 text-center">Expiry Date</th>
                            <th class="py-3 text-center">Days Remaining</th>
                            <th class="py-3 text-center">Alert Channel</th>
                            <th class="py-3 text-center">Acknowledge Status</th>
                            <th class="px-4 py-3 text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var alert in alerts)
                        {
                            var daysLeft = alert.DaysUntilExpiry;
                            var daysClass = daysLeft <= 30 ? "bg-danger text-white" : (daysLeft <= 60 ? "bg-warning text-dark" : "bg-info text-dark");
                            
                            <tr>
                                <td class="px-4 py-3">
                                    <div class="fw-bold text-dark fs-6">@alert.Item.ItemName</div>
                                    <div class="small text-muted">Code: @alert.Item.ItemCode | Unit: @alert.Item.Unit</div>
                                </td>
                                <td class="py-3 font-monospace fw-bold text-dark text-uppercase">
                                    @alert.Batch.BatchNumber
                                </td>
                                <td class="py-3 text-center text-dark">
                                    @alert.ExpiryDate.ToString("yyyy-MM-dd")
                                </td>
                                <td class="py-3 text-center">
                                    <span class="badge px-3 py-2 fw-bold @daysClass shadow-xs">@daysLeft days</span>
                                </td>
                                <td class="py-3 text-center">
                                    @if (alert.AlertType == "SMS")
                                    {
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2 py-1"><i class="bi bi-chat-left-text-fill me-1"></i> SMS Alert</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border px-2 py-1"><i class="bi bi-display me-1"></i> In-App Dashboard</span>
                                    }
                                </td>
                                <td class="py-3 text-center">
                                    @if (alert.IsAcknowledged)
                                    {
                                        <div class="text-success small fw-semibold">
                                            <i class="bi bi-check2"></i> Acknowledged
                                            <div class="fs-9 text-muted fw-normal">By: @(alert.AcknowledgedByUserId ?? "System")</div>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-2 py-1">Pending</span>
                                    }
                                </td>
                                <td class="px-4 py-3 text-end">
                                    @if (!alert.IsAcknowledged)
                                    {
                                        <button class="btn btn-sm btn-outline-success px-3 shadow-xs" @onclick="() => AckAlert(alert.Id)">
                                            <i class="bi bi-check2-all"></i> Acknowledge
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Done</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<ExpiryAlert>? alerts;
    private bool ShowAllAlerts { get; set; } = false;
    private Guid currentTenantId = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAlerts();
    }

    private async Task LoadAlerts()
    {
        if (ShowAllAlerts)
        {
            alerts = await AlertService.GetAllAlertsAsync(currentTenantId);
        }
        else
        {
            alerts = await AlertService.GetUnacknowledgedAlertsAsync(currentTenantId);
        }
    }

    private async Task ToggleFilter()
    {
        await LoadAlerts();
    }

    private async Task AckAlert(Guid id)
    {
        try
        {
            await AlertService.AcknowledgeAlertAsync(id, "system");
            await LoadAlerts();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error acknowledging alert: {ex.Message}");
        }
    }
}

