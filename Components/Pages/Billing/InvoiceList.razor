@page "/billing/invoices"
@using CareSphere.Models
@using CareSphere.Services
@using Microsoft.JSInterop
@inject IInvoiceService InvoiceService
@inject IDocumentService DocumentService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Invoices - CareSphere</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary"><i class="bi bi-file-earmark-spreadsheet me-2"></i>Invoice Management</h2>
        <a href="/billing/invoices/create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Create Invoice</a>
    </div>

    <!-- Summary KPI Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 border-start border-primary border-4">
                <div class="card-body">
                    <h6 class="text-uppercase text-muted fw-bold mb-1" style="font-size: 0.85rem;">Total Invoiced Today</h6>
                    <h3 class="mb-0 fw-bold">INR @totalInvoicedToday.ToString("N2")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 border-start border-success border-4">
                <div class="card-body">
                    <h6 class="text-uppercase text-muted fw-bold mb-1" style="font-size: 0.85rem;">Total Collected Today</h6>
                    <h3 class="mb-0 fw-bold text-success">INR @totalCollectedToday.ToString("N2")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 border-start border-danger border-4">
                <div class="card-body">
                    <h6 class="text-uppercase text-muted fw-bold mb-1" style="font-size: 0.85rem;">Total Outstanding</h6>
                    <h3 class="mb-0 fw-bold text-danger">INR @totalOutstanding.ToString("N2")</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters Section -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" placeholder="Search by Invoice number, Patient name, or MRN..." 
                               @bind="SearchTerm" @bind:event="oninput" @onkeyup="HandleSearchKeyup" />
                    </div>
                </div>
                <div class="col-md-4">
                    <select class="form-select" @bind="StatusFilter" @bind:after="LoadInvoices">
                        <option value="">All Statuses</option>
                        <option value="Draft">Draft</option>
                        <option value="Finalized">Finalized</option>
                        <option value="PartiallyPaid">Partially Paid</option>
                        <option value="Paid">Paid</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary w-100" @onclick="ResetFilters">Reset</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Invoices List Table -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            @if (invoices == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (!invoices.Any())
            {
                <div class="alert alert-info m-3">No invoices found.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle mb-0">
                        <thead class="table-light text-uppercase fs-7">
                            <tr>
                                <th class="ps-3">Invoice #</th>
                                <th>Patient Name</th>
                                <th>MRN</th>
                                <th>Invoice Date</th>
                                <th>Total</th>
                                <th>Paid</th>
                                <th>Balance</th>
                                <th>Status</th>
                                <th class="text-end pe-3">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var inv in invoices)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold">@inv.InvoiceNumber</td>
                                    <td>@inv.Patient?.FirstName @inv.Patient?.LastName</td>
                                    <td>@inv.Patient?.Mrn</td>
                                    <td>@inv.InvoiceDate.ToString("dd MMM yyyy")</td>
                                    <td>@inv.TotalAmount.ToString("C")</td>
                                    <td class="text-success">@inv.PaidAmount.ToString("C")</td>
                                    <td class="fw-bold @(inv.BalanceAmount > 0 ? "text-danger" : "text-secondary")">
                                        @inv.BalanceAmount.ToString("C")
                                    </td>
                                    <td>
                                        <span class="badge @GetInvoiceBadgeClass(inv.Status)">@inv.Status</span>
                                    </td>
                                    <td class="text-end pe-3">
                                        <div class="btn-group btn-group-sm">
                                            <a href="/billing/invoices/@inv.Id" class="btn btn-outline-info" title="View Details">
                                                <i class="bi bi-eye-fill"></i> View
                                            </a>
                                            @if (inv.Status == "Draft")
                                            {
                                                <button class="btn btn-outline-success" @onclick="() => FinalizeInvoice(inv.Id)" title="Finalize Invoice">
                                                    <i class="bi bi-check-circle-fill"></i> Finalize
                                                </button>
                                            }
                                            <button class="btn btn-outline-primary" @onclick="() => DownloadPdf(inv.Id)" title="Download PDF" disabled="@(isDownloading == inv.Id)">
                                                @if (isDownloading == inv.Id)
                                                {
                                                    <span class="spinner-border spinner-border-sm"></span>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-file-earmark-pdf-fill"></i>
                                                }
                                                PDF
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                @if (totalPages > 1)
                {
                    <nav class="d-flex justify-content-center mt-3 mb-3">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <button class="page-item page-link" @onclick="() => GoToPage(currentPage - 1)">Previous</button>
                            </li>
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                int pageNum = i;
                                <li class="page-item @(currentPage == pageNum ? "active" : "")">
                                    <button class="page-item page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <button class="page-item page-link" @onclick="() => GoToPage(currentPage + 1)">Next</button>
                            </li>
                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</div>

@code {
    private List<BillingInvoice>? invoices;
    private string SearchTerm { get; set; } = string.Empty;
    private string StatusFilter { get; set; } = string.Empty;

    private decimal totalInvoicedToday;
    private decimal totalCollectedToday;
    private decimal totalOutstanding;

    private int currentPage = 1;
    private int pageSize = 10;
    private int totalCount = 0;
    private int totalPages => (int)Math.Ceiling((double)totalCount / pageSize);

    private Guid? isDownloading = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadKPIs();
        await LoadInvoices();
    }

    private async Task LoadKPIs()
    {
        // Compute dashboard summary using services or quick aggregates from raw DB if needed
        // For simplicity and adherence to Service layer pattern, we can fetch all or run quick queries.
        // We'll perform it locally or compute via service aggregates.
        var today = DateTime.UtcNow.Date;
        var startOfToday = DateTime.UtcNow.Date;

        var result = await InvoiceService.GetInvoicesByStatusAsync(null, 1, 1000);
        var allInvoices = result.Invoices;

        totalInvoicedToday = allInvoices.Where(i => i.InvoiceDate >= startOfToday && i.Status != "Cancelled").Sum(i => i.TotalAmount);
        totalOutstanding = allInvoices.Where(i => i.Status == "Finalized" || i.Status == "PartiallyPaid").Sum(i => i.BalanceAmount);

        var paymentsResult = await DocumentService.GetDocumentsByInvoiceAsync(Guid.Empty); // placeholder or count
        // Wait, let's load payment sum today by computing from invoices payments
        totalCollectedToday = allInvoices.SelectMany(i => i.Payments)
            .Where(p => p.Status == "Success" && p.PaymentDate >= startOfToday)
            .Sum(p => p.Amount);
    }

    private async Task LoadInvoices()
    {
        invoices = null;
        var result = await InvoiceService.GetInvoicesByStatusAsync(StatusFilter, currentPage, pageSize, SearchTerm);
        invoices = result.Invoices;
        totalCount = result.TotalCount;
    }

    private async Task HandleSearchKeyup(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            currentPage = 1;
            await LoadInvoices();
        }
    }

    private async Task GoToPage(int page)
    {
        currentPage = page;
        await LoadInvoices();
    }

    private async Task ResetFilters()
    {
        SearchTerm = string.Empty;
        StatusFilter = string.Empty;
        currentPage = 1;
        await LoadInvoices();
    }

    private async Task FinalizeInvoice(Guid id)
    {
        try
        {
            await InvoiceService.FinalizeInvoiceAsync(id);
            await LoadKPIs();
            await LoadInvoices();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
    }

    private async Task DownloadPdf(Guid id)
    {
        try
        {
            isDownloading = id;
            var path = await DocumentService.GenerateInvoicePdfAsync(id);
            // JS Trigger Download
            await JSRuntime.InvokeVoidAsync("open", path, "_blank");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error generating PDF: {ex.Message}");
        }
        finally
        {
            isDownloading = null;
        }
    }

    private string GetInvoiceBadgeClass(string status) => status switch
    {
        "Draft" => "bg-secondary text-white",
        "Finalized" => "bg-primary text-white",
        "PartiallyPaid" => "bg-warning text-dark",
        "Paid" => "bg-success text-white",
        "Cancelled" => "bg-danger text-white",
        _ => "bg-light text-dark"
    };
}
