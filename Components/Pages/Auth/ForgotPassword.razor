@page "/auth/forgot-password"
@rendermode InteractiveServer

<PageTitle>Forgot Password — CareSphere</PageTitle>

<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light">
    <div class="card shadow border-0 rounded-4" style="width: 420px;">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <div class="bg-warning bg-gradient rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px;">
                    <i class="bi bi-key-fill text-white fs-3"></i>
                </div>
                <h4 class="fw-bold">Forgot Password</h4>
                <p class="text-muted small">Enter your email to receive a password reset link.</p>
            </div>

            @if (emailSent)
            {
                <div class="alert alert-success d-flex align-items-center" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    <div>If your email is registered, you will receive a reset link shortly.</div>
                </div>
                <div class="text-center mt-3">
                    <a href="/auth/login" class="btn btn-outline-primary">
                        <i class="bi bi-arrow-left me-2"></i>Back to Sign In
                    </a>
                </div>
            }
            else
            {
                <EditForm Model="@model" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label for="forgot-email" class="form-label fw-semibold">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <InputText id="forgot-email" class="form-control" @bind-Value="model.Email"
                                       placeholder="you@hospital.com" type="email" />
                        </div>
                        <ValidationMessage For="@(() => model.Email)" class="text-danger small" />
                    </div>

                    <button type="submit" class="btn btn-warning w-100 py-2 fw-semibold text-dark" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <i class="bi bi-send me-2"></i>Send Reset Link
                    </button>
                </EditForm>

                <div class="text-center mt-3">
                    <a href="/auth/login" class="small text-decoration-none">
                        <i class="bi bi-arrow-left me-1"></i>Back to Sign In
                    </a>
                </div>
            }

            @* TODO: Implement email sending when email service is configured. *@
        </div>
    </div>
</div>

@code {
    private ForgotModel model = new();
    private bool emailSent = false;
    private bool isLoading = false;

    private async Task HandleSubmit()
    {
        isLoading = true;
        // TODO: Implement email sending when email service is configured.
        // For now, always show success to avoid user enumeration.
        await Task.Delay(500);
        emailSent = true;
        isLoading = false;
    }

    private class ForgotModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Enter a valid email.")]
        public string Email { get; set; } = string.Empty;
    }
}
