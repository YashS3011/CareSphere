@page "/auth/login"
@inject IAuthService AuthService
@inject ITenantService TenantService
@inject NavigationManager NavigationManager
@inject IHttpContextAccessor HttpContextAccessor
@inject IConfiguration Configuration

<PageTitle>Sign In — CareSphere</PageTitle>

<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light">
    <div class="card shadow-lg border-0 rounded-4" style="width: 420px;">
        <div class="card-body p-5">
            <!-- Logo / Branding -->
            <div class="text-center mb-4">
                <div class="bg-primary bg-gradient rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px;">
                    <i class="bi bi-heart-pulse-fill text-white fs-3"></i>
                </div>
                <h4 class="fw-bold text-primary mb-0">CareSphere</h4>
                <p class="text-muted small">@hospitalName</p>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger alert-dismissible d-flex align-items-center" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <div>@errorMessage</div>
                </div>
            }

            <EditForm Model="@model" OnValidSubmit="HandleLogin" FormName="LoginForm">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label for="login-email" class="form-label fw-semibold">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <InputText id="login-email" class="form-control" @bind-Value="model.Email"
                                   placeholder="you@hospital.com" type="email" autocomplete="email" />
                    </div>
                    <ValidationMessage For="@(() => model.Email)" class="text-danger small" />
                </div>

                <div class="mb-3">
                    <label for="login-password" class="form-label fw-semibold">Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <InputText id="login-password" class="form-control" @bind-Value="model.Password"
                                   type="password" placeholder="••••••••" autocomplete="current-password" />
                    </div>
                    <ValidationMessage For="@(() => model.Password)" class="text-danger small" />
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="rememberMe" @bind="model.RememberMe" />
                        <label class="form-check-label small" for="rememberMe">Remember me</label>
                    </div>
                    <a href="/auth/forgot-password" class="small text-decoration-none">Forgot password?</a>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <span>Signing in...</span>
                    }
                    else
                    {
                        <i class="bi bi-box-arrow-in-right me-2"></i>
                        <span>Sign In</span>
                    }
                </button>
            </EditForm>

            @if (tenantSettings?.SsoEnabled == true)
            {
                <hr class="my-4" />
                <p class="text-center text-muted small mb-3">Or sign in with</p>
                <div class="d-flex gap-2">
                    @if (tenantSettings.SsoProvider == "Google" || tenantSettings.SsoProvider == null)
                    {
                        <a href="/auth/challenge/Google?returnUrl=/" class="btn btn-outline-secondary flex-fill">
                            <i class="bi bi-google me-2"></i>Google
                        </a>
                    }
                    @if (tenantSettings.SsoProvider == "Microsoft" || tenantSettings.SsoProvider == null)
                    {
                        <a href="/auth/challenge/Microsoft?returnUrl=/" class="btn btn-outline-secondary flex-fill">
                            <i class="bi bi-microsoft me-2"></i>Microsoft
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    [SupplyParameterFromForm]
    private LoginModel model { get; set; } = new();
    private string? errorMessage;
    private bool isLoading = false;
    private string hospitalName = "Hospital Management System";
    private CareSphere.Models.TenantSettings? tenantSettings;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(Error))
        {
            if (Error == "tenant_frozen")
                errorMessage = "This hospital is currently suspended. Please contact platform operations.";
            else if (Error == "impersonation_invalid")
                errorMessage = "Invalid or expired impersonation session.";
            else if (Error == "user_inactive")
                errorMessage = "Your user account is deactivated.";
            else
                errorMessage = "Authentication failed.";
        }

        try
        {
            var tenantIdStr = Configuration["App:DefaultTenantId"] ?? "00000000-0000-0000-0000-000000000001";
            var tenantId = Guid.Parse(tenantIdStr);
            tenantSettings = await TenantService.GetTenantSettingsAsync(tenantId);
            hospitalName = tenantSettings.HospitalName;
        }
        catch { /* Use defaults */ }
    }

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var tenantIdStr = Configuration["App:DefaultTenantId"] ?? "00000000-0000-0000-0000-000000000001";
            var tenantId = Guid.Parse(tenantIdStr);

            var ipAddress = HttpContextAccessor.HttpContext?.Connection?.RemoteIpAddress?.ToString();
            var userAgent = HttpContextAccessor.HttpContext?.Request.Headers["User-Agent"].ToString();

            var result = await AuthService.LoginAsync(model.Email, model.Password, tenantId, ipAddress, userAgent);

            if (result.Success)
            {
                var returnUrl = ReturnUrl ?? "/";
                NavigationManager.NavigateTo(returnUrl, forceLoad: true);
            }
            else
            {
                errorMessage = result.Error ?? "An error occurred during login.";
            }
        }
        catch (Microsoft.AspNetCore.Components.NavigationException)
        {
            throw;
        }
        catch (Exception ex)
        {
            errorMessage = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private class LoginModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required.")]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; } = false;
    }
}
