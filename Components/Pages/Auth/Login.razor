@page "/auth/login"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@inject IAuthService AuthService
@inject ITenantService TenantService
@inject NavigationManager NavigationManager
@inject IHttpContextAccessor HttpContextAccessor
@inject IConfiguration Configuration
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject CareSphere.Modules.Admin.Services.IPermissionService PermissionService

<PageTitle>Sign In — CareSphere</PageTitle>

<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light">
    <div class="card shadow-lg border-0 rounded-4" style="width: 420px;">
        <div class="card-body p-5">
            <!-- Logo / Branding -->
            <div class="text-center mb-4">
                <div class="bg-primary bg-gradient rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px;">
                    <i class="bi bi-heart-pulse-fill text-white fs-3"></i>
                </div>
                <h4 class="fw-bold text-primary mb-0">CareSphere</h4>
                <p class="text-muted small">@hospitalName</p>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger alert-dismissible d-flex align-items-center" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <div>@errorMessage</div>
                </div>
            }

            <EditForm Model="@model" OnValidSubmit="HandleLogin" FormName="LoginForm">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label for="login-email" class="form-label fw-semibold">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <InputText id="login-email" class="form-control" @bind-Value="model.Email"
                                   placeholder="you@hospital.com" type="email" autocomplete="email" />
                    </div>
                    <ValidationMessage For="@(() => model.Email)" class="text-danger small" />
                </div>

                <div class="mb-3">
                    <label for="login-password" class="form-label fw-semibold">Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <InputText id="login-password" class="form-control" @bind-Value="model.Password"
                                   type="password" placeholder="••••••••" autocomplete="current-password" />
                    </div>
                    <ValidationMessage For="@(() => model.Password)" class="text-danger small" />
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="rememberMe" @bind="model.RememberMe" />
                        <label class="form-check-label small" for="rememberMe">Remember me</label>
                    </div>
                    <a href="/auth/forgot-password" class="small text-decoration-none">Forgot password?</a>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <span>Signing in...</span>
                    }
                    else
                    {
                        <i class="bi bi-box-arrow-in-right me-2"></i>
                        <span>Sign In</span>
                    }
                </button>
            </EditForm>

            @if (tenantSettings?.SsoEnabled == true)
            {
                <hr class="my-4" />
                <p class="text-center text-muted small mb-3">Or sign in with</p>
                <div class="d-flex gap-2">
                    @if (tenantSettings.SsoProvider == "Google" || tenantSettings.SsoProvider == null)
                    {
                        <a href="/auth/challenge/Google?returnUrl=/" class="btn btn-outline-secondary flex-fill">
                            <i class="bi bi-google me-2"></i>Google
                        </a>
                    }
                    @if (tenantSettings.SsoProvider == "Microsoft" || tenantSettings.SsoProvider == null)
                    {
                        <a href="/auth/challenge/Microsoft?returnUrl=/" class="btn btn-outline-secondary flex-fill">
                            <i class="bi bi-microsoft me-2"></i>Microsoft
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    [SupplyParameterFromForm]
    private LoginModel model { get; set; } = new();
    private string? errorMessage;
    private bool isLoading = false;
    private string hospitalName = "Hospital Management System";
    private CareSphere.Models.TenantSettings? tenantSettings;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(Error))
        {
            if (Error == "tenant_frozen")
                errorMessage = "This hospital is currently suspended. Please contact platform operations.";
            else if (Error == "impersonation_invalid")
                errorMessage = "Invalid or expired impersonation session.";
            else if (Error == "user_inactive")
                errorMessage = "Your user account is deactivated.";
            else
                errorMessage = "Authentication failed.";
        }

        try
        {
            var tenantIdStr = Configuration["App:DefaultTenantId"] ?? "00000000-0000-0000-0000-000000000001";
            var tenantId = Guid.Parse(tenantIdStr);
            tenantSettings = await TenantService.GetTenantSettingsAsync(tenantId);
            hospitalName = tenantSettings.HospitalName;
        }
        catch { /* Use defaults */ }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // If the user already has a valid tab session (e.g. after F5 redirect from a protected page),
        // skip the login form and send them straight to their dashboard.
        // Must be in OnAfterRenderAsync because JS interop (window.name) requires a connected circuit.
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated == true && string.IsNullOrEmpty(errorMessage))
            {
                var destination = ReturnUrl ?? "/";
                NavigationManager.NavigateTo(destination, forceLoad: false);
            }
        }
        catch { /* Ignore: JS interop not available */ }
    }

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var tenantIdStr = Configuration["App:DefaultTenantId"] ?? "00000000-0000-0000-0000-000000000001";
            var tenantId = Guid.Parse(tenantIdStr);

            string? ipAddress = null;
            string? userAgent = null;

            var httpContext = HttpContextAccessor.HttpContext;
            if (httpContext != null)
            {
                ipAddress = httpContext.Connection?.RemoteIpAddress?.ToString();
                userAgent = httpContext.Request?.Headers["User-Agent"].ToString();
            }

            var result = await AuthService.LoginAsync(model.Email, model.Password, tenantId, ipAddress, userAgent);

            if (result.Success)
            {
                // Store session token in window.name for tab-level isolation
                await JS.InvokeVoidAsync("eval", $"window.name = '{result.SessionToken}'");

                // Get user permissions
                var permissions = await PermissionService.GetUserPermissionsAsync(result.User!.TenantId, result.User!.Id);

                // Notify custom AuthenticationStateProvider to switch UI state immediately
                if (AuthStateProvider is CareSphere.Authorization.TabIsolatedAuthenticationStateProvider tabProvider)
                {
                    var claims = new List<Claim>
                    {
                        new Claim(ClaimTypes.NameIdentifier, result.User.Id),
                        new Claim(ClaimTypes.Name, result.User.UserName ?? result.User.Email ?? ""),
                        new Claim(CareSphereClaimTypes.TenantId, result.User.TenantId.ToString()),
                        new Claim(CareSphereClaimTypes.FullName, result.User.FullName),
                        new Claim(ClaimTypes.Role, result.User.Role),
                        new Claim("role", result.User.Role),
                        new Claim("session_token", result.SessionToken ?? "")
                    };

                    if (result.User.DoctorId.HasValue)
                        claims.Add(new Claim(CareSphereClaimTypes.DoctorId, result.User.DoctorId.Value.ToString()));

                    if (result.User.PatientId.HasValue)
                        claims.Add(new Claim(CareSphereClaimTypes.PatientId, result.User.PatientId.Value.ToString()));

                    foreach (var perm in permissions)
                    {
                        claims.Add(new Claim(CareSphereClaimTypes.Permission, perm));
                    }

                    var identity = new ClaimsIdentity(claims, "TabIsolatedAuth");
                    tabProvider.NotifyUserLogin(new ClaimsPrincipal(identity));
                }

                var returnUrl = ReturnUrl;
                if (string.IsNullOrEmpty(returnUrl) || returnUrl == "/")
                {
                    if (result.User?.Role == CareSphereRoles.HospitalAdmin)
                        returnUrl = "/dashboard";
                    else
                        returnUrl = "/";
                }
                NavigationManager.NavigateTo(returnUrl, forceLoad: false);
            }
            else
            {
                errorMessage = result.Error ?? "An error occurred during login.";
            }
        }
        catch (Microsoft.AspNetCore.Components.NavigationException)
        {
            throw;
        }
        catch (Exception ex)
        {
            System.Console.WriteLine($"[Login Exception]: {ex}");
            errorMessage = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private class LoginModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required.")]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; } = false;
    }
}
