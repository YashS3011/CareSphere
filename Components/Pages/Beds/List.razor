@page "/beds"
@inject CareSphere.Services.IBedService BedService
@inject NavigationManager NavigationManager

<PageTitle>Beds - CareSphere</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Bed Management</h2>
    <a href="/beds/create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Add New Bed</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" action="/beds" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Filter by Ward</label>
                <select name="wardId" class="form-select" @onchange="OnWardFilterChanged">
                    <option value="">All Wards</option>
                    @if (wards != null)
                    {
                        @foreach (var w in wards)
                        {
                            <option value="@w.Id" selected="@(w.Id.ToString() == currentWardId)">@w.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Filter by Status</label>
                <select name="status" class="form-select" @onchange="OnStatusFilterChanged">
                    <option value="">All Statuses</option>
                    <option value="Available" selected="@(currentStatus == "Available")">Available</option>
                    <option value="Occupied" selected="@(currentStatus == "Occupied")">Occupied</option>
                    <option value="Maintenance" selected="@(currentStatus == "Maintenance")">Maintenance</option>
                    <option value="Reserved" selected="@(currentStatus == "Reserved")">Reserved</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="button" class="btn btn-outline-secondary w-100" @onclick="ClearFilters">Clear Filters</button>
            </div>
        </form>
    </div>
</div>

@if (beds == null)
{
    <p><em>Loading...</em></p>
}
else if (!beds.Any())
{
    <div class="alert alert-info">No beds found matching the criteria.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Bed Number</th>
                    <th>Ward</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Active</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var bed in beds)
                {
                    <tr>
                        <td><strong>@bed.BedNumber</strong></td>
                        <td>@(bed.Ward?.Name ?? "Unknown")</td>
                        <td>@bed.BedType</td>
                        <td>
                            @switch (bed.Status)
                            {
                                case "Available":
                                    <span class="badge bg-success">Available</span>
                                    break;
                                case "Occupied":
                                    <span class="badge bg-danger">Occupied</span>
                                    break;
                                case "Maintenance":
                                    <span class="badge bg-warning text-dark">Maintenance</span>
                                    break;
                                case "Reserved":
                                    <span class="badge bg-info">Reserved</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary">@bed.Status</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (bed.IsActive)
                            {
                                <i class="bi bi-check-circle text-success"></i>
                            }
                            else
                            {
                                <i class="bi bi-dash-circle text-danger"></i>
                            }
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a href="/beds/edit/@bed.Id" class="btn btn-warning" title="Edit"><i class="bi bi-pencil"></i> Edit</a>
                                <button class="btn btn-danger" @onclick="() => ConfirmDelete(bed.Id, bed.Status)" title="Delete"><i class="bi bi-trash"></i> Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal fade show" style="display: block; background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this bed?</p>
                    @if (deleteError != null)
                    {
                        <div class="alert alert-danger">@deleteError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="DeleteBed">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "wardId")]
    public string? currentWardId { get; set; }

    [SupplyParameterFromQuery(Name = "status")]
    public string? currentStatus { get; set; }

    private List<CareSphere.Models.Bed>? beds;
    private List<CareSphere.Models.Ward>? wards;
    
    private bool showDeleteConfirm = false;
    private Guid bedIdToDelete = Guid.Empty;
    private string? deleteError;

    protected override async Task OnInitializedAsync()
    {
        wards = await BedService.GetAllWardsAsync();
        await LoadBeds();
    }
    
    // In Static SSR, onchange doesn't automatically fire standard C# methods without JS interop or form submission.
    // For simplicity, we can rely on standard links or submit buttons, but let's implement the reload logic if Blazor handles it.
    private async Task OnWardFilterChanged(ChangeEventArgs e)
    {
        currentWardId = e.Value?.ToString();
        await LoadBeds();
    }
    
    private async Task OnStatusFilterChanged(ChangeEventArgs e)
    {
        currentStatus = e.Value?.ToString();
        await LoadBeds();
    }

    private async Task ClearFilters()
    {
        currentWardId = null;
        currentStatus = null;
        await LoadBeds();
    }

    private async Task LoadBeds()
    {
        beds = await BedService.GetAllBedsAsync(currentWardId, currentStatus);
    }

    private void ConfirmDelete(Guid id, string status)
    {
        if (status == "Occupied")
        {
            deleteError = "Cannot delete a bed that is currently occupied.";
        }
        else
        {
            deleteError = null;
        }
        bedIdToDelete = id;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        bedIdToDelete = Guid.Empty;
        deleteError = null;
    }

    private async Task DeleteBed()
    {
        if (bedIdToDelete != Guid.Empty && deleteError == null)
        {
            try
            {
                await BedService.DeleteBedAsync(bedIdToDelete);
                await LoadBeds();
                showDeleteConfirm = false;
            }
            catch (Exception ex)
            {
                deleteError = ex.Message;
            }
        }
    }
}
