@page "/lab/reports/{requisitionId:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Lab_ViewReports)]
@using CareSphere.Models
@using CareSphere.Services
@using CareSphere.Data
@using Microsoft.EntityFrameworkCore
@inject ILabReportService ReportService
@inject ILabNotificationService NotificationService
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Lab Report View - CareSphere</PageTitle>

<div class="container py-4" style="max-width: 700px;">
    <!-- Back Link -->
    <div class="mb-3">
        <a href="/lab/requisitions/@requisitionId" class="btn btn-link p-0 text-decoration-none link-secondary small">
            <i class="bi bi-arrow-left"></i> Back to Requisition Details
        </a>
    </div>

    @if (loading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading report details...</span>
            </div>
        </div>
    }
    else if (report == null)
    {
        <div class="alert alert-warning d-flex justify-content-between align-items-center">
            <span>No report has been generated for this requisition yet.</span>
            <button class="btn btn-sm btn-primary" @onclick="RegenerateReport">Generate Report</button>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success py-2 small mb-3">@successMessage</div>
        }

        <!-- Header -->
        <div class="mb-4">
            <h1 class="h3 mb-1 text-dark fw-bold"><i class="bi bi-file-earmark-pdf me-2 text-danger"></i>Lab Test Report</h1>
            <p class="text-muted">Report details and distribution logs for Requisition: <strong>@report.Requisition.RequisitionNumber</strong></p>
        </div>

        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-header bg-white py-3 px-4 border-bottom">
                <h5 class="fw-bold text-dark mb-0">Report Details</h5>
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="text-muted small fw-semibold uppercase fs-9 mb-1">File Name</div>
                        <div class="fw-bold text-dark">@report.FileName</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted small fw-semibold uppercase fs-9 mb-1">Generated At</div>
                        <div class="fw-bold text-dark">@report.GeneratedAt.ToLocalTime().ToString("g")</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted small fw-semibold uppercase fs-9 mb-1">Generated By</div>
                        <div class="fw-bold text-dark">@report.GeneratedByUserId</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted small fw-semibold uppercase fs-9 mb-1">Version Status</div>
                        <div>
                            <span class="badge @(report.IsLatest ? "bg-success" : "bg-secondary")">
                                @(report.IsLatest ? "Latest Release" : "Archived / Outdated")
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Notification Status Logs -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-header bg-white py-3 px-4 border-bottom">
                <h5 class="fw-bold text-dark mb-0">Notification Status Logs</h5>
            </div>
            <div class="card-body p-4">
                <div class="d-flex flex-column gap-3">
                    <!-- Patient SMS Status -->
                    <div class="d-flex justify-content-between align-items-center border-bottom pb-2">
                        <div>
                            <div class="fw-semibold text-dark fs-8"><i class="bi bi-chat-left-text me-2"></i>Patient SMS Alert</div>
                            <div class="text-muted fs-9">Recipient: @report.Requisition.Patient.FirstName @report.Requisition.Patient.LastName (@report.Requisition.Patient.Phone)</div>
                        </div>
                        <span class="badge @GetSmsBadgeClass(report.PatientSmsStatus)">
                            @report.PatientSmsStatus
                        </span>
                    </div>

                    <!-- Doctor SMS Status -->
                    <div class="d-flex justify-content-between align-items-center border-bottom pb-2">
                        <div>
                            <div class="fw-semibold text-dark fs-8"><i class="bi bi-chat-square-text me-2"></i>Doctor SMS Alert</div>
                            <div class="text-muted fs-9">Recipient: Dr. @report.Requisition.OrderedByDoctor.FirstName @report.Requisition.OrderedByDoctor.LastName (@report.Requisition.OrderedByDoctor.Phone)</div>
                        </div>
                        <span class="badge @GetSmsBadgeClass(report.DoctorSmsStatus)">
                            @report.DoctorSmsStatus
                        </span>
                    </div>

                    <!-- In-App Notification -->
                    <div class="d-flex justify-content-between align-items-center pb-1">
                        <div>
                            <div class="fw-semibold text-dark fs-8"><i class="bi bi-bell me-2"></i>In-App Notifications</div>
                            <div class="text-muted fs-9">Dispatched to doctor and patient portal accounts</div>
                        </div>
                        <span class="badge @(report.InAppNotificationSent ? "bg-success" : "bg-secondary")">
                            @(report.InAppNotificationSent ? "Sent" : "Pending")
                        </span>
                    </div>

                    @if (report.NotificationSentAt.HasValue)
                    {
                        <div class="text-muted fs-9 mt-2 text-end">
                            Dispatched At: @report.NotificationSentAt.Value.ToLocalTime().ToString("g")
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="d-flex gap-2">
            <a href="/@report.StoragePath" target="_blank" class="btn btn-success px-4 shadow-sm">
                <i class="bi bi-download me-1"></i> Download PDF
            </a>
            <button class="btn btn-outline-primary px-4 shadow-sm" @onclick="RegenerateReport" disabled="@regenerating">
                @if (regenerating)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                Regenerate Report
            </button>
            <button class="btn btn-outline-secondary px-4 shadow-sm" @onclick="ResendNotifications" disabled="@resending">
                @if (resending)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                Resend Notifications
            </button>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid requisitionId { get; set; }

    private bool loading = true;
    private bool regenerating = false;
    private bool resending = false;
    private LabReport? report;
    private string successMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadReportDetails();
    }

    private async Task LoadReportDetails()
    {
        try
        {
            loading = true;
            report = await DbContext.LabReports
                .Include(r => r.Requisition)
                    .ThenInclude(req => req.Patient)
                .Include(r => r.Requisition)
                    .ThenInclude(req => req.OrderedByDoctor)
                .FirstOrDefaultAsync(r => r.RequisitionId == requisitionId && r.IsLatest);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading report details: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task RegenerateReport()
    {
        try
        {
            regenerating = true;
            successMessage = string.Empty;

            var newReport = await ReportService.GenerateReportAsync(Guid.Empty, requisitionId);
            successMessage = "Lab report regenerated and new version released.";
            await LoadReportDetails();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error regenerating report: {ex.Message}");
        }
        finally
        {
            regenerating = false;
        }
    }

    private async Task ResendNotifications()
    {
        if (report == null) return;

        try
        {
            resending = true;
            successMessage = string.Empty;

            await NotificationService.SendReportNotificationsAsync(report.TenantId, report.Id);
            successMessage = "Report notifications successfully resent to doctor and patient.";
            await LoadReportDetails();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error resending notifications: {ex.Message}");
        }
        finally
        {
            resending = false;
        }
    }

    private string GetSmsBadgeClass(string? status)
    {
        return status switch
        {
            "Sent" => "bg-success text-white",
            "Failed" => "bg-danger text-white",
            "Skipped" => "bg-secondary text-white",
            _ => "bg-light text-dark border"
        };
    }
}

<style>
    .fs-8 { font-size: 0.85rem !important; }
    .fs-9 { font-size: 0.78rem !important; }
</style>

