@page "/lab/catalog"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Lab_ViewReports)]
@using CareSphere.Models
@using CareSphere.Services
@inject ILabCatalogService CatalogService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Lab Test Catalog - CareSphere</PageTitle>

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 text-dark fw-bold"><i class="bi bi-book me-2 text-primary"></i>Lab Test Catalog</h1>
            <p class="text-muted mb-0">Manage test catalogs, specimen requirements, turnaround times, pricing, and parameters</p>
        </div>
        <a href="/lab/catalog/create" class="btn btn-primary shadow-sm"><i class="bi bi-plus-lg me-1"></i> Create Test Catalog</a>
    </div>

    <!-- Search and Filter Panel -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control border-start-0" placeholder="Search by test name or code..." @bind="searchQuery" @bind:after="ApplyFilters" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="selectedCategory" @bind:after="ApplyFilters">
                        <option value="">All Categories</option>
                        <option value="Hematology">Hematology</option>
                        <option value="Biochemistry">Biochemistry</option>
                        <option value="Microbiology">Microbiology</option>
                        <option value="Immunology">Immunology</option>
                        <option value="Pathology">Pathology</option>
                        <option value="Radiology">Radiology</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="selectedStatus" @bind:after="ApplyFilters">
                        <option value="">All Statuses</option>
                        <option value="Active">Active Only</option>
                        <option value="Inactive">Inactive Only</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    @if (loading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading tests...</span>
            </div>
        </div>
    }
    else
    {
        <!-- Catalog Table -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="table-responsive">
                <table class="table align-middle mb-0 small">
                    <thead class="table-light fs-8 text-uppercase text-muted">
                        <tr>
                            <th style="width: 5%;"></th>
                            <th>Test Code</th>
                            <th>Test Name</th>
                            <th>Category</th>
                            <th>Sample Type</th>
                            <th class="text-end">Turnaround (Hrs)</th>
                            <th class="text-end">Price (₹)</th>
                            <th class="text-center">Parameters</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (tests == null || !tests.Any())
                        {
                            <tr>
                                <td colspan="10" class="text-center py-4 text-muted">No test catalog entries found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var test in tests)
                            {
                                var testId = test.Id;
                                <tr>
                                    <td class="text-center">
                                        <button class="btn btn-link p-0 text-muted" @onclick="() => ToggleParameters(testId)">
                                            <i class="bi @(expandedTests.Contains(testId) ? "bi-chevron-down" : "bi-chevron-right")"></i>
                                        </button>
                                    </td>
                                    <td class="fw-bold text-dark font-monospace text-uppercase">@test.TestCode</td>
                                    <td>@test.TestName</td>
                                    <td>
                                        <span class="badge bg-light text-dark border">@test.Category</span>
                                    </td>
                                    <td>@test.SampleType</td>
                                    <td class="text-end">@test.TurnaroundHours hrs</td>
                                    <td class="text-end fw-semibold">₹@test.Price.ToString("N2")</td>
                                    <td class="text-center">
                                        <span class="badge bg-primary-subtle text-primary rounded-pill">@test.Parameters.Count</span>
                                    </td>
                                    <td>
                                        <span class="badge @(test.IsActive ? "bg-success" : "bg-secondary")">
                                            @(test.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex gap-1 justify-content-center">
                                            <a href="/lab/catalog/edit/@test.Id" class="btn btn-xs btn-outline-primary py-0 px-2 fs-8"><i class="bi bi-pencil me-1"></i>Edit</a>
                                        </div>
                                    </td>
                                </tr>

                                @if (expandedTests.Contains(testId))
                                {
                                    <tr>
                                        <td></td>
                                        <td colspan="9" class="bg-light p-3 border-start border-primary border-3">
                                            <div class="mb-2 fw-bold text-muted small uppercase">Test Parameters</div>
                                            @if (test.Parameters == null || !test.Parameters.Any())
                                            {
                                                <div class="text-muted small">No parameters configured for this test.</div>
                                            }
                                            else
                                            {
                                                <div class="table-responsive bg-white rounded-3 shadow-xs border">
                                                    <table class="table table-bordered table-sm mb-0 small">
                                                        <thead class="table-light text-muted">
                                                            <tr>
                                                                <th>Parameter Name</th>
                                                                <th>Code</th>
                                                                <th>Unit</th>
                                                                <th>Data Type</th>
                                                                <th>Reference Range</th>
                                                                <th>Sort Order</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var param in test.Parameters.OrderBy(p => p.SortOrder))
                                                            {
                                                                <tr>
                                                                    <td>@param.ParameterName</td>
                                                                    <td class="font-monospace text-uppercase small text-muted">@(param.ParameterCode ?? "-")</td>
                                                                    <td>@(param.Unit ?? "-")</td>
                                                                    <td><span class="badge bg-secondary-subtle text-secondary small">@param.DataType</span></td>
                                                                    <td>
                                                                        @if (param.DataType == "Numeric")
                                                                        {
                                                                            <span>@param.ReferenceRangeLow - @param.ReferenceRangeHigh</span>
                                                                        }
                                                                        else
                                                                        {
                                                                            <span>@param.ReferenceRangeText</span>
                                                                        }
                                                                    </td>
                                                                    <td class="text-center">@param.SortOrder</td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private bool loading = true;
    private string searchQuery = string.Empty;
    private string selectedCategory = string.Empty;
    private string selectedStatus = string.Empty;

    private List<LabTestCatalog>? tests;
    private HashSet<Guid> expandedTests = new();

    private Guid currentTenantId = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadCatalog();
    }

    private async Task LoadCatalog()
    {
        try
        {
            loading = true;

            bool? isActive = null;
            if (selectedStatus == "Active") isActive = true;
            else if (selectedStatus == "Inactive") isActive = false;

            tests = await CatalogService.GetAllTestsAsync(currentTenantId, searchQuery, selectedCategory, isActive);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading test catalog: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task ApplyFilters()
    {
        await LoadCatalog();
    }

    private void ToggleParameters(Guid testId)
    {
        if (expandedTests.Contains(testId))
        {
            expandedTests.Remove(testId);
        }
        else
        {
            expandedTests.Add(testId);
        }
    }
}

<style>
    .fs-8 { font-size: 0.8rem !important; }
    .btn-xs {
        padding: 0.15rem 0.4rem;
        font-size: 0.75rem;
        line-height: 1.5;
        border-radius: 0.2rem;
    }
    .shadow-xs {
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }
</style>

