@page "/doctor-dashboard"
@rendermode InteractiveServer
@using CareSphere.Models
@using CareSphere.Models.DTOs
@inject CareSphere.Services.IDoctorService DoctorService
@inject CareSphere.Services.IEncounterService EncounterService

<PageTitle>Doctor Dashboard - CareSphere</PageTitle>

<h2>Doctor Dashboard</h2>
<hr />

<div class="row mb-4 align-items-end">
    <div class="col-md-4">
        <label class="form-label">Select Doctor</label>
        <select class="form-select" @bind="selectedDoctorId">
            <option value="">-- Select a Doctor --</option>
            @if (activeDoctors != null)
            {
                foreach (var doc in activeDoctors)
                {
                    <option value="@doc.Id">@doc.FullName (@doc.Specialization)</option>
                }
            }
        </select>
    </div>

    <div class="col-md-4">
        <label class="form-label">Date</label>
        <input type="date"
               class="form-control"
               @bind="selectedDate"
               @bind:format="yyyy-MM-dd" />
    </div>
    <div class="col-md-3">
        <label class="form-label">&nbsp;</label>
        <button class="btn btn-primary w-100" @onclick="LoadDashboard">
            <i class="bi bi-arrow-clockwise me-2"></i> Load Dashboard
        </button>
    </div>
</div>

@if (isLoading)
{
    <div class="d-flex justify-content-center mt-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (!string.IsNullOrEmpty(selectedDoctorId) && stats != null)
{
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card shadow py-2" style="border-left: 4px solid #f6c23e;">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Waiting in Queue</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@stats.WaitingCount</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-person-lines-fill fa-2x text-gray-300" style="font-size: 2rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card shadow py-2" style="border-left: 4px solid #4e73df;">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">In Consultation</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@stats.InConsultationCount</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-heart-pulse-fill fa-2x text-gray-300" style="font-size: 2rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card shadow py-2" style="border-left: 4px solid #1cc88a;">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Completed Today</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@stats.CompletedToday</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-check-circle-fill fa-2x text-gray-300" style="font-size: 2rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card shadow py-2" style="border-left: 4px solid #36b9cc;">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Encounters This Week</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@stats.EncountersThisWeek</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-calendar-week-fill fa-2x text-gray-300" style="font-size: 2rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card shadow">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body d-flex gap-3">
                    <a href="/doctor-dashboard/queue/@selectedDoctorId/@selectedDate.ToString("yyyy-MM-dd")"
                       class="btn btn-primary d-flex flex-column align-items-center p-3"
                       style="width: 150px;">
                        <i class="bi bi-list-ol mb-2" style="font-size: 2rem;"></i>
                        <span>View My Queue</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
}
else if (!string.IsNullOrEmpty(selectedDoctorId) && stats == null)
{
    <div class="alert alert-warning">Unable to load dashboard stats.</div>
}
else
{
    <div class="alert alert-info">Please select a doctor to load dashboard.</div>
}

@code {
    private List<Doctor>? activeDoctors;

    private string selectedDoctorId = string.Empty;
    private DateOnly selectedDate = DateOnly.FromDateTime(DateTime.Now);

    private DoctorDashboardStats? stats;
    private bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        activeDoctors = await DoctorService.GetActiveDoctorsAsync();
    }

    private async Task LoadDashboard()
    {
        Console.WriteLine($"LoadDashboard triggered. DoctorId='{selectedDoctorId}', Date='{selectedDate}'");

        if (string.IsNullOrEmpty(selectedDoctorId))
        {
            Console.WriteLine("Doctor ID is null or empty, clearing stats.");
            stats = null;
            return;
        }

        try
        {
            isLoading = true;
            await InvokeAsync(StateHasChanged); // Force spinner UI update

            if (Guid.TryParse(selectedDoctorId, out Guid docId))
            {
                Console.WriteLine($"Fetching stats for DoctorId: {docId}");
                stats = await EncounterService.GetDoctorDashboardAsync(docId, selectedDate);
                Console.WriteLine($"Stats fetched! Waiting: {stats.WaitingCount}, InConsultation: {stats.InConsultationCount}, Completed: {stats.CompletedToday}, Week: {stats.EncountersThisWeek}");
            }
            else
            {
                Console.WriteLine("Failed to parse selectedDoctorId as Guid.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard: {ex.Message}");
            stats = null;
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged); // Force UI update
        }
    }
}