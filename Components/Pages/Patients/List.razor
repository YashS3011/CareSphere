@page "/patients"
@inject CareSphere.Services.IPatientService PatientService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Patients - CareSphere</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Patient Management</h2>
    <a href="/patients/create" class="btn btn-primary">Register New Patient</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <div class="input-group">
            <input type="text" class="form-control" placeholder="Search by name or MRN..." @bind="SearchTerm" @bind:event="oninput" @onkeyup="HandleSearch" />
            <button class="btn btn-outline-secondary" type="button" @onclick="LoadPatients">Search</button>
        </div>
    </div>
</div>

@if (patients == null)
{
    <p><em>Loading...</em></p>
}
else if (!patients.Any())
{
    <div class="alert alert-info">No patients found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>MRN</th>
                    <th>Name</th>
                    <th>DOB</th>
                    <th>Gender</th>
                    <th>Phone</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var patient in patients)
                {
                    <tr>
                        <td>@patient.Mrn</td>
                        <td>@patient.FirstName @patient.LastName</td>
                        <td>@patient.DateOfBirth.ToString("dd MMM yyyy")</td>
                        <td>@patient.Gender</td>
                        <td>@patient.Phone</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a href="/patients/view/@patient.Id" class="btn btn-info" title="View"><i class="bi bi-eye"></i> View</a>
                                <a href="/patients/edit/@patient.Id" class="btn btn-warning" title="Edit"><i class="bi bi-pencil"></i> Edit</a>
                                <button class="btn btn-danger" @onclick="() => ConfirmDelete(patient.Id)" title="Delete"><i class="bi bi-trash"></i> Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal fade show" style="display: block; background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this patient? This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="DeletePatient">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<CareSphere.Models.Patient>? patients;
    private string SearchTerm { get; set; } = string.Empty;
    private bool showDeleteConfirm = false;
    private Guid patientIdToDelete = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadPatients();
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LoadPatients();
        }
    }

    private async Task LoadPatients()
    {
        patients = await PatientService.GetPatientsAsync(SearchTerm);
    }

    private void ConfirmDelete(Guid id)
    {
        patientIdToDelete = id;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        patientIdToDelete = Guid.Empty;
    }

    private async Task DeletePatient()
    {
        if (patientIdToDelete != Guid.Empty)
        {
            await PatientService.DeletePatientAsync(patientIdToDelete);
            await LoadPatients();
        }
        showDeleteConfirm = false;
    }
}
