@page "/patients/create"
@using CareSphere.Models
@inject CareSphere.Services.IPatientService PatientService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Register Patient - CareSphere</PageTitle>

<h2>Register New Patient</h2>
<hr />

<div class="row">
    <div class="col-md-8">
        <EditForm Model="@patient" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Basic Information</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">First Name *</label>
                            <InputText class="form-control" @bind-Value="patient.FirstName" />
                            <ValidationMessage For="@(() => patient.FirstName)" class="text-danger" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Last Name *</label>
                            <InputText class="form-control" @bind-Value="patient.LastName" />
                            <ValidationMessage For="@(() => patient.LastName)" class="text-danger" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Date of Birth *</label>
                            <InputDate class="form-control" @bind-Value="patient.DateOfBirth" />
                            <ValidationMessage For="@(() => patient.DateOfBirth)" class="text-danger" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Gender *</label>
                            <InputSelect class="form-select" @bind-Value="patient.Gender">
                                <option value="">Select Gender</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => patient.Gender)" class="text-danger" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Blood Group</label>
                            <InputSelect class="form-select" @bind-Value="patient.BloodGroup">
                                <option value="">Select Blood Group</option>
                                <option value="A+">A+</option>
                                <option value="A-">A-</option>
                                <option value="B+">B+</option>
                                <option value="B-">B-</option>
                                <option value="AB+">AB+</option>
                                <option value="AB-">AB-</option>
                                <option value="O+">O+</option>
                                <option value="O-">O-</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => patient.BloodGroup)" class="text-danger" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Contact & Identifiers</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Phone Number *</label>
                            <InputText class="form-control" @bind-Value="patient.Phone" />
                            <ValidationMessage For="@(() => patient.Phone)" class="text-danger" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email (Optional)</label>
                            <InputText class="form-control" type="email" @bind-Value="patient.Email" />
                            <ValidationMessage For="@(() => patient.Email)" class="text-danger" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Address</label>
                            <InputTextArea class="form-control" @bind-Value="patient.Address" rows="3" />
                            <ValidationMessage For="@(() => patient.Address)" class="text-danger" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">ABHA ID (Optional)</label>
                            <InputText class="form-control" @bind-Value="patient.AbhaId" placeholder="e.g. 91-XXXX-XXXX-XXXX" />
                            <ValidationMessage For="@(() => patient.AbhaId)" class="text-danger" />
                            <small class="text-muted">ABHA API integration is coming in a future update.</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                    @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> }
                    Register Patient
                </button>
                <a href="/patients" class="btn btn-secondary">Cancel</a>
            </div>
            
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3">@errorMessage</div>
            }
        </EditForm>
    </div>
</div>

@code {
    private Patient patient = new Patient { DateOfBirth = DateTime.Today.AddYears(-30) }; // Default DOB
    private bool isSubmitting = false;
    private string errorMessage = string.Empty;

    private async Task HandleValidSubmit()
    {
        try
        {
            isSubmitting = true;
            errorMessage = string.Empty;
            // MRN is auto-generated by the service
            patient.Mrn = "TBD"; // Satisfy required validation on client before service sets it. Note: EditForm checks [Required].
            await PatientService.CreatePatientAsync(patient);
            NavigationManager.NavigateTo("/patients");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error registering patient: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
