@using CareSphere.Models
@inject CareSphere.Services.ITeleConsultService TeleConsultService
@rendermode InteractiveServer

<div class="card mb-4">
    <div class="card-header bg-light">
        <h5 class="mb-0"><i class="bi bi-camera-video me-2"></i>Tele-Consultation</h5>
    </div>
    <div class="card-body">
        @if (isLoading)
        {
            <p><em>Loading...</em></p>
        }
        else if (activeSession != null)
        {
            @* Active Session Display *@
            <div class="alert alert-success">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="alert-heading mb-1"><i class="bi bi-broadcast me-1"></i> Session Active</h6>
                        <p class="mb-1">
                            <strong>Type:</strong> @activeSession.SessionType |
                            <strong>Started:</strong> @(activeSession.StartedAt?.ToLocalTime().ToString("HH:mm") ?? "—")
                        </p>
                        @if (activeSession.StartedAt.HasValue)
                        {
                            var elapsed = (int)(DateTime.UtcNow - activeSession.StartedAt.Value).TotalMinutes;
                            <p class="mb-0"><strong>Duration:</strong> @elapsed minutes</p>
                        }
                    </div>
                    <button class="btn btn-danger" @onclick="EndSession">
                        <i class="bi bi-stop-circle me-1"></i> End Session
                    </button>
                </div>
                <hr />
                <p class="mb-0">
                    <strong>Meeting Link:</strong>
                    <a href="@activeSession.MeetingLink" target="_blank" class="text-decoration-none">
                        @activeSession.MeetingLink <i class="bi bi-box-arrow-up-right ms-1"></i>
                    </a>
                </p>
                <small class="text-muted">LiveKit integration pending — this is a placeholder link.</small>
            </div>
        }
        else if (scheduledSession != null)
        {
            @* Scheduled session — ready to start *@
            <div class="alert alert-info">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="alert-heading mb-1">Session Scheduled</h6>
                        <p class="mb-0"><strong>Type:</strong> @scheduledSession.SessionType</p>
                    </div>
                    <button class="btn btn-success" @onclick="StartSession">
                        <i class="bi bi-play-fill me-1"></i> Start Session
                    </button>
                </div>
            </div>
        }
        else
        {
            @* No active session — show create form *@
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Session Type</label>
                    <select class="form-select" @bind="newSessionType">
                        <option value="Consultation">Consultation</option>
                        <option value="ICU">ICU</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-primary" @onclick="CreateSession" disabled="@isCreating">
                        @if (isCreating) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-camera-video me-1"></i> Schedule Session
                    </button>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3 py-2">@errorMessage</div>
        }

        @* Session History *@
        @if (pastSessions != null && pastSessions.Any())
        {
            <h6 class="mt-4">Session History</h6>
            <div class="table-responsive">
                <table class="table table-sm table-striped">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Started</th>
                            <th>Ended</th>
                            <th>Duration</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in pastSessions)
                        {
                            <tr>
                                <td>@s.SessionType</td>
                                <td>
                                    @switch (s.Status)
                                    {
                                        case "Ended":
                                            <span class="badge bg-secondary">Ended</span>
                                            break;
                                        case "Active":
                                            <span class="badge bg-success">Active</span>
                                            break;
                                        default:
                                            <span class="badge bg-info">@s.Status</span>
                                            break;
                                    }
                                </td>
                                <td>@(s.StartedAt?.ToLocalTime().ToString("dd MMM HH:mm") ?? "—")</td>
                                <td>@(s.EndedAt?.ToLocalTime().ToString("dd MMM HH:mm") ?? "—")</td>
                                <td>@(s.DurationMinutes.HasValue ? $"{s.DurationMinutes} min" : "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public Guid EncounterId { get; set; }
    [Parameter] public Guid DoctorId { get; set; }
    [Parameter] public Guid PatientId { get; set; }

    private List<TeleConsultSession>? allSessions;
    private TeleConsultSession? activeSession;
    private TeleConsultSession? scheduledSession;
    private List<TeleConsultSession>? pastSessions;

    private bool isLoading = true;
    private bool isCreating = false;
    private string newSessionType = "Consultation";
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadSessions();
        isLoading = false;
    }

    private async Task LoadSessions()
    {
        allSessions = await TeleConsultService.GetSessionsByEncounterAsync(EncounterId);

        activeSession = allSessions.FirstOrDefault(s => s.Status == "Active");
        scheduledSession = activeSession == null ? allSessions.FirstOrDefault(s => s.Status == "Scheduled") : null;
        pastSessions = allSessions.Where(s => s.Status == "Ended").ToList();
    }

    private async Task CreateSession()
    {
        try
        {
            isCreating = true;
            errorMessage = string.Empty;

            await TeleConsultService.CreateSessionAsync(new TeleConsultSession
            {
                EncounterId = EncounterId,
                DoctorId = DoctorId,
                PatientId = PatientId,
                SessionType = newSessionType
            });

            await LoadSessions();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isCreating = false;
        }
    }

    private async Task StartSession()
    {
        try
        {
            errorMessage = string.Empty;
            if (scheduledSession != null)
            {
                await TeleConsultService.StartSessionAsync(scheduledSession.Id);
                await LoadSessions();
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task EndSession()
    {
        try
        {
            errorMessage = string.Empty;
            if (activeSession != null)
            {
                await TeleConsultService.EndSessionAsync(activeSession.Id);
                await LoadSessions();
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}

