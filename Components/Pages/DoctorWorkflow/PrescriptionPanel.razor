@using CareSphere.Models
@using CareSphere.Services
@inject IPrescriptionService PrescriptionService
@inject IClinicalDecisionSupportService CdsService
@implements IDisposable
@rendermode InteractiveServer

<div class="card mb-4">
    <div class="card-header bg-light">
        <h5 class="mb-0"><i class="bi bi-capsule me-2"></i>Prescriptions</h5>
    </div>
    <div class="card-body">
        @* Drug Search & Prescription Form *@
        <div class="card border-dashed mb-3">
            <div class="card-body">
                <h6 class="card-title">Add Prescription</h6>
                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label">Search Drug *</label>
                        <input type="text" class="form-control" placeholder="Type to search drug formulary..."
                               @bind="drugSearchTerm" @bind:event="oninput" @bind:after="OnDrugSearchChanged" />
                        @if (drugResults != null && drugResults.Any())
                        {
                            <div class="list-group mt-1" style="position: absolute; z-index: 100; max-height: 200px; overflow-y: auto;">
                                @foreach (var drug in drugResults)
                                {
                                    <button type="button" class="list-group-item list-group-item-action" @onclick="() => SelectDrug(drug)">
                                        <strong>@drug.GenericName</strong>
                                        @if (!string.IsNullOrEmpty(drug.BrandName))
                                        {
                                            <span class="text-muted"> (@drug.BrandName)</span>
                                        }
                                        <br /><small class="text-muted">@drug.Form — @drug.Strength @drug.Unit | Code: @drug.DrugCode</small>
                                        @if (drug.IsControlled)
                                        {
                                            <span class="badge bg-danger ms-1">Controlled</span>
                                        }
                                    </button>
                                }
                            </div>
                        }
                    </div>

                    @* Drug Interaction Alerts *@
                    @if (interactionAlerts != null && interactionAlerts.Any())
                    {
                        @foreach (var alert in interactionAlerts)
                        {
                            var alertClass = alert.Severity == "Contraindicated" ? "alert-danger" : "alert-warning";
                            var icon = alert.Severity == "Contraindicated" ? "bi-exclamation-triangle-fill" : "bi-exclamation-circle";
                            <div class="col-12">
                                <div class="alert @alertClass py-2 mb-2">
                                    <i class="bi @icon me-1"></i>
                                    <strong>@alert.Severity:</strong> @alert.AlertMessage
                                    <br /><small>Interacting drug: @alert.InteractingDrug</small>
                                </div>
                            </div>
                        }

                        @if (hasContraindication)
                        {
                            <div class="col-12">
                                <label class="form-label text-danger fw-bold">Justification Required (Contraindicated) *</label>
                                <textarea class="form-control border-danger" @bind="contraindicationJustification" rows="2"
                                          placeholder="Provide clinical justification for prescribing despite contraindication..."></textarea>
                            </div>
                        }
                    }

                    <div class="col-md-4">
                        <label class="form-label">Form *</label>
                        <input type="text" class="form-control" @bind="rxForm" placeholder="e.g. Tablet" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Strength *</label>
                        <input type="text" class="form-control" @bind="rxStrength" placeholder="e.g. 500mg" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Route *</label>
                        <select class="form-select" @bind="rxRoute">
                            <option value="">Select Route</option>
                            <option value="Oral">Oral</option>
                            <option value="IV">IV</option>
                            <option value="IM">IM</option>
                            <option value="SC">SC</option>
                            <option value="Topical">Topical</option>
                            <option value="Inhaled">Inhaled</option>
                            <option value="Sublingual">Sublingual</option>
                            <option value="Rectal">Rectal</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Frequency *</label>
                        <select class="form-select" @bind="rxFrequency">
                            <option value="">Select Frequency</option>
                            <option value="OD (Once Daily)">OD (Once Daily)</option>
                            <option value="BD (Twice Daily)">BD (Twice Daily)</option>
                            <option value="TDS (Thrice Daily)">TDS (Thrice Daily)</option>
                            <option value="QID (Four Times Daily)">QID (Four Times Daily)</option>
                            <option value="SOS (As Needed)">SOS (As Needed)</option>
                            <option value="STAT (Immediately)">STAT (Immediately)</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Duration *</label>
                        <input type="text" class="form-control" @bind="rxDuration" placeholder="e.g. 7 days" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Quantity *</label>
                        <input type="number" class="form-control" @bind="rxQuantity" min="1" />
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">Notes</label>
                        <input type="text" class="form-control" @bind="rxNotes" placeholder="Additional instructions..." />
                    </div>
                </div>
                <div class="mt-3">
                    <button class="btn btn-success" @onclick="AddPrescription" disabled="@isAdding">
                        @if (isAdding) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-plus-circle me-1"></i> Add Prescription
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(addError))
                {
                    <div class="alert alert-danger mt-2 py-2">@addError</div>
                }
                @if (!string.IsNullOrEmpty(addSuccess))
                {
                    <div class="alert alert-success mt-2 py-2">@addSuccess</div>
                }
            </div>
        </div>

        @* Existing Prescriptions Table *@
        <h6 class="mt-4">Current Prescriptions</h6>
        @if (prescriptions == null)
        {
            <p><em>Loading...</em></p>
        }
        else if (!prescriptions.Any())
        {
            <p class="text-muted">No prescriptions yet.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped">
                    <thead>
                        <tr>
                            <th>Drug</th>
                            <th>Form / Strength</th>
                            <th>Frequency</th>
                            <th>Duration</th>
                            <th>Route</th>
                            <th>Qty</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var rx in prescriptions)
                        {
                            <tr class="@(rx.Status == "Cancelled" ? "text-decoration-line-through text-muted" : "")">
                                <td>@rx.DrugName <br /><small class="text-muted">@rx.DrugCode</small></td>
                                <td>@rx.Form / @rx.Strength</td>
                                <td>@rx.Frequency</td>
                                <td>@rx.Duration</td>
                                <td>@rx.Route</td>
                                <td>@rx.Quantity</td>
                                <td>
                                    @if (rx.Status == "Active")
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Cancelled</span>
                                    }
                                </td>
                                <td>
                                    @if (rx.Status == "Active")
                                    {
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ShowCancelModal(rx.Id)">
                                            <i class="bi bi-x-circle"></i> Cancel
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@* Cancel Prescription Modal *@
@if (showCancelConfirm)
{
    <div class="modal fade show" style="display: block; background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Cancel Prescription</h5>
                    <button type="button" class="btn-close" @onclick="() => showCancelConfirm = false"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to cancel this prescription?</p>
                    <div class="mb-3">
                        <label class="form-label">Cancellation Reason *</label>
                        <textarea class="form-control" @bind="cancelReason" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showCancelConfirm = false">Close</button>
                    <button type="button" class="btn btn-danger" @onclick="CancelPrescription">Cancel Prescription</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid EncounterId { get; set; }
    [Parameter] public Guid PatientId { get; set; }
    [Parameter] public Guid DoctorId { get; set; }

    private List<Prescription>? prescriptions;
    private List<DrugFormulary>? drugResults;
    private List<DrugInteractionAlert>? interactionAlerts;

    // Form fields
    private string drugSearchTerm = string.Empty;
    private string selectedDrugName = string.Empty;
    private string? selectedDrugCode;
    private string rxForm = string.Empty;
    private string rxStrength = string.Empty;
    private string rxFrequency = string.Empty;
    private string rxDuration = string.Empty;
    private string rxRoute = string.Empty;
    private int rxQuantity = 1;
    private string rxNotes = string.Empty;
    private string contraindicationJustification = string.Empty;

    private bool isAdding = false;
    private bool hasContraindication = false;
    private string addError = string.Empty;
    private string addSuccess = string.Empty;

    // Cancel modal
    private bool showCancelConfirm = false;
    private Guid cancelPrescriptionId = Guid.Empty;
    private string cancelReason = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadPrescriptions();
    }

    private async Task LoadPrescriptions()
    {
        prescriptions = await PrescriptionService.GetPrescriptionsByEncounterAsync(EncounterId);
    }

    private readonly System.Threading.SemaphoreSlim _searchSemaphore = new(1, 1);
    private System.Threading.CancellationTokenSource? _searchCts;

    private async Task OnDrugSearchChanged()
    {
        _searchCts?.Cancel();
        _searchCts?.Dispose();
        _searchCts = new System.Threading.CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            // 150ms debounce
            await Task.Delay(150, token);

            // Serialize database queries
            await _searchSemaphore.WaitAsync(token);
            try
            {
                if (drugSearchTerm.Length >= 2)
                {
                    drugResults = await PrescriptionService.SearchDrugFormularyAsync(drugSearchTerm);
                }
                else
                {
                    drugResults = null;
                }
            }
            finally
            {
                _searchSemaphore.Release();
            }
        }
        catch (TaskCanceledException)
        {
            // Ignore cancellation
        }
        catch (Exception ex)
        {
            addError = ex.Message;
        }
    }

    private async Task SelectDrug(DrugFormulary drug)
    {
        selectedDrugName = drug.GenericName + (string.IsNullOrEmpty(drug.BrandName) ? "" : $" ({drug.BrandName})");
        selectedDrugCode = drug.DrugCode;
        drugSearchTerm = selectedDrugName;
        rxForm = drug.Form;
        rxStrength = $"{drug.Strength} {drug.Unit}";
        drugResults = null;

        // Check drug interactions
        if (prescriptions != null)
        {
            var existingCodes = prescriptions
                .Where(p => p.Status == "Active" && !string.IsNullOrEmpty(p.DrugCode))
                .Select(p => p.DrugCode!)
                .ToList();

            if (existingCodes.Any() && !string.IsNullOrEmpty(selectedDrugCode))
            {
                interactionAlerts = await CdsService.CheckDrugInteractionsAsync(existingCodes, selectedDrugCode);
                hasContraindication = interactionAlerts.Any(a => a.Severity == "Contraindicated");
            }
            else
            {
                interactionAlerts = null;
                hasContraindication = false;
            }
        }
    }

    private async Task AddPrescription()
    {
        try
        {
            addError = string.Empty;
            addSuccess = string.Empty;

            if (string.IsNullOrWhiteSpace(selectedDrugName))
            { addError = "Please search and select a drug."; return; }
            if (string.IsNullOrWhiteSpace(rxForm))
            { addError = "Form is required."; return; }
            if (string.IsNullOrWhiteSpace(rxStrength))
            { addError = "Strength is required."; return; }
            if (string.IsNullOrWhiteSpace(rxFrequency))
            { addError = "Frequency is required."; return; }
            if (string.IsNullOrWhiteSpace(rxDuration))
            { addError = "Duration is required."; return; }
            if (string.IsNullOrWhiteSpace(rxRoute))
            { addError = "Route is required."; return; }

            if (hasContraindication && string.IsNullOrWhiteSpace(contraindicationJustification))
            {
                addError = "Justification is required for contraindicated drug interactions.";
                return;
            }

            isAdding = true;

            var notes = rxNotes;
            if (hasContraindication)
            {
                notes = $"[CONTRAINDICATION OVERRIDE] {contraindicationJustification}\n{notes}";
            }

            await PrescriptionService.CreatePrescriptionAsync(new Prescription
            {
                EncounterId = EncounterId,
                PatientId = PatientId,
                DoctorId = DoctorId,
                DrugName = selectedDrugName,
                DrugCode = selectedDrugCode,
                Form = rxForm,
                Strength = rxStrength,
                Frequency = rxFrequency,
                Duration = rxDuration,
                Route = rxRoute,
                Quantity = rxQuantity,
                Notes = string.IsNullOrWhiteSpace(notes) ? null : notes
            });

            // Reset form
            drugSearchTerm = string.Empty;
            selectedDrugName = string.Empty;
            selectedDrugCode = null;
            rxForm = string.Empty;
            rxStrength = string.Empty;
            rxFrequency = string.Empty;
            rxDuration = string.Empty;
            rxRoute = string.Empty;
            rxQuantity = 1;
            rxNotes = string.Empty;
            contraindicationJustification = string.Empty;
            interactionAlerts = null;
            hasContraindication = false;

            addSuccess = "Prescription added successfully.";
            await LoadPrescriptions();

            _ = Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => { addSuccess = string.Empty; StateHasChanged(); }));
        }
        catch (Exception ex)
        {
            addError = ex.Message;
        }
        finally
        {
            isAdding = false;
        }
    }

    private void ShowCancelModal(Guid id)
    {
        cancelPrescriptionId = id;
        cancelReason = string.Empty;
        showCancelConfirm = true;
    }

    private async Task CancelPrescription()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(cancelReason))
            {
                return;
            }

            await PrescriptionService.CancelPrescriptionAsync(cancelPrescriptionId, cancelReason);
            showCancelConfirm = false;
            await LoadPrescriptions();
        }
        catch (Exception ex)
        {
            addError = ex.Message;
            showCancelConfirm = false;
        }
     }

    public void Dispose()
    {
        _searchSemaphore.Dispose();
        _searchCts?.Dispose();
    }
}

