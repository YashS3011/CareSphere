@page "/doctors/create"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Encounters_View)]
@using CareSphere.Models
@inject CareSphere.Services.IDoctorService DoctorService
@inject NavigationManager NavigationManager

<PageTitle>Add Doctor - CareSphere</PageTitle>

<h2>Add New Doctor</h2>
<hr />

<div class="row">
    <div class="col-md-8">
        <EditForm Model="@doctor" FormName="createDoctor" OnValidSubmit="ProcessValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary class="alert alert-danger" />

            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Doctor Information</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="form-label">First Name *</label>
                            <InputText class="form-control" @bind-Value="doctor.FirstName" />
                            <ValidationMessage For="@(() => doctor.FirstName)" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Last Name *</label>
                            <InputText class="form-control" @bind-Value="doctor.LastName" />
                            <ValidationMessage For="@(() => doctor.LastName)" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Specialization *</label>
                            <InputSelect class="form-select" @bind-Value="doctor.Specialization">
                                <option value="">Select Specialization</option>
                                <option value="General Medicine">General Medicine</option>
                                <option value="Cardiology">Cardiology</option>
                                <option value="Neurology">Neurology</option>
                                <option value="Orthopedics">Orthopedics</option>
                                <option value="Pediatrics">Pediatrics</option>
                                <option value="Gynecology">Gynecology</option>
                                <option value="Dermatology">Dermatology</option>
                                <option value="Ophthalmology">Ophthalmology</option>
                                <option value="ENT">ENT</option>
                                <option value="Psychiatry">Psychiatry</option>
                                <option value="Surgery">Surgery</option>
                                <option value="Radiology">Radiology</option>
                                <option value="Pathology">Pathology</option>
                                <option value="Anesthesiology">Anesthesiology</option>
                                <option value="Emergency Medicine">Emergency Medicine</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => doctor.Specialization)" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Registration Number *</label>
                            <InputText class="form-control" @bind-Value="doctor.RegistrationNumber" />
                            <ValidationMessage For="@(() => doctor.RegistrationNumber)" />
                        </div>

                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Contact Information</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="form-label">Phone</label>
                            <InputText class="form-control" @bind-Value="doctor.Phone" />
                            <ValidationMessage For="@(() => doctor.Phone)" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <InputText class="form-control" type="email" @bind-Value="doctor.Email" />
                            <ValidationMessage For="@(() => doctor.Email)" />
                        </div>

                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Add Doctor
                </button>
                <a href="/doctors" class="btn btn-secondary">Cancel</a>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3">@errorMessage</div>
            }

        </EditForm>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    public Doctor doctor { get; set; } = new();

    private bool isSubmitting = false;
    private string errorMessage = string.Empty;

    private async Task ProcessValidSubmit()
    {
        try
        {
            isSubmitting = true;
            errorMessage = string.Empty;

            await DoctorService.CreateDoctorAsync(doctor);

            NavigationManager.NavigateTo("/doctors");
        }
        catch (Microsoft.AspNetCore.Components.NavigationException)
        {
            throw;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error adding doctor: {ex.Message}";
            isSubmitting = false;
        }
    }
}

