@page "/doctors"
@inject CareSphere.Services.IDoctorService DoctorService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Doctors - CareSphere</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Doctor Management</h2>
    <a href="/doctors/create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> Add Doctor</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <div class="input-group">
            <input type="text" class="form-control" placeholder="Search by name or specialization..." @bind="SearchTerm" @bind:event="oninput" @onkeyup="HandleSearch" />
            <button class="btn btn-outline-secondary" type="button" @onclick="LoadDoctors">Search</button>
        </div>
    </div>
</div>

@if (doctors == null)
{
    <p><em>Loading...</em></p>
}
else if (!doctors.Any())
{
    <div class="alert alert-info">No doctors found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Specialization</th>
                    <th>Registration #</th>
                    <th>Phone</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var doctor in doctors)
                {
                    <tr>
                        <td>Dr. @doctor.FirstName @doctor.LastName</td>
                        <td>@doctor.Specialization</td>
                        <td>@doctor.RegistrationNumber</td>
                        <td>@(doctor.Phone ?? "N/A")</td>
                        <td>
                            @if (doctor.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a href="/doctor/queue/@doctor.Id" class="btn btn-info" title="Queue"><i class="bi bi-clock"></i> Queue</a>
                                <a href="/doctors/edit/@doctor.Id" class="btn btn-warning" title="Edit"><i class="bi bi-pencil"></i> Edit</a>
                                <button class="btn btn-danger" @onclick="() => ConfirmDelete(doctor.Id)" title="Delete"><i class="bi bi-trash"></i> Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal fade show" style="display: block; background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this doctor? This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="DeleteDoctor">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<CareSphere.Models.Doctor>? doctors;
    private string SearchTerm { get; set; } = string.Empty;
    private bool showDeleteConfirm = false;
    private Guid doctorIdToDelete = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadDoctors();
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LoadDoctors();
        }
    }

    private async Task LoadDoctors()
    {
        doctors = await DoctorService.GetAllDoctorsAsync(SearchTerm);
    }

    private void ConfirmDelete(Guid id)
    {
        doctorIdToDelete = id;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        doctorIdToDelete = Guid.Empty;
    }

    private async Task DeleteDoctor()
    {
        if (doctorIdToDelete != Guid.Empty)
        {
            await DoctorService.DeleteDoctorAsync(doctorIdToDelete);
            await LoadDoctors();
        }
        showDeleteConfirm = false;
    }
}
