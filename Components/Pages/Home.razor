@page "/"
@page "/dashboard"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IPatientService PatientService
@inject IBedService BedService
@inject IPharmacyItemService ItemService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ITenantContext TenantContext
@inject CareSphere.Data.ApplicationDbContext DbContext
@inject PageTitleService PageTitle
@rendermode InteractiveServer

<PageTitle>Dashboard - CareSphere</PageTitle>

<div class="container-fluid py-4">
    <!-- Welcome Header Card -->
    <div class="card border-0 rounded-4 shadow-sm bg-gradient text-white mb-4" 
         style="background: linear-gradient(135deg, var(--cs-accent, #1a7fe8) 0%, #0d9488 100%);">
        <div class="card-body p-4 p-md-5">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <span class="badge bg-white bg-opacity-20 text-white rounded-pill px-3 py-2 mb-3 fw-bold uppercase-tracking text-xs">
                        <i class="bi bi-shield-check me-1"></i> @role Workspace
                    </span>
                    <h1 class="display-6 fw-bold mb-2">Welcome back, @fullName!</h1>
                    <p class="lead mb-0 text-white-50">Here is the overview for @hospitalName. Stay healthy, care always.</p>
                </div>
                <div class="col-md-4 text-md-end mt-4 mt-md-0">
                    <div class="text-white-50 small mb-1"><i class="bi bi-clock-fill me-1"></i> Local Server Time</div>
                    <div class="fs-4 fw-bold font-monospace">@DateTime.Now.ToString("dd MMM yyyy, hh:mm tt")</div>
                </div>
            </div>
        </div>
    </div>

    @if (loading)
    {
        <div class="loading-state">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-muted">Gathering your custom metrics...</p>
        </div>
    }
    else
    {
        <!-- Role-based dynamic metrics -->
        <div class="row g-4 mb-4">
            @if (hasPatientsView)
            {
                <div class="col-sm-6 col-xl-3">
                    <div class="stat-card stat-card-primary">
                        <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
                        <div>
                            <div class="stat-value">@totalPatients</div>
                            <div class="stat-label">Total Patients</div>
                        </div>
                        <a href="/patients" class="stretched-link"></a>
                    </div>
                </div>
            }

            @if (hasBedsView)
            {
                <div class="col-sm-6 col-xl-3">
                    <div class="stat-card stat-card-success">
                        <div class="stat-icon"><i class="bi bi-hospital"></i></div>
                        <div>
                            <div class="stat-value">@occupiedBeds / @totalBeds</div>
                            <div class="stat-label">Beds Occupied</div>
                        </div>
                        <a href="@(hasBedsManage ? "/beds/dashboard" : "/wards")" class="stretched-link"></a>
                    </div>
                </div>
            }

            @if (hasPharmacyView)
            {
                <div class="col-sm-6 col-xl-3">
                    <div class="stat-card stat-card-warning">
                        <div class="stat-icon"><i class="bi bi-exclamation-triangle"></i></div>
                        <div>
                            <div class="stat-value">@lowStockCount</div>
                            <div class="stat-label">Low Stock Drugs</div>
                        </div>
                        <a href="/pharmacy/expiry-alerts" class="stretched-link"></a>
                    </div>
                </div>
            }

            @if (hasLabView)
            {
                <div class="col-sm-6 col-xl-3">
                    <div class="stat-card stat-card-info">
                        <div class="stat-icon"><i class="bi bi-droplet"></i></div>
                        <div>
                            <div class="stat-value">@pendingLabCollections</div>
                            <div class="stat-label">Pending Lab Samples</div>
                        </div>
                        <a href="/lab/dashboard" class="stretched-link"></a>
                    </div>
                </div>
            }

            @if (hasBillingView)
            {
                <div class="col-sm-6 col-xl-3">
                    <div class="stat-card stat-card-danger">
                        <div class="stat-icon"><i class="bi bi-currency-rupee"></i></div>
                        <div>
                            <div class="stat-value">₹@totalCollectedToday.ToString("N0")</div>
                            <div class="stat-label">Today's Cash Collection</div>
                        </div>
                        <a href="@(hasBillingDashboardView ? "/billing/dashboard" : "/billing/invoices")" class="stretched-link"></a>
                    </div>
                </div>
            }
        </div>

        <!-- Quick Actions Panel -->
        <div class="row g-4 mb-4">
            <div class="col-12">
                <div class="content-card">
                    <div class="content-card-header bg-light bg-opacity-50">
                        <h5 class="content-card-title"><i class="bi bi-lightning-fill text-warning me-2"></i>Quick Actions Hub</h5>
                    </div>
                    <div class="content-card-body">
                        <div class="d-flex flex-wrap gap-3">
                            <AuthorizeView Policy="@PolicyNames.Permission_Patients_Create">
                                <Authorized>
                                    <a href="/patients/create" class="btn btn-outline-primary px-4 py-2.5 rounded-3 d-flex align-items-center gap-2">
                                        <i class="bi bi-person-plus-fill fs-5"></i> Register Patient
                                    </a>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Policy="@PolicyNames.Permission_Queue_View">
                                <Authorized>
                                    <a href="@(doctorId != Guid.Empty ? $"/doctor/queue/{doctorId}" : "/doctor/queue")" class="btn btn-outline-primary px-4 py-2.5 rounded-3 d-flex align-items-center gap-2">
                                        <i class="bi bi-clock-fill fs-5"></i> My Queue
                                    </a>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Policy="@PolicyNames.Permission_Encounters_Create">
                                <Authorized>
                                    <a href="/encounter/new" class="btn btn-outline-primary px-4 py-2.5 rounded-3 d-flex align-items-center gap-2">
                                        <i class="bi bi-clipboard-plus-fill fs-5"></i> New Encounter
                                    </a>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Policy="@PolicyNames.Permission_Vitals_View">
                                <Authorized>
                                    <a href="/nursing" class="btn btn-outline-primary px-4 py-2.5 rounded-3 d-flex align-items-center gap-2">
                                        <i class="bi bi-heart-pulse-fill fs-5"></i> Nursing Dashboard
                                    </a>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Policy="@PolicyNames.Permission_Pharmacy_Dispense">
                                <Authorized>
                                    <a href="/pharmacy/dispense" class="btn btn-outline-primary px-4 py-2.5 rounded-3 d-flex align-items-center gap-2">
                                        <i class="bi bi-prescription2 fs-5"></i> Dispense Rx
                                    </a>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Policy="@PolicyNames.Permission_Pharmacy_OtcSale">
                                <Authorized>
                                    <a href="/pharmacy/otc-sale" class="btn btn-outline-primary px-4 py-2.5 rounded-3 d-flex align-items-center gap-2">
                                        <i class="bi bi-shop fs-5"></i> OTC POS
                                    </a>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Policy="@PolicyNames.Permission_Lab_OrderTests">
                                <Authorized>
                                    <a href="/laboratory/requisitions" class="btn btn-outline-primary px-4 py-2.5 rounded-3 d-flex align-items-center gap-2">
                                        <i class="bi bi-journal-text fs-5"></i> Requisitions
                                    </a>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Policy="@PolicyNames.Permission_Billing_CreateInvoices">
                                <Authorized>
                                    <a href="/billing/invoices/create" class="btn btn-outline-primary px-4 py-2.5 rounded-3 d-flex align-items-center gap-2">
                                        <i class="bi bi-file-earmark-plus-fill fs-5"></i> Create Invoice
                                    </a>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Policy="@PolicyNames.Permission_Admin_ManageUsers">
                                <Authorized>
                                    <a href="/admin/users" class="btn btn-outline-primary px-4 py-2.5 rounded-3 d-flex align-items-center gap-2">
                                        <i class="bi bi-people-fill fs-5"></i> Manage Users
                                    </a>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Policy="@PolicyNames.Permission_Admin_ManageTenant">
                                <Authorized>
                                    <a href="/admin/tenant-settings" class="btn btn-outline-primary px-4 py-2.5 rounded-3 d-flex align-items-center gap-2">
                                        <i class="bi bi-gear-fill fs-5"></i> Tenant Settings
                                    </a>
                                </Authorized>
                            </AuthorizeView>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Help & Context Panel -->
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card border-0 rounded-4 shadow-sm h-100">
                    <div class="card-body p-4">
                        <h5 class="fw-bold text-dark mb-3"><i class="bi bi-info-circle text-primary me-2"></i>Helpful Information</h5>
                        <p class="text-muted small">You are logged into CareSphere's unified interface. Your dashboard items and sidebar links are dynamically customized according to your role permissions. If you need additional access, please contact your Hospital Administrator.</p>
                        <div class="alert alert-secondary border-0 rounded-3 mb-0 small">
                            <strong>Note:</strong> Standard reports are synchronized in real-time with electronic health records (EMR) and billing modules.
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 rounded-4 shadow-sm h-100">
                    <div class="card-body p-4">
                        <h5 class="fw-bold text-dark mb-3"><i class="bi bi-shield-lock-fill text-success me-2"></i>Security Notice</h5>
                        <p class="text-muted small">All user actions within the CareSphere console are fully logged and audited for compliance purposes. Keep your credentials secure and log out when leaving your workstation.</p>
                        <a href="/auth/logout" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                            <i class="bi bi-box-arrow-right me-1"></i> Sign Out Immediately
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private string fullName = "User";
    private string role = "";
    private string hospitalName = "CareSphere";
    private bool loading = true;
    private Guid doctorId = Guid.Empty;

    private int totalPatients;
    private int totalBeds;
    private int occupiedBeds;
    private int expiringBatchesCount;
    private int lowStockCount;
    private int pendingLabCollections;
    private decimal totalCollectedToday;

    private bool hasPatientsView;
    private bool hasBedsView;
    private bool hasBedsManage;
    private bool hasPharmacyView;
    private bool hasLabView;
    private bool hasBillingView;
    private bool hasBillingDashboardView;

    protected override async Task OnInitializedAsync()
    {
        PageTitle.SetTitle("Dashboard");
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            fullName = CurrentUserHelper.GetFullName(user) ?? user.Identity?.Name ?? "User";
            role = CurrentUserHelper.GetUserRole(user) ?? "";
            hospitalName = user.FindFirst("target_hospital_name")?.Value ?? "CareSphere";
            doctorId = CurrentUserHelper.GetDoctorId(user) ?? Guid.Empty;

            // ── Role-based landing page redirects ──────────────────────────────
            switch (role)
            {
                case CareSphereRoles.PlatformAdmin:
                case "platform_super_admin":
                    NavigationManager.NavigateTo("/platform-admin", replace: true);
                    return;
                case CareSphereRoles.Patient:
                    NavigationManager.NavigateTo("/patient/dashboard", replace: true);
                    return;
                case CareSphereRoles.HospitalAdmin:
                    {
                        var baseRelativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
                        if (string.IsNullOrEmpty(baseRelativePath) || baseRelativePath == "/")
                        {
                            NavigationManager.NavigateTo("/dashboard", replace: true);
                            return;
                        }
                        break;
                    }
                case CareSphereRoles.WardManager:
                    NavigationManager.NavigateTo("/beds/dashboard", replace: true);
                    return;
            }
            // ──────────────────────────────────────────────────────────────────

            hasPatientsView = user.HasClaim(c => c.Type == CareSphereClaimTypes.Permission && c.Value == CareSpherePermissions.Patients_View);
            hasBedsView = user.HasClaim(c => c.Type == CareSphereClaimTypes.Permission && c.Value == CareSpherePermissions.Beds_View);
            hasBedsManage = user.HasClaim(c => c.Type == CareSphereClaimTypes.Permission && c.Value == CareSpherePermissions.Beds_Manage);
            hasPharmacyView = user.HasClaim(c => c.Type == CareSphereClaimTypes.Permission && c.Value == CareSpherePermissions.Pharmacy_ViewStock);
            hasLabView = user.HasClaim(c => c.Type == CareSphereClaimTypes.Permission && c.Value == CareSpherePermissions.Lab_ViewReports);
            hasBillingView = user.HasClaim(c => c.Type == CareSphereClaimTypes.Permission && c.Value == CareSpherePermissions.Billing_ViewInvoices);
            hasBillingDashboardView = user.HasClaim(c => c.Type == CareSphereClaimTypes.Permission && c.Value == CareSpherePermissions.Billing_View);

            // Fetch statistics safely
            try
            {
                if (hasPatientsView)
                {
                    totalPatients = await PatientService.GetPatientCountAsync();
                }
            }
            catch {}

            try
            {
                if (hasBedsView)
                {
                    var bedStats = await BedService.GetDashboardStatsAsync();
                    totalBeds = bedStats.TotalBeds;
                    occupiedBeds = bedStats.Occupied;
                }
            }
            catch {}

            try
            {
                if (hasPharmacyView)
                {
                    var currentTenantId = TenantContext.TenantId;
                    lowStockCount = (await ItemService.GetLowStockItemsAsync(currentTenantId)).Count;
                    var expirationThreshold = DateTime.UtcNow.AddDays(90);
                    expiringBatchesCount = await Microsoft.EntityFrameworkCore.EntityFrameworkQueryableExtensions.CountAsync(
                        DbContext.PharmacyBatches.Where(b => b.TenantId == currentTenantId && b.IsActive && b.CurrentStock > 0 && b.ExpiryDate <= expirationThreshold)
                    );
                }
            }
            catch {}

            try
            {
                if (hasLabView)
                {
                    var currentTenantId = TenantContext.TenantId;
                    pendingLabCollections = await Microsoft.EntityFrameworkCore.EntityFrameworkQueryableExtensions.CountAsync(
                        DbContext.LabRequisitions.Where(r => r.TenantId == currentTenantId && r.Status == "Ordered")
                    );
                }
            }
            catch {}

            try
            {
                if (hasBillingView)
                {
                    var startOfToday = DateTime.UtcNow.Date;
                    totalCollectedToday = await Microsoft.EntityFrameworkCore.EntityFrameworkQueryableExtensions.SumAsync(
                        DbContext.Payments.Where(p => p.Status == "Success" && p.PaymentDate >= startOfToday),
                        p => p.Amount
                    );
                }
            }
            catch {}
        }

        loading = false;
    }
}
