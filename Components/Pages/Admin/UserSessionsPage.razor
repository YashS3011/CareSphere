@page "/admin/sessions"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Admin_ManageUsers)]
@inject CareSphere.Services.IAuthService AuthService
@inject CareSphere.Data.ApplicationDbContext DbContext
@inject CareSphere.Services.UserTimeZoneService UserTimeZone
@inject IConfiguration Configuration
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer

<PageTitle>User Sessions — CareSphere</PageTitle>

<h2 class="mb-4"><i class="bi bi-shield-exclamation me-2 text-primary"></i>Active User Sessions</h2>

@if (sessions == null)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (!sessions.Any())
{
    <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>No active sessions found.</div>
}
else
{
    @if (!string.IsNullOrEmpty(actionMessage))
    {
        <div class="alert alert-@(actionSuccess ? "success" : "danger")">@actionMessage</div>
    }
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>User</th>
                        <th>IP Address</th>
                        <th>Device</th>
                        <th>Created</th>
                        <th>Last Activity</th>
                        <th>Expires</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var session in sessions)
                    {
                        <tr>
                            <td>
                                @if (userNames.TryGetValue(session.UserId, out var name))
                                {
                                    <span class="fw-semibold">@name</span>
                                    <span class="text-muted small d-block">@session.UserId[..Math.Min(8, session.UserId.Length)]...</span>
                                }
                                else
                                {
                                    <span class="text-muted font-monospace small">@session.UserId[..Math.Min(12, session.UserId.Length)]...</span>
                                }
                            </td>
                            <td class="small">@(session.IpAddress ?? "—")</td>
                            <td class="small">@(session.DeviceInfo ?? "—")</td>
                            <td class="small">@UserTimeZone.ToLocal(session.CreatedAt).ToString("dd MMM HH:mm")</td>
                            <td class="small">@UserTimeZone.ToLocal(session.LastActivityAt).ToString("dd MMM HH:mm")</td>
                            <td class="small @(session.ExpiresAt < DateTime.UtcNow ? "text-danger" : "")">
                                @UserTimeZone.ToLocal(session.ExpiresAt).ToString("dd MMM HH:mm")
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => RevokeSession(session.UserId)">
                                    <i class="bi bi-x-circle me-1"></i>Revoke
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <p class="text-muted small mt-2">Showing @sessions.Count active sessions</p>
}

@code {
    private List<CareSphere.Models.UserSession>? sessions;
    private Dictionary<string, string> userNames = new();
    private string? actionMessage;
    private bool actionSuccess;

    protected override async Task OnInitializedAsync() => await LoadSessions();

    private async Task LoadSessions()
    {
        var tenantId = GetTenantId();
        sessions = await DbContext.UserSessions
            .Where(s => s.TenantId == tenantId && !s.IsRevoked && s.ExpiresAt > DateTime.UtcNow)
            .OrderByDescending(s => s.LastActivityAt)
            .ToListAsync();

        var userIds = sessions.Select(s => s.UserId).Distinct().ToList();
        userNames = await DbContext.Users
            .Where(u => userIds.Contains(u.Id))
            .ToDictionaryAsync(u => u.Id, u => u.FullName);
    }

    private async Task RevokeSession(string userId)
    {
        try
        {
            await AuthService.RevokeAllSessionsAsync(userId);
            actionSuccess = true;
            actionMessage = "All sessions for this user have been revoked.";
            await LoadSessions();
        }
        catch
        {
            actionSuccess = false;
            actionMessage = "Failed to revoke sessions.";
        }
    }

    private Guid GetTenantId()
    {
        var str = Configuration["App:DefaultTenantId"] ?? "00000000-0000-0000-0000-000000000001";
        return Guid.TryParse(str, out var id) ? id : Guid.Empty;
    }
}
