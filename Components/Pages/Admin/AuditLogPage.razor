@page "/admin/audit-log"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Admin_ViewAuditLog)]
@inject CareSphere.Services.IAuditLogService AuditLogService
@inject CareSphere.Data.ApplicationDbContext DbContext
@inject CareSphere.Services.UserTimeZoneService UserTimeZone
@inject IConfiguration Configuration
@inject IJSRuntime JS
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer

<PageTitle>Audit Log — CareSphere</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-journal-check me-2 text-primary"></i>Audit Log</h2>
    <button class="btn btn-outline-success" @onclick="ExportCsv" disabled="@isExporting">
        @if (isExporting) { <span class="spinner-border spinner-border-sm me-2"></span> }
        <i class="bi bi-download me-2"></i>Download CSV
    </button>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <input type="text" class="form-control" placeholder="User ID..." @bind="filterUserId" />
            </div>
            <div class="col-md-2">
                <select class="form-select" @bind="filterAction">
                    <option value="">All Actions</option>
                    @foreach (var action in distinctActions)
                    {
                        <option value="@action">@action</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select" @bind="filterResourceType">
                    <option value="">All Resources</option>
                    @foreach (var rt in distinctResourceTypes)
                    {
                        <option value="@rt">@rt</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <input type="date" class="form-control" @bind="filterDateFrom" />
            </div>
            <div class="col-md-2">
                <input type="date" class="form-control" @bind="filterDateTo" />
            </div>
            <div class="col-md-1">
                <button class="btn btn-primary w-100" @onclick="ApplyFilters">
                    <i class="bi bi-funnel"></i>
                </button>
            </div>
        </div>
    </div>
</div>

@if (result == null)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between">
            <small class="text-muted">@result.TotalCount total records — Page @result.PageNumber of @result.TotalPages</small>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Timestamp</th>
                        <th>User</th>
                        <th>Action</th>
                        <th>Resource Type</th>
                        <th>Resource ID</th>
                        <th>IP Address</th>
                        <th>Device</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var evt in result.Items)
                    {
                        <tr>
                            <td class="small text-nowrap">@UserTimeZone.ToLocal(evt.Timestamp).ToString("dd MMM yyyy HH:mm:ss")</td>
                            <td class="small fw-semibold" title="@evt.UserId">@GetUserName(evt.UserId)</td>
                            <td><span class="badge bg-info text-dark">@evt.Action</span></td>
                            <td class="small">@evt.ResourceType</td>
                            <td class="small font-monospace" title="@evt.ResourceId">
                                @(evt.ResourceId.Length > 12 ? evt.ResourceId[..12] + "..." : evt.ResourceId)
                            </td>
                            <td class="small">@(evt.IpAddress ?? "—")</td>
                            <td class="small">@(evt.Device ?? "—")</td>
                        </tr>
                    }
                    @if (!result.Items.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">No audit events found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (result.TotalPages > 1)
        {
            <div class="card-footer bg-white d-flex justify-content-center gap-2">
                <button class="btn btn-sm btn-outline-secondary" @onclick="PrevPage" disabled="@(currentPage <= 1)">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <span class="btn btn-sm btn-light disabled">@currentPage / @result.TotalPages</span>
                <button class="btn btn-sm btn-outline-secondary" @onclick="NextPage" disabled="@(currentPage >= result.TotalPages)">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        }
    </div>
}

@code {
    private CareSphere.Services.PagedResult<CareSphere.Models.AuditEvent>? result;
    private string filterUserId = "";
    private string filterAction = "";
    private string filterResourceType = "";
    private DateTime? filterDateFrom;
    private DateTime? filterDateTo;
    private int currentPage = 1;
    private bool isExporting = false;

    // Dynamic filter options loaded from DB
    private List<string> distinctActions = new();
    private List<string> distinctResourceTypes = new();

    // User name resolution cache
    private Dictionary<string, string> userNameCache = new();

    protected override async Task OnInitializedAsync()
    {
        var tenantId = GetTenantId();

        // Load dynamic filter options
        distinctActions = await AuditLogService.GetDistinctActionsAsync(tenantId);
        distinctResourceTypes = await AuditLogService.GetDistinctResourceTypesAsync(tenantId);

        await LoadData();
    }

    private async Task ApplyFilters() { currentPage = 1; await LoadData(); }
    private async Task PrevPage() { if (currentPage > 1) { currentPage--; await LoadData(); } }
    private async Task NextPage() { currentPage++; await LoadData(); }

    private async Task LoadData()
    {
        var tenantId = GetTenantId();
        result = await AuditLogService.GetAuditLogsAsync(
            tenantId,
            string.IsNullOrEmpty(filterUserId) ? null : filterUserId,
            string.IsNullOrEmpty(filterAction) ? null : filterAction,
            string.IsNullOrEmpty(filterResourceType) ? null : filterResourceType,
            filterDateFrom, filterDateTo,
            currentPage, 50);

        // Resolve user names for current page results
        if (result?.Items != null)
        {
            var newUserIds = result.Items
                .Select(e => e.UserId)
                .Where(uid => !userNameCache.ContainsKey(uid))
                .Distinct()
                .ToList();

            foreach (var uid in newUserIds)
            {
                var user = await DbContext.Users
                    .Cast<CareSphere.Models.ApplicationUser>()
                    .FirstOrDefaultAsync(u => u.Id == uid);
                userNameCache[uid] = user?.FullName ?? (uid.Length > 10 ? uid[..10] + "..." : uid);
            }
        }
    }

    private string GetUserName(string userId)
    {
        return userNameCache.TryGetValue(userId, out var name) ? name : (userId.Length > 10 ? userId[..10] + "..." : userId);
    }

    private async Task ExportCsv()
    {
        isExporting = true;
        try
        {
            var tenantId = GetTenantId();
            var csv = await AuditLogService.ExportAuditLogsAsync(
                tenantId,
                string.IsNullOrEmpty(filterUserId) ? null : filterUserId,
                string.IsNullOrEmpty(filterAction) ? null : filterAction,
                string.IsNullOrEmpty(filterResourceType) ? null : filterResourceType,
                filterDateFrom, filterDateTo);

            var base64 = Convert.ToBase64String(csv);
            var fileName = $"audit_log_{DateTime.UtcNow:yyyyMMdd_HHmmss}.csv";
            await JS.InvokeVoidAsync("eval",
                $"const a=document.createElement('a');a.href='data:text/csv;base64,{base64}';a.download='{fileName}';a.click()");
        }
        finally { isExporting = false; }
    }

    private Guid GetTenantId()
    {
        var str = Configuration["App:DefaultTenantId"] ?? "00000000-0000-0000-0000-000000000001";
        return Guid.TryParse(str, out var id) ? id : Guid.Empty;
    }
}
