@page "/admin/analytics"
@attribute [Authorize(Policy = PolicyNames.Permission_Analytics_View)]
@inject IAnalyticsService AnalyticsService
@inject TabIsolatedAuthenticationStateProvider AuthStateProvider

<PageTitle>Analytics Dashboard — CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-graph-up-arrow"></i></div>
            <div>
                <h1 class="page-title">Analytics Dashboard</h1>
                <p class="page-subtitle">Cross-module administrative KPIs, revenue flows, and hospital performance metrics</p>
            </div>
        </div>
    </div>
</div>

<!-- Section 1: Bed Occupancy -->
<div class="content-card mb-4">
    <div class="content-card-header">
        <h5 class="content-card-title"><i class="bi bi-hospital me-2 text-primary"></i>Bed Occupancy Metrics</h5>
    </div>
    <div class="content-card-body">
        @if (loadingBed)
        {
            <div class="loading-state py-4">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 text-muted">Loading bed metrics...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorBed))
        {
            <div class="alert alert-danger border-0 shadow-sm mb-0"><i class="bi bi-x-circle-fill me-2"></i>@errorBed</div>
        }
        else if (bedMetrics != null)
        {
            <div class="row g-4 align-items-center">
                <div class="col-lg-7">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="stat-card stat-card-primary">
                                <div class="stat-icon"><i class="bi bi-hospital"></i></div>
                                <div>
                                    <div class="stat-value text-dark fs-4">@bedMetrics.TotalBeds</div>
                                    <div class="stat-label">Total Beds</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="stat-card stat-card-danger">
                                <div class="stat-icon"><i class="bi bi-person-fill-dash"></i></div>
                                <div>
                                    <div class="stat-value text-dark fs-4">@bedMetrics.OccupiedBeds</div>
                                    <div class="stat-label">Occupied Beds</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="stat-card stat-card-success">
                                <div class="stat-icon"><i class="bi bi-person-fill-check"></i></div>
                                <div>
                                    <div class="stat-value text-dark fs-4">@bedMetrics.AvailableBeds</div>
                                    <div class="stat-label">Available Beds</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="stat-card stat-card-info">
                                <div class="stat-icon"><i class="bi bi-pie-chart"></i></div>
                                <div>
                                    <div class="stat-value text-dark fs-4">@bedMetrics.OccupancyRatePercent.ToString("F1")%</div>
                                    <div class="stat-label">Occupancy Rate</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 mt-3">
                            <div class="p-3 bg-primary-subtle text-primary border border-primary-subtle rounded-3 text-center">
                                <i class="bi bi-hourglass-split me-2"></i>Average Length of Stay: <strong>@bedMetrics.AverageLengthOfStayDays.ToString("F1") Days</strong>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="p-3 border border-light-subtle rounded-4 bg-white shadow-sm">
                        <ApexChart TItem="ChartData" Title="Bed Occupancy Distribution" Height="220">
                            <ApexPointSeries TItem="ChartData"
                                             Items="GetBedChartData()"
                                             Name="Beds"
                                             SeriesType="SeriesType.Pie"
                                             XValue="e => e.Label"
                                             YValue="e => e.Value" />
                        </ApexChart>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Section 2: Revenue -->
<div class="content-card mb-4">
    <div class="content-card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="content-card-title"><i class="bi bi-cash-coin me-2 text-primary"></i>Revenue & Billing Metrics</h5>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <input type="date" class="form-control form-control-sm text-dark" @bind="fromDate" style="width: 140px;" />
            <span class="text-muted small">to</span>
            <input type="date" class="form-control form-control-sm text-dark" @bind="toDate" style="width: 140px;" />
            <button class="btn btn-primary btn-sm px-3" @onclick="LoadRevenueMetricsAsync"><i class="bi bi-arrow-clockwise me-1"></i> Refresh</button>
        </div>
    </div>
    <div class="content-card-body">
        @if (loadingRevenue)
        {
            <div class="loading-state py-4">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 text-muted">Loading revenue metrics...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorRevenue))
        {
            <div class="alert alert-danger border-0 shadow-sm mb-0"><i class="bi bi-x-circle-fill me-2"></i>@errorRevenue</div>
        }
        else if (revenueMetrics != null)
        {
            <div class="row g-4 align-items-center">
                <div class="col-lg-6">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="stat-card stat-card-primary">
                                <div class="stat-icon"><i class="bi bi-receipt"></i></div>
                                <div>
                                    <div class="stat-value text-dark fs-5">₹@revenueMetrics.TotalInvoiced.ToString("N0")</div>
                                    <div class="stat-label">Total Invoiced</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="stat-card stat-card-success">
                                <div class="stat-icon"><i class="bi bi-cash-coin"></i></div>
                                <div>
                                    <div class="stat-value text-dark fs-5">₹@revenueMetrics.TotalCollected.ToString("N0")</div>
                                    <div class="stat-label">Total Collected</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="stat-card stat-card-danger">
                                <div class="stat-icon"><i class="bi bi-exclamation-circle"></i></div>
                                <div>
                                    <div class="stat-value text-dark fs-5">₹@revenueMetrics.TotalOutstanding.ToString("N0")</div>
                                    <div class="stat-label">Outstanding</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="stat-card stat-card-info">
                                <div class="stat-icon"><i class="bi bi-journal-text"></i></div>
                                <div>
                                    <div class="stat-value text-dark fs-5">@revenueMetrics.InvoiceCount</div>
                                    <div class="stat-label">Invoices Count</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="p-3 border border-light-subtle rounded-4 bg-white shadow-sm">
                        <ApexChart TItem="ChartDataDecimal" Title="Revenue Breakdown (INR)" Height="220">
                            <ApexPointSeries TItem="ChartDataDecimal"
                                             Items="GetRevenueChartData()"
                                             Name="Amount"
                                             SeriesType="SeriesType.Bar"
                                             XValue="e => e.Label"
                                             YValue="e => e.Value" />
                        </ApexChart>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Group Row for Doctors & Labs -->
<div class="row g-4 mb-4">
    <!-- Section 3: Top 5 Doctors -->
    <div class="col-lg-6">
        <div class="content-card h-100">
            <div class="content-card-header">
                <h5 class="content-card-title"><i class="bi bi-people-fill me-2 text-primary"></i>Top 5 Doctors by Encounters</h5>
            </div>
            <div class="content-card-body p-0">
                @if (loadingDoctor)
                {
                    <div class="loading-state py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                }
                else if (!string.IsNullOrEmpty(errorDoctor))
                {
                    <div class="alert alert-danger border-0 m-3"><i class="bi bi-x-circle-fill me-2"></i>@errorDoctor</div>
                }
                else if (doctorMetrics != null)
                {
                    @if (doctorMetrics.TopDoctors.Count == 0)
                    {
                        <div class="text-center py-5 text-muted small">No encounter records found.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover data-table mb-0 small">
                                <thead>
                                    <tr>
                                        <th class="ps-3" style="width: 15%">Rank</th>
                                        <th>Doctor Name</th>
                                        <th>Specialty</th>
                                        <th class="text-end pe-3">Encounters</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ int rank = 1; }
                                    @foreach (var doc in doctorMetrics.TopDoctors)
                                    {
                                        <tr>
                                            <td class="ps-3 fw-bold text-dark">#@rank</td>
                                            <td class="fw-semibold text-dark">@doc.DoctorName</td>
                                            <td><span class="badge bg-light text-primary border border-light-subtle">@doc.Specialty</span></td>
                                            <td class="text-end pe-3 fw-bold text-primary">@doc.EncounterCount</td>
                                        </tr>
                                        rank++;
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Section 4: Lab Metrics -->
    <div class="col-lg-6">
        <div class="content-card h-100">
            <div class="content-card-header">
                <h5 class="content-card-title"><i class="bi bi-activity me-2 text-primary"></i>Laboratory Metrics (This Month)</h5>
            </div>
            <div class="content-card-body p-4">
                @if (loadingLab)
                {
                    <div class="loading-state py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                }
                else if (!string.IsNullOrEmpty(errorLab))
                {
                    <div class="alert alert-danger border-0 mb-0"><i class="bi bi-x-circle-fill me-2"></i>@errorLab</div>
                }
                else if (labMetrics != null)
                {
                    <div class="row g-3">
                        <div class="col-12">
                            <div class="border border-light-subtle rounded-3 p-3 bg-light-subtle d-flex justify-content-between align-items-center">
                                <div>
                                    <small class="text-muted d-block small text-uppercase fw-bold">Requisitions Ordered</small>
                                    <span class="h4 fw-bold text-dark mb-0">@labMetrics.TotalRequisitionsThisMonth</span>
                                </div>
                                <div class="fs-2 text-primary opacity-50"><i class="bi bi-file-earmark-medical"></i></div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="border border-light-subtle rounded-3 p-3 bg-light-subtle d-flex justify-content-between align-items-center">
                                <div>
                                    <small class="text-muted d-block small text-uppercase fw-bold">Abnormal Results Flagged</small>
                                    <span class="h4 fw-bold text-danger mb-0">@labMetrics.AbnormalResultsThisMonth</span>
                                </div>
                                <div class="fs-2 text-danger opacity-50"><i class="bi bi-exclamation-octagon"></i></div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="border border-primary-subtle rounded-3 p-3 bg-primary-subtle text-primary d-flex justify-content-between align-items-center">
                                <div>
                                    <small class="d-block small text-uppercase fw-bold opacity-75">Avg Turnaround Time</small>
                                    <span class="h4 fw-bold mb-0">@labMetrics.AverageTurnaroundHours.ToString("F1") hrs</span>
                                </div>
                                <div class="fs-2 opacity-50"><i class="bi bi-stopwatch"></i></div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Section 5: Pharmacy Stock -->
<div class="content-card mb-4">
    <div class="content-card-header">
        <h5 class="content-card-title"><i class="bi bi-capsule me-2 text-primary"></i>Pharmacy &amp; Stock Metrics</h5>
    </div>
    <div class="content-card-body">
        @if (loadingPharmacy)
        {
            <div class="loading-state py-4">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 text-muted">Loading pharmacy metrics...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorPharmacy))
        {
            <div class="alert alert-danger border-0 shadow-sm mb-0"><i class="bi bi-x-circle-fill me-2"></i>@errorPharmacy</div>
        }
        else if (pharmacyMetrics != null)
        {
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="stat-card stat-card-primary">
                        <div class="stat-icon"><i class="bi bi-currency-rupee"></i></div>
                        <div class="stat-value">₹@pharmacyMetrics.TotalStockValue.ToString("N0")</div>
                        <div class="stat-label">Total Stock Value</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card stat-card-danger">
                        <div class="stat-icon"><i class="bi bi-exclamation-triangle"></i></div>
                        <div class="stat-value">@pharmacyMetrics.LowStockItemsCount</div>
                        <div class="stat-label">Low Stock Items</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card stat-card-warning">
                        <div class="stat-icon"><i class="bi bi-hourglass-split"></i></div>
                        <div class="stat-value">@pharmacyMetrics.NearExpiryBatchesCount</div>
                        <div class="stat-label">Near-Expiry Batches (90 Days)</div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private BedOccupancyMetrics? bedMetrics;
    private RevenueMetrics? revenueMetrics;
    private LabMetrics? labMetrics;
    private TopDoctorsMetrics? doctorMetrics;
    private PharmacyMetrics? pharmacyMetrics;

    private bool loadingBed = true;
    private bool loadingRevenue = true;
    private bool loadingLab = true;
    private bool loadingDoctor = true;
    private bool loadingPharmacy = true;

    private string? errorBed;
    private string? errorRevenue;
    private string? errorLab;
    private string? errorDoctor;
    private string? errorPharmacy;

    private DateTime fromDate = new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
    private DateTime toDate = DateTime.UtcNow.Date;
    private Guid currentTenantId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var tenantIdOpt = CurrentUserHelper.GetTenantId(user);
        if (tenantIdOpt.HasValue)
        {
            currentTenantId = tenantIdOpt.Value;
            // Run sequentially to avoid EF Core concurrent DbContext access exceptions
            await LoadBedMetricsAsync();
            await LoadRevenueMetricsAsync();
            await LoadLabMetricsAsync();
            await LoadDoctorMetricsAsync();
            await LoadPharmacyMetricsAsync();
        }
    }

    private async Task LoadBedMetricsAsync()
    {
        loadingBed = true;
        errorBed = null;
        StateHasChanged();
        try
        {
            bedMetrics = await AnalyticsService.GetBedOccupancyAsync(currentTenantId);
        }
        catch (Exception)
        {
            errorBed = "Failed to load bed occupancy metrics.";
        }
        finally
        {
            loadingBed = false;
            StateHasChanged();
        }
    }

    private async Task LoadRevenueMetricsAsync()
    {
        loadingRevenue = true;
        errorRevenue = null;
        StateHasChanged();
        try
        {
            revenueMetrics = await AnalyticsService.GetRevenueAsync(currentTenantId, fromDate, toDate);
        }
        catch (Exception)
        {
            errorRevenue = "Failed to load revenue metrics.";
        }
        finally
        {
            loadingRevenue = false;
            StateHasChanged();
        }
    }

    private async Task LoadLabMetricsAsync()
    {
        loadingLab = true;
        errorLab = null;
        StateHasChanged();
        try
        {
            labMetrics = await AnalyticsService.GetLabMetricsAsync(currentTenantId);
        }
        catch (Exception)
        {
            errorLab = "Failed to load laboratory metrics.";
        }
        finally
        {
            loadingLab = false;
            StateHasChanged();
        }
    }

    private async Task LoadDoctorMetricsAsync()
    {
        loadingDoctor = true;
        errorDoctor = null;
        StateHasChanged();
        try
        {
            doctorMetrics = await AnalyticsService.GetTopDoctorsByEncountersAsync(currentTenantId);
        }
        catch (Exception)
        {
            errorDoctor = "Failed to load doctor encounter rankings.";
        }
        finally
        {
            loadingDoctor = false;
            StateHasChanged();
        }
    }

    private async Task LoadPharmacyMetricsAsync()
    {
        loadingPharmacy = true;
        errorPharmacy = null;
        StateHasChanged();
        try
        {
            pharmacyMetrics = await AnalyticsService.GetPharmacyMetricsAsync(currentTenantId);
        }
        catch (Exception)
        {
            errorPharmacy = "Failed to load pharmacy metrics.";
        }
        finally
        {
            loadingPharmacy = false;
            StateHasChanged();
        }
    }

    private List<ChartData> GetBedChartData()
    {
        if (bedMetrics == null) return new();
        return new List<ChartData>
        {
            new ChartData { Label = "Occupied", Value = bedMetrics.OccupiedBeds },
            new ChartData { Label = "Available", Value = bedMetrics.AvailableBeds }
        };
    }

    private List<ChartDataDecimal> GetRevenueChartData()
    {
        if (revenueMetrics == null) return new();
        return new List<ChartDataDecimal>
        {
            new ChartDataDecimal { Label = "Invoiced", Value = revenueMetrics.TotalInvoiced },
            new ChartDataDecimal { Label = "Collected", Value = revenueMetrics.TotalCollected },
            new ChartDataDecimal { Label = "Outstanding", Value = revenueMetrics.TotalOutstanding }
        };
    }

    public class ChartData
    {
        public string Label { get; set; } = string.Empty;
        public int Value { get; set; }
    }

    public class ChartDataDecimal
    {
        public string Label { get; set; } = string.Empty;
        public decimal Value { get; set; }
    }
}
