@page "/admin/sessions"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Admin_ManageUsers)]
@inject IAuthService AuthService
@inject CareSphere.Data.ApplicationDbContext DbContext
@inject UserTimeZoneService UserTimeZone
@inject IConfiguration Configuration
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer

<PageTitle>User Sessions — CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-shield-exclamation"></i></div>
            <div>
                <h1 class="page-title">Active User Sessions</h1>
                <p class="page-subtitle">Monitor current user activities, device metrics, and active session details</p>
            </div>
        </div>
    </div>
</div>

@if (sessions == null)
{
    <div class="loading-state py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading active sessions...</p>
    </div>
}
else if (!sessions.Any())
{
    <div class="content-card py-5 text-center mb-4">
        <div class="content-card-body">
            <i class="bi bi-shield-check text-muted display-4 mb-3 d-block"></i>
            <h5 class="fw-bold">No Active Sessions</h5>
            <p class="text-muted small">There are currently no active user sessions recorded.</p>
        </div>
    </div>
}
else
{
    @if (!string.IsNullOrEmpty(actionMessage))
    {
        <div class="alert alert-@(actionSuccess ? "success" : "danger") alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi @(actionSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2"></i>
            @actionMessage
            <button type="button" class="btn-close" @onclick="() => actionMessage = null"></button>
        </div>
    }
    
    <div class="content-card mb-4">
        <div class="content-card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover data-table mb-0 small">
                    <thead>
                        <tr>
                            <th class="ps-4">User</th>
                            <th>IP Address</th>
                            <th>Device</th>
                            <th>Created</th>
                            <th>Last Activity</th>
                            <th>Expires</th>
                            <th class="pe-4 text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var session in sessions)
                        {
                            <tr>
                                <td class="ps-4">
                                    @if (userNames.TryGetValue(session.UserId, out var name))
                                    {
                                        <div class="fw-semibold text-dark">@name</div>
                                        <div class="text-muted small font-monospace">@session.UserId[..Math.Min(8, session.UserId.Length)]...</div>
                                    }
                                    else
                                    {
                                        <span class="text-muted font-monospace small">@session.UserId[..Math.Min(12, session.UserId.Length)]...</span>
                                    }
                                </td>
                                <td>
                                    <span class="font-monospace">@(session.IpAddress ?? "—")</span>
                                </td>
                                <td>
                                    <span class="text-muted">@(session.DeviceInfo ?? "—")</span>
                                </td>
                                <td>@UserTimeZone.ToLocal(session.CreatedAt).ToString("dd MMM HH:mm")</td>
                                <td>@UserTimeZone.ToLocal(session.LastActivityAt).ToString("dd MMM HH:mm")</td>
                                <td class="@(session.ExpiresAt < DateTime.UtcNow ? "text-danger fw-bold" : "")">
                                    @UserTimeZone.ToLocal(session.ExpiresAt).ToString("dd MMM HH:mm")
                                </td>
                                <td class="pe-4 text-end">
                                    <button class="btn btn-xs btn-outline-danger" @onclick="() => RevokeSession(session.UserId)">
                                        <i class="bi bi-x-circle me-1"></i> Revoke
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="d-flex justify-content-between align-items-center p-3 border-top bg-light-subtle">
                <span class="small text-muted">Showing @sessions.Count active sessions</span>
            </div>
        </div>
    </div>
}

@code {
    private List<CareSphere.Models.UserSession>? sessions;
    private Dictionary<string, string> userNames = new();
    private string? actionMessage;
    private bool actionSuccess;

    protected override async Task OnInitializedAsync() => await LoadSessions();

    private async Task LoadSessions()
    {
        var tenantId = GetTenantId();
        sessions = await DbContext.UserSessions
            .Where(s => s.TenantId == tenantId && !s.IsRevoked && s.ExpiresAt > DateTime.UtcNow)
            .OrderByDescending(s => s.LastActivityAt)
            .ToListAsync();

        var userIds = sessions.Select(s => s.UserId).Distinct().ToList();
        userNames = await DbContext.Users
            .Where(u => userIds.Contains(u.Id))
            .ToDictionaryAsync(u => u.Id, u => u.FullName);
    }

    private async Task RevokeSession(string userId)
    {
        try
        {
            await AuthService.RevokeAllSessionsAsync(userId);
            actionSuccess = true;
            actionMessage = "All sessions for this user have been revoked.";
            await LoadSessions();
        }
        catch
        {
            actionSuccess = false;
            actionMessage = "Failed to revoke sessions.";
        }
    }

    private Guid GetTenantId()
    {
        var str = Configuration["App:DefaultTenantId"] ?? "00000000-0000-0000-0000-000000000001";
        return Guid.TryParse(str, out var id) ? id : Guid.Empty;
    }
}
