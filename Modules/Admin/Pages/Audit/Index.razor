@page "/admin/audit-log"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Admin_ViewAuditLog)]
@inject IAuditLogService AuditLogService
@inject CareSphere.Data.ApplicationDbContext DbContext
@inject UserTimeZoneService UserTimeZone
@inject IConfiguration Configuration
@inject IJSRuntime JS
@inject CareSphere.Infrastructure.PageTitleService PageTitle
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer

<PageTitle>Audit Log — CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-journal-check"></i></div>
            <div>
                <h1 class="page-title">Audit Logs</h1>
                <p class="page-subtitle">Track, filter, and export system-wide administrative changes, data edits, and resource access events</p>
            </div>
        </div>
        <div class="page-actions">
            <button class="btn btn-outline-success" @onclick="ExportCsv" disabled="@isExporting">
                @if (isExporting)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                }
                else
                {
                    <i class="bi bi-download me-1"></i>
                }
                Export CSV
            </button>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="content-card mb-4">
    <div class="content-card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label text-muted small fw-semibold">User ID / Username</label>
                <input type="text" class="form-control" placeholder="Search by User ID..." @bind="filterUserId" />
            </div>
            <div class="col-md-2">
                <label class="form-label text-muted small fw-semibold">Action</label>
                <select class="form-select" @bind="filterAction">
                    <option value="">All Actions</option>
                    @foreach (var action in distinctActions)
                    {
                        <option value="@action">@action</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label text-muted small fw-semibold">Resource Type</label>
                <select class="form-select" @bind="filterResourceType">
                    <option value="">All Resources</option>
                    @foreach (var rt in distinctResourceTypes)
                    {
                        <option value="@rt">@rt</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label text-muted small fw-semibold">From Date</label>
                <input type="date" class="form-control" @bind="filterDateFrom" />
            </div>
            <div class="col-md-2">
                <label class="form-label text-muted small fw-semibold">To Date</label>
                <input type="date" class="form-control" @bind="filterDateTo" />
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <button class="btn btn-primary w-100" @onclick="ApplyFilters" style="height: 38px;">
                    <i class="bi bi-funnel"></i>
                </button>
            </div>
        </div>
    </div>
</div>

@if (result == null)
{
    <div class="loading-state py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading audit records...</p>
    </div>
}
else
{
    <div class="content-card mb-4">
        <div class="content-card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover data-table mb-0 small">
                    <thead>
                        <tr>
                            <th class="ps-4">Timestamp</th>
                            <th>User</th>
                            <th>Action</th>
                            <th>Resource Type</th>
                            <th>Resource ID</th>
                            <th>IP Address</th>
                            <th class="pe-4">Device</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var evt in result.Items)
                        {
                            <tr>
                                <td class="ps-4 text-nowrap">@UserTimeZone.ToLocal(evt.Timestamp).ToString("dd MMM yyyy HH:mm:ss")</td>
                                <td class="fw-semibold text-dark" title="@evt.UserId">@GetUserName(evt.UserId)</td>
                                <td>
                                    <span class="badge bg-light text-dark border">@evt.Action</span>
                                </td>
                                <td>@evt.ResourceType</td>
                                <td class="font-monospace" title="@evt.ResourceId">
                                    @(evt.ResourceId.Length > 12 ? evt.ResourceId[..12] + "..." : evt.ResourceId)
                                </td>
                                <td class="font-monospace">@(evt.IpAddress ?? "—")</td>
                                <td class="pe-4 text-muted">@(evt.Device ?? "—")</td>
                            </tr>
                        }
                        @if (!result.Items.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5">
                                    <i class="bi bi-journal-x display-6 text-muted mb-2 d-block"></i>
                                    <span>No audit events found matching the filters.</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <div class="d-flex justify-content-between align-items-center p-3 border-top bg-light-subtle">
                <span class="small text-muted">@result.TotalCount total records</span>
                @if (result.TotalPages > 1)
                {
                    <nav class="d-flex align-items-center gap-2">
                        <button class="btn btn-xs btn-outline-secondary" @onclick="PrevPage" disabled="@(currentPage <= 1)">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        <span class="small text-muted">Page @currentPage of @result.TotalPages</span>
                        <button class="btn btn-xs btn-outline-secondary" @onclick="NextPage" disabled="@(currentPage >= result.TotalPages)">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </nav>
                }
            </div>
        </div>
    </div>
}

@code {
    private PagedResult<CareSphere.Models.AuditEvent>? result;
    private string filterUserId = "";
    private string filterAction = "";
    private string filterResourceType = "";
    private DateTime? filterDateFrom;
    private DateTime? filterDateTo;
    private int currentPage = 1;
    private bool isExporting = false;

    private List<string> distinctActions = new();
    private List<string> distinctResourceTypes = new();
    private Dictionary<string, string> userNameCache = new();

    protected override async Task OnInitializedAsync()
    {
        PageTitle.SetTitle("Administration / Audit Logs");
        var tenantId = GetTenantId();
        distinctActions = await AuditLogService.GetDistinctActionsAsync(tenantId);
        distinctResourceTypes = await AuditLogService.GetDistinctResourceTypesAsync(tenantId);
        await LoadData();
    }

    private async Task ApplyFilters() { currentPage = 1; await LoadData(); }
    private async Task PrevPage() { if (currentPage > 1) { currentPage--; await LoadData(); } }
    private async Task NextPage() { currentPage++; await LoadData(); }

    private async Task LoadData()
    {
        var tenantId = GetTenantId();
        result = await AuditLogService.GetAuditLogsAsync(
            tenantId,
            string.IsNullOrEmpty(filterUserId) ? null : filterUserId,
            string.IsNullOrEmpty(filterAction) ? null : filterAction,
            string.IsNullOrEmpty(filterResourceType) ? null : filterResourceType,
            filterDateFrom, filterDateTo,
            currentPage, 50);

        if (result?.Items != null)
        {
            var newUserIds = result.Items.Select(e => e.UserId).Where(uid => !userNameCache.ContainsKey(uid)).Distinct().ToList();
            foreach (var uid in newUserIds)
            {
                var user = await DbContext.Users.Cast<CareSphere.Models.ApplicationUser>().FirstOrDefaultAsync(u => u.Id == uid);
                userNameCache[uid] = user?.FullName ?? (uid.Length > 10 ? uid[..10] + "..." : uid);
            }
        }
    }

    private string GetUserName(string userId) =>
        userNameCache.TryGetValue(userId, out var name) ? name : (userId.Length > 10 ? userId[..10] + "..." : userId);

    private async Task ExportCsv()
    {
        isExporting = true;
        try
        {
            var tenantId = GetTenantId();
            var csv = await AuditLogService.ExportAuditLogsAsync(tenantId,
                string.IsNullOrEmpty(filterUserId) ? null : filterUserId,
                string.IsNullOrEmpty(filterAction) ? null : filterAction,
                string.IsNullOrEmpty(filterResourceType) ? null : filterResourceType,
                filterDateFrom, filterDateTo);
            var base64 = Convert.ToBase64String(csv);
            var fileName = $"audit_log_{DateTime.UtcNow:yyyyMMdd_HHmmss}.csv";
            await JS.InvokeVoidAsync("eval",
                $"const a=document.createElement('a');a.href='data:text/csv;base64,{base64}';a.download='{fileName}';a.click()");
        }
        finally { isExporting = false; }
    }

    private Guid GetTenantId()
    {
        var str = Configuration["App:DefaultTenantId"] ?? "00000000-0000-0000-0000-000000000001";
        return Guid.TryParse(str, out var id) ? id : Guid.Empty;
    }
}
