@page "/admin/tenant-settings"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Admin_ManageTenant)]
@inject ITenantService TenantService
@inject IConfiguration Configuration
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Tenant Settings — CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-gear-fill"></i></div>
            <div>
                <h1 class="page-title">Tenant Settings</h1>
                <p class="page-subtitle">Configure hospital metadata, active status, Single Sign-On providers, and subscriptions</p>
            </div>
        </div>
    </div>
</div>

@if (settings == null)
{
    <div class="loading-state py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading settings...</p>
    </div>
}
else
{
    @if (!string.IsNullOrEmpty(saveMessage))
    {
        <div class="alert alert-@(saveSuccess ? "success" : "danger") alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi @(saveSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2"></i>
            @saveMessage
            <button type="button" class="btn-close" @onclick='() => saveMessage = null'></button>
        </div>
    }

    <!-- Custom Nav Tabs -->
    <ul class="nav nav-tabs mb-4 border-bottom-0" style="gap: 8px;">
        <li class="nav-item">
            <button class="nav-link px-4 py-2.5 rounded border-0 fw-semibold d-flex align-items-center gap-2 @(activeTab == "general" ? "bg-primary text-white" : "bg-light text-dark")" @onclick='() => activeTab = "general"' style="transition: all 0.2s;">
                <i class="bi bi-building"></i> General
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link px-4 py-2.5 rounded border-0 fw-semibold d-flex align-items-center gap-2 @(activeTab == "sso" ? "bg-primary text-white" : "bg-light text-dark")" @onclick='() => activeTab = "sso"' style="transition: all 0.2s;">
                <i class="bi bi-key"></i> SSO
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link px-4 py-2.5 rounded border-0 fw-semibold d-flex align-items-center gap-2 @(activeTab == "subscription" ? "bg-primary text-white" : "bg-light text-dark")" @onclick='() => activeTab = "subscription"' style="transition: all 0.2s;">
                <i class="bi bi-gem"></i> Subscription
            </button>
        </li>
    </ul>

    <div class="content-card mb-4" style="max-width: 800px;">
        <div class="content-card-body p-4">
            @if (activeTab == "general")
            {
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label fw-semibold text-dark">Hospital Name <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="settings.HospitalName" placeholder="CareSphere Hospital" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-dark">Logo Path</label>
                        <input class="form-control" @bind="settings.HospitalLogoPath" placeholder="/images/logo.png" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold text-dark">Address Line 1</label>
                        <input class="form-control" @bind="settings.AddressLine1" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold text-dark">Address Line 2</label>
                        <input class="form-control" @bind="settings.AddressLine2" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-dark">City</label>
                        <input class="form-control" @bind="settings.City" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-dark">State</label>
                        <input class="form-control" @bind="settings.State" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-dark">PIN Code</label>
                        <input class="form-control" @bind="settings.PinCode" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-dark">Phone</label>
                        <input class="form-control" @bind="settings.Phone" type="tel" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-dark">Email</label>
                        <input class="form-control" @bind="settings.Email" type="email" />
                    </div>
                    <div class="col-12 mt-4 pt-3 border-top">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="tenantActive" @bind="settings.IsActive" style="width: 2em; height: 1em;" />
                            <label class="form-check-label fw-bold text-dark ms-2" for="tenantActive">Tenant Status (Active)</label>
                        </div>
                        <div class="form-text text-muted">Deactivating the tenant freezes all logins for this tenant.</div>
                    </div>
                </div>
                <div class="mt-4 pt-3 border-top d-flex gap-2">
                    <button class="btn btn-primary" @onclick="SaveGeneral" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        }
                        else
                        {
                            <i class="bi bi-floppy-fill me-2"></i>
                        }
                        Save General Settings
                    </button>
                </div>
            }

            @if (activeTab == "sso")
            {
                <div class="alert alert-warning d-flex align-items-center mb-4 border-0 shadow-sm">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <div><strong>Warning:</strong> SSO configuration changes require an application restart to take effect.</div>
                </div>
                <div class="row g-3">
                    <div class="col-12">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="ssoEnabled" @bind="settings.SsoEnabled" style="width: 2em; height: 1em;" />
                            <label class="form-check-label fw-bold text-dark ms-2" for="ssoEnabled">Enable SSO Authentication</label>
                        </div>
                    </div>
                    @if (settings.SsoEnabled)
                    {
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-dark">SSO Provider</label>
                            <select class="form-select" @bind="settings.SsoProvider">
                                <option value="">— Select Provider —</option>
                                <option value="Google">Google</option>
                                <option value="Microsoft">Microsoft</option>
                                <option value="OIDC">Generic OIDC</option>
                                <option value="SAML">SAML 2.0</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-dark">Client ID</label>
                            <input class="form-control" @bind="settings.OidcClientId" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-dark">Client Secret</label>
                            <input class="form-control" type="password" @bind="settings.OidcClientSecret" />
                        </div>
                    }
                </div>
                <div class="mt-4 pt-3 border-top">
                    <button class="btn btn-primary" @onclick="SaveSso" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        }
                        else
                        {
                            <i class="bi bi-floppy-fill me-2"></i>
                        }
                        Save SSO Settings
                    </button>
                </div>
            }

            @if (activeTab == "subscription")
            {
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-dark">Subscription Tier</label>
                        <input class="form-control bg-light" value="@settings.SubscriptionTier" disabled />
                        <div class="form-text">Contact support to upgrade your subscription tier.</div>
                    </div>
                    <div class="col-12 mt-3">
                        <div class="alert alert-info border-0 shadow-sm d-flex align-items-center">
                            <i class="bi bi-info-circle-fill me-2 fs-5 text-primary"></i>
                            <div>To upgrade your plan, please contact <strong>@(string.IsNullOrEmpty(settings.Email) ? "support@caresphere.in" : settings.Email)</strong>.</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private CareSphere.Models.TenantSettings? settings;
    private TenantStats? stats;
    private string activeTab = "general";
    private string? saveMessage;
    private bool saveSuccess;
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        var tenantId = GetTenantId();
        settings = await TenantService.GetTenantSettingsAsync(tenantId);
        stats = await TenantService.GetTenantStatsAsync(tenantId);
    }

    private async Task SaveGeneral()
    {
        if (settings == null) return;
        isSaving = true;
        try
        {
            var actorId = await GetActorId();
            await TenantService.UpdateTenantSettingsAsync(settings, actorId);
            saveSuccess = true;
            saveMessage = "General settings saved successfully.";
        }
        catch { saveSuccess = false; saveMessage = "Failed to save settings."; }
        finally { isSaving = false; }
    }

    private async Task SaveSso()
    {
        if (settings == null) return;
        isSaving = true;
        try
        {
            var actorId = await GetActorId();
            await TenantService.ConfigureSsoAsync(GetTenantId(), settings.SsoEnabled, settings.SsoProvider,
                settings.OidcClientId, settings.OidcClientSecret, settings.OidcAuthority, settings.SamlMetadataUrl, actorId);
            saveSuccess = true;
            saveMessage = "SSO settings saved. Application restart required.";
        }
        catch { saveSuccess = false; saveMessage = "Failed to save SSO settings."; }
        finally { isSaving = false; }
    }

    private Guid GetTenantId()
    {
        var str = Configuration["App:DefaultTenantId"] ?? "00000000-0000-0000-0000-000000000001";
        return Guid.TryParse(str, out var id) ? id : Guid.Empty;
    }

    private async Task<string> GetActorId()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        return authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "admin";
    }
}
