@page "/notifications/templates"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Admin_ManageTenant)]
@rendermode InteractiveServer
@inject INotificationTemplateService TemplateService
@inject NavigationManager NavigationManager

<PageTitle>Alert Templates - CareSphere</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 text-gray-800">Alert Templates</h1>
            <p class="text-muted mb-0">Configure communication scripts, notification types, and channel-specific messaging templates.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary btn-sm" @onclick="SeedTemplates">
                <i class="bi bi-cloud-arrow-down me-1"></i> Seed Default Templates
            </button>
            <a href="/notifications/templates/create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i> Create Template
            </a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(alertMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @alertMessage
            <button type="button" class="btn-close" @onclick="() => alertMessage = null"></button>
        </div>
    }

    @if (groupedTemplates == null)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (!groupedTemplates.Any())
    {
        <div class="card text-center p-5 shadow-sm border-0">
            <div class="card-body">
                <i class="bi bi-file-earmark-text text-muted fs-1 mb-3"></i>
                <h4>No Templates Configured</h4>
                <p class="text-muted">Get started by seeding the default set of multilingual templates or creating your own custom script.</p>
                <div class="d-flex justify-content-center gap-2 mt-4">
                    <button class="btn btn-primary" @onclick="SeedTemplates">Seed Default Templates</button>
                    <a href="/notifications/templates/create" class="btn btn-outline-secondary">Create Template</a>
                </div>
            </div>
        </div>
    }
    else
    {
        @foreach (var group in groupedTemplates)
        {
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                    <h5 class="m-0 font-weight-bold text-primary">
                        <i class="bi bi-tags me-2"></i> @FormatNotificationType(group.Key)
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Template Name</th>
                                    <th>Channel</th>
                                    <th>Language</th>
                                    <th>Status</th>
                                    <th>Body Preview</th>
                                    <th class="pe-4 text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var template in group.Value)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold">@template.TemplateName</td>
                                        <td><span class="badge @GetChannelBadgeClass(template.Channel)">@template.Channel</span></td>
                                        <td><span class="badge bg-light text-dark border">@FormatLanguage(template.Language)</span></td>
                                        <td>
                                            @if (template.IsActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Inactive</span>
                                            }
                                        </td>
                                        <td>
                                            <span title="@template.TemplateBody" class="d-inline-block text-truncate text-muted small" style="max-width: 250px;">
                                                @template.TemplateBody
                                            </span>
                                        </td>
                                        <td class="pe-4 text-end">
                                            <div class="btn-group btn-group-sm">
                                                <a href="/notifications/templates/edit/@template.Id" class="btn btn-outline-secondary" title="Edit Template">
                                                    <i class="bi bi-pencil"></i> Edit
                                                </a>
                                                <button class="btn @(template.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                        @onclick="() => ToggleActive(template)">
                                                    @(template.IsActive ? "Disable" : "Enable")
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private Dictionary<string, List<NotificationTemplate>>? groupedTemplates;
    private string? alertMessage;
    private readonly Guid currentTenantId = Guid.Empty;

    protected override async Task OnInitializedAsync() => await LoadTemplates();

    private async Task LoadTemplates()
    {
        groupedTemplates = await TemplateService.GetAllTemplatesAsync(currentTenantId);
    }

    private async Task SeedTemplates()
    {
        await TemplateService.SeedDefaultTemplatesAsync(currentTenantId);
        alertMessage = "Default English communication templates have been seeded successfully.";
        await LoadTemplates();
    }

    private async Task ToggleActive(NotificationTemplate template)
    {
        await TemplateService.UpdateTemplateAsync(template.Id, template.TemplateBody, !template.IsActive);
        alertMessage = $"Template '{template.TemplateName}' active status updated.";
        await LoadTemplates();
    }

    private string GetChannelBadgeClass(string channel) => channel.ToLower() switch
    {
        "sms" => "bg-primary text-white",
        "whatsapp" => "bg-success text-white",
        "voice" => "bg-warning text-dark",
        "inapp" => "bg-info text-dark",
        _ => "bg-secondary text-white"
    };

    private string FormatLanguage(string lang) => lang switch
    {
        "en" => "English", "hi" => "Hindi", "ta" => "Tamil", "te" => "Telugu",
        "kn" => "Kannada", "ml" => "Malayalam", "bn" => "Bengali",
        "mr" => "Marathi", "gu" => "Gujarati", "pa" => "Punjabi",
        _ => lang
    };

    private string FormatNotificationType(string type) => type switch
    {
        "AppointmentReminder" => "Appointment Reminder",
        "FollowUpReminder" => "Follow-up Reminder",
        "DischargeNotification" => "Discharge Notice",
        "LabReportReady" => "Lab Report Ready",
        "GeneralAlert" => "General Alert",
        _ => type
    };
}
