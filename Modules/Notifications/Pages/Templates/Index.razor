@page "/notifications/templates"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Admin_ManageTenant)]
@rendermode InteractiveServer
@inject INotificationTemplateService TemplateService
@inject NavigationManager NavigationManager
@inject ITenantContext TenantContext

<PageTitle>Alert Templates - CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-file-earmark-text"></i></div>
            <div>
                <h1 class="page-title">Alert Templates</h1>
                <p class="page-subtitle">Configure communication scripts, notification types, and channel-specific messaging templates</p>
            </div>
        </div>
        <div class="page-actions">
            <button class="btn btn-outline-primary" @onclick="SeedTemplates">
                <i class="bi bi-cloud-arrow-down me-1"></i> Seed Default Templates
            </button>
            <a href="/notifications/templates/create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i> Create Template
            </a>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(alertMessage))
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        @alertMessage
        <button type="button" class="btn-close" @onclick="() => alertMessage = null"></button>
    </div>
}

@if (groupedTemplates == null)
{
    <div class="loading-state py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading templates...</p>
    </div>
}
else if (!groupedTemplates.Any())
{
    <div class="content-card py-5 text-center mb-4">
        <div class="content-card-body">
            <i class="bi bi-file-earmark-text text-muted display-4 mb-3 d-block"></i>
            <h5 class="fw-bold">No Templates Configured</h5>
            <p class="text-muted small">Get started by seeding the default set of multilingual templates or creating your own custom script.</p>
            <div class="d-flex justify-content-center gap-2 mt-4">
                <button class="btn btn-primary" @onclick="SeedTemplates">Seed Default Templates</button>
                <a href="/notifications/templates/create" class="btn btn-outline-secondary">Create Template</a>
            </div>
        </div>
    </div>
}
else
{
    @foreach (var group in groupedTemplates)
    {
        <div class="content-card mb-4">
            <div class="content-card-header">
                <h5 class="content-card-title">
                    <i class="bi bi-tags-fill me-2 text-primary"></i> @FormatNotificationType(group.Key)
                </h5>
            </div>
            <div class="content-card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover data-table mb-0 small">
                        <thead>
                            <tr>
                                <th class="ps-4">Template Name</th>
                                <th>Channel</th>
                                <th>Language</th>
                                <th>Status</th>
                                <th>Body Preview</th>
                                <th class="pe-4 text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var template in group.Value)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-dark">@template.TemplateName</td>
                                    <td>
                                        <span class="badge @GetChannelBadgeClass(template.Channel)">@template.Channel</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border">@FormatLanguage(template.Language)</span>
                                    </td>
                                    <td>
                                        @if (template.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <span title="@template.TemplateBody" class="d-inline-block text-truncate text-muted" style="max-width: 250px;">
                                            @template.TemplateBody
                                        </span>
                                    </td>
                                    <td class="pe-4 text-end">
                                        <div class="d-flex justify-content-end gap-1">
                                            <a href="/notifications/templates/edit/@template.Id" class="btn btn-xs btn-outline-secondary" title="Edit Template">
                                                <i class="bi bi-pencil"></i> Edit
                                            </a>
                                            <button class="btn btn-xs @(template.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                    @onclick="() => ToggleActive(template)">
                                                @(template.IsActive ? "Disable" : "Enable")
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@code {
    private Dictionary<string, List<NotificationTemplate>>? groupedTemplates;
    private string? alertMessage;
    private Guid currentTenantId => TenantContext.TenantId;

    protected override async Task OnInitializedAsync() => await LoadTemplates();

    private async Task LoadTemplates()
    {
        groupedTemplates = await TemplateService.GetAllTemplatesAsync(currentTenantId);
    }

    private async Task SeedTemplates()
    {
        await TemplateService.SeedDefaultTemplatesAsync(currentTenantId);
        alertMessage = "Default English communication templates have been seeded successfully.";
        await LoadTemplates();
    }

    private async Task ToggleActive(NotificationTemplate template)
    {
        await TemplateService.UpdateTemplateAsync(template.Id, template.TemplateBody, !template.IsActive);
        alertMessage = $"Template '{template.TemplateName}' active status updated.";
        await LoadTemplates();
    }

    private string GetChannelBadgeClass(string channel) => channel.ToLower() switch
    {
        "sms" => "bg-primary-subtle text-primary border border-primary-subtle",
        "whatsapp" => "bg-success-subtle text-success border border-success-subtle",
        "voice" => "bg-warning-subtle text-warning border border-warning-subtle",
        "inapp" => "bg-info-subtle text-info border border-info-subtle",
        _ => "bg-secondary-subtle text-secondary border border-secondary-subtle"
    };

    private string FormatLanguage(string lang) => lang switch
    {
        "en" => "English", "hi" => "Hindi", "ta" => "Tamil", "te" => "Telugu",
        "kn" => "Kannada", "ml" => "Malayalam", "bn" => "Bengali",
        "mr" => "Marathi", "gu" => "Gujarati", "pa" => "Punjabi",
        _ => lang
    };

    private string FormatNotificationType(string type) => type switch
    {
        "AppointmentReminder" => "Appointment Reminder",
        "FollowUpReminder" => "Follow-up Reminder",
        "DischargeNotification" => "Discharge Notice",
        "LabReportReady" => "Lab Report Ready",
        "GeneralAlert" => "General Alert",
        _ => type
    };
}
