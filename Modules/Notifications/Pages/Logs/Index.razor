@page "/notifications/logs"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Admin_ManageTenant)]
@rendermode InteractiveServer
@inject INotificationDashboardService DashboardService
@inject INotificationSenderService SenderService
@inject NavigationManager NavigationManager

<PageTitle>Notification Logs - CareSphere</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3">Notification Logs</h1>
            <p class="text-muted mb-0">Complete log of all outbound notification activity.</p>
        </div>
        <a href="/notifications/dashboard" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
        </a>
    </div>

    @if (!string.IsNullOrEmpty(alertMessage))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @alertMessage
            <button type="button" class="btn-close" @onclick="() => alertMessage = null"></button>
        </div>
    }

    @if (recentLogs == null)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (!recentLogs.Any())
    {
        <div class="alert alert-info text-center py-4"><i class="bi bi-info-circle fs-3 d-block mb-2"></i> No notifications logged yet.</div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Sent At</th>
                                <th>Recipient</th>
                                <th>Channel</th>
                                <th>Type</th>
                                <th>Message Preview</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in recentLogs)
                            {
                                <tr>
                                    <td>@log.CreatedAt.ToLocalTime().ToString("g")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(log.RecipientName))
                                        {
                                            <div><strong>@log.RecipientName</strong></div>
                                        }
                                        @if (!string.IsNullOrEmpty(log.RecipientPhone))
                                        {
                                            <small class="text-muted">@log.RecipientPhone</small>
                                        }
                                    </td>
                                    <td><span class="badge @GetChannelBadgeClass(log.Channel)">@log.Channel</span></td>
                                    <td>@FormatNotificationType(log.NotificationType)</td>
                                    <td>
                                        <span title="@log.MessageBody" class="d-inline-block text-truncate" style="max-width: 300px;">
                                            @log.MessageBody
                                        </span>
                                    </td>
                                    <td><span class="badge @GetStatusBadgeClass(log.Status)">@log.Status</span></td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="/notifications/logs/@log.Id" class="btn btn-outline-secondary" title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            @if (log.Status.Equals("Failed", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <button class="btn btn-outline-primary" @onclick="() => RetryLog(log.Id)" title="Retry Sending">
                                                    <i class="bi bi-arrow-repeat"></i> Retry
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<NotificationLog>? recentLogs;
    private string? alertMessage;
    private readonly Guid currentTenantId = Guid.Empty;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        recentLogs = await DashboardService.GetRecentLogsAsync(currentTenantId);
    }

    private async Task RetryLog(Guid logId)
    {
        var result = await SenderService.RetryLogAsync(logId);
        alertMessage = result ? "Notification successfully retried and sent." : "Notification retry triggered.";
        await LoadData();
    }

    private string GetChannelBadgeClass(string channel) => channel.ToLower() switch
    {
        "sms" => "bg-primary text-white",
        "whatsapp" => "bg-success text-white",
        "voice" => "bg-warning text-dark",
        "inapp" => "bg-info text-dark",
        _ => "bg-secondary text-white"
    };

    private string GetStatusBadgeClass(string status) => status.ToLower() switch
    {
        "sent" or "delivered" => "bg-success text-white",
        "failed" => "bg-danger text-white",
        "pending" => "bg-warning text-dark",
        "skipped" => "bg-secondary text-white",
        _ => "bg-secondary text-white"
    };

    private string FormatNotificationType(string type) => type switch
    {
        "AppointmentReminder" => "Appointment Reminder",
        "FollowUpReminder" => "Follow-up Reminder",
        "DischargeNotification" => "Discharge Notice",
        "LabReportReady" => "Lab Report Ready",
        "GeneralAlert" => "General Alert",
        _ => type
    };
}
