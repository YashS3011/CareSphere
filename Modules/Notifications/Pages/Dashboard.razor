@page "/notifications/dashboard"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Admin_ManageTenant)]
@rendermode InteractiveServer
@inject INotificationDashboardService DashboardService
@inject INotificationSenderService SenderService
@inject NavigationManager NavigationManager
@inject ITenantContext TenantContext

<PageTitle>Notifications Dashboard - CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-bell-fill"></i></div>
            <div>
                <h1 class="page-title">Notifications &amp; Engagement</h1>
                <p class="page-subtitle">Monitor outbound patient alerts, reminders, and delivery performance metrics</p>
            </div>
        </div>
        <div class="page-actions">
            <button class="btn btn-outline-secondary" @onclick="RefreshData">
                <i class="bi bi-arrow-clockwise me-1"></i> Refresh
            </button>
            <a href="/notifications/templates" class="btn btn-primary">
                <i class="bi bi-file-earmark-text me-1"></i> Manage Templates
            </a>
        </div>
    </div>
</div>

@if (ShowLogs == true)
{
    <div class="content-card mb-4">
        <div class="content-card-header">
            <h5 class="content-card-title"><i class="bi bi-clock-history me-2"></i>Recent Notification Logs</h5>
            <button class="btn btn-sm btn-outline-secondary" @onclick="ShowFullDashboard">Back to Full Dashboard</button>
        </div>
        <div class="content-card-body p-0">
            @if (recentLogs == null)
            {
                <div class="loading-state py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-3 text-muted">Loading logs...</p>
                </div>
            }
            else if (!recentLogs.Any())
            {
                <div class="loading-state py-5">
                    <i class="bi bi-clock text-muted display-4 mb-3 d-block"></i>
                    <h5 class="fw-bold">No Notifications Logged</h5>
                    <p class="text-muted small">No notifications have been sent or registered yet.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover data-table mb-0 small">
                        <thead>
                            <tr>
                                <th>Sent At</th>
                                <th>Recipient</th>
                                <th>Channel</th>
                                <th>Type</th>
                                <th>Message Preview</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in recentLogs)
                            {
                                <tr>
                                    <td>@log.CreatedAt.ToLocalTime().ToString("g")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(log.RecipientName))
                                        {
                                            <div class="fw-semibold text-dark">@log.RecipientName</div>
                                        }
                                        @if (!string.IsNullOrEmpty(log.RecipientPhone))
                                        {
                                            <small class="text-muted font-monospace">@log.RecipientPhone</small>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @GetChannelBadgeClass(log.Channel)">@log.Channel</span>
                                    </td>
                                    <td>@FormatNotificationType(log.NotificationType)</td>
                                    <td>
                                        <span title="@log.MessageBody" class="d-inline-block text-truncate" style="max-width: 300px;">@log.MessageBody</span>
                                    </td>
                                    <td>
                                        <span class="badge @GetStatusBadgeClass(log.Status)">@log.Status</span>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-1">
                                            <a href="/notifications/logs/@log.Id" class="btn btn-xs btn-outline-secondary" title="View Details">
                                                <i class="bi bi-eye"></i> View
                                            </a>
                                            @if (log.Status.Equals("Failed", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <button class="btn btn-xs btn-outline-primary" @onclick="() => RetryLog(log.Id)" title="Retry Sending">
                                                    <i class="bi bi-arrow-repeat"></i> Retry
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}
else
{
    @if (stats == null)
    {
        <div class="loading-state py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-muted">Loading stats...</p>
        </div>
    }
    else
    {
        <!-- KPI Section -->
        <div class="row g-4 mb-4">
            <div class="col-sm-6 col-xl-3">
                <div class="stat-card stat-card-success">
                    <div class="stat-icon"><i class="bi bi-send-fill"></i></div>
                    <div class="stat-value">@stats.TotalSentToday</div>
                    <div class="stat-label">Total Sent Today</div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="stat-card stat-card-danger">
                    <div class="stat-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
                    <div class="stat-value">@stats.TotalFailedToday</div>
                    <div class="stat-label">Total Failed Today</div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="stat-card stat-card-info">
                    <div class="stat-icon"><i class="bi bi-calendar-event"></i></div>
                    <div class="stat-value">@stats.TotalPendingReminders</div>
                    <div class="stat-label">Pending Reminders</div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="stat-card stat-card-primary">
                    <div class="stat-icon"><i class="bi bi-pie-chart-fill"></i></div>
                    <div class="stat-value">@stats.DeliveryRatePercent%</div>
                    <div class="stat-label">Delivery Success Rate</div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(alertMessage))
        {
            <div class="alert alert-info alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
                <i class="bi bi-info-circle-fill me-2"></i>
                @alertMessage
                <button type="button" class="btn-close" @onclick="() => alertMessage = null"></button>
            </div>
        }

        <!-- Recent Logs -->
        <div class="content-card mb-4">
            <div class="content-card-header">
                <h5 class="content-card-title"><i class="bi bi-clock-history me-2"></i>Recent Outbox Activity</h5>
                <button class="btn btn-sm btn-outline-secondary" @onclick="ShowLogsOnly">View Filtered Log Sheet</button>
            </div>
            <div class="content-card-body p-0">
                @if (recentLogs == null)
                {
                    <div class="loading-state py-4">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                }
                else if (!recentLogs.Any())
                {
                    <div class="loading-state py-4">
                        <p class="text-muted mb-0">No outbound notifications registered today.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover data-table mb-0 small">
                            <thead>
                                <tr>
                                    <th>Sent At</th>
                                    <th>Recipient</th>
                                    <th>Channel</th>
                                    <th>Type</th>
                                    <th>Status</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in recentLogs)
                                {
                                    <tr>
                                        <td>@log.CreatedAt.ToLocalTime().ToString("g")</td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(log.RecipientName))
                                            {
                                                <div class="fw-semibold text-dark">@log.RecipientName</div>
                                            }
                                            @if (!string.IsNullOrEmpty(log.RecipientPhone))
                                            {
                                                <small class="text-muted font-monospace">@log.RecipientPhone</small>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge @GetChannelBadgeClass(log.Channel)">@log.Channel</span>
                                        </td>
                                        <td>@FormatNotificationType(log.NotificationType)</td>
                                        <td>
                                            <span class="badge @GetStatusBadgeClass(log.Status)">@log.Status</span>
                                        </td>
                                        <td class="text-end">
                                            <a href="/notifications/logs/@log.Id" class="btn btn-xs btn-outline-secondary">
                                                <i class="bi bi-eye"></i> View
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    [Parameter][SupplyParameterFromQuery]
    public bool? ShowLogs { get; set; }

    private NotificationDashboardStats? stats;
    private List<NotificationLog>? recentLogs;
    private List<NotificationLog>? failedLogs;
    private string? alertMessage;
    private bool isRetryingAll = false;
    private Guid currentTenantId => TenantContext.TenantId;

    protected override async Task OnInitializedAsync() => await LoadDashboardData();
    protected override async Task OnParametersSetAsync() => await LoadDashboardData();

    private async Task LoadDashboardData()
    {
        stats = await DashboardService.GetDashboardStatsAsync(currentTenantId);
        recentLogs = await DashboardService.GetRecentLogsAsync(currentTenantId);
        failedLogs = await DashboardService.GetFailedLogsAsync(currentTenantId);
    }

    private async Task RefreshData()
    {
        await LoadDashboardData();
        alertMessage = "Dashboard metrics refreshed successfully.";
    }

    private void ShowLogsOnly() => NavigationManager.NavigateTo("/notifications/dashboard?showLogs=true");
    private void ShowFullDashboard() => NavigationManager.NavigateTo("/notifications/dashboard");

    private async Task RetryLog(Guid logId)
    {
        var result = await SenderService.RetryLogAsync(logId);
        alertMessage = result ? "Notification successfully retried and sent." : "Notification retry triggered. Verify the log details for updated outcomes.";
        await LoadDashboardData();
    }

    private string GetChannelBadgeClass(string channel) => channel.ToLower() switch
    {
        "sms" => "bg-primary-subtle text-primary border border-primary-subtle",
        "whatsapp" => "bg-success-subtle text-success border border-success-subtle",
        "voice" => "bg-warning-subtle text-warning border border-warning-subtle",
        "inapp" => "bg-info-subtle text-info border border-info-subtle",
        _ => "bg-secondary-subtle text-secondary border border-secondary-subtle"
    };

    private string GetStatusBadgeClass(string status) => status.ToLower() switch
    {
        "sent" or "delivered" => "bg-success-subtle text-success border border-success-subtle",
        "failed" => "bg-danger-subtle text-danger border border-danger-subtle",
        "pending" => "bg-warning-subtle text-warning border border-warning-subtle",
        "skipped" => "bg-secondary-subtle text-secondary border border-secondary-subtle",
        _ => "bg-secondary-subtle text-secondary border border-secondary-subtle"
    };

    private string FormatNotificationType(string type) => type switch
    {
        "AppointmentReminder" => "Appointment Reminder",
        "FollowUpReminder" => "Follow-up Reminder",
        "DischargeNotification" => "Discharge Notice",
        "LabReportReady" => "Lab Report Ready",
        "GeneralAlert" => "General Alert",
        _ => type
    };
}
