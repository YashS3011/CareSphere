@page "/pharmacy/dashboard"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Pharmacy_ViewStock)]
@using CareSphere.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject IExpiryAlertService AlertService
@inject IPharmacyItemService ItemService
@inject NavigationManager NavigationManager
@inject ITenantContext TenantContext
@rendermode InteractiveServer

<PageTitle>Pharmacy Dashboard - CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-capsule-pill"></i></div>
            <div>
                <h1 class="page-title">Pharmacy Dashboard</h1>
                <p class="page-subtitle">Overview of pharmacy stock, expiries, dispenses, and OTC sales</p>
            </div>
        </div>
        <div class="page-actions">
            <a href="/pharmacy/dispense" class="btn btn-primary"><i class="bi bi-prescription2 me-1"></i> Dispense Rx</a>
            <a href="/pharmacy/otc-sale" class="btn btn-outline-secondary"><i class="bi bi-shop me-1"></i> OTC POS</a>
        </div>
    </div>
</div>

@if (loading)
{
    <div class="loading-state"><div class="spinner-border text-primary" role="status"></div><p class="mt-3 text-muted">Loading dashboard data...</p></div>
}
else
{
    <div class="row g-4 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="stat-card stat-card-primary">
                <div class="stat-icon"><i class="bi bi-box-seam"></i></div>
                <div class="stat-value">@totalCatalogItems</div>
                <div class="stat-label">Catalog Items</div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="stat-card stat-card-danger">
                <div class="stat-icon"><i class="bi bi-exclamation-triangle"></i></div>
                <div class="stat-value">@expiringBatchesCount</div>
                <div class="stat-label">Expiring (90d)</div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="stat-card stat-card-warning">
                <div class="stat-icon"><i class="bi bi-dash-circle"></i></div>
                <div class="stat-value">@lowStockCount</div>
                <div class="stat-label">Low Stock Alerts</div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="stat-card stat-card-success">
                <div class="stat-icon"><i class="bi bi-currency-rupee"></i></div>
                <div class="stat-value">₹@todayOtcSalesAmount.ToString("F0")</div>
                <div class="stat-label">OTC Sales Today</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Expiring Batches -->
        <div class="col-lg-6">
            <div class="content-card h-100">
                <div class="content-card-header">
                    <h5 class="content-card-title"><i class="bi bi-exclamation-triangle me-2 text-danger"></i>Near Expiry Batches (90 Days)</h5>
                    <a href="/pharmacy/expiry-alerts" class="btn btn-sm btn-outline-secondary">View All</a>
                </div>
                <div class="content-card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover data-table mb-0 small">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th>Batch #</th>
                                    <th>Expiry Date</th>
                                    <th class="text-end">Stock</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (expiringSoon == null || !expiringSoon.Any())
                                {
                                    <tr><td colspan="4" class="text-center py-4 text-muted">No batches near expiry.</td></tr>
                                }
                                else
                                {
                                    @foreach (var batch in expiringSoon)
                                    {
                                        var daysRemaining = (batch.ExpiryDate.Date - DateTime.UtcNow.Date).Days;
                                        var daysClass = daysRemaining <= 30 ? "text-danger fw-bold" : "text-warning fw-semibold";
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@batch.Item.ItemName</div>
                                                <div class="text-muted small">@batch.Item.ItemCode</div>
                                            </td>
                                            <td class="font-monospace text-uppercase">@batch.BatchNumber</td>
                                            <td class="@daysClass">
                                                @batch.ExpiryDate.ToString("dd MMM yyyy")
                                                <div class="text-muted fw-normal small">@daysRemaining days left</div>
                                            </td>
                                            <td class="text-end fw-semibold">@batch.CurrentStock @batch.Item.Unit</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Low Stock -->
        <div class="col-lg-6">
            <div class="content-card h-100">
                <div class="content-card-header">
                    <h5 class="content-card-title"><i class="bi bi-dash-circle me-2 text-warning"></i>Reorder Alert Items</h5>
                    <a href="/pharmacy/items" class="btn btn-sm btn-outline-secondary">Catalog</a>
                </div>
                <div class="content-card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover data-table mb-0 small">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th>Category</th>
                                    <th class="text-end">Reorder Lvl</th>
                                    <th class="text-end">Current Stock</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (lowStockItems == null || !lowStockItems.Any())
                                {
                                    <tr><td colspan="4" class="text-center py-4 text-muted">All items have safe stock levels.</td></tr>
                                }
                                else
                                {
                                    @foreach (var dto in lowStockItems)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@dto.Item.ItemName</div>
                                                <div class="text-muted small">@dto.Item.ItemCode</div>
                                            </td>
                                            <td><span class="badge bg-secondary-subtle text-secondary">@dto.Item.Category</span></td>
                                            <td class="text-end text-muted">@dto.Item.ReorderLevel</td>
                                            <td class="text-end text-danger fw-bold">@dto.TotalStock @dto.Item.Unit</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private int totalCatalogItems, expiringBatchesCount, lowStockCount;
    private decimal todayOtcSalesAmount;
    private List<PharmacyBatch>? expiringSoon;
    private List<PharmacyItemStockDto>? lowStockItems;
    private Guid currentTenantId = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            loading = true;
            currentTenantId = TenantContext.TenantId;
            await AlertService.CheckAndGenerateExpiryAlertsAsync(currentTenantId);
            totalCatalogItems = await DbContext.PharmacyItems.CountAsync(i => i.TenantId == currentTenantId && i.IsActive);
            var expirationThreshold = DateTime.UtcNow.AddDays(90);
            expiringBatchesCount = await DbContext.PharmacyBatches.CountAsync(b => b.TenantId == currentTenantId && b.IsActive && b.CurrentStock > 0 && b.ExpiryDate <= expirationThreshold);
            expiringSoon = await DbContext.PharmacyBatches.Include(b => b.Item).Where(b => b.TenantId == currentTenantId && b.IsActive && b.CurrentStock > 0 && b.ExpiryDate <= expirationThreshold).OrderBy(b => b.ExpiryDate).Take(10).ToListAsync();
            lowStockItems = await ItemService.GetLowStockItemsAsync(currentTenantId);
            lowStockCount = lowStockItems.Count;
            lowStockItems = lowStockItems.Take(10).ToList();
            var today = DateTime.UtcNow.Date;
            todayOtcSalesAmount = await DbContext.OtcSales.Where(s => s.TenantId == currentTenantId && s.SaleDate.Date == today && s.PaymentStatus == "Paid").SumAsync(s => s.TotalAmount);
        }
        catch (Exception ex) { Console.WriteLine($"Error loading dashboard: {ex.Message}"); }
        finally { loading = false; }
    }
}
