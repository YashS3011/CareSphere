@page "/pharmacy/items"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Pharmacy_ViewStock)]
@inject IPharmacyItemService ItemService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Pharmacy Items - CareSphere</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 text-dark fw-bold"><i class="bi bi-box-seam me-2 text-primary"></i>Pharmacy Items</h1>
            <p class="text-muted mb-0">Manage items catalog, reorder levels, and barcodes</p>
        </div>
        <a href="/pharmacy/items/create" class="btn btn-primary d-flex align-items-center gap-2 px-4 shadow-sm">
            <i class="bi bi-plus-circle"></i> Add New Item
        </a>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label text-muted small fw-semibold">Search</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" class="form-control border-start-0 ps-0" placeholder="Search by name, code, generic..." @bind="SearchQuery" @bind:event="oninput" @onkeyup="HandleSearch" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label text-muted small fw-semibold">Category</label>
                    <select class="form-select" @bind="SelectedCategory" @bind:after="FilterChanged">
                        <option value="">All Categories</option>
                        <option value="Medicine">Medicine</option>
                        <option value="Surgical">Surgical</option>
                        <option value="Consumable">Consumable</option>
                        <option value="Equipment">Equipment</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label text-muted small fw-semibold">Prescription Rule</label>
                    <select class="form-select" @bind="SelectedRequiresPrescription" @bind:after="FilterChanged">
                        <option value="">All Items</option>
                        <option value="true">Requires Prescription</option>
                        <option value="false">OTC (No Rx Needed)</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-light w-100" @onclick="ClearFilters">Clear Filters</button>
                </div>
            </div>
        </div>
    </div>

    @if (items == null)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!items.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <i class="bi bi-box text-muted display-1 mb-3"></i>
            <h4 class="fw-bold">No Pharmacy Items Found</h4>
            <p class="text-muted">Try modifying your filters or add a new item to the catalog.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-uppercase fs-7 fw-semibold text-muted">
                        <tr>
                            <th class="px-4 py-3">Code / Barcode</th>
                            <th class="py-3">Item Details</th>
                            <th class="py-3">Category</th>
                            <th class="py-3">Unit / Specifications</th>
                            <th class="py-3 text-center">Prescription</th>
                            <th class="py-3 text-center">Status</th>
                            <th class="px-4 py-3 text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var item in items)
                        {
                            <tr>
                                <td class="px-4 py-3">
                                    <div class="font-monospace fw-bold text-dark">@item.ItemCode</div>
                                    @if (!string.IsNullOrEmpty(item.Barcode))
                                    {
                                        <div class="small text-muted"><i class="bi bi-upc"></i> @item.Barcode</div>
                                    }
                                </td>
                                <td class="py-3">
                                    <div class="fw-bold text-dark fs-6">@item.ItemName</div>
                                    @if (!string.IsNullOrEmpty(item.GenericName))
                                    {
                                        <div class="small text-secondary">@item.GenericName</div>
                                    }
                                </td>
                                <td class="py-3">
                                    <span class="badge rounded-pill bg-light text-dark border px-2 py-1">@item.Category</span>
                                </td>
                                <td class="py-3">
                                    <div>@item.Unit</div>
                                    <div class="small text-muted">@(item.Form) @(string.IsNullOrEmpty(item.Strength) ? "" : $"({item.Strength})")</div>
                                </td>
                                <td class="py-3 text-center">
                                    @if (item.RequiresPrescription)
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-2 py-1">Rx Required</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info-subtle text-info border border-info-subtle px-2 py-1">OTC</span>
                                    }
                                </td>
                                <td class="py-3 text-center">
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1">Inactive</span>
                                    }
                                </td>
                                <td class="px-4 py-3 text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a href="/pharmacy/items/@item.Id/batches" class="btn btn-sm btn-outline-primary" title="View Batches">
                                            <i class="bi bi-layers"></i> Batches
                                        </a>
                                        <a href="/pharmacy/items/edit/@item.Id" class="btn btn-sm btn-outline-secondary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (totalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center mt-3">
                <span class="small text-muted">Showing page @currentPage of @totalPages</span>
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <button class="page-item page-link" @onclick="() => NavigateToPage(currentPage - 1)">Previous</button>
                        </li>
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            var pageNumber = i;
                            <li class="page-item @(currentPage == pageNumber ? "active" : "")">
                                <button class="page-link" @onclick="() => NavigateToPage(pageNumber)">@pageNumber</button>
                            </li>
                        }
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <button class="page-item page-link" @onclick="() => NavigateToPage(currentPage + 1)">Next</button>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    }
</div>

@code {
    private List<PharmacyItem>? items;
    private string SearchQuery { get; set; } = string.Empty;
    private string SelectedCategory { get; set; } = string.Empty;
    private string SelectedRequiresPrescription { get; set; } = string.Empty;

    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages = 1;
    private Guid currentTenantId = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadItems();
    }

    private async Task LoadItems()
    {
        bool? reqPresc = null;
        if (bool.TryParse(SelectedRequiresPrescription, out var res))
            reqPresc = res;

        var totalItems = await ItemService.GetItemsCountAsync(currentTenantId, SearchQuery, SelectedCategory, reqPresc);
        totalPages = (int)Math.Ceiling((double)totalItems / pageSize);
        if (totalPages == 0) totalPages = 1;
        if (currentPage > totalPages) currentPage = totalPages;

        items = await ItemService.SearchItemsAsync(currentTenantId, SearchQuery, SelectedCategory, reqPresc, currentPage, pageSize);
    }

    private async Task HandleSearch() { currentPage = 1; await LoadItems(); }
    private async Task FilterChanged() { currentPage = 1; await LoadItems(); }

    private async Task ClearFilters()
    {
        SearchQuery = string.Empty;
        SelectedCategory = string.Empty;
        SelectedRequiresPrescription = string.Empty;
        currentPage = 1;
        await LoadItems();
    }

    private async Task NavigateToPage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
            await LoadItems();
        }
    }
}
