@page "/beds"
@rendermode InteractiveServer
@attribute [Authorize(Policy = PolicyNames.Permission_Beds_View)]
@inject IBedService BedService
@inject NavigationManager NavigationManager

<PageTitle>Beds - CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-layout-three-columns"></i></div>
            <div>
                <h1 class="page-title">Bed Management</h1>
                <p class="page-subtitle">Configure beds and manage assignments by ward</p>
            </div>
        </div>
        <AuthorizeView Policy="@PolicyNames.Permission_Beds_Manage">
            <Authorized>
                <div class="page-actions">
                    <a href="/beds/create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> Add New Bed</a>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>
</div>

<div class="content-card mb-4">
    <div class="content-card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold">Filter by Ward</label>
                <select class="form-select" @onchange="OnWardFilterChanged">
                    <option value="">All Wards</option>
                    @if (wards != null)
                    {
                        @foreach (var w in wards)
                        {
                            <option value="@w.Id" selected="@(w.Id.ToString() == currentWardId)">@w.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold">Filter by Status</label>
                <select class="form-select" @onchange="OnStatusFilterChanged">
                    <option value="">All Statuses</option>
                    <option value="Available" selected="@(currentStatus == "Available")">Available</option>
                    <option value="Occupied" selected="@(currentStatus == "Occupied")">Occupied</option>
                    <option value="Maintenance" selected="@(currentStatus == "Maintenance")">Maintenance</option>
                    <option value="Reserved" selected="@(currentStatus == "Reserved")">Reserved</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="button" class="btn btn-outline-secondary w-100" @onclick="ClearFilters">
                    <i class="bi bi-x-circle me-1"></i> Clear
                </button>
            </div>
        </div>
    </div>
</div>

@if (beds == null)
{
    <div class="loading-state">
        <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
        <p class="mt-3 text-muted">Loading beds...</p>
    </div>
}
else if (!beds.Any())
{
    <div class="empty-state-card">
        <i class="bi bi-layout-three-columns"></i>
        <h5>No beds found</h5>
        <p>No beds match your current filters. Try adjusting or <button class="btn btn-link p-0" @onclick="ClearFilters">clear filters</button>.</p>
    </div>
}
else
{
    <div class="content-card">
        <div class="content-card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover data-table mb-0">
                    <thead>
                        <tr>
                            <th>Bed Number</th>
                            <th>Ward</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Active</th>
                            <AuthorizeView Policy="@PolicyNames.Permission_Beds_Manage">
                                <Authorized>
                                    <th class="text-end">Actions</th>
                                </Authorized>
                            </AuthorizeView>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bed in beds)
                        {
                            <tr>
                                <td><strong>@bed.BedNumber</strong></td>
                                <td>@(bed.Ward?.Name ?? "Unknown")</td>
                                <td><span class="badge bg-secondary bg-opacity-10 text-secondary">@bed.BedType</span></td>
                                <td>
                                    @switch (bed.Status)
                                    {
                                        case "Available": <span class="badge bg-success-subtle text-success">Available</span> break;
                                        case "Occupied": <span class="badge bg-danger-subtle text-danger">Occupied</span> break;
                                        case "Maintenance": <span class="badge bg-warning-subtle text-warning">Maintenance</span> break;
                                        case "Reserved": <span class="badge bg-info-subtle text-info">Reserved</span> break;
                                        default: <span class="badge bg-secondary-subtle text-secondary">@bed.Status</span> break;
                                    }
                                </td>
                                <td>
                                    @if (bed.IsActive) { <span class="badge bg-success-subtle text-success"><i class="bi bi-check-circle-fill me-1"></i>Yes</span> }
                                    else { <span class="badge bg-secondary-subtle text-secondary"><i class="bi bi-dash-circle-fill me-1"></i>No</span> }
                                </td>
                                <AuthorizeView Policy="@PolicyNames.Permission_Beds_Manage">
                                    <Authorized>
                                        <td class="text-end">
                                            <div class="btn-group btn-group-sm">
                                                <a href="/beds/edit/@bed.Id" class="btn btn-outline-primary" title="Edit"><i class="bi bi-pencil"></i></a>
                                                <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete(bed.Id, bed.Status)" title="Delete"><i class="bi bi-trash"></i></button>
                                            </div>
                                        </td>
                                    </Authorized>
                                </AuthorizeView>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal fade show" style="display:block;background:rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">Are you sure you want to delete this bed? This action cannot be undone.</p>
                    @if (deleteError != null) { <div class="alert alert-danger mt-3">@deleteError</div> }
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="DeleteBed" disabled="@(deleteError != null)"><i class="bi bi-trash me-1"></i> Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "wardId")] public string? currentWardId { get; set; }
    [SupplyParameterFromQuery(Name = "status")] public string? currentStatus { get; set; }

    private List<Bed>? beds;
    private List<Ward>? wards;
    private bool showDeleteConfirm = false;
    private Guid bedIdToDelete = Guid.Empty;
    private string? deleteError;

    protected override async Task OnInitializedAsync()
    {
        wards = await BedService.GetAllWardsAsync();
        await LoadBeds();
    }

    private async Task OnWardFilterChanged(ChangeEventArgs e) { currentWardId = e.Value?.ToString(); await LoadBeds(); }
    private async Task OnStatusFilterChanged(ChangeEventArgs e) { currentStatus = e.Value?.ToString(); await LoadBeds(); }
    private async Task ClearFilters() { currentWardId = null; currentStatus = null; await LoadBeds(); }
    private async Task LoadBeds() { beds = await BedService.GetAllBedsAsync(currentWardId, currentStatus); }

    private void ConfirmDelete(Guid id, string status)
    {
        deleteError = status == "Occupied" ? "Cannot delete a bed that is currently occupied." : null;
        bedIdToDelete = id;
        showDeleteConfirm = true;
    }

    private void CancelDelete() { showDeleteConfirm = false; bedIdToDelete = Guid.Empty; deleteError = null; }

    private async Task DeleteBed()
    {
        if (bedIdToDelete != Guid.Empty && deleteError == null)
        {
            try { await BedService.DeleteBedAsync(bedIdToDelete); await LoadBeds(); showDeleteConfirm = false; }
            catch (Exception ex) { deleteError = ex.Message; }
        }
    }
}
