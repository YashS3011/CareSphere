@page "/beds/create"
@attribute [Authorize(Policy = PolicyNames.Permission_Beds_Manage)]
@inject IBedService BedService
@inject NavigationManager NavigationManager

<PageTitle>Add New Bed - CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-plus-square-fill"></i></div>
            <div>
                <h1 class="page-title">Add New Bed</h1>
                <p class="page-subtitle">Configure a new bed and assign it to a ward</p>
            </div>
        </div>
        <div class="page-actions">
            <a href="/beds" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Back to Beds</a>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="content-card">
            <div class="content-card-header">
                <h5 class="content-card-title"><i class="bi bi-info-circle me-2"></i>Bed Details</h5>
            </div>
            <div class="content-card-body">
                <EditForm Model="@bed" FormName="createBed" OnValidSubmit="ProcessValidSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="alert alert-danger" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Bed Number <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="bed.BedNumber" placeholder="e.g. ICU-01" />
                            <ValidationMessage For="@(() => bed.BedNumber)" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Ward <span class="text-danger">*</span></label>
                            <InputSelect class="form-select" @bind-Value="bed.WardIdAsString">
                                <option value="">Select Ward</option>
                                @if (wards != null)
                                {
                                    @foreach (var w in wards)
                                    {
                                        <option value="@w.Id">@w.Name (@w.WardType)</option>
                                    }
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => bed.WardIdAsString)" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Bed Type <span class="text-danger">*</span></label>
                            <InputSelect class="form-select" @bind-Value="bed.BedType">
                                <option value="">Select Bed Type</option>
                                <option value="Standard">Standard</option>
                                <option value="ICU">ICU</option>
                                <option value="Isolation">Isolation</option>
                                <option value="Pediatric">Pediatric</option>
                                <option value="Maternity">Maternity</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => bed.BedType)" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Initial Status</label>
                            <InputSelect class="form-select" @bind-Value="bed.Status">
                                <option value="Available">Available</option>
                                <option value="Maintenance">Maintenance</option>
                                <option value="Reserved">Reserved</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => bed.Status)" />
                        </div>

                        <div class="col-12">
                            <div class="form-check form-switch mt-1">
                                <InputCheckbox class="form-check-input" @bind-Value="bed.IsActive" id="isActiveCheck" />
                                <label class="form-check-label fw-semibold" for="isActiveCheck">Active Bed</label>
                                <div class="form-text">Inactive beds will not appear in allocation workflows.</div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger mt-3"><i class="bi bi-exclamation-triangle me-2"></i>@errorMessage</div>
                    }

                    <div class="form-actions mt-4">
                        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                            @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            <i class="bi bi-check-lg me-1"></i> Save Bed
                        </button>
                        <a href="/beds" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    public BedFormModel bed { get; set; } = new();

    public class BedFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string BedNumber { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required]
        public string WardIdAsString { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required]
        public string BedType { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required]
        public string Status { get; set; } = "Available";
        public bool IsActive { get; set; } = true;
    }

    private List<Ward>? wards;
    private bool isSubmitting = false;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        wards = await BedService.GetAllWardsAsync();
    }

    private async Task ProcessValidSubmit()
    {
        try
        {
            isSubmitting = true;
            errorMessage = string.Empty;
            var newBed = new Bed
            {
                BedNumber = bed.BedNumber,
                WardId = Guid.Parse(bed.WardIdAsString),
                BedType = bed.BedType,
                Status = bed.Status,
                IsActive = bed.IsActive
            };
            await BedService.CreateBedAsync(newBed);
            NavigationManager.NavigateTo("/beds");
        }
        catch (Microsoft.AspNetCore.Components.NavigationException) { throw; }
        catch (Exception ex)
        {
            errorMessage = $"Error creating bed: {ex.Message}";
            isSubmitting = false;
        }
    }
}
