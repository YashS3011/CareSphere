@page "/allotments/create"
@attribute [Authorize(Policy = PolicyNames.Permission_Beds_Allocate)]
@inject IBedService BedService
@inject IPatientReadModel PatientReadModel
@inject ITenantContext TenantContext
@inject NavigationManager NavigationManager
@inject CareSphere.Data.ApplicationDbContext DbContext
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer

<PageTitle>Admit Patient - CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-box-arrow-in-right"></i></div>
            <div>
                <h1 class="page-title">Admit Patient</h1>
                <p class="page-subtitle">Assign a patient to an available bed</p>
            </div>
        </div>
        <div class="page-actions">
            <a href="/beds/dashboard" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Dashboard</a>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <EditForm Model="@allotment" FormName="createAllotment" OnValidSubmit="ProcessValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary class="alert alert-danger" />

            <!-- Patient Search -->
            <div class="content-card mb-4">
                <div class="content-card-header">
                    <h5 class="content-card-title"><i class="bi bi-person-search me-2"></i>Find Patient</h5>
                </div>
                <div class="content-card-body">
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" placeholder="Search by name or MRN..." @bind="patientSearchQuery" @bind:event="oninput" />
                        <button type="button" class="btn btn-primary" @onclick="SearchPatients">
                            <i class="bi bi-search me-1"></i> Search
                        </button>
                    </div>

                    @if (foundPatients != null)
                    {
                        <div class="patient-search-results mb-3">
                            @foreach (var p in foundPatients)
                            {
                                <button type="button"
                                        class="patient-result-item @(allotment.PatientIdAsString == p.Id.ToString() ? "selected" : "")"
                                        @onclick="() => SelectPatient(p)">
                                    <div>
                                        <div class="fw-semibold">@p.FullName</div>
                                        <div class="text-muted small">MRN: @p.MRN</div>
                                    </div>
                                    <i class="bi @(allotment.PatientIdAsString == p.Id.ToString() ? "bi-check-circle-fill text-success" : "bi-circle")"></i>
                                </button>
                            }
                        </div>
                    }

                    @if (selectedPatientSummary != null)
                    {
                        <div class="selected-patient-banner">
                            <i class="bi bi-person-check-fill me-2"></i>
                            Selected: <strong>@selectedPatientSummary.FullName</strong> &mdash; <span class="text-muted">MRN: @selectedPatientSummary.MRN</span>
                        </div>
                    }
                    <InputText type="hidden" @bind-Value="allotment.PatientIdAsString" />
                    <ValidationMessage For="@(() => allotment.PatientIdAsString)" />
                </div>
            </div>

            <!-- Allotment Details -->
            <div class="content-card mb-4">
                <div class="content-card-header">
                    <h5 class="content-card-title"><i class="bi bi-clipboard2-fill me-2"></i>Allotment Details</h5>
                </div>
                <div class="content-card-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Available Bed <span class="text-danger">*</span></label>
                            <InputSelect class="form-select" @bind-Value="allotment.BedIdAsString">
                                <option value="">Select a Bed</option>
                                @if (availableBeds != null)
                                {
                                    @foreach (var b in availableBeds)
                                    {
                                        <option value="@b.Id">@b.Ward.Name — Bed: @b.BedNumber (@b.BedType)</option>
                                    }
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => allotment.BedIdAsString)" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Admission Type <span class="text-danger">*</span></label>
                            <InputSelect class="form-select" @bind-Value="allotment.AdmissionType">
                                <option value="">Select Type</option>
                                <option value="OPD">OPD</option>
                                <option value="IPD">IPD</option>
                                <option value="Emergency">Emergency</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => allotment.AdmissionType)" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Date of Admission <span class="text-danger">*</span></label>
                            <InputDate class="form-control" @bind-Value="allotment.AdmissionDate" />
                            <ValidationMessage For="@(() => allotment.AdmissionDate)" />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Admitting Doctor</label>
                            <InputText class="form-control" @bind-Value="allotment.AdmittingDoctor" placeholder="Doctor's name (optional)" />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Notes</label>
                            <InputTextArea class="form-control" @bind-Value="allotment.Notes" rows="3" placeholder="Additional admission notes..." />
                        </div>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-warning"><i class="bi bi-info-circle me-2"></i>@errorMessage</div>
            }

            <div class="form-actions">
                <button type="submit" class="btn btn-success btn-lg" disabled="@(isSubmitting || string.IsNullOrEmpty(allotment.PatientIdAsString))">
                    @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-2"></span> }
                    <i class="bi bi-box-arrow-in-right me-1"></i> Admit Patient
                </button>
                <a href="/beds/dashboard" class="btn btn-outline-secondary btn-lg">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    public AllotmentFormModel allotment { get; set; } = new() { AdmissionDate = DateTime.Now };

    public class AllotmentFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please select a patient by searching above.")]
        public string PatientIdAsString { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please select an available bed.")]
        public string BedIdAsString { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Admission type is required.")]
        public string AdmissionType { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required]
        public DateTime AdmissionDate { get; set; }
        public string? AdmittingDoctor { get; set; }
        public string? Notes { get; set; }
    }

    private string patientSearchQuery = string.Empty;
    private IEnumerable<PatientSummary>? foundPatients;
    private PatientSummary? selectedPatientSummary;
    private List<Bed>? availableBeds;
    private bool isSubmitting = false;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync() { availableBeds = await BedService.GetAvailableBedsAsync(); }

    private async Task SearchPatients()
    {
        if (!string.IsNullOrWhiteSpace(patientSearchQuery))
        {
            var allPatients = await PatientReadModel.SearchAsync(patientSearchQuery, TenantContext.TenantId);
            var activePatientIds = await DbContext.BedAllotments
                .Where(a => a.Status == "Active" && a.TenantId == TenantContext.TenantId)
                .Select(a => a.PatientId).ToListAsync();
            foundPatients = allPatients.Where(p => !activePatientIds.Contains(p.Id)).ToList();
            errorMessage = allPatients.Count() > foundPatients.Count()
                ? "Note: Some patients are excluded because they are already admitted. Discharge them first before re-admitting."
                : string.Empty;
        }
    }

    private void SelectPatient(PatientSummary summary) { selectedPatientSummary = summary; allotment.PatientIdAsString = summary.Id.ToString(); }

    private async Task ProcessValidSubmit()
    {
        try
        {
            isSubmitting = true; errorMessage = string.Empty;
            var newAllotment = new BedAllotment
            {
                PatientId = Guid.Parse(allotment.PatientIdAsString),
                BedId = Guid.Parse(allotment.BedIdAsString),
                AdmissionDate = allotment.AdmissionDate.ToUniversalTime(),
                AdmissionType = allotment.AdmissionType,
                AdmittingDoctor = allotment.AdmittingDoctor,
                Notes = allotment.Notes
            };
            await BedService.AdmitPatientAsync(newAllotment);
            NavigationManager.NavigateTo("/beds/dashboard");
        }
        catch (Microsoft.AspNetCore.Components.NavigationException) { throw; }
        catch (Exception ex) { errorMessage = $"Error admitting patient: {ex.Message}"; isSubmitting = false; }
    }
}
