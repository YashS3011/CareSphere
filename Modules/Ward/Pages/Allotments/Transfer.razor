@page "/allotments/transfer"
@page "/allotments/transfer/{Id:guid}"
@attribute [Authorize(Policy = PolicyNames.Permission_Beds_Allocate)]
@using CareSphere.Models
@using CareSphere.Data
@using Microsoft.EntityFrameworkCore
@inject IBedService BedService
@inject IPatientReadModel PatientReadModel
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Transfer Patient - CareSphere</PageTitle>

<h2>Transfer Patient</h2>
<hr />

@if (Id == Guid.Empty)
{
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="m-0 fw-bold">Select Active Allotment to Transfer</h5>
        </div>
        <div class="card-body p-4">
            @if (activeAllotments == null)
            {
                <p><em>Loading active allotments...</em></p>
            }
            else if (!activeAllotments.Any())
            {
                <div class="alert alert-info">No active bed allotments found to transfer.</div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var alt in activeAllotments)
                    {
                        var patient = patientSummaries.TryGetValue(alt.PatientId, out var p) ? p : null;
                        <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" @onclick="() => SelectAllotment(alt.Id)">
                            <div>
                                <h6 class="mb-1 fw-bold">Patient: @(patient?.FullName ?? "Loading...") (MRN: @(patient?.MRN ?? ""))</h6>
                                <small class="text-muted">Current Bed: @alt.Bed?.BedNumber (@alt.Bed?.Ward?.Name) | Admitted: @alt.AdmissionDate.ToLocalTime().ToString("dd MMM yyyy")</small>
                            </div>
                            <span class="badge bg-primary rounded-pill">Select</span>
                        </button>
                    }
                </div>
            }
        </div>
    </div>
}
else
{
    @if (activeAllotment == null && !string.IsNullOrEmpty(errorMessage) && isNotFound)
    {
        <div class="alert alert-danger">@errorMessage</div>
        <a href="/allotments" class="btn btn-primary">Back to Allotments</a>
    }
    else if (activeAllotment == null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="alert alert-info">
            <h5>Current Admission Details:</h5>
            <strong>Patient:</strong> @(patientSummary?.FullName ?? "Unknown") (MRN: @(patientSummary?.MRN ?? "Unknown"))<br />
            <strong>Current Bed:</strong> @activeAllotment.Bed.BedNumber (@activeAllotment.Bed.Ward.Name)<br />
            <strong>Admitted On:</strong> @activeAllotment.AdmissionDate.ToString("dd MMM yyyy HH:mm")
        </div>

        <div class="row">
            <div class="col-md-6">
                <EditForm Model="@transfer" FormName="transferPatient" OnValidSubmit="ProcessValidSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="alert alert-danger" />
                    
                    <div class="card mb-4">
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">Select New Available Bed *</label>
                                <InputSelect class="form-select" @bind-Value="transfer.NewBedIdAsString">
                                    <option value="">Select a Bed</option>
                                    @if (availableBeds != null)
                                    {
                                        @foreach (var b in availableBeds)
                                        {
                                            <option value="@b.Id">@b.Ward.Name - Bed: @b.BedNumber (@b.BedType)</option>
                                        }
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => transfer.NewBedIdAsString)" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Transfer Reason *</label>
                                <InputTextArea class="form-control" @bind-Value="transfer.Reason" rows="3" />
                                <ValidationMessage For="@(() => transfer.Reason)" />
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            Confirm Transfer
                        </button>
                        <a href="/allotments" class="btn btn-secondary">Cancel</a>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage) && !isNotFound)
                    {
                        <div class="alert alert-danger mt-3">@errorMessage</div>
                    }
                </EditForm>
            </div>
        </div>
    }
}

@code {
    [Parameter]
    public Guid Id { get; set; } = Guid.Empty;

    [SupplyParameterFromForm]
    public TransferFormModel transfer { get; set; } = new();

    public class TransferFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please select a new bed.")]
        public string NewBedIdAsString { get; set; } = string.Empty;
        
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please enter a reason for the transfer.")]
        public string Reason { get; set; } = string.Empty;
    }

    private List<BedAllotment>? activeAllotments;
    private Dictionary<Guid, PatientSummary> patientSummaries = new();

    private BedAllotment? activeAllotment;
    private PatientSummary? patientSummary;
    private List<Bed>? availableBeds;
    private bool isNotFound = false;
    private bool isSubmitting = false;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (Id == Guid.Empty)
        {
            activeAllotments = await DbContext.BedAllotments
                .Include(a => a.Bed).ThenInclude(b => b.Ward)
                .Where(a => a.Status == "Active")
                .OrderByDescending(a => a.AdmissionDate)
                .ToListAsync();

            var patientIds = activeAllotments.Select(a => a.PatientId).Distinct().ToList();
            foreach (var pId in patientIds)
            {
                var summary = await PatientReadModel.GetSummaryAsync(pId, Guid.Empty);
                if (summary != null)
                {
                    patientSummaries[pId] = summary;
                }
            }
        }
        else
        {
            activeAllotment = await DbContext.BedAllotments
                .Include(a => a.Bed).ThenInclude(b => b.Ward)
                .FirstOrDefaultAsync(a => a.Id == Id && a.Status == "Active");

            if (activeAllotment == null)
            {
                isNotFound = true;
                errorMessage = "Allotment not found or is no longer active.";
                return;
            }

            patientSummary = await PatientReadModel.GetSummaryAsync(activeAllotment.PatientId, Guid.Empty);
            availableBeds = await BedService.GetAvailableBedsAsync();
        }
    }

    private void SelectAllotment(Guid allotmentId)
    {
        NavigationManager.NavigateTo($"/allotments/transfer/{allotmentId}");
    }

    private async Task ProcessValidSubmit()
    {
        try
        {
            isSubmitting = true;
            errorMessage = string.Empty;

            await BedService.TransferPatientAsync(Id, Guid.Parse(transfer.NewBedIdAsString), transfer.Reason);

            NavigationManager.NavigateTo("/allotments");
        }
        catch (Microsoft.AspNetCore.Components.NavigationException)
        {
            throw; // Expected during redirect
        }
        catch (Exception ex)
        {
            errorMessage = $"Error transferring patient: {ex.Message}";
            isSubmitting = false;
        }
    }
}
