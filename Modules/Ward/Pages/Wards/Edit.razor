@page "/wards/edit/{Id:guid}"
@attribute [Authorize(Policy = PolicyNames.Permission_Beds_Manage)]
@inject IBedService BedService
@inject NavigationManager NavigationManager

<PageTitle>Edit Ward - CareSphere</PageTitle>

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1"><i class="bi bi-pencil-square text-primary"></i> Edit Ward</h3>
        <p class="text-muted small mb-0">Modify configuration details of the hospital ward</p>
    </div>
    <div class="page-actions">
        <a href="/wards" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to Wards
        </a>
    </div>
</div>

@if (ward == null && !isNotFound)
{
    <div class="text-center py-5 bg-white rounded shadow-sm">
        <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
        <p class="text-muted mt-2 mb-0">Loading ward details...</p>
    </div>
}
else if (isNotFound)
{
    <div class="alert alert-danger d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <div>Ward not found.</div>
    </div>
    <a href="/wards" class="btn btn-primary">Back to Ward List</a>
}
else if (ward != null)
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <EditForm Model="@ward" FormName="editWard" OnValidSubmit="ProcessValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary class="alert alert-danger mb-4" />
                
                <InputText type="hidden" @bind-Value="ward.IdAsString" />

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Ward Name <span class="text-danger">*</span></label>
                        <InputText class="form-control" @bind-Value="ward.Name" />
                        <ValidationMessage For="@(() => ward.Name)" />
                    </div>
                    
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Ward Type <span class="text-danger">*</span></label>
                        <InputSelect class="form-select" @bind-Value="ward.WardType">
                            <option value="">Select Ward Type</option>
                            <option value="General" selected="@(ward.WardType == "General")">General</option>
                            <option value="ICU" selected="@(ward.WardType == "ICU")">ICU</option>
                            <option value="Emergency" selected="@(ward.WardType == "Emergency")">Emergency</option>
                            <option value="Private" selected="@(ward.WardType == "Private")">Private</option>
                            <option value="Semi-Private" selected="@(ward.WardType == "Semi-Private")">Semi-Private</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => ward.WardType)" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Building / Block</label>
                        <InputText class="form-control" @bind-Value="ward.Building" />
                        <ValidationMessage For="@(() => ward.Building)" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Floor</label>
                        <InputText class="form-control" @bind-Value="ward.Floor" />
                        <ValidationMessage For="@(() => ward.Floor)" />
                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-end border-top pt-3">
                    <a href="/wards" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        }
                        <i class="bi bi-check-circle me-1"></i> Update Ward
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger d-flex align-items-center mt-3" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <div>@errorMessage</div>
                    </div>
                }
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    [SupplyParameterFromForm]
    public WardFormModel? ward { get; set; }

    public class WardFormModel
    {
        public string IdAsString { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string WardType { get; set; } = string.Empty;
        public string? Building { get; set; }
        public string? Floor { get; set; }
    }

    private bool isNotFound = false;
    private bool isSubmitting = false;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (ward == null) // Not a postback
        {
            var dbWard = await BedService.GetWardByIdAsync(Id);
            if (dbWard == null)
            {
                isNotFound = true;
            }
            else
            {
                ward = new WardFormModel
                {
                    IdAsString = dbWard.Id.ToString(),
                    Name = dbWard.Name,
                    WardType = dbWard.WardType,
                    Building = dbWard.Building,
                    Floor = dbWard.Floor
                };
            }
        }
    }

    private async Task ProcessValidSubmit()
    {
        if (ward == null) return;
        
        try
        {
            isSubmitting = true;
            errorMessage = string.Empty;

            var dbWard = await BedService.GetWardByIdAsync(Guid.Parse(ward.IdAsString));
            if (dbWard != null)
            {
                dbWard.Name = ward.Name;
                dbWard.WardType = ward.WardType;
                dbWard.Building = ward.Building;
                dbWard.Floor = ward.Floor;
                await BedService.UpdateWardAsync(dbWard);
                NavigationManager.NavigateTo("/wards");
            }
        }
        catch (Microsoft.AspNetCore.Components.NavigationException)
        {
            throw; // Expected redirect
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating ward: {ex.Message}";
            isSubmitting = false;
        }
    }
}
