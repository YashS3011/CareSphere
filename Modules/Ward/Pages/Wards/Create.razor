@page "/wards/create"
@attribute [Authorize(Policy = PolicyNames.Permission_Beds_Manage)]
@inject IBedService BedService
@inject NavigationManager NavigationManager

<PageTitle>Add New Ward - CareSphere</PageTitle>

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1"><i class="bi bi-plus-circle text-primary"></i> Add New Ward</h3>
        <p class="text-muted small mb-0">Create a new hospital ward configuration</p>
    </div>
    <div class="page-actions">
        <a href="/wards" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to Wards
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <EditForm Model="@ward" FormName="createWard" OnValidSubmit="ProcessValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary class="alert alert-danger mb-4" />
            
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Ward Name <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="ward.Name" placeholder="e.g. ICU Wing A" />
                    <ValidationMessage For="@(() => ward.Name)" />
                </div>
                
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Ward Type <span class="text-danger">*</span></label>
                    <InputSelect class="form-select" @bind-Value="ward.WardType">
                        <option value="">Select Ward Type</option>
                        <option value="General">General</option>
                        <option value="ICU">ICU</option>
                        <option value="Emergency">Emergency</option>
                        <option value="Private">Private</option>
                        <option value="Semi-Private">Semi-Private</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => ward.WardType)" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Building / Block</label>
                    <InputText class="form-control" @bind-Value="ward.Building" placeholder="e.g. Block B" />
                    <ValidationMessage For="@(() => ward.Building)" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Floor</label>
                    <InputText class="form-control" @bind-Value="ward.Floor" placeholder="e.g. 2nd Floor" />
                    <ValidationMessage For="@(() => ward.Floor)" />
                </div>
            </div>

            <div class="d-flex gap-2 justify-content-end border-top pt-3">
                <a href="/wards" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    }
                    <i class="bi bi-check-circle me-1"></i> Save Ward
                </button>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger d-flex align-items-center mt-3" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <div>@errorMessage</div>
                </div>
            }
        </EditForm>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    public Ward ward { get; set; } = new();

    private bool isSubmitting = false;
    private string errorMessage = string.Empty;

    private async Task ProcessValidSubmit()
    {
        try
        {
            isSubmitting = true;
            errorMessage = string.Empty;

            await BedService.CreateWardAsync(ward);

            NavigationManager.NavigateTo("/wards");
        }
        catch (Microsoft.AspNetCore.Components.NavigationException)
        {
            throw; // Expected during redirect
        }
        catch (Exception ex)
        {
            errorMessage = $"Error creating ward: {ex.Message}";
            isSubmitting = false;
        }
    }
}
