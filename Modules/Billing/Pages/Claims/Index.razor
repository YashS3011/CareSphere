@page "/billing/claims"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Billing_ViewInvoices)]
@using Microsoft.JSInterop
@inject IClaimService ClaimService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Claims - CareSphere</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary"><i class="bi bi-shield-check-fill me-2"></i>Insurance Claims</h2>
        <a href="/billing/invoices" class="btn btn-outline-primary"><i class="bi bi-file-earmark-plus me-1"></i>New Claim (via Invoice)</a>
    </div>

    <!-- Filters -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" placeholder="Search by Claim number, Patient name, or Policy number..."
                               @bind="SearchTerm" @bind:event="oninput" @onkeyup="HandleSearchKeyup" />
                    </div>
                </div>
                <div class="col-md-4">
                    <select class="form-select" @bind="StatusFilter" @bind:after="LoadClaims">
                        <option value="">All Statuses</option>
                        <option value="Draft">Draft</option>
                        <option value="Submitted">Submitted</option>
                        <option value="UnderReview">Under Review</option>
                        <option value="Approved">Approved</option>
                        <option value="PartiallyApproved">Partially Approved</option>
                        <option value="Rejected">Rejected</option>
                        <option value="Resubmitted">Resubmitted</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary w-100" @onclick="ResetFilters">Reset</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Claims List Table -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            @if (claims == null)
            {
                <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
            }
            else if (!claims.Any())
            {
                <div class="alert alert-info m-3">No claims found.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle mb-0">
                        <thead class="table-light text-uppercase fs-7">
                            <tr>
                                <th class="ps-3">Claim #</th>
                                <th>Patient Name</th>
                                <th>Insurance Provider</th>
                                <th>Policy Number</th>
                                <th class="text-end">Claimed</th>
                                <th class="text-end">Approved</th>
                                <th>Status</th>
                                <th>Submitted Date</th>
                                <th class="text-end pe-3">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var claim in claims)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold">@claim.ClaimNumber</td>
                                    <td>@claim.Patient?.FirstName @claim.Patient?.LastName</td>
                                    <td>@claim.InsuranceProvider</td>
                                    <td>@claim.PolicyNumber</td>
                                    <td class="text-end fw-bold">@claim.ClaimedAmount.ToString("C")</td>
                                    <td class="text-end text-success fw-bold">
                                        @(claim.ApprovedAmount.HasValue ? claim.ApprovedAmount.Value.ToString("C") : "--")
                                    </td>
                                    <td>
                                        <span class="badge @GetClaimBadgeClass(claim.Status)">@claim.Status</span>
                                    </td>
                                    <td>
                                        @(claim.SubmittedAt.HasValue ? claim.SubmittedAt.Value.ToString("dd MMM yyyy") : "Not Submitted")
                                    </td>
                                    <td class="text-end pe-3">
                                        <div class="btn-group btn-group-sm">
                                            <a href="/billing/claims/@claim.Id" class="btn btn-outline-info" title="View Details">
                                                <i class="bi bi-eye-fill"></i> View
                                            </a>
                                            <a href="/billing/claims/@claim.Id" class="btn btn-outline-warning" title="Update Status">
                                                <i class="bi bi-arrow-repeat"></i> Update Status
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (totalPages > 1)
                {
                    <nav class="d-flex justify-content-center mt-3 mb-3">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <button class="page-item page-link" @onclick="() => GoToPage(currentPage - 1)">Previous</button>
                            </li>
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                int pageNum = i;
                                <li class="page-item @(currentPage == pageNum ? "active" : "")">
                                    <button class="page-item page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <button class="page-item page-link" @onclick="() => GoToPage(currentPage + 1)">Next</button>
                            </li>
                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</div>

@code {
    private List<InsuranceClaim>? claims;
    private string SearchTerm { get; set; } = string.Empty;
    private string StatusFilter { get; set; } = string.Empty;

    private int currentPage = 1;
    private int pageSize = 10;
    private int totalCount = 0;
    private int totalPages => (int)Math.Ceiling((double)totalCount / pageSize);

    protected override async Task OnInitializedAsync() => await LoadClaims();

    private async Task LoadClaims()
    {
        claims = null;
        var result = await ClaimService.GetClaimsByStatusAsync(StatusFilter, currentPage, pageSize, SearchTerm);
        claims = result.Claims;
        totalCount = result.TotalCount;
    }

    private async Task HandleSearchKeyup(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { currentPage = 1; await LoadClaims(); }
    }

    private async Task GoToPage(int page) { currentPage = page; await LoadClaims(); }

    private async Task ResetFilters()
    {
        SearchTerm = string.Empty;
        StatusFilter = string.Empty;
        currentPage = 1;
        await LoadClaims();
    }

    private string GetClaimBadgeClass(string status) => status switch
    {
        "Draft" => "bg-secondary text-white",
        "Submitted" => "bg-primary text-white",
        "UnderReview" => "bg-info text-white",
        "Approved" => "bg-success text-white",
        "PartiallyApproved" => "bg-warning text-dark",
        "Rejected" => "bg-danger text-white",
        "Resubmitted" => "bg-purple text-white",
        _ => "bg-light text-dark"
    };
}
