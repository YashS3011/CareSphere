@page "/billing/dashboard"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Billing_ViewInvoices)]
@using Microsoft.EntityFrameworkCore
@using CareSphere.Data
@inject ApplicationDbContext DbContext
@inject CareSphere.Authorization.TabIsolatedAuthenticationStateProvider AuthStateProvider
@inject CareSphere.Infrastructure.PageTitleService PageTitle
@rendermode InteractiveServer

<PageTitle>Billing Dashboard - CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-wallet2"></i></div>
            <div>
                <h1 class="page-title">Billing &amp; Claims</h1>
                <p class="page-subtitle">Overview of hospital revenue, outstanding balances, and insurance claim approvals.</p>
            </div>
        </div>
        <div class="page-actions">
            <a href="/billing/invoices/create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Create Invoice</a>
            <a href="/billing/invoices" class="btn btn-outline-secondary">View Invoices</a>
            <a href="/billing/claims" class="btn btn-outline-secondary">View Claims</a>
        </div>
    </div>
</div>

<div class="container-fluid px-0">

    <!-- KPI Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-4 col-xl-2">
            <div class="stat-card stat-card-primary">
                <div class="stat-icon"><i class="bi bi-currency-rupee"></i></div>
                <div><div class="stat-value">₹@totalRevenueMonth.ToString("N0")</div><div class="stat-label">Revenue (Month)</div></div>
            </div>
        </div>
        <div class="col-md-4 col-xl-2">
            <div class="stat-card stat-card-danger">
                <div class="stat-icon"><i class="bi bi-exclamation-circle"></i></div>
                <div><div class="stat-value">₹@totalOutstanding.ToString("N0")</div><div class="stat-label">Outstanding</div></div>
            </div>
        </div>
        <div class="col-md-4 col-xl-2">
            <div class="stat-card stat-card-info">
                <div class="stat-icon"><i class="bi bi-send"></i></div>
                <div><div class="stat-value">@totalClaimsSubmittedMonth</div><div class="stat-label">Claims Submitted</div></div>
            </div>
        </div>
        <div class="col-md-4 col-xl-2">
            <div class="stat-card stat-card-success">
                <div class="stat-icon"><i class="bi bi-check-circle"></i></div>
                <div><div class="stat-value">@totalClaimsApprovedMonth</div><div class="stat-label">Claims Approved</div></div>
            </div>
        </div>
        <div class="col-md-4 col-xl-2">
            <div class="stat-card stat-card-warning">
                <div class="stat-icon"><i class="bi bi-percent"></i></div>
                <div><div class="stat-value">@claimApprovalRate.ToString("F1")%</div><div class="stat-label">Approval Rate</div></div>
            </div>
        </div>
        <div class="col-md-4 col-xl-2">
            <div class="stat-card stat-card-primary">
                <div class="stat-icon"><i class="bi bi-calendar-check"></i></div>
                <div><div class="stat-value">₹@totalCollectedToday.ToString("N0")</div><div class="stat-label">Collected Today</div></div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Recent Invoices Table -->
        <div class="col-lg-6">
            <div class="content-card h-100">
                <div class="content-card-header">
                    <h5 class="content-card-title"><i class="bi bi-file-earmark-text me-2"></i>Recent Invoices</h5>
                    <a href="/billing/invoices" class="btn btn-sm btn-outline-secondary">View All</a>
                </div>
                <div class="content-card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-uppercase fs-7">
                                <tr>
                                    <th class="ps-3">Invoice #</th>
                                    <th>Patient</th>
                                    <th>Date</th>
                                    <th>Total</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (recentInvoices == null)
                                {
                                    <tr><td colspan="5" class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary" role="status"></div></td></tr>
                                }
                                else if (!recentInvoices.Any())
                                {
                                    <tr><td colspan="5" class="text-center py-4 text-muted">No recent invoices.</td></tr>
                                }
                                else
                                {
                                    @foreach (var inv in recentInvoices)
                                    {
                                        <tr>
                                            <td class="ps-3 fw-bold"><a href="/billing/invoices/@inv.Id" class="text-decoration-none">@inv.InvoiceNumber</a></td>
                                            <td>@inv.Patient?.FirstName @inv.Patient?.LastName</td>
                                            <td>@inv.InvoiceDate.ToString("dd MMM yyyy")</td>
                                            <td class="fw-bold">@inv.TotalAmount.ToString("C")</td>
                                            <td><span class="badge @GetInvoiceBadgeClass(inv.Status)">@inv.Status</span></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Payments Table -->
        <div class="col-lg-6">
            <div class="content-card h-100">
                <div class="content-card-header">
                    <h5 class="content-card-title"><i class="bi bi-credit-card me-2"></i>Recent Payments</h5>
                    <a href="/billing/payments" class="btn btn-sm btn-outline-secondary">View All</a>
                </div>
                <div class="content-card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-uppercase fs-7">
                                <tr>
                                    <th class="ps-3">Invoice #</th>
                                    <th>Patient</th>
                                    <th>Method</th>
                                    <th>Amount</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (recentPayments == null)
                                {
                                    <tr><td colspan="5" class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary" role="status"></div></td></tr>
                                }
                                else if (!recentPayments.Any())
                                {
                                    <tr><td colspan="5" class="text-center py-4 text-muted">No recent payments.</td></tr>
                                }
                                else
                                {
                                    @foreach (var pay in recentPayments)
                                    {
                                        <tr>
                                            <td class="ps-3 fw-bold">@pay.BillingInvoice?.InvoiceNumber</td>
                                            <td>@pay.Patient?.FirstName @pay.Patient?.LastName</td>
                                            <td><i class="@GetPaymentIconClass(pay.PaymentMethod) me-1"></i> @pay.PaymentMethod</td>
                                            <td class="fw-bold text-success">@pay.Amount.ToString("C")</td>
                                            <td>@pay.PaymentDate.ToString("dd MMM yyyy")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private decimal totalRevenueMonth;
    private decimal totalOutstanding;
    private int totalClaimsSubmittedMonth;
    private int totalClaimsApprovedMonth;
    private double claimApprovalRate;
    private decimal totalCollectedToday;

    private List<BillingInvoice>? recentInvoices;
    private List<Payment>? recentPayments;

    protected override async Task OnInitializedAsync()
    {
        PageTitle.SetTitle("Billing / Dashboard");
        await AuthStateProvider.GetAuthenticationStateAsync();
        var startOfMonth = new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1, 0, 0, 0, DateTimeKind.Utc);
        var startOfToday = DateTime.UtcNow.Date;

        totalRevenueMonth = await DbContext.Payments
            .Where(p => p.Status == "Success" && p.PaymentDate >= startOfMonth)
            .SumAsync(p => (decimal?)p.Amount) ?? 0m;

        totalOutstanding = await DbContext.BillingInvoices
            .Where(i => i.Status == "Finalized" || i.Status == "PartiallyPaid")
            .SumAsync(i => (decimal?)i.BalanceAmount) ?? 0m;

        totalClaimsSubmittedMonth = await DbContext.InsuranceClaims
            .Where(c => c.Status != "Draft" && c.CreatedAt >= startOfMonth)
            .CountAsync();

        totalClaimsApprovedMonth = await DbContext.InsuranceClaims
            .Where(c => (c.Status == "Approved" || c.Status == "PartiallyApproved") && c.CreatedAt >= startOfMonth)
            .CountAsync();

        claimApprovalRate = totalClaimsSubmittedMonth > 0
            ? ((double)totalClaimsApprovedMonth / totalClaimsSubmittedMonth) * 100
            : 0.0;

        totalCollectedToday = await DbContext.Payments
            .Where(p => p.Status == "Success" && p.PaymentDate >= startOfToday)
            .SumAsync(p => (decimal?)p.Amount) ?? 0m;

        recentInvoices = await DbContext.BillingInvoices
            .Include(i => i.Patient)
            .OrderByDescending(i => i.InvoiceDate)
            .Take(10)
            .ToListAsync();

        recentPayments = await DbContext.Payments
            .Include(p => p.Patient)
            .Include(p => p.BillingInvoice)
            .OrderByDescending(p => p.PaymentDate)
            .Take(10)
            .ToListAsync();
    }

    private string GetInvoiceBadgeClass(string status) => status switch
    {
        "Draft" => "bg-secondary text-white",
        "Finalized" => "bg-primary text-white",
        "PartiallyPaid" => "bg-warning text-dark",
        "Paid" => "bg-success text-white",
        "Cancelled" => "bg-danger text-white",
        _ => "bg-light text-dark"
    };

    private string GetPaymentIconClass(string method) => method switch
    {
        "Cash" => "bi bi-cash-stack text-success",
        "UPI" => "bi bi-phone text-primary",
        "Card" => "bi bi-credit-card text-info",
        "Insurance" => "bi bi-shield-check text-warning",
        _ => "bi bi-wallet"
    };
}
