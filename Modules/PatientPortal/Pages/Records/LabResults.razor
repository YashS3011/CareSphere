@page "/patient/records/lab-results"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Lab_ViewReports)]
@inject IPatientPortalService PortalService
@inject AuthenticationStateProvider AuthStateProvider
@inject PageTitleService PageTitle
@rendermode InteractiveServer

<PageTitle>My Lab Results — Patient Portal</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-droplet"></i></div>
            <div>
                <h1 class="page-title">Lab Test Results</h1>
                <p class="page-subtitle">All laboratory test requisitions and their statuses.</p>
            </div>
        </div>
    </div>
</div>

@if (loading)
{
    <div class="d-flex justify-content-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
}
else if (!requisitions.Any())
{
    <div class="alert alert-info border-0 rounded-3"><i class="bi bi-info-circle me-2"></i>No lab orders found.</div>
}
else
{
    <div class="content-card">
        <div class="table-responsive">
            <table class="table table-hover data-table mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Order Date</th>
                        <th>Requisition #</th>
                        <th>Ordered By</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in requisitions)
                    {
                        <tr>
                            <td class="small text-muted">@r.OrderedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                            <td class="fw-semibold font-monospace small">@r.RequisitionNumber</td>
                            <td class="text-muted">Dr. @(r.OrderedByDoctor?.FullName ?? "—")</td>
                            <td>
                                <span class="badge @StatusBadge(r.Status)">@r.Status</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private List<LabRequisition> requisitions = new();

    protected override async Task OnInitializedAsync()
    {
        PageTitle.SetTitle("My Lab Results");
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var pidStr = auth.User.FindFirst(CareSphereClaimTypes.PatientId)?.Value;
        if (Guid.TryParse(pidStr, out var pid))
            requisitions = await PortalService.GetMyLabRequisitionsAsync(pid);
        loading = false;
    }

    private static string StatusBadge(string s) => s switch
    {
        "Reported" or "Verified" => "bg-success",
        "Ordered"                => "bg-warning text-dark",
        "Collected"              => "bg-info text-dark",
        _                        => "bg-secondary",
    };
}
