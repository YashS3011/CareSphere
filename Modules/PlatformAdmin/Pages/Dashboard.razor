@page "/platform-admin"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Platform_ManageHospitals)]
@inject IPlatformAdminService PlatformService
@inject NavigationManager Nav
@inject PageTitleService PageTitle
@rendermode InteractiveServer

<PageTitle>Platform Dashboard — CareSphere</PageTitle>

<div class="container-fluid py-4">
    <!-- Welcome Banner -->
    <div class="card border-0 rounded-4 shadow-sm text-white mb-4"
         style="background: linear-gradient(135deg, #1e3a5f 0%, #0d6efd 100%);">
        <div class="card-body p-4 p-md-5">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <span class="badge bg-white bg-opacity-20 text-white rounded-pill px-3 py-2 mb-3 fw-bold">
                        <i class="bi bi-cloud-fill me-1"></i> CareSphere Vendor Platform
                    </span>
                    <h1 class="display-6 fw-bold mb-2">Platform Administration</h1>
                    <p class="lead mb-0 text-white-50">Manage hospital clients, subscriptions, and system-wide settings.</p>
                </div>
                <div class="col-md-4 text-md-end mt-4 mt-md-0">
                    <div class="text-white-50 small mb-1"><i class="bi bi-clock-fill me-1"></i>Server Time</div>
                    <div class="fs-4 fw-bold font-monospace">@DateTime.Now.ToString("dd MMM yyyy")</div>
                </div>
            </div>
        </div>
    </div>

    @if (loading)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <!-- Stats Row -->
        <div class="row g-4 mb-4">
            <div class="col-sm-6 col-xl-3">
                <div class="stat-card stat-card-primary">
                    <div class="stat-icon"><i class="bi bi-hospital-fill"></i></div>
                    <div>
                        <div class="stat-value">@totalHospitals</div>
                        <div class="stat-label">Total Hospitals</div>
                    </div>
                    <a href="/platform-admin/hospitals" class="stretched-link"></a>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="stat-card stat-card-success">
                    <div class="stat-icon"><i class="bi bi-check-circle-fill"></i></div>
                    <div>
                        <div class="stat-value">@activeHospitals</div>
                        <div class="stat-label">Active Hospitals</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="stat-card stat-card-danger">
                    <div class="stat-icon"><i class="bi bi-lock-fill"></i></div>
                    <div>
                        <div class="stat-value">@frozenHospitals</div>
                        <div class="stat-label">Frozen Hospitals</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="stat-card stat-card-info">
                    <div class="stat-icon"><i class="bi bi-stars"></i></div>
                    <div>
                        <div class="stat-value">@enterpriseCount</div>
                        <div class="stat-label">Enterprise Clients</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="content-card mb-4">
            <div class="content-card-header">
                <h5 class="content-card-title"><i class="bi bi-lightning-fill text-warning me-2"></i>Quick Actions</h5>
            </div>
            <div class="content-card-body">
                <div class="d-flex flex-wrap gap-3">
                    <a href="/platform-admin/hospitals/create" class="btn btn-primary rounded-3 px-4">
                        <i class="bi bi-plus-circle-fill me-2"></i>Onboard New Hospital
                    </a>
                    <a href="/platform-admin/hospitals" class="btn btn-outline-primary rounded-3 px-4">
                        <i class="bi bi-hospital me-2"></i>View All Hospitals
                    </a>
                </div>
            </div>
        </div>

        <!-- Hospital Table Preview -->
        <div class="content-card">
            <div class="content-card-header">
                <h5 class="content-card-title"><i class="bi bi-hospital me-2"></i>Recent Hospitals</h5>
                <a href="/platform-admin/hospitals" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="content-card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover data-table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Hospital Name</th>
                                <th>City</th>
                                <th>Tier</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var h in hospitals.Take(5))
                            {
                                <tr>
                                    <td class="fw-semibold">@h.HospitalName</td>
                                    <td>@(h.City ?? "—")</td>
                                    <td><span class="badge bg-primary">@h.SubscriptionTier</span></td>
                                    <td>
                                        @if (h.IsActive)
                                        { <span class="badge bg-success">Active</span> }
                                        else
                                        { <span class="badge bg-danger">Frozen</span> }
                                    </td>
                                    <td>
                                        <a href="/platform-admin/hospitals/@h.TenantId" class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-arrow-right"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool loading = true;
    private List<CareSphere.Models.TenantSettings> hospitals = new();
    private int totalHospitals, activeHospitals, frozenHospitals, enterpriseCount;

    protected override async Task OnInitializedAsync()
    {
        PageTitle.SetTitle("Platform Dashboard");
        hospitals = await PlatformService.GetAllHospitalsAsync();
        totalHospitals    = hospitals.Count;
        activeHospitals   = hospitals.Count(h => h.IsActive);
        frozenHospitals   = hospitals.Count(h => !h.IsActive);
        enterpriseCount   = hospitals.Count(h => h.SubscriptionTier == "Enterprise");
        loading = false;
    }
}
