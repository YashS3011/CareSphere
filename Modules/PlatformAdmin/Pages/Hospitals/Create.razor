@page "/platform-admin/hospitals/create"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Platform_ManageHospitals)]
@inject IPlatformAdminService PlatformService
@inject NavigationManager Nav
@inject PageTitleService PageTitle
@rendermode InteractiveServer

<PageTitle>Onboard Hospital — CareSphere Platform</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-plus-circle-fill"></i></div>
            <div>
                <h1 class="page-title">Onboard New Hospital</h1>
                <p class="page-subtitle">Register a new hospital client. A default Hospital Admin account will be created automatically.</p>
            </div>
        </div>
        <div class="page-actions">
            <a href="/platform-admin/hospitals" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Back
            </a>
        </div>
    </div>
</div>

@if (success && createdTenant != null)
{
    <div class="alert alert-success border-0 rounded-4 shadow-sm mb-4">
        <h5 class="fw-bold"><i class="bi bi-check-circle-fill me-2"></i>Hospital Onboarded Successfully!</h5>
        <p class="mb-1">Hospital <strong>@createdTenant.HospitalName</strong> has been created.</p>
        <hr />
        <p class="mb-1 small">A default Hospital Admin account has been created:</p>
        <div class="row g-2 mt-1">
            <div class="col-md-6">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white fw-semibold">Email</span>
                    <input type="text" class="form-control font-monospace" value="@adminEmail" readonly />
                </div>
            </div>
            <div class="col-md-6">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white fw-semibold">Password</span>
                    <input type="text" class="form-control font-monospace" value="@adminPassword" readonly />
                </div>
            </div>
        </div>
        <p class="text-danger small mt-2 mb-0"><i class="bi bi-exclamation-triangle me-1"></i>Save these credentials now — they are shown only once.</p>
        <div class="mt-3">
            <a href="/platform-admin/hospitals/@createdTenant.TenantId" class="btn btn-sm btn-primary me-2">View Hospital</a>
            <a href="/platform-admin/hospitals/create" class="btn btn-sm btn-outline-secondary">Onboard Another</a>
        </div>
    </div>
}
else
{
    <div class="content-card">
        <div class="content-card-body">
            @if (!string.IsNullOrEmpty(errorMsg))
            {
                <div class="alert alert-danger"><i class="bi bi-x-circle me-1"></i>@errorMsg</div>
            }

            <div class="row g-4">
                <!-- Hospital Info -->
                <div class="col-12">
                    <h6 class="fw-bold text-primary mb-3"><i class="bi bi-hospital me-2"></i>Hospital Information</h6>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Hospital Name <span class="text-danger">*</span></label>
                    <input class="form-control" @bind="hospitalName" placeholder="e.g. City General Hospital" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Email</label>
                    <input class="form-control" type="email" @bind="email" placeholder="info@hospital.com" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Address Line</label>
                    <input class="form-control" @bind="addressLine1" placeholder="123 Hospital Rd" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">City</label>
                    <input class="form-control" @bind="city" placeholder="Mumbai" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">State</label>
                    <input class="form-control" @bind="state" placeholder="Maharashtra" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Phone</label>
                    <input class="form-control" @bind="phone" placeholder="+91 9999999999" />
                </div>

                <!-- Subscription -->
                <div class="col-12 mt-2">
                    <h6 class="fw-bold text-primary mb-3"><i class="bi bi-stars me-2"></i>Subscription</h6>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Subscription Tier <span class="text-danger">*</span></label>
                    <select class="form-select" @bind="subscriptionTier">
                        <option value="Free">Free</option>
                        <option value="Basic">Basic</option>
                        <option value="Pro">Pro</option>
                        <option value="Enterprise">Enterprise</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Max Users Allowed</label>
                    <input class="form-control" type="number" @bind="maxUsers" min="1" max="10000" />
                </div>

                <div class="col-12 mt-2">
                    <button class="btn btn-primary px-5" @onclick="DoCreate" disabled="@saving">
                        @if (saving)
                        { <span class="spinner-border spinner-border-sm me-2"></span> }
                        <i class="bi bi-check-circle-fill me-1"></i>Onboard Hospital
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string hospitalName = "";
    private string email = "";
    private string addressLine1 = "";
    private string city = "";
    private string state = "";
    private string phone = "";
    private string subscriptionTier = "Basic";
    private int maxUsers = 100;

    private bool saving;
    private bool success;
    private string? errorMsg;
    private CareSphere.Models.TenantSettings? createdTenant;
    private string adminEmail = "";
    private string adminPassword = "";

    protected override void OnInitialized() => PageTitle.SetTitle("Platform / Onboard Hospital");

    private async Task DoCreate()
    {
        if (string.IsNullOrWhiteSpace(hospitalName))
        {
            errorMsg = "Hospital Name is required.";
            return;
        }
        saving = true;
        errorMsg = null;
        try
        {
            var result = await PlatformService.CreateHospitalAsync(
                hospitalName, city, state, phone, email, subscriptionTier, maxUsers, addressLine1);
            createdTenant = result.Tenant;
            adminEmail    = result.AdminEmail;
            adminPassword = result.AdminPassword;
            success = true;
        }
        catch (Exception ex)
        {
            errorMsg = ex.Message;
        }
        finally { saving = false; }
    }
}
