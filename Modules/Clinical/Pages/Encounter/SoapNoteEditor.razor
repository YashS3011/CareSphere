@using CareSphere.Models
@using CareSphere.Modules.Clinical.Services
@using System.IO
@using System.Linq
@inject ISoapNoteService SoapNoteService
@inject IEncounterService EncounterService
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@rendermode InteractiveServer

<div class="card mb-4">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-journal-text me-2"></i>SOAP Note</h5>
        @if (soapNote != null)
        {
            @if (soapNote.Status == "Final")
            {
                <span class="badge bg-success"><i class="bi bi-lock-fill me-1"></i>Finalized</span>
            }
            else
            {
                <span class="badge bg-warning text-dark">Draft</span>
            }
        }
    </div>
    <div class="card-body">
        @if (isLoading)
        {
            <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary me-2" role="status"><span class="visually-hidden">Loading...</span></div><span class="text-muted">Loading SOAP note...</span></div>
        }
        else
        {
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Subjective</label>
                    <small class="text-muted d-block mb-1">Patient's history, symptoms, and complaints</small>
                    <textarea class="form-control" rows="5" @bind="subjective" disabled="@isFinalized"
                              placeholder="What the patient reports..."></textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Objective</label>
                    <small class="text-muted d-block mb-1">Clinical findings, vitals, exam results</small>
                    <textarea class="form-control" rows="5" @bind="objective" disabled="@isFinalized"
                              placeholder="Examination findings, vitals, lab results..."></textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Assessment</label>
                    <small class="text-muted d-block mb-1">Diagnosis or differential diagnoses</small>
                    <textarea class="form-control" rows="5" @bind="assessment" disabled="@isFinalized"
                              placeholder="Diagnosis, differential diagnosis..."></textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Plan</label>
                    <small class="text-muted d-block mb-1">Treatment plan, follow-up, referrals</small>
                    <textarea class="form-control" rows="5" @bind="plan" disabled="@isFinalized"
                              placeholder="Treatment plan, medications, follow-up..."></textarea>
                </div>
            </div>

            <hr class="my-4" />

            <div class="row g-3 mb-4">
                <div class="col-md-12">
                    <h6 class="fw-bold mb-2"><i class="bi bi-tag-fill me-2 text-primary"></i>ICD-10 Diagnoses</h6>
                </div>
                
                @if (!isFinalized)
                {
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Search ICD-10 Code or Description</label>
                        <div class="position-relative">
                            <input class="form-control" type="text" placeholder="Type to search (e.g. Hypertension)..."
                                   @bind="searchIcdQuery" @oninput="SearchIcd" />
                            @if (filteredIcdCodes.Any())
                            {
                                <ul class="list-group position-absolute w-100 shadow" style="z-index: 1000; max-height: 200px; overflow-y: auto;">
                                    @foreach (var item in filteredIcdCodes)
                                    {
                                        <button type="button" class="list-group-item list-group-item-action text-start"
                                                @onclick="() => SelectIcdItem(item)">
                                            <strong>@item.Code</strong> &mdash; @item.Description
                                        </button>
                                    }
                                </ul>
                            }
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Type</label>
                        <select class="form-select" @bind="selectedDiagnosisType">
                            <option value="Primary">Primary</option>
                            <option value="Secondary">Secondary</option>
                        </select>
                    </div>

                    <div class="col-md-3 d-flex align-items-end">
                        <button type="button" class="btn btn-primary w-100" @onclick="AddDiagnosis"
                                disabled="@(string.IsNullOrEmpty(selectedIcdCode))">
                            <i class="bi bi-plus-circle me-1"></i> Add Diagnosis
                        </button>
                    </div>
                }

                <div class="col-md-12 mt-3">
                    <label class="form-label fw-semibold text-muted">Current tagged diagnoses:</label>
                    @if (diagnoses == null || !diagnoses.Any())
                    {
                        <div class="text-muted small p-2 border rounded bg-light">No diagnoses coded for this encounter yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 15%">ICD Code</th>
                                        <th>Description</th>
                                        <th style="width: 20%">Type</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var diag in diagnoses)
                                    {
                                        <tr>
                                            <td><span class="badge bg-dark">@diag.IcdCode</span></td>
                                            <td>@diag.IcdDescription</td>
                                            <td>
                                                @if (diag.DiagnosisType == "Primary")
                                                {
                                                    <span class="badge bg-danger">Primary</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Secondary</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            @if (!isFinalized)
            {
                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-outline-primary" @onclick="SaveDraft" disabled="@isSaving">
                        @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-save me-1"></i> Save Draft
                    </button>
                    <button class="btn btn-success" @onclick="ConfirmFinalize" disabled="@isSaving">
                        <i class="bi bi-check-circle me-1"></i> Finalize
                    </button>
                </div>
            }

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="alert alert-success mt-3 py-2">@statusMessage</div>
            }
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3 py-2">@errorMessage</div>
            }

            @if (soapNote != null && isFinalized && soapNote.FinalizedAt.HasValue)
            {
                <div class="alert alert-info mt-3 py-2">
                    <i class="bi bi-info-circle me-1"></i>
                    Finalized on @soapNote.FinalizedAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                </div>
            }
        }
    </div>
</div>

@if (showFinalizeConfirm)
{
    <div class="modal fade show" style="display: block; background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Finalization</h5>
                    <button type="button" class="btn-close" @onclick="() => showFinalizeConfirm = false"></button>
                </div>
                <div class="modal-body">
                    <p><strong>Are you sure you want to finalize this SOAP note?</strong></p>
                    <p class="text-danger">Once finalized, the note cannot be edited.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showFinalizeConfirm = false">Cancel</button>
                    <button type="button" class="btn btn-success" @onclick="Finalize">Finalize</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid EncounterId { get; set; }

    [Parameter]
    public Guid DoctorId { get; set; }

    private SoapNote? soapNote;
    private string subjective = string.Empty;
    private string objective = string.Empty;
    private string assessment = string.Empty;
    private string plan = string.Empty;

    private bool isLoading = true;
    private bool isSaving = false;
    private bool isFinalized = false;
    private bool showFinalizeConfirm = false;
    private string statusMessage = string.Empty;
    private string errorMessage = string.Empty;

    private List<IcdCodeItem> icdCodes = new();
    private List<IcdCodeItem> filteredIcdCodes = new();
    private string searchIcdQuery = "";
    private List<EncounterDiagnosis> diagnoses = new();

    private string selectedIcdCode = "";
    private string selectedIcdDescription = "";
    private string selectedDiagnosisType = "Secondary";

    public class IcdCodeItem
    {
        public string Code { get; set; } = "";
        public string Description { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadSoapNote();
        await LoadIcdCodes();
        await LoadDiagnoses();
        isLoading = false;
    }

    private async Task LoadSoapNote()
    {
        soapNote = await SoapNoteService.GetSoapNoteByEncounterAsync(EncounterId);
        if (soapNote != null)
        {
            subjective = soapNote.Subjective;
            objective = soapNote.Objective;
            assessment = soapNote.Assessment;
            plan = soapNote.Plan;
            isFinalized = soapNote.Status == "Final";
        }
    }

    private async Task LoadIcdCodes()
    {
        try
        {
            var path = Path.Combine(Env.WebRootPath, "data", "icd10.csv");
            if (File.Exists(path))
            {
                var lines = await File.ReadAllLinesAsync(path);
                foreach (var line in lines.Skip(1))
                {
                    if (string.IsNullOrWhiteSpace(line)) continue;
                    var parts = line.Split(',', 2);
                    if (parts.Length == 2)
                    {
                        icdCodes.Add(new IcdCodeItem
                        {
                            Code = parts[0].Trim().Trim('"'),
                            Description = parts[1].Trim().Trim('"')
                        });
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading ICD-10 codes: {ex.Message}");
        }
    }

    private async Task LoadDiagnoses()
    {
        diagnoses = await EncounterService.GetDiagnosesAsync(EncounterId);
    }

    private void SearchIcd(ChangeEventArgs e)
    {
        searchIcdQuery = e.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(searchIcdQuery))
        {
            filteredIcdCodes.Clear();
        }
        else
        {
            var lowerQuery = searchIcdQuery.ToLower();
            filteredIcdCodes = icdCodes
                .Where(c => c.Code.ToLower().Contains(lowerQuery) || c.Description.ToLower().Contains(lowerQuery))
                .Take(10)
                .ToList();
        }
    }

    private void SelectIcdItem(IcdCodeItem item)
    {
        selectedIcdCode = item.Code;
        selectedIcdDescription = item.Description;
        searchIcdQuery = $"{item.Code} - {item.Description}";
        filteredIcdCodes.Clear();
    }

    private async Task AddDiagnosis()
    {
        if (string.IsNullOrEmpty(selectedIcdCode))
            return;

        try
        {
            errorMessage = string.Empty;
            await EncounterService.AddDiagnosisAsync(EncounterId, selectedIcdCode, selectedIcdDescription, selectedDiagnosisType);
            await LoadDiagnoses();
            selectedIcdCode = "";
            selectedIcdDescription = "";
            searchIcdQuery = "";
            selectedDiagnosisType = "Secondary";
        }
        catch (Exception ex)
        {
            errorMessage = $"Error adding diagnosis: {ex.Message}";
        }
    }

    private async Task SaveDraft()
    {
        try
        {
            isSaving = true;
            errorMessage = string.Empty;

            if (soapNote == null)
            {
                // Create new
                soapNote = await SoapNoteService.CreateSoapNoteAsync(new SoapNote
                {
                    EncounterId = EncounterId,
                    CreatedByDoctorId = DoctorId,
                    Subjective = subjective,
                    Objective = objective,
                    Assessment = assessment,
                    Plan = plan
                });
            }
            else
            {
                // Update existing
                soapNote.Subjective = subjective;
                soapNote.Objective = objective;
                soapNote.Assessment = assessment;
                soapNote.Plan = plan;
                soapNote = await SoapNoteService.UpdateSoapNoteAsync(soapNote);
            }

            statusMessage = "Draft saved successfully.";
            _ = Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => { statusMessage = string.Empty; StateHasChanged(); }));
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ConfirmFinalize()
    {
        showFinalizeConfirm = true;
    }

    private async Task Finalize()
    {
        try
        {
            showFinalizeConfirm = false;
            isSaving = true;
            errorMessage = string.Empty;

            // Save draft first if not yet created
            if (soapNote == null)
            {
                await SaveDraft();
            }

            if (soapNote != null)
            {
                await SoapNoteService.FinalizeSoapNoteAsync(soapNote.Id);
                await LoadSoapNote();
                statusMessage = "SOAP note finalized successfully.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }
}
