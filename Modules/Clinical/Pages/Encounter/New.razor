@page "/encounter/new"
@attribute [Authorize(Policy = PolicyNames.Permission_Encounters_Create)]
@using CareSphere.Models
@inject IEncounterService EncounterService
@inject IPatientReadModel PatientReadModel
@inject IDoctorService DoctorService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>New Encounter - CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-plus-square-fill"></i></div>
            <div>
                <h1 class="page-title">Start New Encounter</h1>
                <p class="page-subtitle">Create a new clinical encounter for a patient</p>
            </div>
        </div>
        <div class="page-actions">
            <a href="/encounters" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Back to Encounters</a>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <EditForm Model="@formModel" FormName="createEncounter" OnValidSubmit="ProcessValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary class="alert alert-danger" />

            <!-- Patient Search -->
            <div class="content-card mb-4">
                <div class="content-card-header">
                    <h5 class="content-card-title"><i class="bi bi-person-search me-2"></i>Find Patient</h5>
                </div>
                <div class="content-card-body">
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" placeholder="Search by name or MRN..." @bind="patientSearchQuery" @bind:event="oninput" />
                        <button type="button" class="btn btn-primary" @onclick="SearchPatients"><i class="bi bi-search me-1"></i> Search</button>
                    </div>
                    @if (foundPatients != null)
                    {
                        <div class="patient-search-results mb-3">
                            @foreach (var p in foundPatients)
                            {
                                <button type="button" class="patient-result-item @(formModel.PatientIdAsString == p.Id.ToString() ? "selected" : "")" @onclick="() => SelectPatient(p)">
                                    <div>
                                        <div class="fw-semibold">@p.FullName</div>
                                        <div class="text-muted small">MRN: @p.MRN</div>
                                    </div>
                                    <i class="bi @(formModel.PatientIdAsString == p.Id.ToString() ? "bi-check-circle-fill text-success" : "bi-circle")"></i>
                                </button>
                            }
                        </div>
                    }
                    @if (selectedPatientSummary != null)
                    {
                        <div class="selected-patient-banner">
                            <i class="bi bi-person-check-fill me-2"></i>
                            Selected: <strong>@selectedPatientSummary.FullName</strong> &mdash; <span class="text-muted">MRN: @selectedPatientSummary.MRN</span>
                        </div>
                    }
                    <InputText type="hidden" @bind-Value="formModel.PatientIdAsString" />
                    <ValidationMessage For="@(() => formModel.PatientIdAsString)" />
                </div>
            </div>

            <!-- Encounter Details -->
            <div class="content-card mb-4">
                <div class="content-card-header">
                    <h5 class="content-card-title"><i class="bi bi-clipboard2 me-2"></i>Encounter Details</h5>
                </div>
                <div class="content-card-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Doctor <span class="text-danger">*</span></label>
                            <InputSelect class="form-select" @bind-Value="formModel.DoctorIdAsString">
                                <option value="">Select a Doctor</option>
                                @if (doctors != null)
                                {
                                    @foreach (var d in doctors)
                                    {
                                        <option value="@d.Id">Dr. @d.FirstName @d.LastName (@d.Specialization)</option>
                                    }
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => formModel.DoctorIdAsString)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Encounter Type <span class="text-danger">*</span></label>
                            <InputSelect class="form-select" @bind-Value="formModel.EncounterType">
                                <option value="">Select Type</option>
                                <option value="OPD">OPD</option>
                                <option value="IPD">IPD</option>
                                <option value="Emergency">Emergency</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => formModel.EncounterType)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Date <span class="text-danger">*</span></label>
                            <InputDate class="form-control" @bind-Value="formModel.AdmissionDate" />
                            <ValidationMessage For="@(() => formModel.AdmissionDate)" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Chief Complaint</label>
                            <InputTextArea class="form-control" @bind-Value="formModel.ChiefComplaint" rows="3" placeholder="Describe the patient's chief complaint..." />
                        </div>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>@errorMessage</div>
            }

            <div class="form-actions">
                <button type="submit" class="btn btn-primary btn-lg" disabled="@(isSubmitting || string.IsNullOrEmpty(formModel.PatientIdAsString))">
                    @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-2"></span> }
                    <i class="bi bi-clipboard2-plus me-1"></i> Start Encounter
                </button>
                <a href="/encounters" class="btn btn-outline-secondary btn-lg">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    public EncounterFormModel formModel { get; set; } = new() { AdmissionDate = DateTime.Now };

    public class EncounterFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please select a patient by searching above.")]
        public string PatientIdAsString { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please select a doctor.")]
        public string DoctorIdAsString { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Encounter type is required.")]
        public string EncounterType { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required]
        public DateTime AdmissionDate { get; set; }
        public string? ChiefComplaint { get; set; }
    }

    private string patientSearchQuery = string.Empty;
    private IEnumerable<PatientSummary>? foundPatients;
    private PatientSummary? selectedPatientSummary;
    private List<Doctor>? doctors;
    private bool isSubmitting = false;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync() { doctors = await DoctorService.GetActiveDoctorsAsync(); }

    private async Task SearchPatients()
    {
        if (!string.IsNullOrWhiteSpace(patientSearchQuery))
            foundPatients = await PatientReadModel.SearchAsync(patientSearchQuery, Guid.Empty);
    }

    private void SelectPatient(PatientSummary summary) { selectedPatientSummary = summary; formModel.PatientIdAsString = summary.Id.ToString(); }

    private async Task ProcessValidSubmit()
    {
        try
        {
            isSubmitting = true; errorMessage = string.Empty;
            var encounter = new Encounter
            {
                PatientId = Guid.Parse(formModel.PatientIdAsString),
                DoctorId = Guid.Parse(formModel.DoctorIdAsString),
                EncounterType = formModel.EncounterType,
                AdmissionDate = formModel.AdmissionDate.ToUniversalTime(),
                ChiefComplaint = formModel.ChiefComplaint,
                Status = "Planned"
            };
            var created = await EncounterService.CreateEncounterAsync(encounter);
            NavigationManager.NavigateTo($"/encounter/view/{created.Id}");
        }
        catch (Microsoft.AspNetCore.Components.NavigationException) { throw; }
        catch (Exception ex) { errorMessage = $"Error creating encounter: {ex.Message}"; isSubmitting = false; }
    }
}
