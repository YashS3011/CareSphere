@page "/encounter/view/{id:guid}"
@attribute [Authorize(Policy = PolicyNames.Permission_Encounters_View)]
@using CareSphere.Models
@inject IEncounterService EncounterService
@rendermode InteractiveServer

<PageTitle>Encounter Workspace - CareSphere</PageTitle>

@if (encounter == null && !isNotFound)
{
    <div class="loading-state"><div class="spinner-border text-primary" role="status"></div><p class="mt-3 text-muted">Loading encounter workspace...</p></div>
}
else if (isNotFound)
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>Encounter not found.</div>
    <a href="/encounters" class="btn btn-primary">Back to Encounters</a>
}
else if (encounter != null)
{
    <div class="page-header">
        <div class="page-header-content">
            <div class="page-title-group">
                <div class="page-icon"><i class="bi bi-clipboard2-pulse-fill"></i></div>
                <div>
                    <h1 class="page-title">Clinical Workspace</h1>
                    <p class="page-subtitle">
                        @encounter.Patient.FirstName @encounter.Patient.LastName
                        <span class="badge bg-secondary-subtle text-secondary ms-1">@encounter.Patient.Mrn</span>
                        &mdash;
                        @switch (encounter.Status)
                        {
                            case "Planned": <span class="badge bg-warning-subtle text-warning ms-1">Planned</span> break;
                            case "InProgress": <span class="badge bg-success-subtle text-success ms-1">In Progress</span> break;
                            case "Completed": <span class="badge bg-secondary-subtle text-secondary ms-1">Completed</span> break;
                        }
                    </p>
                </div>
            </div>
            <div class="page-actions">
                @if (encounter.Status == "Planned")
                {
                    <button class="btn btn-success" @onclick='() => UpdateStatus("InProgress")'><i class="bi bi-play-fill me-1"></i> Start Encounter</button>
                }
                @if (encounter.Status == "InProgress")
                {
                    <a href="/laboratory/requisitions/create?patientId=@encounter.PatientId&encounterId=@encounter.Id" class="btn btn-outline-primary me-2"><i class="bi bi-flask me-1"></i> Order Lab</a>
                    <div class="d-inline-block me-2">
                        <select class="form-select w-auto d-inline-block" @bind="selectedDisposition">
                            <option value="">Select Disposition...</option>
                            <option value="OPD">OPD</option>
                            <option value="IPD">IPD</option>
                            <option value="Emergency">Emergency</option>
                        </select>
                    </div>
                    <button class="btn btn-warning" @onclick="CompleteEncounter" disabled="@(string.IsNullOrEmpty(selectedDisposition))"><i class="bi bi-check-circle me-1"></i> Complete</button>
                }
                <a href="/encounters" class="btn btn-outline-secondary ms-2"><i class="bi bi-arrow-left me-1"></i> Back</a>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>@statusMessage</div>
    }

    <!-- Encounter Summary -->
    <div class="content-card mb-4">
        <div class="content-card-header">
            <h5 class="content-card-title"><i class="bi bi-info-circle me-2"></i>Encounter Summary</h5>
        </div>
        <div class="content-card-body">
            <div class="row g-3">
                <div class="col-md-2">
                    <div class="detail-item">
                        <span class="detail-label">Patient</span>
                        <span class="detail-value fw-semibold">@encounter.Patient.FirstName @encounter.Patient.LastName</span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="detail-item">
                        <span class="detail-label">Doctor</span>
                        <span class="detail-value">Dr. @encounter.Doctor.FirstName @encounter.Doctor.LastName<br/><small class="text-muted">@encounter.Doctor.Specialization</small></span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="detail-item">
                        <span class="detail-label">Type</span>
                        <span class="detail-value">
                            @switch (encounter.EncounterType)
                            {
                                case "OPD": <span class="badge bg-info-subtle text-info">OPD</span> break;
                                case "IPD": <span class="badge bg-primary-subtle text-primary">IPD</span> break;
                                case "Emergency": <span class="badge bg-danger-subtle text-danger">Emergency</span> break;
                                default: <span class="badge bg-secondary-subtle text-secondary">@encounter.EncounterType</span> break;
                            }
                        </span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="detail-item">
                        <span class="detail-label">Disposition</span>
                        <span class="detail-value">
                            @if (!string.IsNullOrEmpty(encounter.DischargeDisposition))
                            {
                                @switch (encounter.DischargeDisposition)
                                {
                                    case "OPD": <span class="badge bg-info-subtle text-info">OPD</span> break;
                                    case "IPD": <span class="badge bg-primary-subtle text-primary">IPD</span> break;
                                    case "Emergency": <span class="badge bg-danger-subtle text-danger">Emergency</span> break;
                                    default: <span class="badge bg-secondary-subtle text-secondary">@encounter.DischargeDisposition</span> break;
                                }
                            }
                            else
                            {
                                <span class="text-muted">&mdash;</span>
                            }
                        </span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="detail-item">
                        <span class="detail-label">Date</span>
                        <span class="detail-value">@encounter.AdmissionDate.ToLocalTime().ToString("dd MMM yyyy")</span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="detail-item">
                        <span class="detail-label">Chief Complaint</span>
                        <span class="detail-value">@(string.IsNullOrEmpty(encounter.ChiefComplaint) ? "—" : encounter.ChiefComplaint)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <SoapNoteEditor EncounterId="encounter.Id" DoctorId="encounter.DoctorId" />
    <PrescriptionPanel EncounterId="encounter.Id" PatientId="encounter.PatientId" DoctorId="encounter.DoctorId" />
    <TeleConsultPanel EncounterId="encounter.Id" DoctorId="encounter.DoctorId" PatientId="encounter.PatientId" />
}

@code {
    [Parameter] public Guid id { get; set; }
    private Encounter? encounter;
    private bool isNotFound = false;
    private string statusMessage = string.Empty;
    private string selectedDisposition = "";

    protected override async Task OnInitializedAsync()
    {
        encounter = await EncounterService.GetEncounterByIdAsync(id);
        if (encounter == null) isNotFound = true;
    }

    private async Task UpdateStatus(string newStatus)
    {
        try
        {
            await EncounterService.UpdateEncounterStatusAsync(id, newStatus);
            encounter = await EncounterService.GetEncounterByIdAsync(id);
            statusMessage = $"Encounter status updated to {newStatus}.";
            _ = Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => { statusMessage = string.Empty; StateHasChanged(); }));
        }
        catch (Exception ex) { statusMessage = $"Error: {ex.Message}"; }
    }

    private async Task CompleteEncounter()
    {
        if (string.IsNullOrEmpty(selectedDisposition))
        {
            statusMessage = "Error: Please select a disposition.";
            return;
        }

        try
        {
            await EncounterService.SetDispositionAsync(id, selectedDisposition);
            await EncounterService.UpdateEncounterStatusAsync(id, "Completed");
            encounter = await EncounterService.GetEncounterByIdAsync(id);
            statusMessage = "Encounter completed successfully.";
            _ = Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => { statusMessage = string.Empty; StateHasChanged(); }));
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
        }
    }
}
