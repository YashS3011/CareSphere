@page "/encounters"
@attribute [Authorize(Policy = PolicyNames.Permission_Encounters_View)]
@inject IEncounterService EncounterService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Encounters - CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-clipboard2-pulse-fill"></i></div>
            <div>
                <h1 class="page-title">Clinical Encounters</h1>
                <p class="page-subtitle">View and manage all patient clinical encounters</p>
            </div>
        </div>
        <div class="page-actions">
            <a href="/encounter/new" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> New Encounter</a>
        </div>
    </div>
</div>

<div class="content-card mb-4">
    <div class="content-card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control" placeholder="Search by patient name or MRN..."
                           @bind="SearchTerm" @bind:event="oninput" @onkeyup="HandleSearch" />
                    <button class="btn btn-primary" type="button" @onclick="LoadEncounters">Search</button>
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="StatusFilter" @bind:after="LoadEncounters">
                    <option value="">All Statuses</option>
                    <option value="Planned">Planned</option>
                    <option value="InProgress">In Progress</option>
                    <option value="Completed">Completed</option>
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="TypeFilter" @bind:after="LoadEncounters">
                    <option value="">All Types</option>
                    <option value="OPD">OPD</option>
                    <option value="IPD">IPD</option>
                    <option value="Emergency">Emergency</option>
                </select>
            </div>
        </div>
    </div>
</div>

@if (encounters == null)
{
    <div class="loading-state"><div class="spinner-border text-primary" role="status"></div><p class="mt-3 text-muted">Loading encounters...</p></div>
}
else if (!encounters.Any())
{
    <div class="empty-state-card">
        <i class="bi bi-clipboard2"></i>
        <h5>No encounters found</h5>
        <p>No clinical encounters match your search. Try adjusting filters or start a new encounter.</p>
    </div>
}
else
{
    <div class="content-card">
        <div class="content-card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover data-table mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Type</th>
                            <th>Chief Complaint</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var enc in encounters)
                        {
                            <tr>
                                <td class="text-muted small">@enc.AdmissionDate.ToLocalTime().ToString("dd MMM yyyy")</td>
                                <td>
                                    <div class="fw-semibold">@enc.Patient.FirstName @enc.Patient.LastName</div>
                                    <div class="text-muted small">@enc.Patient.Mrn</div>
                                </td>
                                <td>Dr. @enc.Doctor.FirstName @enc.Doctor.LastName</td>
                                <td>
                                    @switch (enc.EncounterType)
                                    {
                                        case "OPD": <span class="badge bg-info-subtle text-info">OPD</span> break;
                                        case "IPD": <span class="badge bg-primary-subtle text-primary">IPD</span> break;
                                        case "Emergency": <span class="badge bg-danger-subtle text-danger">Emergency</span> break;
                                        default: <span class="badge bg-secondary-subtle text-secondary">@enc.EncounterType</span> break;
                                    }
                                </td>
                                <td class="text-muted small">
                                    @(string.IsNullOrEmpty(enc.ChiefComplaint) ? "—" : (enc.ChiefComplaint.Length > 50 ? enc.ChiefComplaint.Substring(0, 50) + "…" : enc.ChiefComplaint))
                                </td>
                                <td>
                                    @switch (enc.Status)
                                    {
                                        case "Planned": <span class="badge bg-warning-subtle text-warning">Planned</span> break;
                                        case "InProgress": <span class="badge bg-success-subtle text-success">In Progress</span> break;
                                        case "Completed": <span class="badge bg-secondary-subtle text-secondary">Completed</span> break;
                                        default: <span class="badge bg-secondary-subtle text-secondary">@enc.Status</span> break;
                                    }
                                </td>
                                <td class="text-end">
                                    <a href="/encounter/view/@enc.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-clipboard2-pulse me-1"></i> Open
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private List<Encounter>? encounters;
    private string SearchTerm { get; set; } = string.Empty;
    private string StatusFilter { get; set; } = string.Empty;
    private string TypeFilter { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync() { await LoadEncounters(); }

    private async Task HandleSearch(KeyboardEventArgs e) { if (e.Key == "Enter") await LoadEncounters(); }
    private async Task LoadEncounters() { encounters = await EncounterService.GetAllEncountersAsync(SearchTerm, StatusFilter, TypeFilter); }
}
