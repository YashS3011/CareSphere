@page "/encounters"
@attribute [Authorize(Policy = PolicyNames.Permission_Encounters_View)]
@inject IEncounterService EncounterService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Encounters - CareSphere</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Clinical Encounters</h2>
    <a href="/encounter/new" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> New Encounter</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="input-group">
                    <input type="text" class="form-control" placeholder="Search by patient name or MRN..." @bind="SearchTerm" @bind:event="oninput" @onkeyup="HandleSearch" />
                    <button class="btn btn-outline-secondary" type="button" @onclick="LoadEncounters">Search</button>
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="StatusFilter" @bind:after="LoadEncounters">
                    <option value="">All Statuses</option>
                    <option value="Planned">Planned</option>
                    <option value="InProgress">In Progress</option>
                    <option value="Completed">Completed</option>
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="TypeFilter" @bind:after="LoadEncounters">
                    <option value="">All Types</option>
                    <option value="OPD">OPD</option>
                    <option value="IPD">IPD</option>
                    <option value="Emergency">Emergency</option>
                </select>
            </div>
        </div>
    </div>
</div>

@if (encounters == null)
{
    <p><em>Loading...</em></p>
}
else if (!encounters.Any())
{
    <div class="alert alert-info">No encounters found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Patient</th>
                    <th>Doctor</th>
                    <th>Type</th>
                    <th>Chief Complaint</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var enc in encounters)
                {
                    <tr>
                        <td>@enc.AdmissionDate.ToLocalTime().ToString("dd MMM yyyy")</td>
                        <td>
                            @enc.Patient.FirstName @enc.Patient.LastName
                            <br /><small class="text-muted">@enc.Patient.Mrn</small>
                        </td>
                        <td>Dr. @enc.Doctor.FirstName @enc.Doctor.LastName</td>
                        <td>
                            @switch (enc.EncounterType)
                            {
                                case "OPD":
                                    <span class="badge bg-info">OPD</span>
                                    break;
                                case "IPD":
                                    <span class="badge bg-primary">IPD</span>
                                    break;
                                case "Emergency":
                                    <span class="badge bg-danger">Emergency</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary">@enc.EncounterType</span>
                                    break;
                            }
                        </td>
                        <td>@(string.IsNullOrEmpty(enc.ChiefComplaint) ? "—" : (enc.ChiefComplaint.Length > 50 ? enc.ChiefComplaint.Substring(0, 50) + "..." : enc.ChiefComplaint))</td>
                        <td>
                            @switch (enc.Status)
                            {
                                case "Planned":
                                    <span class="badge bg-warning text-dark">Planned</span>
                                    break;
                                case "InProgress":
                                    <span class="badge bg-success">In Progress</span>
                                    break;
                                case "Completed":
                                    <span class="badge bg-secondary">Completed</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary">@enc.Status</span>
                                    break;
                            }
                        </td>
                        <td>
                            <a href="/encounter/view/@enc.Id" class="btn btn-sm btn-info" title="Open Workspace"><i class="bi bi-clipboard2-pulse me-1"></i> Open</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Encounter>? encounters;
    private string SearchTerm { get; set; } = string.Empty;
    private string StatusFilter { get; set; } = string.Empty;
    private string TypeFilter { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadEncounters();
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LoadEncounters();
        }
    }

    private async Task LoadEncounters()
    {
        encounters = await EncounterService.GetAllEncountersAsync(SearchTerm, StatusFilter, TypeFilter);
    }
}
