@page "/doctor/queue"
@page "/doctor/queue/{DoctorId:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "Queue_Access")]
@using CareSphere.Models
@inject IServiceScopeFactory ScopeFactory
@inject IDoctorService DoctorService
@inject IPatientReadModel PatientReadModel
@inject ITenantContext TenantContext
@inject NavigationManager NavigationManager
@inject CareSphere.Infrastructure.RealTimeEventBus EventBus
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Patient Queue - CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-clock-history"></i></div>
            <div>
                <h1 class="page-title">Patient Queue</h1>
                @if (doctor != null)
                {
                    <p class="page-subtitle">
                        Dr. @doctor.FirstName @doctor.LastName &mdash; @doctor.Specialization
                        <button class="btn btn-link btn-sm p-0 ms-2 text-decoration-none" @onclick="SwitchDoctor">
                            <i class="bi bi-arrow-left-right me-1"></i>Switch Doctor
                        </button>
                    </p>
                }
                else
                {
                    <p class="page-subtitle">Select a doctor to view their live patient queue</p>
                }
            </div>
        </div>
        @if (doctor != null)
        {
            <div class="page-actions">
                <button class="btn btn-success" @onclick="ShowAddToQueue"><i class="bi bi-plus-circle me-1"></i> Add to Queue</button>
                <button class="btn btn-outline-secondary" @onclick="RefreshQueue"><i class="bi bi-arrow-clockwise me-1"></i> Refresh</button>
            </div>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@statusMessage
    </div>
}

@if (doctor == null)
{
    <div class="row justify-content-center mt-4">
        <div class="col-md-5">
            <div class="content-card">
                <div class="content-card-header">
                    <h5 class="content-card-title"><i class="bi bi-person-badge me-2"></i>Select Doctor</h5>
                </div>
                <div class="content-card-body">
                    <p class="text-muted mb-3">Select a doctor to view their active patient queue.</p>
                    <label class="form-label fw-semibold">Active Doctors</label>
                    <select class="form-select" @onchange="OnDoctorChanged">
                        <option value="">-- Choose a Doctor --</option>
                        @if (activeDoctors != null)
                        {
                            @foreach (var d in activeDoctors)
                            {
                                <option value="@d.Id">Dr. @d.FirstName @d.LastName (@d.Specialization)</option>
                            }
                        }
                    </select>
                    @if (activeDoctors != null && !activeDoctors.Any())
                    {
                        <div class="alert alert-warning mt-3 mb-0"><i class="bi bi-exclamation-triangle me-1"></i> No active doctors found.</div>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
    @if (queueEntries == null)
    {
        <div class="loading-state"><div class="spinner-border text-primary" role="status"></div><p class="mt-3 text-muted">Loading queue...</p></div>
    }
    else if (!queueEntries.Any())
    {
        <div class="empty-state-card">
            <i class="bi bi-clock"></i>
            <h5>Queue is empty</h5>
            <p>No patients are currently in the queue. Add a patient to get started.</p>
            <button class="btn btn-success mt-2" @onclick="ShowAddToQueue"><i class="bi bi-plus-circle me-1"></i> Add to Queue</button>
        </div>
    }
    else
    {
        <div class="content-card">
            <div class="content-card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle data-table mb-0">
                        <thead>
                            <tr>
                                <th style="width:50px">#</th>
                                <th>Patient</th>
                                <th>MRN</th>
                                <th>Triage</th>
                                <th>Status</th>
                                <th>Checked In</th>
                                <th>Est. Wait</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in queueEntries)
                            {
                                <tr>
                                    <td><span class="queue-position">@entry.QueuePosition</span></td>
                                    <td><span class="fw-semibold">@entry.Patient.FirstName @entry.Patient.LastName</span></td>
                                    <td><span class="badge bg-secondary-subtle text-secondary">@entry.Patient.Mrn</span></td>
                                    <td>
                                        @switch (entry.TriagePriority)
                                        {
                                            case "Emergency": <span class="badge bg-danger"><i class="bi bi-exclamation-triangle me-1"></i>Emergency</span> break;
                                            case "Urgent": <span class="badge bg-warning text-dark">Urgent</span> break;
                                            case "Routine": <span class="badge bg-info text-dark">Routine</span> break;
                                            default: <span class="badge bg-secondary">@entry.TriagePriority</span> break;
                                        }
                                    </td>
                                    <td>
                                        @switch (entry.Status)
                                        {
                                            case "Waiting": <span class="badge bg-warning-subtle text-warning">Waiting</span> break;
                                            case "InConsultation": <span class="badge bg-primary-subtle text-primary">In Consultation</span> break;
                                            default: <span class="badge bg-secondary-subtle text-secondary">@entry.Status</span> break;
                                        }
                                    </td>
                                    <td class="text-muted">@entry.CheckedInAt.ToLocalTime().ToString("HH:mm")</td>
                                    <td>
                                        @if (entry.Status == "Waiting" && entry.EstimatedWaitMinutes.HasValue)
                                        { <span class="text-muted small">~@entry.EstimatedWaitMinutes min</span> }
                                        else { <span class="text-muted">—</span> }
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            @if (entry.Status == "Waiting")
                                            {
                                                <button class="btn btn-outline-primary" @onclick="@(() => UpdateStatus(entry.Id, "InConsultation"))"><i class="bi bi-play-fill me-1"></i>Start</button>
                                                <button class="btn btn-outline-secondary" @onclick="@(() => UpdateStatus(entry.Id, "NoShow"))"><i class="bi bi-x-circle me-1"></i>No Show</button>
                                            }
                                            @if (entry.Status == "InConsultation")
                                            {
                                                <button class="btn btn-outline-success" @onclick="@(() => UpdateStatus(entry.Id, "Completed"))"><i class="bi bi-check-circle me-1"></i>Complete</button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@if (showAddForm)
{
    <div class="modal fade show" style="display:block;background:rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title"><i class="bi bi-plus-circle me-2 text-success"></i>Add Patient to Queue</h5>
                    <button type="button" class="btn-close" @onclick="() => showAddForm = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Select Patient <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="selectedPatientId">
                            <option value="">Select a Patient</option>
                            @if (patients != null)
                            {
                                @foreach (var p in patients)
                                {
                                    <option value="@p.Id">@p.FullName (MRN: @p.MRN)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Triage Priority <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="selectedTriagePriority">
                            <option value="Routine">Routine</option>
                            <option value="Urgent">Urgent</option>
                            <option value="Emergency">Emergency</option>
                        </select>
                    </div>
                    <div class="mb-0">
                        <label class="form-label fw-semibold">Notes <span class="text-muted small">(optional)</span></label>
                        <textarea class="form-control" @bind="queueNotes" rows="2" placeholder="Brief reason for visit..."></textarea>
                    </div>
                    @if (!string.IsNullOrEmpty(addError)) { <div class="alert alert-danger mt-3 mb-0">@addError</div> }
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary" @onclick="() => showAddForm = false">Cancel</button>
                    <button type="button" class="btn btn-success" @onclick="AddPatientToQueue"><i class="bi bi-plus-circle me-1"></i> Add to Queue</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid DoctorId { get; set; }

    private Doctor? doctor;
    private List<DoctorQueueEntry>? queueEntries;
    private IEnumerable<PatientSummary>? patients;
    private List<Doctor>? activeDoctors;
    private bool _isDisposed = false;
    private bool _isSubscribed = false;
    private bool showAddForm = false;
    private string selectedPatientId = string.Empty;
    private string selectedTriagePriority = "Routine";
    private string queueNotes = string.Empty;
    private string addError = string.Empty;
    private string statusMessage = string.Empty;

    protected override async Task OnInitializedAsync() { activeDoctors = await DoctorService.GetActiveDoctorsAsync(); }

    protected override async Task OnParametersSetAsync()
    {
        if (DoctorId != Guid.Empty)
        {
            doctor = await DoctorService.GetDoctorByIdAsync(DoctorId);
            if (doctor != null)
            {
                await RefreshQueue();
                if (!_isSubscribed)
                {
                    EventBus.Subscribe("QueueUpdated", async payload => 
                    {
                        if (_isDisposed) return;
                        if (Guid.TryParse(payload, out var updatedDocId) && updatedDocId == DoctorId)
                        {
                            await InvokeAsync(async () => { 
                                if (_isDisposed) return; 
                                await RefreshQueue(); 
                                StateHasChanged(); 
                            });
                        }
                    });
                    _isSubscribed = true;
                }
            }
            else { queueEntries = null; }
        }
        else { doctor = null; queueEntries = null; }
    }

    private async Task RefreshQueue()
    {
        if (_isDisposed) return;
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var scopedTenant = scope.ServiceProvider.GetRequiredService<ITenantContext>();
            scopedTenant.SetTenantId(TenantContext.TenantId);
            var queueService = scope.ServiceProvider.GetRequiredService<IQueueService>();
            queueEntries = await queueService.GetQueueForDoctorAsync(DoctorId);
        }
        catch (Exception ex) { if (!_isDisposed) Console.WriteLine($"[QueueIndex] Error refreshing queue: {ex.Message}"); }
    }

    private async Task ShowAddToQueue()
    {
        patients = await PatientReadModel.SearchAsync("", TenantContext.TenantId);
        selectedPatientId = string.Empty; selectedTriagePriority = "Routine"; queueNotes = string.Empty; addError = string.Empty;
        showAddForm = true;
    }

    private async Task AddPatientToQueue()
    {
        try
        {
            if (string.IsNullOrEmpty(selectedPatientId)) { addError = "Please select a patient."; return; }
            var entry = new DoctorQueueEntry { DoctorId = DoctorId, PatientId = Guid.Parse(selectedPatientId), TriagePriority = selectedTriagePriority, Notes = string.IsNullOrWhiteSpace(queueNotes) ? null : queueNotes, TenantId = doctor?.TenantId ?? Guid.Empty };
            using var scope = ScopeFactory.CreateScope();
            var scopedTenant = scope.ServiceProvider.GetRequiredService<ITenantContext>();
            scopedTenant.SetTenantId(TenantContext.TenantId);
            var queueService = scope.ServiceProvider.GetRequiredService<IQueueService>();
            await queueService.AddToQueueAsync(entry);
            showAddForm = false; statusMessage = "Patient added to queue.";
            await RefreshQueue();
            _ = Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => { statusMessage = string.Empty; StateHasChanged(); }));
        }
        catch (Exception ex) { addError = ex.Message; }
    }

    private async Task UpdateStatus(Guid entryId, string newStatus)
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var scopedTenant = scope.ServiceProvider.GetRequiredService<ITenantContext>();
            scopedTenant.SetTenantId(TenantContext.TenantId);
            var queueService = scope.ServiceProvider.GetRequiredService<IQueueService>();
            await queueService.UpdateStatusAsync(entryId, newStatus);
            statusMessage = $"Status updated to {newStatus}.";
            await RefreshQueue();
            _ = Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => { statusMessage = string.Empty; StateHasChanged(); }));
        }
        catch (Exception ex) { statusMessage = $"Error: {ex.Message}"; }
    }

    private void OnDoctorChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        if (!string.IsNullOrEmpty(val) && Guid.TryParse(val, out var selectedId)) NavigationManager.NavigateTo($"/doctor/queue/{selectedId}");
    }

    private void SwitchDoctor() { NavigationManager.NavigateTo("/doctor/queue"); }

    public void Dispose() { _isDisposed = true; }
}
