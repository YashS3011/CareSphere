@page "/doctor/queue"
@page "/doctor/queue/{DoctorId:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Encounters_View)]
@using CareSphere.Models
@inject IQueueService QueueService
@inject IDoctorService DoctorService
@inject IPatientReadModel PatientReadModel
@inject NavigationManager NavigationManager
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Patient Queue - CareSphere</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2><i class="bi bi-clock me-2"></i>Patient Queue</h2>
        @if (doctor != null)
        {
            <p class="text-muted mb-0">
                Dr. @doctor.FirstName @doctor.LastName — @doctor.Specialization
                <button class="btn btn-sm btn-link text-decoration-none ms-2 p-0 align-baseline" @onclick="SwitchDoctor">
                    <i class="bi bi-arrow-left-right me-1"></i>Switch Doctor
                </button>
            </p>
        }
    </div>
    @if (doctor != null)
    {
        <div>
            <button class="btn btn-success" @onclick="ShowAddToQueue"><i class="bi bi-plus-circle me-1"></i> Add to Queue</button>
            <button class="btn btn-outline-secondary ms-2" @onclick="RefreshQueue"><i class="bi bi-arrow-clockwise me-1"></i> Refresh</button>
        </div>
    }
</div>

@if (doctor == null)
{
    <div class="card shadow-sm mx-auto mt-5" style="max-width: 500px;">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-person-badge me-2"></i>Select Doctor Queue</h5>
        </div>
        <div class="card-body p-4">
            <p class="text-muted">Please select a doctor to view their active patient queue and check in new patients.</p>
            <div class="mb-3">
                <label class="form-label fw-bold">Active Doctors</label>
                <select class="form-select" @onchange="OnDoctorChanged">
                    <option value="">-- Choose a Doctor --</option>
                    @if (activeDoctors != null)
                    {
                        @foreach (var d in activeDoctors)
                        {
                            <option value="@d.Id">Dr. @d.FirstName @d.LastName (@d.Specialization)</option>
                        }
                    }
                </select>
            </div>
            @if (activeDoctors != null && !activeDoctors.Any())
            {
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle me-1"></i> No active doctors found. Please add doctors first.
                </div>
            }
        </div>
    </div>
}
else
{
    @if (queueEntries == null)
    {
        <p><em>Loading queue...</em></p>
    }
    else if (!queueEntries.Any())
    {
        <div class="alert alert-info"><i class="bi bi-info-circle me-1"></i> No patients in queue.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Patient Name</th>
                        <th>MRN</th>
                        <th>Status</th>
                        <th>Checked In</th>
                        <th>Est. Wait (min)</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in queueEntries)
                    {
                        <tr>
                            <td><strong>@entry.QueuePosition</strong></td>
                            <td>@entry.Patient.FirstName @entry.Patient.LastName</td>
                            <td><span class="badge bg-secondary">@entry.Patient.Mrn</span></td>
                            <td>
                                @switch (entry.Status)
                                {
                                    case "Waiting":
                                        <span class="badge bg-warning text-dark">Waiting</span>
                                        break;
                                    case "InConsultation":
                                        <span class="badge bg-primary">In Consultation</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">@entry.Status</span>
                                        break;
                                }
                            </td>
                            <td>@entry.CheckedInAt.ToLocalTime().ToString("HH:mm")</td>
                            <td>
                                @if (entry.Status == "Waiting" && entry.EstimatedWaitMinutes.HasValue)
                                {
                                    <span>~@entry.EstimatedWaitMinutes min</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    @if (entry.Status == "Waiting")
                                    {
                                        <button class="btn btn-primary" @onclick="@(() => UpdateStatus(entry.Id, "InConsultation"))" title="Start Consultation">
                                            <i class="bi bi-play-fill"></i> Start
                                        </button>
                                        <button class="btn btn-secondary" @onclick="@(() => UpdateStatus(entry.Id, "NoShow"))" title="Mark No Show">
                                            <i class="bi bi-x-circle"></i> No Show
                                        </button>
                                    }
                                    @if (entry.Status == "InConsultation")
                                    {
                                        <button class="btn btn-success" @onclick="@(() => UpdateStatus(entry.Id, "Completed"))" title="Complete">
                                            <i class="bi bi-check-circle"></i> Complete
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@if (showAddForm)
{
    <div class="modal fade show" style="display: block; background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Patient to Queue</h5>
                    <button type="button" class="btn-close" @onclick="() => showAddForm = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Select Patient *</label>
                        <select class="form-select" @bind="selectedPatientId">
                            <option value="">Select a Patient</option>
                            @if (patients != null)
                            {
                                @foreach (var p in patients)
                                {
                                    <option value="@p.Id">@p.FullName (MRN: @p.MRN)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notes (Optional)</label>
                        <textarea class="form-control" @bind="queueNotes" rows="2"></textarea>
                    </div>
                    @if (!string.IsNullOrEmpty(addError))
                    {
                        <div class="alert alert-danger">@addError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => showAddForm = false">Cancel</button>
                    <button type="button" class="btn btn-success" @onclick="AddPatientToQueue">Add to Queue</button>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert alert-success mt-3">@statusMessage</div>
}

@code {
    [Parameter]
    public Guid DoctorId { get; set; }

    private Doctor? doctor;
    private List<DoctorQueueEntry>? queueEntries;
    private IEnumerable<PatientSummary>? patients;
    private List<Doctor>? activeDoctors;
    private System.Threading.Timer? refreshTimer;

    private bool showAddForm = false;
    private string selectedPatientId = string.Empty;
    private string queueNotes = string.Empty;
    private string addError = string.Empty;
    private string statusMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        activeDoctors = await DoctorService.GetActiveDoctorsAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (DoctorId != Guid.Empty)
        {
            doctor = await DoctorService.GetDoctorByIdAsync(DoctorId);
            if (doctor != null)
            {
                await RefreshQueue();

                if (refreshTimer == null)
                {
                    // Auto-refresh every 30 seconds
                    refreshTimer = new System.Threading.Timer(async _ =>
                    {
                        await InvokeAsync(async () =>
                        {
                            await RefreshQueue();
                            StateHasChanged();
                        });
                    }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
                }
            }
            else
            {
                refreshTimer?.Dispose();
                refreshTimer = null;
                queueEntries = null;
            }
        }
        else
        {
            doctor = null;
            refreshTimer?.Dispose();
            refreshTimer = null;
            queueEntries = null;
        }
    }

    private async Task RefreshQueue()
    {
        queueEntries = await QueueService.GetQueueForDoctorAsync(DoctorId);
    }

    private async Task ShowAddToQueue()
    {
        patients = await PatientReadModel.SearchAsync("", Guid.Empty);
        selectedPatientId = string.Empty;
        queueNotes = string.Empty;
        addError = string.Empty;
        showAddForm = true;
    }

    private async Task AddPatientToQueue()
    {
        try
        {
            if (string.IsNullOrEmpty(selectedPatientId))
            {
                addError = "Please select a patient.";
                return;
            }

            var entry = new DoctorQueueEntry
            {
                DoctorId = DoctorId,
                PatientId = Guid.Parse(selectedPatientId),
                Notes = string.IsNullOrWhiteSpace(queueNotes) ? null : queueNotes,
                TenantId = doctor?.TenantId ?? Guid.Empty
            };

            await QueueService.AddToQueueAsync(entry);
            showAddForm = false;
            statusMessage = "Patient added to queue.";
            await RefreshQueue();

            // Clear status message after a brief period
            _ = Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => { statusMessage = string.Empty; StateHasChanged(); }));
        }
        catch (Exception ex)
        {
            addError = ex.Message;
        }
    }

    private async Task UpdateStatus(Guid entryId, string newStatus)
    {
        try
        {
            await QueueService.UpdateStatusAsync(entryId, newStatus);
            statusMessage = $"Status updated to {newStatus}.";
            await RefreshQueue();

            _ = Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => { statusMessage = string.Empty; StateHasChanged(); }));
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
        }
    }

    private void OnDoctorChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        if (!string.IsNullOrEmpty(val) && Guid.TryParse(val, out var selectedId))
        {
            NavigationManager.NavigateTo($"/doctor/queue/{selectedId}");
        }
    }

    private void SwitchDoctor()
    {
        NavigationManager.NavigateTo("/doctor/queue");
    }

    public void Dispose()
    {
        refreshTimer?.Dispose();
    }
}
