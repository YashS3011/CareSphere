@page "/teleconsult/join/{Id:guid}"
@attribute [Authorize(Policy = PolicyNames.Permission_Encounters_View)]
@using CareSphere.Data
@using Microsoft.EntityFrameworkCore
@inject IServiceScopeFactory ScopeFactory
@inject ITenantContext TenantContext
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Teleconsult Room - CareSphere</PageTitle>

<div class="container-fluid bg-dark text-white min-vh-100 p-4 d-flex flex-column justify-content-between rounded-3 shadow" style="margin-top: -1.5rem;">
    @* Top Header Bar *@
    <div class="d-flex justify-content-between align-items-center mb-3 py-2 border-bottom border-secondary">
        <div class="d-flex align-items-center gap-2">
            <span class="badge bg-danger p-2 animate-pulse"><i class="bi bi-broadcast me-1"></i> LIVE</span>
            <h4 class="mb-0 fw-semibold text-white">Teleconsult Meeting</h4>
        </div>
        <div class="text-muted small">
            Session ID: <span class="text-light text-monospace">@Id.ToString().Substring(0, 8)...</span>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex flex-column justify-content-center align-items-center my-auto" style="height: 50vh;">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Entering Teleconsult Room...</span>
            </div>
            <p class="mt-3 text-muted">Securing media feed and connecting...</p>
        </div>
    }
    else if (session == null)
    {
        <div class="alert alert-danger my-auto text-center" style="max-width: 500px; margin: 0 auto;">
            <i class="bi bi-exclamation-triangle-fill display-4 mb-3"></i>
            <h5>Session Not Found</h5>
            <p class="mb-3">This teleconsultation session could not be found or has expired.</p>
            <a href="/teleconsult" class="btn btn-outline-light">Return to List</a>
        </div>
    }
    else
    {
        @* Call Video Grid *@
        <div class="row flex-grow-1 g-3 my-2 align-items-stretch" style="min-height: 55vh;">
            @* Remote Feed (Patient) *@
            <div class="col-md-8 d-flex">
                <div class="card bg-secondary bg-opacity-25 border border-secondary text-white w-100 position-relative rounded-3 overflow-hidden shadow">
                    @if (isPatientVideoEnabled)
                    {
                        @* Beautiful CSS abstract simulated camera view *@
                        <div class="w-100 h-100 d-flex justify-content-center align-items-center bg-gradient" style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);">
                            <div class="text-center">
                                <i class="bi bi-person-video display-1 text-white opacity-25"></i>
                                <h5 class="mt-3 text-white">Patient Video Stream</h5>
                                <span class="badge bg-success bg-opacity-75">HD Connected</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="w-100 h-100 d-flex justify-content-center align-items-center bg-black bg-opacity-50">
                            <div class="text-center text-muted">
                                <i class="bi bi-camera-video-off display-2 mb-3"></i>
                                <h5>Patient has turned off camera</h5>
                            </div>
                        </div>
                    }
                    @* Overlay Label *@
                    <div class="position-absolute bottom-0 start-0 m-3 px-3 py-1 bg-dark bg-opacity-75 text-white rounded-pill d-flex align-items-center gap-2" style="font-size: 0.85rem;">
                        <i class="bi bi-person-fill text-info"></i>
                        <span>Patient: @session.Patient.FirstName @session.Patient.LastName</span>
                        @if (!isPatientMuted)
                        {
                            <i class="bi bi-mic-fill text-success"></i>
                        }
                        else
                        {
                            <i class="bi bi-mic-mute-fill text-danger"></i>
                        }
                    </div>
                </div>
            </div>

            @* Local Feed (Doctor/Self) *@
            <div class="col-md-4 d-flex">
                <div class="card bg-secondary bg-opacity-25 border border-secondary text-white w-100 position-relative rounded-3 overflow-hidden shadow">
                    @if (isLocalVideoEnabled)
                    {
                        <div class="w-100 h-100 d-flex justify-content-center align-items-center bg-gradient" style="background: linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%);">
                            <div class="text-center">
                                <i class="bi bi-person-badge-fill display-2 text-white opacity-25"></i>
                                <h6 class="mt-2 text-white">Your Feed</h6>
                                <span class="badge bg-success bg-opacity-75">Transmitting</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="w-100 h-100 d-flex justify-content-center align-items-center bg-black bg-opacity-50">
                            <div class="text-center text-muted">
                                <i class="bi bi-camera-video-off display-4 mb-2"></i>
                                <h6>Camera disabled</h6>
                            </div>
                        </div>
                    }
                    @* Overlay Label *@
                    <div class="position-absolute bottom-0 start-0 m-3 px-3 py-1 bg-dark bg-opacity-75 text-white rounded-pill d-flex align-items-center gap-2" style="font-size: 0.85rem;">
                        <i class="bi bi-person-badge-fill text-primary"></i>
                        <span>Dr. @session.Doctor.LastName (You)</span>
                        @if (!isLocalMuted)
                        {
                            <i class="bi bi-mic-fill text-success"></i>
                        }
                        else
                        {
                            <i class="bi bi-mic-mute-fill text-danger"></i>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Control Bar *@
        <div class="d-flex justify-content-between align-items-center py-3 border-top border-secondary mt-3">
            @* Left: status *@
            <div class="d-flex align-items-center gap-3">
                <span class="d-inline-flex align-items-center gap-2 text-success" style="font-size: 0.9rem;">
                    <span class="spinner-grow spinner-grow-sm text-success" role="status"></span>
                    Encrypting Call Link (SRTP)
                </span>
            </div>

            @* Center: Actions *@
            <div class="d-flex justify-content-center align-items-center gap-3">
                <button class="btn btn-lg rounded-circle @(isLocalMuted ? "btn-danger" : "btn-outline-light")" style="width: 54px; height: 54px; padding: 0;" @onclick="ToggleMute" title="@(isLocalMuted ? "Unmute Mic" : "Mute Mic")">
                    @if (isLocalMuted)
                    {
                        <i class="bi bi-mic-mute fs-4"></i>
                    }
                    else
                    {
                        <i class="bi bi-mic fs-4"></i>
                    }
                </button>
                <button class="btn btn-lg rounded-circle @(isLocalVideoEnabled ? "btn-outline-light" : "btn-danger")" style="width: 54px; height: 54px; padding: 0;" @onclick="ToggleVideo" title="@(isLocalVideoEnabled ? "Disable Camera" : "Enable Camera")">
                    @if (isLocalVideoEnabled)
                    {
                        <i class="bi bi-camera-video fs-4"></i>
                    }
                    else
                    {
                        <i class="bi bi-camera-video-off fs-4"></i>
                    }
                </button>
                <button class="btn btn-lg rounded-circle @(isScreenSharing ? "btn-success" : "btn-outline-light")" style="width: 54px; height: 54px; padding: 0;" @onclick="ToggleScreenShare" title="@(isScreenSharing ? "Stop Screen Share" : "Share Screen")">
                    <i class="bi bi-display fs-4"></i>
                </button>
            </div>

            @* Right: Leave button *@
            <div>
                <button class="btn btn-danger btn-lg px-4" @onclick="LeaveRoom">
                    <i class="bi bi-telephone-x me-2"></i>Leave Room
                </button>
            </div>
        </div>
    }
</div>

<style>
    .animate-pulse {
        animation: pulse-animation 2s infinite;
    }
    @@keyframes pulse-animation {
        0% { opacity: 1; }
        50% { opacity: 0.5; }
        100% { opacity: 1; }
    }
</style>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private TeleConsultSession? session;
    private bool isLoading = true;

    private bool isLocalMuted = false;
    private bool isLocalVideoEnabled = true;
    private bool isScreenSharing = false;

    private bool isPatientMuted = false;
    private bool isPatientVideoEnabled = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            using (var scope = ScopeFactory.CreateScope())
            {
                var scopedTenant = scope.ServiceProvider.GetRequiredService<ITenantContext>();
                scopedTenant.SetTenantId(TenantContext.TenantId);

                var dbContext = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
                session = await dbContext.TeleConsultSessions
                    .Include(s => s.Patient)
                    .Include(s => s.Doctor)
                    .FirstOrDefaultAsync(s => s.Id == Id);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[TeleConsultJoin] Error connecting: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleMute()
    {
        isLocalMuted = !isLocalMuted;
    }

    private void ToggleVideo()
    {
        isLocalVideoEnabled = !isLocalVideoEnabled;
    }

    private void ToggleScreenShare()
    {
        isScreenSharing = !isScreenSharing;
    }

    private void LeaveRoom()
    {
        NavigationManager.NavigateTo("/teleconsult");
    }
}
