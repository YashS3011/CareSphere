@page "/laboratory/requisitions"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Lab_ViewReports)]
@using CareSphere.Models
@using CareSphere.Modules.Laboratory.Services
@using CareSphere.Modules.Shared.Services
@using CareSphere.Data
@using Microsoft.EntityFrameworkCore
@inject ILabRequisitionService RequisitionService
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Lab Requisitions - CareSphere</PageTitle>

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 text-dark fw-bold"><i class="bi bi-receipt me-2 text-primary"></i>Lab Requisitions</h1>
            <p class="text-muted mb-0">Track and manage laboratory orders, specimen logs, processing states, and report releases</p>
        </div>
        <a href="/laboratory/requisitions/create" class="btn btn-primary shadow-sm"><i class="bi bi-plus-lg me-1"></i> Create Requisition</a>
    </div>

    <!-- Search and Filter Panel -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control border-start-0" placeholder="Search by requisition number, patient name, or MRN..." @bind="searchQuery" @bind:after="ApplyFilters" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="selectedPriority" @bind:after="ApplyFilters">
                        <option value="">All Priorities</option>
                        <option value="Stat">Stat</option>
                        <option value="Urgent">Urgent</option>
                        <option value="Routine">Routine</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="selectedStatus" @bind:after="ApplyFilters">
                        <option value="">All Statuses</option>
                        <option value="Ordered">Ordered</option>
                        <option value="SampleCollected">SampleCollected</option>
                        <option value="Processing">Processing</option>
                        <option value="Completed">Completed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    @if (loading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading requisitions...</span>
            </div>
        </div>
    }
    else
    {
        <!-- Requisitions Table -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="table-responsive">
                <table class="table align-middle mb-0 small">
                    <thead class="table-light fs-8 text-uppercase text-muted">
                        <tr>
                            <th>Requisition #</th>
                            <th>Patient Name</th>
                            <th>MRN</th>
                            <th>Doctor Name</th>
                            <th>Ordered At</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th class="text-center">Tests Count</th>
                            <th class="text-center" style="width: 15%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (requisitions == null || !requisitions.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center py-4 text-muted">No lab requisitions found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var req in requisitions)
                            {
                                <tr>
                                    <td class="fw-bold text-dark font-monospace text-uppercase">@req.RequisitionNumber</td>
                                    <td>@req.Patient.FirstName @req.Patient.LastName</td>
                                    <td class="font-monospace text-muted">@req.Patient.Mrn</td>
                                    <td>Dr. @req.OrderedByDoctor.FirstName @req.OrderedByDoctor.LastName</td>
                                    <td class="text-muted">@req.OrderedAt.ToLocalTime().ToString("g")</td>
                                    <td>
                                        <span class="badge @GetPriorityBadgeClass(req.Priority)">
                                            @req.Priority
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @GetStatusBadgeClass(req.Status)">
                                            @req.Status
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark border">@req.Items.Count</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex gap-1 justify-content-center">
                                            <a href="/laboratory/requisitions/@req.Id" class="btn btn-xs btn-outline-primary py-0 px-2 fs-8">View</a>
                                            @if (req.Status == "Ordered")
                                            {
                                                <button class="btn btn-xs btn-outline-danger py-0 px-2 fs-8" @onclick="() => CancelRequisition(req.Id)">Cancel</button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private bool loading = true;
    private string searchQuery = string.Empty;
    private string selectedPriority = string.Empty;
    private string selectedStatus = string.Empty;

    private List<LabRequisition>? requisitions;

    private Guid currentTenantId = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadRequisitions();
    }

    private async Task LoadRequisitions()
    {
        try
        {
            loading = true;

            var query = DbContext.LabRequisitions
                .Include(r => r.Patient)
                .Include(r => r.OrderedByDoctor)
                .Include(r => r.Items)
                .Where(r => r.TenantId == currentTenantId);

            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var lowerSearch = searchQuery.ToLower();
                query = query.Where(r => r.RequisitionNumber.ToLower().Contains(lowerSearch) ||
                                         (r.Patient.FirstName + " " + r.Patient.LastName).ToLower().Contains(lowerSearch) ||
                                         r.Patient.Mrn.ToLower().Contains(lowerSearch));
            }

            if (!string.IsNullOrWhiteSpace(selectedPriority))
            {
                query = query.Where(r => r.Priority == selectedPriority);
            }

            if (!string.IsNullOrWhiteSpace(selectedStatus))
            {
                query = query.Where(r => r.Status == selectedStatus);
            }

            requisitions = await query
                .OrderByDescending(r => r.OrderedAt)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading requisitions: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task ApplyFilters()
    {
        await LoadRequisitions();
    }

    private async Task CancelRequisition(Guid id)
    {
        try
        {
            await RequisitionService.CancelRequisitionAsync(id);
            await LoadRequisitions();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cancelling requisition: {ex.Message}");
        }
    }

    private string GetPriorityBadgeClass(string priority)
    {
        return priority switch
        {
            "Stat" => "bg-danger text-white",
            "Urgent" => "bg-warning text-dark",
            _ => "bg-success text-white"
        };
    }

    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Completed" => "bg-success text-white",
            "Cancelled" => "bg-secondary text-white",
            "Processing" => "bg-info text-info-emphasis",
            "SampleCollected" => "bg-warning text-dark",
            _ => "bg-primary text-white"
        };
    }
}

<style>
    .fs-8 { font-size: 0.8rem !important; }
    .btn-xs {
        padding: 0.15rem 0.4rem;
        font-size: 0.75rem;
        line-height: 1.5;
        border-radius: 0.2rem;
    }
</style>
