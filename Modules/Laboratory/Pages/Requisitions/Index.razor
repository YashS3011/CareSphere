@page "/laboratory/requisitions"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Lab_ViewReports)]
@using CareSphere.Models
@using CareSphere.Modules.Laboratory.Services
@using CareSphere.Modules.Shared.Services
@using CareSphere.Data
@using Microsoft.EntityFrameworkCore
@inject ILabRequisitionService RequisitionService
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@inject CareSphere.Authorization.TabIsolatedAuthenticationStateProvider AuthStateProvider
@inject ITenantContext TenantContext
@rendermode InteractiveServer

<PageTitle>Lab Requisitions - CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-receipt"></i></div>
            <div>
                <h1 class="page-title">Lab Requisitions</h1>
                <p class="page-subtitle">Track and manage laboratory orders, specimen logs, and processing states</p>
            </div>
        </div>
        <div class="page-actions">
            <a href="/laboratory/requisitions/create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Create Requisition</a>
        </div>
    </div>
</div>

<div class="content-card mb-4">
    <div class="content-card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control" placeholder="Search by req#, patient name, or MRN..." @bind="searchQuery" @bind:after="ApplyFilters" />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="selectedPriority" @bind:after="ApplyFilters">
                    <option value="">All Priorities</option>
                    <option value="Stat">Stat</option>
                    <option value="Urgent">Urgent</option>
                    <option value="Routine">Routine</option>
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="selectedStatus" @bind:after="ApplyFilters">
                    <option value="">All Statuses</option>
                    <option value="Ordered">Ordered</option>
                    <option value="SampleCollected">Sample Collected</option>
                    <option value="Processing">Processing</option>
                    <option value="Completed">Completed</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
            </div>
        </div>
    </div>
</div>

@if (loading)
{
    <div class="loading-state"><div class="spinner-border text-primary" role="status"></div><p class="mt-3 text-muted">Loading requisitions...</p></div>
}
else
{
    <div class="content-card">
        <div class="content-card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover data-table mb-0 small">
                    <thead>
                        <tr>
                            <th>Requisition #</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Ordered At</th>
                            <th>Priority</th>
                            <th>Tests</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (requisitions == null || !requisitions.Any())
                        {
                            <tr><td colspan="8" class="text-center py-4 text-muted">No lab requisitions found.</td></tr>
                        }
                        else
                        {
                            @foreach (var req in requisitions)
                            {
                                <tr>
                                    <td class="fw-semibold font-monospace text-uppercase">@req.RequisitionNumber</td>
                                    <td>
                                        <div>@req.Patient.FirstName @req.Patient.LastName</div>
                                        <div class="text-muted small">@req.Patient.Mrn</div>
                                    </td>
                                    <td>Dr. @req.OrderedByDoctor.FirstName @req.OrderedByDoctor.LastName</td>
                                    <td class="text-muted small">@req.OrderedAt.ToLocalTime().ToString("g")</td>
                                    <td><span class="badge @GetPriorityBadgeClass(req.Priority)">@req.Priority</span></td>
                                    <td><span class="badge bg-secondary-subtle text-secondary">@req.Items.Count</span></td>
                                    <td><span class="badge @GetStatusBadgeClass(req.Status)">@req.Status</span></td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a href="/laboratory/requisitions/@req.Id" class="btn btn-outline-primary">View</a>
                                            @if (req.Status == "Ordered") { <button class="btn btn-outline-danger" @onclick="() => CancelRequisition(req.Id)">Cancel</button> }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private string searchQuery = string.Empty;
    private string selectedPriority = string.Empty;
    private string selectedStatus = string.Empty;
    private List<LabRequisition>? requisitions;
    private Guid currentTenantId = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentTenantId = TenantContext.TenantId;
        await LoadRequisitions();
    }

    private async Task LoadRequisitions()
    {
        try
        {
            loading = true;
            var query = DbContext.LabRequisitions.Include(r => r.Patient).Include(r => r.OrderedByDoctor).Include(r => r.Items).Where(r => r.TenantId == currentTenantId);
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var lowerSearch = searchQuery.ToLower();
                query = query.Where(r => r.RequisitionNumber.ToLower().Contains(lowerSearch) || (r.Patient.FirstName + " " + r.Patient.LastName).ToLower().Contains(lowerSearch) || r.Patient.Mrn.ToLower().Contains(lowerSearch));
            }
            if (!string.IsNullOrWhiteSpace(selectedPriority)) query = query.Where(r => r.Priority == selectedPriority);
            if (!string.IsNullOrWhiteSpace(selectedStatus)) query = query.Where(r => r.Status == selectedStatus);
            requisitions = await query.OrderByDescending(r => r.OrderedAt).ToListAsync();
        }
        catch (Exception ex) { Console.WriteLine($"Error loading requisitions: {ex.Message}"); }
        finally { loading = false; }
    }

    private async Task ApplyFilters() { await LoadRequisitions(); }

    private async Task CancelRequisition(Guid id)
    {
        try { await RequisitionService.CancelRequisitionAsync(id); await LoadRequisitions(); }
        catch (Exception ex) { Console.WriteLine($"Error cancelling requisition: {ex.Message}"); }
    }

    private string GetPriorityBadgeClass(string priority) => priority switch
    {
        "Stat" => "bg-danger-subtle text-danger",
        "Urgent" => "bg-warning-subtle text-warning",
        _ => "bg-success-subtle text-success"
    };

    private string GetStatusBadgeClass(string status) => status switch
    {
        "Completed" => "bg-success-subtle text-success",
        "Cancelled" => "bg-secondary-subtle text-secondary",
        "Processing" => "bg-info-subtle text-info",
        "SampleCollected" => "bg-warning-subtle text-warning",
        _ => "bg-primary-subtle text-primary"
    };
}
