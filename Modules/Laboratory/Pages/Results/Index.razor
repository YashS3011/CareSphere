@page "/laboratory/results"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Lab_EnterResults)]
@using CareSphere.Models
@using CareSphere.Modules.Laboratory.Services
@using CareSphere.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@inject CareSphere.Authorization.TabIsolatedAuthenticationStateProvider AuthStateProvider
@inject ITenantContext TenantContext
@rendermode InteractiveServer

<PageTitle>Result Entry Queue - CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-clipboard-data-fill"></i></div>
            <div>
                <h1 class="page-title">Result Entry Queue</h1>
                <p class="page-subtitle">Lab requisition items pending result entry and verification</p>
            </div>
        </div>
    </div>
</div>

<div class="content-card mb-4">
    <div class="content-card-body">
        <div class="row align-items-center">
            <div class="col-md-4">
                <label class="form-label text-muted small fw-semibold mb-1">Filter by Status</label>
                <select class="form-select" @bind="selectedStatus" @bind:after="LoadQueue">
                    <option value="Pending">Pending (Processing / Sample Collected)</option>
                    <option value="Completed">Completed / Verified</option>
                    <option value="All">All Results</option>
                </select>
            </div>
        </div>
    </div>
</div>

@if (loading)
{
    <div class="loading-state"><div class="spinner-border text-primary" role="status"></div><p class="mt-3 text-muted">Loading queue...</p></div>
}
else
{
    <div class="content-card">
        <div class="content-card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover data-table mb-0 small">
                    <thead>
                        <tr>
                            <th>Requisition #</th>
                            <th>Patient</th>
                            <th>Test Name</th>
                            <th>Sample Type</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (pendingItems == null || !pendingItems.Any())
                        {
                            <tr><td colspan="6" class="text-center py-4 text-muted">No test results found.</td></tr>
                        }
                        else
                        {
                            @foreach (var item in pendingItems)
                            {
                                <tr>
                                    <td class="fw-semibold font-monospace text-uppercase">@item.Requisition.RequisitionNumber</td>
                                    <td>
                                        <div>@item.Requisition.Patient.FirstName @item.Requisition.Patient.LastName</div>
                                        <div class="text-muted small">@item.Requisition.Patient.Mrn</div>
                                    </td>
                                    <td class="fw-semibold">@item.Test.TestName</td>
                                    <td class="text-muted">@item.Test.SampleType</td>
                                    <td><span class="badge @GetStatusBadgeClass(item.Status)">@item.Status</span></td>
                                    <td class="text-end">
                                        @if (item.Status == "Completed")
                                        {
                                            <a href="/laboratory/requisitions/@item.Id/results" class="btn btn-sm btn-outline-info">
                                                <i class="bi bi-eye me-1"></i> View Results
                                            </a>
                                        }
                                        else
                                        {
                                            <a href="/laboratory/requisitions/@item.Id/results" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-pencil-square me-1"></i> Enter Results
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private List<LabRequisitionItem>? pendingItems;
    private Guid currentTenantId = Guid.Empty;
    private string selectedStatus = "Pending";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentTenantId = TenantContext.TenantId;
        await LoadQueue();
    }

    private async Task LoadQueue()
    {
        try
        {
            loading = true;
            var query = DbContext.LabRequisitionItems
                .Include(i => i.Requisition).ThenInclude(r => r.Patient)
                .Include(i => i.Test)
                .Where(i => i.Requisition.TenantId == currentTenantId);

            if (selectedStatus == "Pending")
            {
                query = query.Where(i => i.Status == "Processing" || i.Status == "SampleCollected");
            }
            else if (selectedStatus == "Completed")
            {
                query = query.Where(i => i.Status == "Completed");
            }
            else
            {
                query = query.Where(i => i.Status == "Processing" || i.Status == "SampleCollected" || i.Status == "Completed");
            }

            pendingItems = await query.OrderByDescending(i => i.Requisition.OrderedAt).ToListAsync();
        }
        catch (Exception ex) { Console.WriteLine($"Error loading results queue: {ex.Message}"); }
        finally { loading = false; }
    }

    private string GetStatusBadgeClass(string status) => status switch
    {
        "Completed" => "bg-success-subtle text-success",
        "Cancelled" => "bg-secondary-subtle text-secondary",
        "Processing" => "bg-info-subtle text-info",
        "SampleCollected" => "bg-warning-subtle text-warning",
        _ => "bg-primary-subtle text-primary"
    };
}
