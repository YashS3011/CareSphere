@page "/laboratory/catalog"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Lab_ViewReports)]
@using CareSphere.Models
@using CareSphere.Modules.Laboratory.Services
@using CareSphere.Modules.Shared.Services
@inject ILabCatalogService CatalogService
@inject ITenantContext TenantContext
@inject NavigationManager NavigationManager
@inject CareSphere.Authorization.TabIsolatedAuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Lab Test Catalog - CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-book-fill"></i></div>
            <div>
                <h1 class="page-title">Lab Test Catalog</h1>
                <p class="page-subtitle">Manage test catalogs, specimen requirements, turnaround times, and pricing</p>
            </div>
        </div>
        <div class="page-actions">
            <a href="/laboratory/catalog/create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Create Test</a>
        </div>
    </div>
</div>

<div class="content-card mb-4">
    <div class="content-card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control" placeholder="Search by test name or code..." @bind="searchQuery" @bind:after="ApplyFilters" />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="selectedCategory" @bind:after="ApplyFilters">
                    <option value="">All Categories</option>
                    <option value="Hematology">Hematology</option>
                    <option value="Biochemistry">Biochemistry</option>
                    <option value="Microbiology">Microbiology</option>
                    <option value="Immunology">Immunology</option>
                    <option value="Pathology">Pathology</option>
                    <option value="Radiology">Radiology</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="selectedStatus" @bind:after="ApplyFilters">
                    <option value="">All Statuses</option>
                    <option value="Active">Active Only</option>
                    <option value="Inactive">Inactive Only</option>
                </select>
            </div>
        </div>
    </div>
</div>

@if (loading)
{
    <div class="loading-state"><div class="spinner-border text-primary" role="status"></div><p class="mt-3 text-muted">Loading catalog...</p></div>
}
else
{
    <div class="content-card">
        <div class="content-card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover data-table mb-0 small">
                    <thead>
                        <tr>
                            <th style="width:40px"></th>
                            <th>Test Code</th>
                            <th>Test Name</th>
                            <th>Category</th>
                            <th>Sample Type</th>
                            <th class="text-end">TAT (Hrs)</th>
                            <th class="text-end">Price</th>
                            <th class="text-center">Params</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (tests == null || !tests.Any())
                        {
                            <tr><td colspan="10" class="text-center py-4 text-muted">No test catalog entries found.</td></tr>
                        }
                        else
                        {
                            @foreach (var test in tests)
                            {
                                var testId = test.Id;
                                <tr>
                                    <td class="text-center">
                                        <button class="btn btn-link p-0 text-muted" @onclick="() => ToggleParameters(testId)">
                                            <i class="bi @(expandedTests.Contains(testId) ? "bi-chevron-down" : "bi-chevron-right")"></i>
                                        </button>
                                    </td>
                                    <td class="fw-semibold font-monospace text-uppercase">@test.TestCode</td>
                                    <td class="fw-semibold">@test.TestName</td>
                                    <td><span class="badge bg-secondary-subtle text-secondary">@test.Category</span></td>
                                    <td class="text-muted">@test.SampleType</td>
                                    <td class="text-end text-muted">@test.TurnaroundHours h</td>
                                    <td class="text-end fw-semibold">₹@test.Price.ToString("N2")</td>
                                    <td class="text-center"><span class="badge bg-primary-subtle text-primary">@test.Parameters.Count</span></td>
                                    <td>
                                        @if (test.IsActive) { <span class="badge bg-success-subtle text-success">Active</span> }
                                        else { <span class="badge bg-secondary-subtle text-secondary">Inactive</span> }
                                    </td>
                                    <td class="text-end">
                                        <a href="/laboratory/catalog/edit/@test.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil me-1"></i> Edit</a>
                                    </td>
                                </tr>
                                @if (expandedTests.Contains(testId))
                                {
                                    <tr class="table-light">
                                        <td></td>
                                        <td colspan="9" class="ps-3 border-start border-primary border-3">
                                            <div class="mb-2 fw-semibold text-muted small text-uppercase">Test Parameters</div>
                                            @if (test.Parameters == null || !test.Parameters.Any())
                                            {
                                                <div class="text-muted small">No parameters configured for this test.</div>
                                            }
                                            else
                                            {
                                                <table class="table table-sm table-bordered mb-0 small bg-white rounded">
                                                    <thead class="table-light text-muted">
                                                        <tr>
                                                            <th>Parameter</th>
                                                            <th>Code</th>
                                                            <th>Unit</th>
                                                            <th>Type</th>
                                                            <th>Reference Range</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var param in test.Parameters.OrderBy(p => p.SortOrder))
                                                        {
                                                            <tr>
                                                                <td>@param.ParameterName</td>
                                                                <td class="font-monospace text-muted small">@(param.ParameterCode ?? "-")</td>
                                                                <td>@(param.Unit ?? "-")</td>
                                                                <td><span class="badge bg-secondary-subtle text-secondary">@param.DataType</span></td>
                                                                <td>@(param.DataType == "Numeric" ? $"{param.ReferenceRangeLow} - {param.ReferenceRangeHigh}" : param.ReferenceRangeText)</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private string searchQuery = string.Empty;
    private string selectedCategory = string.Empty;
    private string selectedStatus = string.Empty;
    private List<LabTestCatalog>? tests;
    private HashSet<Guid> expandedTests = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        await LoadCatalog();
    }

    private async Task LoadCatalog()
    {
        try
        {
            loading = true;
            bool? isActive = selectedStatus == "Active" ? true : selectedStatus == "Inactive" ? false : null;
            tests = await CatalogService.GetAllTestsAsync(TenantContext.TenantId, searchQuery, selectedCategory, isActive);
        }
        catch (Exception ex) { Console.WriteLine($"Error loading test catalog: {ex.Message}"); }
        finally { loading = false; }
    }

    private async Task ApplyFilters() { await LoadCatalog(); }
    private void ToggleParameters(Guid testId) { if (expandedTests.Contains(testId)) expandedTests.Remove(testId); else expandedTests.Add(testId); }
}
