@page "/laboratory/samples"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Lab_CollectSample)]
@using CareSphere.Models
@using CareSphere.Modules.Laboratory.Services
@using CareSphere.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@inject CareSphere.Authorization.TabIsolatedAuthenticationStateProvider AuthStateProvider
@inject ITenantContext TenantContext
@rendermode InteractiveServer

<PageTitle>Sample Collection - CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-droplet-fill"></i></div>
            <div>
                <h1 class="page-title">Sample Collection Queue</h1>
                <p class="page-subtitle">Lab requisitions pending specimen collection</p>
            </div>
        </div>
    </div>
</div>

@if (loading)
{
    <div class="loading-state"><div class="spinner-border text-primary" role="status"></div><p class="mt-3 text-muted">Loading queue...</p></div>
}
else
{
    <div class="content-card">
        <div class="content-card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover data-table mb-0 small">
                    <thead>
                        <tr>
                            <th>Requisition #</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Ordered At</th>
                            <th>Priority</th>
                            <th>Tests</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (pendingRequisitions == null || !pendingRequisitions.Any())
                        {
                            <tr><td colspan="7" class="text-center py-4 text-muted">No pending sample collections found.</td></tr>
                        }
                        else
                        {
                            @foreach (var req in pendingRequisitions)
                            {
                                <tr>
                                    <td class="fw-semibold font-monospace text-uppercase">@req.RequisitionNumber</td>
                                    <td>
                                        <div>@req.Patient.FirstName @req.Patient.LastName</div>
                                        <div class="text-muted small">@req.Patient.Mrn</div>
                                    </td>
                                    <td>Dr. @req.OrderedByDoctor.FirstName @req.OrderedByDoctor.LastName</td>
                                    <td class="text-muted small">@req.OrderedAt.ToLocalTime().ToString("g")</td>
                                    <td><span class="badge @GetPriorityBadgeClass(req.Priority)">@req.Priority</span></td>
                                    <td class="text-muted small">@string.Join(", ", req.Items.Select(i => i.Test.TestName))</td>
                                    <td class="text-end">
                                        <a href="/laboratory/requisitions/@req.Id/collect-sample" class="btn btn-sm btn-warning">
                                            <i class="bi bi-droplet-fill me-1"></i> Collect Sample
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private List<LabRequisition>? pendingRequisitions;
    private Guid currentTenantId = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentTenantId = TenantContext.TenantId;
        await LoadQueue();
    }

    private async Task LoadQueue()
    {
        try
        {
            loading = true;
            pendingRequisitions = await DbContext.LabRequisitions
                .Include(r => r.Patient).Include(r => r.OrderedByDoctor)
                .Include(r => r.Items).ThenInclude(i => i.Test)
                .Where(r => r.TenantId == currentTenantId && r.Status == "Ordered")
                .OrderByDescending(r => r.OrderedAt).ToListAsync();
        }
        catch (Exception ex) { Console.WriteLine($"Error loading sample collection queue: {ex.Message}"); }
        finally { loading = false; }
    }

    private string GetPriorityBadgeClass(string priority) => priority switch
    {
        "Stat" => "bg-danger-subtle text-danger",
        "Urgent" => "bg-warning-subtle text-warning",
        _ => "bg-success-subtle text-success"
    };
}
