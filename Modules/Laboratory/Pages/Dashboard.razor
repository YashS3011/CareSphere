@page "/lab/dashboard"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Lab_ViewReports)]
@using CareSphere.Models
@using CareSphere.Modules.Laboratory.Services
@using CareSphere.Modules.Shared.Services
@using CareSphere.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject ILabRequisitionService RequisitionService
@inject ILabNotificationService NotificationService
@inject NavigationManager NavigationManager
@inject CareSphere.Authorization.TabIsolatedAuthenticationStateProvider AuthStateProvider
@inject ITenantContext TenantContext
@rendermode InteractiveServer

<PageTitle>Laboratory Dashboard - CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-flask-fill"></i></div>
            <div>
                <h1 class="page-title">Laboratory Dashboard</h1>
                <p class="page-subtitle">Overview of lab tests, requisitions, samples, and alerts</p>
            </div>
        </div>
        <div class="page-actions">
            <a href="/laboratory/requisitions/create" class="btn btn-primary"><i class="bi bi-plus me-1"></i> Order Lab Tests</a>
            <a href="/laboratory/catalog" class="btn btn-outline-secondary"><i class="bi bi-book me-1"></i> Test Catalog</a>
        </div>
    </div>
</div>

@if (loading)
{
    <div class="loading-state"><div class="spinner-border text-primary" role="status"></div><p class="mt-3 text-muted">Loading dashboard data...</p></div>
}
else
{
    <div class="row g-4 mb-4">
        <div class="col-sm-6 col-xl">
            <div class="stat-card stat-card-primary">
                <div class="stat-icon"><i class="bi bi-receipt"></i></div>
                <div class="stat-value">@totalTestsOrderedToday</div>
                <div class="stat-label">Ordered Today</div>
            </div>
        </div>
        <div class="col-sm-6 col-xl">
            <div class="stat-card stat-card-warning">
                <div class="stat-icon"><i class="bi bi-box-arrow-in-down"></i></div>
                <div class="stat-value">@pendingSampleCollectionCount</div>
                <div class="stat-label">Pending Collection</div>
            </div>
        </div>
        <div class="col-sm-6 col-xl">
            <div class="stat-card" style="border-left:4px solid #0dcaf0;">
                <div class="stat-icon" style="background:rgba(13,202,240,0.1);color:#0dcaf0;"><i class="bi bi-gear"></i></div>
                <div class="stat-value">@samplesInProcessingCount</div>
                <div class="stat-label">In Processing</div>
            </div>
        </div>
        <div class="col-sm-6 col-xl">
            <div class="stat-card stat-card-success">
                <div class="stat-icon"><i class="bi bi-file-earmark-check"></i></div>
                <div class="stat-value">@reportsReadyToday</div>
                <div class="stat-label">Reports Today</div>
            </div>
        </div>
        <div class="col-sm-6 col-xl">
            <div class="stat-card stat-card-danger">
                <div class="stat-icon"><i class="bi bi-exclamation-triangle"></i></div>
                <div class="stat-value">@abnormalResultsToday</div>
                <div class="stat-label">Abnormal Today</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Pending Requisitions -->
        <div class="col-lg-8">
            <div class="content-card h-100">
                <div class="content-card-header">
                    <h5 class="content-card-title"><i class="bi bi-clock-history me-2"></i>Pending Lab Requisitions</h5>
                    <a href="/laboratory/requisitions" class="btn btn-sm btn-outline-secondary">View All</a>
                </div>
                <div class="content-card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover data-table mb-0 small">
                            <thead>
                                <tr>
                                    <th>Req #</th>
                                    <th>Patient</th>
                                    <th>Ordered By</th>
                                    <th>Priority</th>
                                    <th>Ordered At</th>
                                    <th>Status</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (pendingRequisitions == null || !pendingRequisitions.Any())
                                {
                                    <tr><td colspan="7" class="text-center py-4 text-muted">No pending requisitions.</td></tr>
                                }
                                else
                                {
                                    @foreach (var req in pendingRequisitions)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@req.RequisitionNumber</td>
                                            <td>
                                                <div>@req.Patient.FirstName @req.Patient.LastName</div>
                                                <div class="text-muted small">@req.Patient.Mrn</div>
                                            </td>
                                            <td>Dr. @req.OrderedByDoctor.FirstName @req.OrderedByDoctor.LastName</td>
                                            <td>
                                                <span class="badge @GetPriorityBadgeClass(req.Priority)">@req.Priority</span>
                                            </td>
                                            <td class="text-muted">@req.OrderedAt.ToLocalTime().ToString("g")</td>
                                            <td><span class="badge bg-secondary-subtle text-secondary">@req.Status</span></td>
                                            <td class="text-end">
                                                <div class="btn-group btn-group-sm">
                                                    <a href="/laboratory/requisitions/@req.Id" class="btn btn-outline-primary">View</a>
                                                    @if (req.Status == "Ordered")
                                                    {
                                                        <AuthorizeView Policy="@PolicyNames.Permission_Lab_CollectSample">
                                                            <Authorized>
                                                                <a href="/laboratory/requisitions/@req.Id/collect-sample" class="btn btn-outline-warning">Collect</a>
                                                            </Authorized>
                                                        </AuthorizeView>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Notifications Panel -->
        <div class="col-lg-4">
            <div class="content-card h-100">
                <div class="content-card-header">
                    <h5 class="content-card-title"><i class="bi bi-bell-fill me-2 text-danger"></i>Lab Alerts</h5>
                </div>
                <div class="content-card-body p-0" style="max-height:400px;overflow-y:auto;">
                    @if (recentNotifications == null || !recentNotifications.Any())
                    {
                        <div class="empty-state" style="padding:2rem 1rem;">
                            <i class="bi bi-bell-slash" style="font-size:2rem;opacity:0.3;"></i>
                            <p class="mt-2 mb-0 text-muted small">No unread notifications.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var notif in recentNotifications)
                        {
                            <div class="notification-item">
                                <div class="flex-grow-1">
                                    <div class="fw-semibold small">@notif.Title</div>
                                    <div class="text-muted" style="font-size:0.78rem;">@notif.Message</div>
                                    <div class="text-muted" style="font-size:0.7rem;">@notif.CreatedAt.ToLocalTime().ToString("g")</div>
                                </div>
                                <button class="btn btn-sm btn-link p-0 text-muted ms-2" @onclick="() => DismissNotification(notif.Id)" title="Dismiss">
                                    <i class="bi bi-x-circle"></i>
                                </button>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private int totalTestsOrderedToday, pendingSampleCollectionCount, samplesInProcessingCount, reportsReadyToday, abnormalResultsToday;
    private List<LabRequisition>? pendingRequisitions;
    private List<InAppNotification>? recentNotifications;
    private Guid currentTenantId = Guid.Empty;
    private string currentDoctorId = "00000000-0000-0000-0000-000000000000";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            currentTenantId = TenantContext.TenantId;
            currentDoctorId = authState.User.FindFirst("doctor_id")?.Value ?? authState.User.FindFirst(CareSphereClaimTypes.DoctorId)?.Value ?? "00000000-0000-0000-0000-000000000000";
            loading = true;
            var today = DateTime.UtcNow.Date;
            var requisitionsToday = await DbContext.LabRequisitions.Include(r => r.Items).Where(r => r.TenantId == currentTenantId && r.OrderedAt.Date == today).ToListAsync();
            totalTestsOrderedToday = requisitionsToday.Sum(r => r.Items.Count);
            pendingSampleCollectionCount = await DbContext.LabRequisitions.CountAsync(r => r.TenantId == currentTenantId && r.Status == "Ordered");
            samplesInProcessingCount = await DbContext.LabRequisitions.CountAsync(r => r.TenantId == currentTenantId && (r.Status == "Processing" || r.Status == "SampleCollected"));
            reportsReadyToday = await DbContext.LabReports.CountAsync(r => r.TenantId == currentTenantId && r.GeneratedAt.Date == today && r.IsLatest);
            abnormalResultsToday = await DbContext.LabResults.CountAsync(r => r.TenantId == currentTenantId && r.EnteredAt.Date == today && r.IsAbnormal);
            pendingRequisitions = await RequisitionService.GetPendingRequisitionsAsync(currentTenantId);
            recentNotifications = await NotificationService.GetUnreadNotificationsAsync("Doctor", currentDoctorId);
        }
        catch (Exception ex) { Console.WriteLine($"Error loading lab dashboard: {ex.Message}"); }
        finally { loading = false; }
    }

    private string GetPriorityBadgeClass(string priority) => priority switch
    {
        "Stat" => "bg-danger-subtle text-danger",
        "Urgent" => "bg-warning-subtle text-warning",
        _ => "bg-success-subtle text-success"
    };

    private async Task DismissNotification(Guid id)
    {
        try
        {
            await NotificationService.MarkNotificationReadAsync(id);
            recentNotifications = await NotificationService.GetUnreadNotificationsAsync("Doctor", currentDoctorId);
        }
        catch (Exception ex) { Console.WriteLine($"Error dismissing notification: {ex.Message}"); }
    }
}
