@page "/lab/dashboard"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = PolicyNames.Permission_Lab_ViewReports)]
@using CareSphere.Models
@using CareSphere.Modules.Laboratory.Services
@using CareSphere.Modules.Shared.Services
@using CareSphere.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject ILabRequisitionService RequisitionService
@inject ILabNotificationService NotificationService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Laboratory Dashboard - CareSphere</PageTitle>

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 text-dark fw-bold"><i class="bi bi-flask me-2 text-primary"></i>Laboratory Dashboard</h1>
            <p class="text-muted mb-0">Overview of lab tests, requisitions, sample collection, processing, and alerts</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/laboratory/requisitions/create" class="btn btn-primary shadow-sm"><i class="bi bi-plus me-1"></i> Order Lab Tests</a>
            <a href="/laboratory/catalog" class="btn btn-outline-primary shadow-sm"><i class="bi bi-book me-1"></i> Test Catalog</a>
        </div>
    </div>

    @if (loading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading dashboard data...</span>
            </div>
        </div>
    }
    else
    {
        <!-- KPI summary row -->
        <div class="row g-3 mb-4">
            <div class="col-md-6 col-lg-2col" style="flex: 1; min-width: 200px;">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-3 bg-white">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-receipt fs-4"></i>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold uppercase fs-8">Ordered Today</div>
                            <h3 class="fw-bold text-dark mb-0">@totalTestsOrderedToday</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-2col" style="flex: 1; min-width: 200px;">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-3 bg-white">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-warning-subtle text-warning-emphasis d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-box-arrow-in-down fs-4"></i>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold uppercase fs-8">Pending Collection</div>
                            <h3 class="fw-bold text-warning-emphasis mb-0">@pendingSampleCollectionCount</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-2col" style="flex: 1; min-width: 200px;">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-3 bg-white">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-info-subtle text-info-emphasis d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-gear fs-4"></i>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold uppercase fs-8">In Processing</div>
                            <h3 class="fw-bold text-info-emphasis mb-0">@samplesInProcessingCount</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-2col" style="flex: 1; min-width: 200px;">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-3 bg-white">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-success-subtle text-success d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-file-earmark-check fs-4"></i>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold uppercase fs-8">Reports Today</div>
                            <h3 class="fw-bold text-success mb-0">@reportsReadyToday</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-2col" style="flex: 1; min-width: 200px;">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-3 bg-white">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-danger-subtle text-danger d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-exclamation-triangle fs-4"></i>
                        </div>
                        <div>
                            <div class="text-muted small fw-semibold uppercase fs-8">Abnormal Today</div>
                            <h3 class="fw-bold text-danger mb-0">@abnormalResultsToday</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Pending Requisitions Table -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-header bg-white py-3 px-4 d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold text-dark mb-0"><i class="bi bi-clock-history text-primary me-2"></i>Pending Lab Requisitions</h5>
                        <a href="/laboratory/requisitions" class="btn btn-xs btn-outline-secondary py-0">View All</a>
                    </div>
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 small">
                            <thead class="table-light fs-8 text-uppercase text-muted">
                                <tr>
                                    <th>Req Number</th>
                                    <th>Patient</th>
                                    <th>MRN</th>
                                    <th>Ordered By</th>
                                    <th>Priority</th>
                                    <th>Ordered At</th>
                                    <th>Status</th>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (pendingRequisitions == null || !pendingRequisitions.Any())
                                {
                                    <tr>
                                        <td colspan="8" class="text-center py-4 text-muted">No pending requisitions.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var req in pendingRequisitions)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@req.RequisitionNumber</td>
                                            <td>@req.Patient.FirstName @req.Patient.LastName</td>
                                            <td class="font-monospace text-muted">@req.Patient.Mrn</td>
                                            <td>Dr. @req.OrderedByDoctor.FirstName @req.OrderedByDoctor.LastName</td>
                                            <td>
                                                <span class="badge @GetPriorityBadgeClass(req.Priority)">
                                                    @req.Priority
                                                </span>
                                            </td>
                                            <td class="text-muted">@req.OrderedAt.ToLocalTime().ToString("g")</td>
                                            <td>
                                                <span class="badge bg-light text-dark border">
                                                    @req.Status
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                <div class="d-flex gap-1 justify-content-center">
                                                    <a href="/laboratory/requisitions/@req.Id" class="btn btn-xs btn-outline-primary py-0 px-2 fs-8">View</a>
                                                    @if (req.Status == "Ordered")
                                                    {
                                                        <a href="/laboratory/requisitions/@req.Id/collect-sample" class="btn btn-xs btn-outline-warning py-0 px-2 fs-8">Collect Sample</a>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- InAppNotifications Panel -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-header bg-white py-3 px-4 d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold text-dark mb-0"><i class="bi bi-bell text-danger me-2"></i>Lab Notifications</h5>
                    </div>
                    <div class="card-body p-3" style="max-height: 400px; overflow-y: auto;">
                        @if (recentNotifications == null || !recentNotifications.Any())
                        {
                            <div class="text-center text-muted py-4 small">
                                No unread notifications.
                            </div>
                        }
                        else
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var notif in recentNotifications)
                                {
                                    <div class="list-group-item px-0 py-2 border-0 border-bottom">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <div class="fw-semibold text-dark fs-8">@notif.Title</div>
                                                <div class="text-muted fs-9">@notif.Message</div>
                                                <small class="text-muted fs-10">@notif.CreatedAt.ToLocalTime().ToString("g")</small>
                                            </div>
                                            <button class="btn btn-sm btn-link text-decoration-none p-0 text-secondary" @onclick="() => DismissNotification(notif.Id)" title="Dismiss">
                                                <i class="bi bi-x-circle fs-8"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool loading = true;
    private int totalTestsOrderedToday = 0;
    private int pendingSampleCollectionCount = 0;
    private int samplesInProcessingCount = 0;
    private int reportsReadyToday = 0;
    private int abnormalResultsToday = 0;

    private List<LabRequisition>? pendingRequisitions;
    private List<InAppNotification>? recentNotifications;

    private Guid currentTenantId = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            loading = true;

            var today = DateTime.UtcNow.Date;

            // 1. Total tests ordered today
            var requisitionsToday = await DbContext.LabRequisitions
                .Include(r => r.Items)
                .Where(r => r.TenantId == currentTenantId && r.OrderedAt.Date == today)
                .ToListAsync();
            totalTestsOrderedToday = requisitionsToday.Sum(r => r.Items.Count);

            // 2. Pending sample collection count
            pendingSampleCollectionCount = await DbContext.LabRequisitions
                .CountAsync(r => r.TenantId == currentTenantId && r.Status == "Ordered");

            // 3. Samples in processing
            samplesInProcessingCount = await DbContext.LabRequisitions
                .CountAsync(r => r.TenantId == currentTenantId && (r.Status == "Processing" || r.Status == "SampleCollected"));

            // 4. Reports ready today
            reportsReadyToday = await DbContext.LabReports
                .CountAsync(r => r.TenantId == currentTenantId && r.GeneratedAt.Date == today && r.IsLatest);

            // 5. Abnormal results today
            abnormalResultsToday = await DbContext.LabResults
                .CountAsync(r => r.TenantId == currentTenantId && r.EnteredAt.Date == today && r.IsAbnormal);

            // Pending requisitions list (all non-Completed/non-Cancelled)
            pendingRequisitions = await RequisitionService.GetPendingRequisitionsAsync(currentTenantId);

            // Recent unread doctor/lab notifications
            recentNotifications = await NotificationService.GetUnreadNotificationsAsync("Doctor", "00000000-0000-0000-0000-000000000000");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading lab dashboard: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private string GetPriorityBadgeClass(string priority)
    {
        return priority switch
        {
            "Stat" => "bg-danger text-white",
            "Urgent" => "bg-warning text-dark",
            _ => "bg-success text-white"
        };
    }

    private async Task DismissNotification(Guid id)
    {
        try
        {
            await NotificationService.MarkNotificationReadAsync(id);
            recentNotifications = await NotificationService.GetUnreadNotificationsAsync("Doctor", "00000000-0000-0000-0000-000000000000");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error dismissing notification: {ex.Message}");
        }
    }
}

<style>
    .fs-8 { font-size: 0.8rem !important; }
    .fs-9 { font-size: 0.72rem !important; }
    .fs-10 { font-size: 0.65rem !important; }
    .btn-xs {
        padding: 0.1rem 0.4rem;
        font-size: 0.75rem;
        line-height: 1.5;
        border-radius: 0.2rem;
    }
</style>
