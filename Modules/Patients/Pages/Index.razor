@page "/patients"
@attribute [Authorize(Policy = PolicyNames.Permission_Patients_View)]
@inject IPatientService PatientService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Patients - CareSphere</PageTitle>

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1"><i class="bi bi-people-fill text-primary"></i> Patient Management</h3>
        <p class="text-muted small mb-0">Search, view, and manage all registered patients</p>
    </div>
    <div class="page-actions">
        <AuthorizeView Policy="@PolicyNames.Permission_Patients_Create">
            <Authorized>
                <a href="/patients/create" class="btn btn-primary shadow-sm">
                    <i class="bi bi-person-plus-fill me-1"></i> Register New Patient
                </a>
            </Authorized>
        </AuthorizeView>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-3">
        <div class="input-group">
            <span class="input-group-text bg-light border-end-0"><i class="bi bi-search text-muted"></i></span>
            <input type="text" class="form-control bg-light border-start-0 ps-0" placeholder="Search by name or MRN..." @bind="SearchTerm" @bind:event="oninput" @onkeyup="HandleSearch" />
            <button class="btn btn-primary" type="button" @onclick="LoadPatients">Search</button>
        </div>
    </div>
</div>

@if (patients == null)
{
    <div class="text-center py-5 bg-white rounded shadow-sm">
        <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
        <p class="text-muted mt-2 mb-0">Loading patients...</p>
    </div>
}
else if (!patients.Any())
{
    <div class="text-center py-5 text-muted bg-white rounded shadow-sm">
        <i class="bi bi-person-x-fill display-3 opacity-50 mb-3 d-block text-secondary"></i>
        <h5>No Patients Found</h5>
        <p class="small text-muted">Try adjusting your search or register a new patient to get started.</p>
        <AuthorizeView Policy="@PolicyNames.Permission_Patients_Create">
            <Authorized>
                <a href="/patients/create" class="btn btn-primary btn-sm mt-2">
                    <i class="bi bi-person-plus-fill me-1"></i> Register Patient
                </a>
            </Authorized>
        </AuthorizeView>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">MRN</th>
                            <th>Name</th>
                            <th>DOB</th>
                            <th>Gender</th>
                            <th>Phone</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var patient in patients)
                        {
                            <tr>
                                <td class="ps-4"><span class="font-monospace fw-semibold text-muted">@patient.Mrn</span></td>
                                <td class="fw-semibold">@patient.FirstName @patient.LastName</td>
                                <td>@patient.DateOfBirth.ToString("dd MMM yyyy")</td>
                                <td>
                                    <span class="badge @(patient.Gender == "Male" ? "bg-primary-subtle text-primary" : patient.Gender == "Female" ? "bg-danger-subtle text-danger" : "bg-secondary-subtle text-secondary") border">
                                        @patient.Gender
                                    </span>
                                </td>
                                <td>@patient.Phone</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group btn-group-sm">
                                        <a href="/patients/@patient.Id" class="btn btn-outline-info" title="View"><i class="bi bi-eye-fill me-1"></i>View</a>
                                        <AuthorizeView Policy="@PolicyNames.Permission_Patients_Edit">
                                            <Authorized>
                                                <a href="/patients/preferences/@patient.Id" class="btn btn-outline-primary" title="Preferences"><i class="bi bi-bell-fill"></i></a>
                                                <a href="/patients/edit/@patient.Id" class="btn btn-outline-warning" title="Edit"><i class="bi bi-pencil-fill"></i></a>
                                            </Authorized>
                                        </AuthorizeView>
                                        <AuthorizeView Policy="@PolicyNames.Permission_Patients_Delete">
                                            <Authorized>
                                                <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete(patient.Id)" title="Delete"><i class="bi bi-trash-fill"></i></button>
                                            </Authorized>
                                        </AuthorizeView>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal fade show" style="display: block; background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Delete</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="mb-0">Are you sure you want to delete this patient record? This action cannot be undone and will remove all associated history.</p>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="DeletePatient">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Patient>? patients;
    private string SearchTerm { get; set; } = string.Empty;
    private bool showDeleteConfirm = false;
    private Guid patientIdToDelete = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadPatients();
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LoadPatients();
        }
    }

    private async Task LoadPatients()
    {
        patients = await PatientService.GetPatientsAsync(SearchTerm);
    }

    private void ConfirmDelete(Guid id)
    {
        patientIdToDelete = id;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        patientIdToDelete = Guid.Empty;
    }

    private async Task DeletePatient()
    {
        if (patientIdToDelete != Guid.Empty)
        {
            await PatientService.DeletePatientAsync(patientIdToDelete);
            await LoadPatients();
        }
        showDeleteConfirm = false;
        patientIdToDelete = Guid.Empty;
    }
}
