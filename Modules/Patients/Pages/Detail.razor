@page "/patients/{id:guid}"
@attribute [Authorize(Policy = PolicyNames.Permission_Patients_View)]
@using CareSphere.Models
@using CareSphere.Data
@using Microsoft.EntityFrameworkCore
@inject IPatientService PatientService
@inject ApplicationDbContext DbContext
@rendermode InteractiveServer

<PageTitle>Patient Detail - CareSphere</PageTitle>

@if (patient == null && !isNotFound)
{
    <p><em>Loading...</em></p>
}
else if (isNotFound)
{
    <div class="alert alert-danger">Patient not found.</div>
    <a href="/patients" class="btn btn-primary">Back to List</a>
}
else if (patient != null)
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Patient Profile: @patient.FirstName @patient.LastName</h2>
        <div>
            <a href="/patients/preferences/@patient.Id" class="btn btn-outline-primary me-2"><i class="bi bi-bell-fill"></i> Notification Preferences</a>
            <a href="/patients/edit/@patient.Id" class="btn btn-warning"><i class="bi bi-pencil"></i> Edit</a>
            <a href="/patients" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Demographics</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm table-borderless">
                        <tbody>
                            <tr>
                                <th style="width: 40%">MRN:</th>
                                <td><span class="badge bg-secondary fs-6">@patient.Mrn</span></td>
                            </tr>
                            <tr>
                                <th>Name:</th>
                                <td>@patient.FirstName @patient.LastName</td>
                            </tr>
                            <tr>
                                <th>DOB (Age):</th>
                                <td>
                                    @patient.DateOfBirth.ToString("dd MMM yyyy") 
                                    <span class="text-muted">(@CalculateAge(patient.DateOfBirth) years)</span>
                                </td>
                            </tr>
                            <tr>
                                <th>Gender:</th>
                                <td>@patient.Gender</td>
                            </tr>
                            <tr>
                                <th>Blood Group:</th>
                                <td>@(string.IsNullOrEmpty(patient.BloodGroup) ? "N/A" : patient.BloodGroup)</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Contact & Identifiers</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm table-borderless">
                        <tbody>
                            <tr>
                                <th style="width: 40%">Phone:</th>
                                <td>@patient.Phone</td>
                            </tr>
                            <tr>
                                <th>Email:</th>
                                <td>@(string.IsNullOrEmpty(patient.Email) ? "N/A" : patient.Email)</td>
                            </tr>
                            <tr>
                                <th>Address:</th>
                                <td>@(string.IsNullOrEmpty(patient.Address) ? "N/A" : patient.Address)</td>
                            </tr>
                            <tr>
                                <th>ABHA ID:</th>
                                <td>@(string.IsNullOrEmpty(patient.AbhaId) ? "N/A" : patient.AbhaId)</td>
                            </tr>
                            <tr>
                                <th>Registered On:</th>
                                <td>@patient.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    @if (preferences != null)
    {
        <div class="row">
            <div class="col-12">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Patient Preferences</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Preferred Language:</strong> @preferences.PreferredLanguage</p>
                                <p><strong>Preferred Channel:</strong> @preferences.PreferredChannel</p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>SMS Opt Out:</strong> @(preferences.OptOutSms ? "Yes" : "No")</p>
                                <p><strong>WhatsApp Opt Out:</strong> @(preferences.OptOutWhatsApp ? "Yes" : "No")</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter]
    public Guid id { get; set; }

    private Patient? patient;
    private PatientPreference? preferences;
    private bool isNotFound = false;

    protected override async Task OnInitializedAsync()
    {
        patient = await PatientService.GetPatientByIdAsync(id);
        if (patient == null)
        {
            isNotFound = true;
        }
        else
        {
            preferences = await DbContext.PatientPreferences
                .AsNoTracking()
                .FirstOrDefaultAsync(p => p.PatientId == id);
        }
    }

    private int CalculateAge(DateTime dob)
    {
        var today = DateTime.Today;
        var age = today.Year - dob.Year;
        if (dob.Date > today.AddYears(-age)) age--;
        return age;
    }
}
