@page "/patients/{id:guid}"
@attribute [Authorize(Policy = PolicyNames.Permission_Patients_View)]
@using CareSphere.Models
@using CareSphere.Data
@using Microsoft.EntityFrameworkCore
@inject IPatientService PatientService
@inject ApplicationDbContext DbContext
@rendermode InteractiveServer

<PageTitle>Patient Detail - CareSphere</PageTitle>

@if (patient == null && !isNotFound)
{
    <div class="text-center py-5 bg-white rounded shadow-sm">
        <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
        <p class="text-muted mt-2 mb-0">Loading patient details...</p>
    </div>
}
else if (isNotFound)
{
    <div class="alert alert-danger d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <div>Patient record not found.</div>
    </div>
    <a href="/patients" class="btn btn-primary">Back to Patient List</a>
}
else if (patient != null)
{
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1"><i class="bi bi-person-fill text-primary"></i> Patient Profile: @patient.FirstName @patient.LastName</h3>
            <p class="text-muted small mb-0">View demographic info, identifiers, and notification preferences</p>
        </div>
        <div class="page-actions d-flex gap-2">
            <a href="/patients/preferences/@patient.Id" class="btn btn-outline-primary"><i class="bi bi-bell-fill me-1"></i> Preferences</a>
            <a href="/patients/edit/@patient.Id" class="btn btn-primary"><i class="bi bi-pencil me-1"></i> Edit Record</a>
            <a href="/patients" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Back</a>
        </div>
    </div>

    <div class="row">
        <!-- Main Content (Demographics and Preferences) -->
        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <h5 class="text-uppercase text-muted small fw-bold mb-3 border-bottom pb-2">Demographics</h5>
                    
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="text-muted small">Medical Record Number (MRN)</div>
                            <div class="fw-bold font-monospace fs-5">@patient.Mrn</div>
                        </div>
                        <div class="col-sm-6">
                            <div class="text-muted small">Date of Birth (Age)</div>
                            <div class="fw-semibold text-dark">
                                @patient.DateOfBirth.ToString("dd MMM yyyy")
                                <span class="text-muted font-monospace small">(@CalculateAge(patient.DateOfBirth) years old)</span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="text-muted small">Gender</div>
                            <div class="fw-semibold text-dark">@patient.Gender</div>
                        </div>
                        <div class="col-sm-6">
                            <div class="text-muted small">Blood Group</div>
                            <div class="fw-semibold">
                                @if (string.IsNullOrEmpty(patient.BloodGroup))
                                {
                                    <span class="text-muted">Not Recorded</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger border">@patient.BloodGroup</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @if (preferences != null)
            {
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <h5 class="text-uppercase text-muted small fw-bold mb-3 border-bottom pb-2">Notification &amp; Language Preferences</h5>
                        
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <div class="text-muted small mb-1">Preferred Channel</div>
                                <div class="fw-semibold text-dark">
                                    <i class="bi @(preferences.PreferredChannel == "WhatsApp" ? "bi-whatsapp text-success" : preferences.PreferredChannel == "SMS" ? "bi-chat-left-text text-primary" : preferences.PreferredChannel == "Voice" ? "bi-telephone text-info" : "bi-phone") me-1"></i>
                                    @preferences.PreferredChannel
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="text-muted small mb-1">Preferred Language</div>
                                <div class="fw-semibold text-dark">@preferences.PreferredLanguage.ToUpper()</div>
                            </div>
                            <div class="col-sm-6">
                                <div class="text-muted small mb-1">SMS Status</div>
                                <div>
                                    @if (preferences.OptOutSms)
                                    {
                                        <span class="badge bg-danger-subtle text-danger"><i class="bi bi-x-circle me-1"></i> Opted Out</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success-subtle text-success"><i class="bi bi-check-circle me-1"></i> Subscribed</span>
                                    }
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="text-muted small mb-1">WhatsApp Status</div>
                                <div>
                                    @if (preferences.OptOutWhatsApp)
                                    {
                                        <span class="badge bg-danger-subtle text-danger"><i class="bi bi-x-circle me-1"></i> Opted Out</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success-subtle text-success"><i class="bi bi-check-circle me-1"></i> Subscribed</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar Summary Card (Contact & Identifiers) -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="text-uppercase text-muted small fw-bold mb-3 border-bottom pb-2">Contact &amp; Identity</h5>
                    
                    <div class="mb-3">
                        <div class="text-muted small">Phone Number</div>
                        <div class="fw-semibold text-dark"><i class="bi bi-telephone me-1 text-muted"></i> @patient.Phone</div>
                    </div>
                    
                    <div class="mb-3">
                        <div class="text-muted small">Email Address</div>
                        <div class="fw-semibold text-dark">
                            @if (string.IsNullOrEmpty(patient.Email))
                            {
                                <span class="text-muted">No Email Provided</span>
                            }
                            else
                            {
                                <a href="mailto:@patient.Email" class="text-decoration-none"><i class="bi bi-envelope me-1 text-muted"></i> @patient.Email</a>
                            }
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <div class="text-muted small">Address</div>
                        <div class="fw-semibold text-dark">
                            @if (string.IsNullOrEmpty(patient.Address))
                            {
                                <span class="text-muted">No Address Recorded</span>
                            }
                            else
                            {
                                <i class="bi bi-geo-alt me-1 text-muted"></i> @patient.Address
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">ABHA ID</div>
                        <div class="fw-semibold">
                            @if (string.IsNullOrEmpty(patient.AbhaId))
                            {
                                <span class="text-muted">Not Linked</span>
                            }
                            else
                            {
                                <span class="badge bg-info-subtle text-info border"><i class="bi bi-shield-check me-1"></i> @patient.AbhaId</span>
                            }
                        </div>
                    </div>

                    <div class="border-top pt-3 mt-3">
                        <div class="text-muted small">Registered Since</div>
                        <div class="fw-semibold text-dark" style="font-size: 0.9rem;">
                            <i class="bi bi-calendar-check me-1 text-muted"></i>
                            @patient.CreatedAt.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid id { get; set; }

    private Patient? patient;
    private PatientPreference? preferences;
    private bool isNotFound = false;

    protected override async Task OnInitializedAsync()
    {
        patient = await PatientService.GetPatientByIdAsync(id);
        if (patient == null)
        {
            isNotFound = true;
        }
        else
        {
            preferences = await DbContext.PatientPreferences
                .AsNoTracking()
                .FirstOrDefaultAsync(p => p.PatientId == id);
        }
    }

    private int CalculateAge(DateTime dob)
    {
        var today = DateTime.Today;
        var age = today.Year - dob.Year;
        if (dob.Date > today.AddYears(-age)) age--;
        return age;
    }
}
