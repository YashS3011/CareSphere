@page "/patients/create"
@attribute [Authorize(Policy = PolicyNames.Permission_Patients_Create)]
@using CareSphere.Models
@using CareSphere.Data
@inject IPatientService PatientService
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager

<PageTitle>Register Patient - CareSphere</PageTitle>

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1"><i class="bi bi-person-plus-fill text-primary"></i> Register New Patient</h3>
        <p class="text-muted small mb-0">Add a new patient record to the system</p>
    </div>
    <div class="page-actions">
        <a href="/patients" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <EditForm Model="@patient" FormName="registerPatient" OnValidSubmit="ProcessValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary class="alert alert-danger mb-4" />
            <InputText type="hidden" @bind-Value="patient.Mrn" />

            <!-- Basic Information Section -->
            <h5 class="text-uppercase text-muted small fw-bold mb-3 border-bottom pb-2">Basic Information</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">First Name <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="patient.FirstName" />
                    <ValidationMessage For="@(() => patient.FirstName)" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Last Name <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="patient.LastName" />
                    <ValidationMessage For="@(() => patient.LastName)" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Date of Birth <span class="text-danger">*</span></label>
                    <InputDate class="form-control" @bind-Value="patient.DateOfBirth" />
                    <ValidationMessage For="@(() => patient.DateOfBirth)" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Gender <span class="text-danger">*</span></label>
                    <InputSelect class="form-select" @bind-Value="patient.Gender">
                        <option value="">Select Gender</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => patient.Gender)" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Blood Group</label>
                    <InputSelect class="form-select" @bind-Value="patient.BloodGroup">
                        <option value="">Select Blood Group</option>
                        <option value="A+">A+</option>
                        <option value="A-">A-</option>
                        <option value="B+">B+</option>
                        <option value="B-">B-</option>
                        <option value="AB+">AB+</option>
                        <option value="AB-">AB-</option>
                        <option value="O+">O+</option>
                        <option value="O-">O-</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => patient.BloodGroup)" />
                </div>
            </div>

            <!-- Preferences Section -->
            <h5 class="text-uppercase text-muted small fw-bold mb-3 border-bottom pb-2">Preferences</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Preferred Channel <span class="text-danger">*</span></label>
                    <InputSelect class="form-select" @bind-Value="preferredChannel">
                        <option value="SMS">SMS Text Messages</option>
                        <option value="WhatsApp">WhatsApp Message</option>
                        <option value="Voice">Voice Automated Call</option>
                        <option value="InApp">In-App Portal Notification</option>
                    </InputSelect>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Preferred Language <span class="text-danger">*</span></label>
                    <InputSelect class="form-select" @bind-Value="preferredLanguage">
                        <option value="en">English</option>
                        <option value="hi">Hindi (हिंदी)</option>
                        <option value="ta">Tamil (தமிழ்)</option>
                        <option value="te">Telugu (తెలుగు)</option>
                        <option value="kn">Kannada (ਕನ್ನಡ)</option>
                        <option value="ml">Malayalam (മലയാളം)</option>
                        <option value="bn">Bengali (বাংলা)</option>
                        <option value="mr">Marathi (मराठी)</option>
                        <option value="gu">Gujarati (ગુજરાતી)</option>
                        <option value="pa">Punjabi (ਪੰਜਾਬੀ)</option>
                    </InputSelect>
                </div>
            </div>

            <!-- Contact & Identifiers Section -->
            <h5 class="text-uppercase text-muted small fw-bold mb-3 border-bottom pb-2">Contact &amp; Identifiers</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Phone Number <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="patient.Phone" />
                    <ValidationMessage For="@(() => patient.Phone)" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Email (Optional)</label>
                    <InputText class="form-control" type="email" @bind-Value="patient.Email" />
                    <ValidationMessage For="@(() => patient.Email)" />
                </div>

                <div class="col-12">
                    <label class="form-label fw-semibold">Address</label>
                    <InputTextArea class="form-control" @bind-Value="patient.Address" rows="3" />
                    <ValidationMessage For="@(() => patient.Address)" />
                </div>

                <div class="col-md-12">
                    <label class="form-label fw-semibold">ABHA ID (Optional)</label>
                    <InputText class="form-control" @bind-Value="patient.AbhaId" placeholder="e.g. 91-XXXX-XXXX-XXXX" />
                    <ValidationMessage For="@(() => patient.AbhaId)" />
                    <small class="text-muted d-block mt-1">
                        <i class="bi bi-info-circle me-1"></i> ABHA API integration is coming in a future update.
                    </small>
                </div>
            </div>

            <!-- Buttons -->
            <div class="d-flex gap-2 justify-content-end border-top pt-3">
                <a href="/patients" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    }
                    <i class="bi bi-check-circle me-1"></i> Register Patient
                </button>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger d-flex align-items-center mt-3" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <div>@errorMessage</div>
                </div>
            }
        </EditForm>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    public Patient patient { get; set; } = new()
    {
        DateOfBirth = DateTime.Today.AddYears(-30),
        Mrn = "TBD"
    };

    private string preferredChannel { get; set; } = "SMS";
    private string preferredLanguage { get; set; } = "en";

    private bool isSubmitting = false;
    private string errorMessage = string.Empty;

    private async Task ProcessValidSubmit()
    {
        try
        {
            isSubmitting = true;
            errorMessage = string.Empty;

            await PatientService.CreatePatientAsync(patient);

            // Add/save PatientPreference directly
            var pref = new PatientPreference
            {
                Id = Guid.NewGuid(),
                PatientId = patient.Id,
                TenantId = patient.TenantId,
                PreferredChannel = preferredChannel,
                PreferredLanguage = preferredLanguage,
                CreatedAt = DateTime.UtcNow
            };
            DbContext.PatientPreferences.Add(pref);
            await DbContext.SaveChangesAsync();

            NavigationManager.NavigateTo("/patients");
        }
        catch (Microsoft.AspNetCore.Components.NavigationException)
        {
            throw;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error registering patient: {ex.Message}";
            isSubmitting = false;
        }
    }
}
