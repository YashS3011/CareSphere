@page "/patients/edit/{id:guid}"
@attribute [Authorize(Policy = PolicyNames.Permission_Patients_Edit)]
@using CareSphere.Models
@using CareSphere.Data
@using Microsoft.EntityFrameworkCore
@inject IPatientService PatientService
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Edit Patient - CareSphere</PageTitle>

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1"><i class="bi bi-pencil-square text-primary"></i> Edit Patient Record</h3>
        <p class="text-muted small mb-0">Modify details for registered patient</p>
    </div>
    <div class="page-actions">
        <a href="/patients" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>
</div>

@if (patient == null && !isNotFound)
{
    <div class="text-center py-5 bg-white rounded shadow-sm">
        <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
        <p class="text-muted mt-2 mb-0">Loading patient details...</p>
    </div>
}
else if (isNotFound)
{
    <div class="alert alert-danger d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <div>Patient record not found.</div>
    </div>
    <a href="/patients" class="btn btn-primary">Back to Patient List</a>
}
else if (patient != null)
{
    <EditForm Model="@patient" OnValidSubmit="HandleValidSubmit" FormName="editPatient">
        <DataAnnotationsValidator />
        
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">
                <!-- Basic Information Section -->
                <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                    <h5 class="text-uppercase text-muted small fw-bold mb-0">Basic Information</h5>
                    <span class="badge bg-secondary-subtle text-secondary border">MRN: @patient.Mrn</span>
                </div>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">First Name <span class="text-danger">*</span></label>
                        <InputText class="form-control" @bind-Value="patient.FirstName" />
                        <ValidationMessage For="@(() => patient.FirstName)" class="text-danger" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Last Name <span class="text-danger">*</span></label>
                        <InputText class="form-control" @bind-Value="patient.LastName" />
                        <ValidationMessage For="@(() => patient.LastName)" class="text-danger" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Date of Birth <span class="text-danger">*</span></label>
                        <InputDate class="form-control" @bind-Value="patient.DateOfBirth" />
                        <ValidationMessage For="@(() => patient.DateOfBirth)" class="text-danger" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Gender <span class="text-danger">*</span></label>
                        <InputSelect class="form-select" @bind-Value="patient.Gender">
                            <option value="">Select Gender</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => patient.Gender)" class="text-danger" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Blood Group</label>
                        <InputSelect class="form-select" @bind-Value="patient.BloodGroup">
                            <option value="">Select Blood Group</option>
                            <option value="A+">A+</option>
                            <option value="A-">A-</option>
                            <option value="B+">B+</option>
                            <option value="B-">B-</option>
                            <option value="AB+">AB+</option>
                            <option value="AB-">AB-</option>
                            <option value="O+">O+</option>
                            <option value="O-">O-</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => patient.BloodGroup)" class="text-danger" />
                    </div>
                </div>

                @if (preferences != null)
                {
                    <!-- Preferences Section -->
                    <h5 class="text-uppercase text-muted small fw-bold mb-3 border-bottom pb-2">Preferences</h5>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Preferred Channel <span class="text-danger">*</span></label>
                            <InputSelect class="form-select" @bind-Value="preferences.PreferredChannel">
                                <option value="SMS">SMS Text Messages</option>
                                <option value="WhatsApp">WhatsApp Message</option>
                                <option value="Voice">Voice Automated Call</option>
                                <option value="InApp">In-App Portal Notification</option>
                            </InputSelect>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Preferred Language <span class="text-danger">*</span></label>
                            <InputSelect class="form-select" @bind-Value="preferences.PreferredLanguage">
                                <option value="en">English</option>
                                <option value="hi">Hindi (हिंदी)</option>
                                <option value="ta">Tamil (தமிழ்)</option>
                                <option value="te">Telugu (తెలుగు)</option>
                                <option value="kn">Kannada (ਕನ್ನಡ)</option>
                                <option value="ml">Malayalam (മലയാളം)</option>
                                <option value="bn">Bengali (বাংলা)</option>
                                <option value="mr">Marathi (मराठी)</option>
                                <option value="gu">Gujarati (ગુજરાતી)</option>
                                <option value="pa">Punjabi (ਪੰਜਾਬੀ)</option>
                            </InputSelect>
                        </div>
                    </div>
                }

                <!-- Contact & Identifiers Section -->
                <h5 class="text-uppercase text-muted small fw-bold mb-3 border-bottom pb-2">Contact &amp; Identifiers</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Phone Number <span class="text-danger">*</span></label>
                        <InputText class="form-control" @bind-Value="patient.Phone" />
                        <ValidationMessage For="@(() => patient.Phone)" class="text-danger" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Email (Optional)</label>
                        <InputText class="form-control" type="email" @bind-Value="patient.Email" />
                        <ValidationMessage For="@(() => patient.Email)" class="text-danger" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Address</label>
                        <InputTextArea class="form-control" @bind-Value="patient.Address" rows="3" />
                        <ValidationMessage For="@(() => patient.Address)" class="text-danger" />
                    </div>
                    <div class="col-md-12">
                        <label class="form-label fw-semibold">ABHA ID (Optional)</label>
                        <InputText class="form-control" @bind-Value="patient.AbhaId" placeholder="e.g. 91-XXXX-XXXX-XXXX" />
                        <ValidationMessage For="@(() => patient.AbhaId)" class="text-danger" />
                    </div>
                </div>

                <!-- Submit and Cancel Buttons -->
                <div class="d-flex gap-2 justify-content-end border-top pt-3">
                    <a href="/patients" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        }
                        <i class="bi bi-check-circle me-1"></i> Save Changes
                    </button>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger d-flex align-items-center mt-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <div>@errorMessage</div>
            </div>
        }
    </EditForm>
}

@code {
    [Parameter]
    public Guid id { get; set; }

    private Patient? patient;
    private PatientPreference? preferences;
    private bool isNotFound = false;
    private bool isSubmitting = false;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        patient = await PatientService.GetPatientByIdAsync(id);
        if (patient == null)
        {
            isNotFound = true;
        }
        else
        {
            preferences = await DbContext.PatientPreferences
                .FirstOrDefaultAsync(p => p.PatientId == id);

            if (preferences == null)
            {
                preferences = new PatientPreference
                {
                    Id = Guid.NewGuid(),
                    PatientId = id,
                    TenantId = patient.TenantId,
                    PreferredChannel = "SMS",
                    PreferredLanguage = "en",
                    CreatedAt = DateTime.UtcNow
                };
                DbContext.PatientPreferences.Add(preferences);
                await DbContext.SaveChangesAsync();
            }
        }
    }

    private async Task HandleValidSubmit()
    {
        if (patient != null)
        {
            try
            {
                isSubmitting = true;
                errorMessage = string.Empty;
                
                await PatientService.UpdatePatientAsync(patient);
                
                if (preferences != null)
                {
                    preferences.UpdatedAt = DateTime.UtcNow;
                    DbContext.PatientPreferences.Update(preferences);
                    await DbContext.SaveChangesAsync();
                }
                
                NavigationManager.NavigateTo("/patients");
            }
            catch (Exception ex)
            {
                errorMessage = $"Error updating patient: {ex.Message}";
            }
            finally
            {
                isSubmitting = false;
            }
        }
    }
}
