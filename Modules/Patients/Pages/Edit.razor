@page "/patients/edit/{id:guid}"
@attribute [Authorize(Policy = PolicyNames.Permission_Patients_Edit)]
@using CareSphere.Models
@using CareSphere.Data
@using Microsoft.EntityFrameworkCore
@inject IPatientService PatientService
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Edit Patient - CareSphere</PageTitle>

<h2>Edit Patient</h2>
<hr />

@if (patient == null && !isNotFound)
{
    <p><em>Loading...</em></p>
}
else if (isNotFound)
{
    <div class="alert alert-danger">Patient not found.</div>
    <a href="/patients" class="btn btn-primary">Back to List</a>
}
else if (patient != null)
{
    <EditForm Model="@patient" OnValidSubmit="HandleValidSubmit" FormName="editPatient">
        <DataAnnotationsValidator />
        
        <div class="card mb-4">
            <div class="card-header bg-light d-flex justify-content-between">
                <h5 class="mb-0">Basic Information</h5>
                <span class="badge bg-secondary">MRN: @patient.Mrn</span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">First Name *</label>
                        <InputText class="form-control" @bind-Value="patient.FirstName" />
                        <ValidationMessage For="@(() => patient.FirstName)" class="text-danger" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Last Name *</label>
                        <InputText class="form-control" @bind-Value="patient.LastName" />
                        <ValidationMessage For="@(() => patient.LastName)" class="text-danger" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Date of Birth *</label>
                        <InputDate class="form-control" @bind-Value="patient.DateOfBirth" />
                        <ValidationMessage For="@(() => patient.DateOfBirth)" class="text-danger" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Gender *</label>
                        <InputSelect class="form-select" @bind-Value="patient.Gender">
                            <option value="">Select Gender</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => patient.Gender)" class="text-danger" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Blood Group</label>
                        <InputSelect class="form-select" @bind-Value="patient.BloodGroup">
                            <option value="">Select Blood Group</option>
                            <option value="A+">A+</option>
                            <option value="A-">A-</option>
                            <option value="B+">B+</option>
                            <option value="B-">B-</option>
                            <option value="AB+">AB+</option>
                            <option value="AB-">AB-</option>
                            <option value="O+">O+</option>
                            <option value="O-">O-</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => patient.BloodGroup)" class="text-danger" />
                    </div>
                </div>
            </div>
        </div>

        @if (preferences != null)
        {
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Preferences</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Preferred Channel *</label>
                            <InputSelect class="form-select" @bind-Value="preferences.PreferredChannel">
                                <option value="SMS">SMS Text Messages</option>
                                <option value="WhatsApp">WhatsApp Message</option>
                                <option value="Voice">Voice Automated Call</option>
                                <option value="InApp">In-App Portal Notification</option>
                            </InputSelect>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Preferred Language *</label>
                            <InputSelect class="form-select" @bind-Value="preferences.PreferredLanguage">
                                <option value="en">English</option>
                                <option value="hi">Hindi (हिंदी)</option>
                                <option value="ta">Tamil (தமிழ்)</option>
                                <option value="te">Telugu (తెలుగు)</option>
                                <option value="kn">Kannada (ਕನ್ನಡ)</option>
                                <option value="ml">Malayalam (മലയാളം)</option>
                                <option value="bn">Bengali (বাংলা)</option>
                                <option value="mr">Marathi (मराठी)</option>
                                <option value="gu">Gujarati (ગુજરાતી)</option>
                                <option value="pa">Punjabi (ਪੰਜਾਬੀ)</option>
                            </InputSelect>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">Contact & Identifiers</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Phone Number *</label>
                        <InputText class="form-control" @bind-Value="patient.Phone" />
                        <ValidationMessage For="@(() => patient.Phone)" class="text-danger" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email (Optional)</label>
                        <InputText class="form-control" type="email" @bind-Value="patient.Email" />
                        <ValidationMessage For="@(() => patient.Email)" class="text-danger" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Address</label>
                        <InputTextArea class="form-control" @bind-Value="patient.Address" rows="3" />
                        <ValidationMessage For="@(() => patient.Address)" class="text-danger" />
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">ABHA ID (Optional)</label>
                        <InputText class="form-control" @bind-Value="patient.AbhaId" placeholder="e.g. 91-XXXX-XXXX-XXXX" />
                        <ValidationMessage For="@(() => patient.AbhaId)" class="text-danger" />
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-warning" disabled="@isSubmitting">
                @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> }
                Save Changes
            </button>
            <a href="/patients" class="btn btn-secondary">Cancel</a>
        </div>
        
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }
    </EditForm>
}

@code {
    [Parameter]
    public Guid id { get; set; }

    private Patient? patient;
    private PatientPreference? preferences;
    private bool isNotFound = false;
    private bool isSubmitting = false;
    private string errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        patient = await PatientService.GetPatientByIdAsync(id);
        if (patient == null)
        {
            isNotFound = true;
        }
        else
        {
            preferences = await DbContext.PatientPreferences
                .FirstOrDefaultAsync(p => p.PatientId == id);

            if (preferences == null)
            {
                preferences = new PatientPreference
                {
                    Id = Guid.NewGuid(),
                    PatientId = id,
                    TenantId = patient.TenantId,
                    PreferredChannel = "SMS",
                    PreferredLanguage = "en",
                    CreatedAt = DateTime.UtcNow
                };
                DbContext.PatientPreferences.Add(preferences);
                await DbContext.SaveChangesAsync();
            }
        }
    }

    private async Task HandleValidSubmit()
    {
        if (patient != null)
        {
            try
            {
                isSubmitting = true;
                errorMessage = string.Empty;
                
                await PatientService.UpdatePatientAsync(patient);
                
                if (preferences != null)
                {
                    preferences.UpdatedAt = DateTime.UtcNow;
                    DbContext.PatientPreferences.Update(preferences);
                    await DbContext.SaveChangesAsync();
                }
                
                NavigationManager.NavigateTo("/patients");
            }
            catch (Exception ex)
            {
                errorMessage = $"Error updating patient: {ex.Message}";
            }
            finally
            {
                isSubmitting = false;
            }
        }
    }
}
