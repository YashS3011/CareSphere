@page "/appointments/book"
@attribute [Authorize(Policy = PolicyNames.Permission_Appointments_Create)]
@inject IAppointmentService AppointmentService
@inject IDoctorScheduleService DoctorScheduleService
@inject IDoctorReadModel DoctorReadModel
@inject IPatientReadModel PatientReadModel
@inject TabIsolatedAuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<div class="container py-4 animate-fade-in">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card bg-dark text-white border-0 shadow">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="h3 mb-1 fw-bold">Book Appointment</h1>
                        <p class="text-light opacity-75 mb-0">Schedule a patient with a doctor</p>
                    </div>
                    <div>
                        <a href="/appointments" class="btn btn-outline-light">
                            <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm p-4">
                <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-info-circle me-2 text-primary"></i>Appointment Details</h5>

                <!-- Step 1: Select Doctor -->
                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary">Step 1: Select Doctor</label>
                    <select class="form-select form-select-lg" @onchange="OnDoctorChanged">
                        <option value="">-- Select Doctor --</option>
                        @foreach (var doc in doctors)
                        {
                            <option value="@doc.Id">@doc.FullName (@doc.Specialty)</option>
                        }
                    </select>
                </div>

                <!-- Step 2: Select Date -->
                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary">Step 2: Select Date</label>
                    <input type="date" class="form-control form-control-lg" min="@DateTime.UtcNow.ToString("yyyy-MM-dd")" value="@selectedDate.ToString("yyyy-MM-dd")" @onchange="OnDateChanged" disabled="@(selectedDoctorId == Guid.Empty)" />
                </div>

                <!-- Step 3: Select Time Slot -->
                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary">Step 3: Select Time Slot</label>
                    @if (selectedDoctorId == Guid.Empty)
                    {
                        <div class="p-3 border rounded text-muted bg-light small">Select a doctor first to see schedules.</div>
                    }
                    else if (isSlotsLoading)
                    {
                        <div class="d-flex align-items-center py-2">
                            <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                            <span class="text-muted small">Loading available slots...</span>
                        </div>
                    }
                    else if (allSlots.Count == 0)
                    {
                        <div class="alert alert-warning border-0 small mb-0"><i class="bi bi-calendar-x me-2"></i>Doctor is not scheduled to work on this day.</div>
                    }
                    else
                    {
                        <div class="row g-2">
                            @foreach (var slot in allSlots)
                            {
                                var isBooked = bookedSlots.Contains(slot);
                                var isSelected = selectedSlot == slot;
                                <div class="col-auto">
                                    <button type="button" 
                                            class="btn @(isBooked ? "btn-secondary opacity-25" : (isSelected ? "btn-primary fw-bold" : "btn-outline-primary"))" 
                                            disabled="@isBooked"
                                            @onclick="() => SelectSlot(slot)">
                                        @slot.ToString("hh:mm tt")
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Step 4: Search and Select Patient -->
                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary">Step 4: Select Patient</label>
                    <div class="input-group">
                        <input type="text" class="form-control" placeholder="Search patient by Name, MRN, or Phone..." @bind="patientSearchQuery" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
                        <button class="btn btn-outline-primary" type="button" @onclick="SearchPatients"><i class="bi bi-search"></i> Search</button>
                    </div>
                    @if (isSearchingPatients)
                    {
                        <div class="d-flex align-items-center py-2">
                            <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                            <span class="text-muted small">Searching...</span>
                        </div>
                    }
                    else if (patientSearchResults.Any())
                    {
                        <div class="list-group mt-2 border shadow-sm rounded overflow-auto" style="max-height: 200px;">
                            @foreach (var p in patientSearchResults)
                            {
                                <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(selectedPatient?.Id == p.Id ? "active" : "")" @onclick="() => SelectPatient(p)">
                                    <div>
                                        <div class="fw-bold">@p.FullName</div>
                                        <small class="opacity-75">MRN: @p.MRN | Phone: @p.Phone</small>
                                    </div>
                                    @if (selectedPatient?.Id == p.Id)
                                    {
                                        <span class="badge bg-light text-primary"><i class="bi bi-check-lg"></i> Selected</span>
                                    }
                                </button>
                            }
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(patientSearchQuery) && patientSearchQuery.Length >= 2)
                    {
                        <div class="p-2 border rounded bg-light text-muted small mt-2">No patients found.</div>
                    }
                </div>

                <!-- Step 5: Select Appointment Type -->
                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary">Step 5: Select Appointment Type</label>
                    <select class="form-select form-select-lg" @bind="appointmentType">
                        <option value="OPD">OPD (Outpatient Department)</option>
                        <option value="FollowUp">FollowUp</option>
                        <option value="TeleConsult">TeleConsult</option>
                    </select>
                </div>

                <!-- Step 6: Notes -->
                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary">Step 6: Notes (Optional)</label>
                    <textarea class="form-control" rows="3" placeholder="Add any booking notes here..." @bind="notes"></textarea>
                </div>

                <!-- Submit Button -->
                <div class="d-grid mt-4">
                    <button type="button" class="btn btn-primary btn-lg" disabled="@(!IsFormValid())" @onclick="ConfirmBooking">
                        <i class="bi bi-calendar-check-fill me-2"></i>Confirm Appointment
                    </button>
                </div>

            </div>
        </div>

        <!-- Right Summary Panel -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm bg-light p-4 sticky-top" style="top: 2rem;">
                <h5 class="fw-bold mb-3 text-dark"><i class="bi bi-journal-text me-2 text-primary"></i>Summary</h5>
                <hr />
                <div class="mb-3">
                    <small class="text-secondary d-block">Doctor</small>
                    <strong class="text-dark">@(selectedDoctorName ?? "None selected")</strong>
                </div>
                <div class="mb-3">
                    <small class="text-secondary d-block">Date</small>
                    <strong class="text-dark">@selectedDate.ToString("dddd, dd MMM yyyy")</strong>
                </div>
                <div class="mb-3">
                    <small class="text-secondary d-block">Time Slot</small>
                    <strong class="text-primary fs-5">@(selectedSlot.HasValue ? selectedSlot.Value.ToString("hh:mm tt") : "None selected")</strong>
                </div>
                <div class="mb-3">
                    <small class="text-secondary d-block">Patient</small>
                    <strong class="text-dark">@(selectedPatient?.FullName ?? "None selected")</strong>
                    @if (selectedPatient != null)
                    {
                        <span class="d-block small text-muted">MRN: @selectedPatient.MRN</span>
                    }
                </div>
                <div class="mb-3">
                    <small class="text-secondary d-block">Type</small>
                    <span class="badge bg-info text-dark">@appointmentType</span>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<DoctorSummary> doctors = new();
    private Guid selectedDoctorId = Guid.Empty;
    private string? selectedDoctorName;
    private DateTime selectedDate = DateTime.UtcNow.Date;

    private List<DateTime> allSlots = new();
    private List<DateTime> bookedSlots = new();
    private DateTime? selectedSlot;
    private bool isSlotsLoading = false;

    private string patientSearchQuery = string.Empty;
    private List<PatientSummary> patientSearchResults = new();
    private PatientSummary? selectedPatient;
    private bool isSearchingPatients = false;

    private string appointmentType = "OPD";
    private string notes = string.Empty;

    private string? successMessage;
    private string? errorMessage;

    private Guid currentTenantId;
    private string currentUserId = "system";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var tenantIdOpt = CurrentUserHelper.GetTenantId(user);
        var userIdOpt = CurrentUserHelper.GetUserId(user);

        if (tenantIdOpt.HasValue)
        {
            currentTenantId = tenantIdOpt.Value;
            currentUserId = userIdOpt ?? "system";
            doctors = (await DoctorReadModel.GetAllAsync(currentTenantId)).ToList();
        }
    }

    private async Task OnDoctorChanged(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var docId))
        {
            selectedDoctorId = docId;
            selectedDoctorName = doctors.FirstOrDefault(d => d.Id == docId)?.FullName;
            selectedSlot = null;
            await LoadSlotsAsync();
        }
        else
        {
            selectedDoctorId = Guid.Empty;
            selectedDoctorName = null;
            selectedSlot = null;
            allSlots.Clear();
            bookedSlots.Clear();
        }
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            selectedDate = date;
            selectedSlot = null;
            await LoadSlotsAsync();
        }
    }

    private async Task LoadSlotsAsync()
    {
        if (selectedDoctorId == Guid.Empty) return;

        isSlotsLoading = true;
        errorMessage = null;
        try
        {
            allSlots.Clear();
            bookedSlots.Clear();

            var dayOfWeekVal = (int)selectedDate.DayOfWeek;
            var schedules = await DoctorScheduleService.GetScheduleAsync(selectedDoctorId, currentTenantId);
            var schedule = schedules.FirstOrDefault(s => s.DayOfWeek == dayOfWeekVal && s.IsActive);

            if (schedule != null)
            {
                var current = selectedDate.Date.Add(schedule.StartTime);
                var end = selectedDate.Date.Add(schedule.EndTime);
                var duration = TimeSpan.FromMinutes(schedule.SlotDurationMinutes);

                while (current + duration <= end)
                {
                    allSlots.Add(current);
                    current = current.Add(duration);
                }

                var appointments = await AppointmentService.GetByDoctorAsync(selectedDoctorId, selectedDate, currentTenantId);
                bookedSlots = appointments.Where(a => a.Status != "Cancelled").Select(a => a.SlotStart).ToList();
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load slots: " + ex.Message;
        }
        finally
        {
            isSlotsLoading = false;
        }
    }

    private void SelectSlot(DateTime slot)
    {
        selectedSlot = slot;
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchPatients();
        }
    }

    private async Task SearchPatients()
    {
        if (string.IsNullOrWhiteSpace(patientSearchQuery) || patientSearchQuery.Length < 2) return;

        isSearchingPatients = true;
        try
        {
            var results = await PatientReadModel.SearchAsync(patientSearchQuery, currentTenantId);
            patientSearchResults = results.ToList();
        }
        catch (Exception ex)
        {
            errorMessage = "Patient search failed: " + ex.Message;
        }
        finally
        {
            isSearchingPatients = false;
        }
    }

    private void SelectPatient(PatientSummary patient)
    {
        selectedPatient = patient;
    }

    private bool IsFormValid()
    {
        return selectedDoctorId != Guid.Empty &&
               selectedSlot.HasValue &&
               selectedPatient != null &&
               !string.IsNullOrEmpty(appointmentType);
    }

    private async Task ConfirmBooking()
    {
        if (!IsFormValid()) return;

        successMessage = null;
        errorMessage = null;

        try
        {
            await AppointmentService.BookAsync(
                selectedPatient!.Id,
                selectedDoctorId,
                selectedSlot!.Value,
                appointmentType,
                notes,
                currentUserId,
                currentTenantId
            );

            successMessage = "Appointment booked successfully!";
            ResetForm();
        }
        catch (InvalidOperationException ex) when (ex.Message.Contains("no longer available"))
        {
            errorMessage = "Slot no longer available";
            await LoadSlotsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = "Booking failed: " + ex.Message;
        }
    }

    private void ResetForm()
    {
        selectedSlot = null;
        selectedPatient = null;
        patientSearchQuery = string.Empty;
        patientSearchResults.Clear();
        notes = string.Empty;
        appointmentType = "OPD";
        // Reload slots to show updated availability
        _ = LoadSlotsAsync();
    }
}
