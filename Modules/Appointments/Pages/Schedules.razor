@page "/appointments/schedules"
@attribute [Authorize(Policy = PolicyNames.Permission_DoctorSchedule_Manage)]
@inject IDoctorScheduleService DoctorScheduleService
@inject IDoctorReadModel DoctorReadModel
@inject TabIsolatedAuthenticationStateProvider AuthStateProvider

<div class="container py-4 animate-fade-in">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card bg-dark text-white border-0 shadow">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="h3 mb-1 fw-bold">Doctor weekly Schedules</h1>
                        <p class="text-light opacity-75 mb-0">Define weekly work hours and slot durations per doctor</p>
                    </div>
                    <div>
                        <a href="/appointments" class="btn btn-outline-light">
                            <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    <div class="card border-0 shadow-sm p-4 mb-4">
        <div class="row align-items-center">
            <div class="col-md-6">
                <label class="form-label fw-bold text-secondary">Select Doctor</label>
                <select class="form-select form-select-lg" @onchange="OnDoctorChanged">
                    <option value="">-- Select Doctor --</option>
                    @foreach (var doc in doctors)
                    {
                        <option value="@doc.Id">@doc.FullName (@doc.Specialty)</option>
                    }
                </select>
            </div>
        </div>
    </div>

    @if (selectedDoctorId != Guid.Empty)
    {
        @if (isLoading)
        {
            <div class="d-flex justify-content-center my-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading schedule...</span>
                </div>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3 border-0 border-bottom">
                    <h5 class="card-title fw-bold text-dark mb-0"><i class="bi bi-calendar3 me-2 text-primary"></i>Weekly Availability</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4" style="width: 15%;">Day</th>
                                    <th style="width: 20%;">Start Time</th>
                                    <th style="width: 20%;">End Time</th>
                                    <th style="width: 20%;">Slot Duration</th>
                                    <th class="text-end pe-4" style="width: 25%;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var dayOfWeek in DisplayOrder)
                                {
                                    var schedule = doctorSchedules.FirstOrDefault(s => s.DayOfWeek == dayOfWeek);
                                    var dayName = DayNames[dayOfWeek];
                                    var isEditing = editingDayOfWeek == dayOfWeek;

                                    <tr>
                                        <td class="ps-4 fw-bold text-dark">@dayName</td>
                                        @if (isEditing)
                                        {
                                            <td>
                                                <input type="time" class="form-control form-control-sm" @bind="editStartTime" @bind:event="oninput" />
                                            </td>
                                            <td>
                                                <input type="time" class="form-control form-control-sm" @bind="editEndTime" @bind:event="oninput" />
                                            </td>
                                            <td>
                                                <select class="form-select form-select-sm" @bind="editSlotDuration">
                                                    <option value="10">10 Mins</option>
                                                    <option value="15">15 Mins</option>
                                                    <option value="20">20 Mins</option>
                                                    <option value="30">30 Mins</option>
                                                    <option value="45">45 Mins</option>
                                                    <option value="60">60 Mins</option>
                                                </select>
                                            </td>
                                            <td class="text-end pe-4">
                                                <button class="btn btn-success btn-sm me-1" @onclick="() => SaveSchedule(dayOfWeek)">
                                                    <i class="bi bi-check-lg me-1"></i>Save
                                                </button>
                                                <button class="btn btn-outline-secondary btn-sm" @onclick="CancelEdit">
                                                    Cancel
                                                </button>
                                            </td>
                                        }
                                        else
                                        {
                                            if (schedule != null && schedule.IsActive)
                                            {
                                                <td>@FormatTimeSpan(schedule.StartTime)</td>
                                                <td>@FormatTimeSpan(schedule.EndTime)</td>
                                                <td><span class="badge bg-light text-primary">@schedule.SlotDurationMinutes Mins</span></td>
                                                <td class="text-end pe-4">
                                                    <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => StartEdit(dayOfWeek, schedule)">
                                                        <i class="bi bi-pencil me-1"></i>Edit
                                                    </button>
                                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeactivateSchedule(schedule)">
                                                        Remove
                                                    </button>
                                                </td>
                                            }
                                            else
                                            {
                                                <td colspan="3" class="text-muted small">No schedule set for this day</td>
                                                <td class="text-end pe-4">
                                                    <button class="btn btn-primary btn-sm" @onclick="() => StartAdd(dayOfWeek)">
                                                        <i class="bi bi-plus-lg me-1"></i>Add Schedule
                                                    </button>
                                                </td>
                                            }
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<DoctorSummary> doctors = new();
    private Guid selectedDoctorId = Guid.Empty;
    private List<DoctorSchedule> doctorSchedules = new();
    private bool isLoading = false;
    private Guid currentTenantId;

    // Day of week display order: Mon, Tue, Wed, Thu, Fri, Sat, Sun
    private readonly int[] DisplayOrder = new[] { 1, 2, 3, 4, 5, 6, 0 };
    private readonly string[] DayNames = new[] { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };

    private int? editingDayOfWeek;
    private DateTime editStartTime;
    private DateTime editEndTime;
    private int editSlotDuration = 15;

    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var tenantIdOpt = CurrentUserHelper.GetTenantId(user);

        if (tenantIdOpt.HasValue)
        {
            currentTenantId = tenantIdOpt.Value;
            doctors = (await DoctorReadModel.GetAllAsync(currentTenantId)).ToList();
        }
    }

    private async Task OnDoctorChanged(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var docId))
        {
            selectedDoctorId = docId;
            editingDayOfWeek = null;
            await LoadSchedulesAsync();
        }
        else
        {
            selectedDoctorId = Guid.Empty;
            doctorSchedules.Clear();
        }
    }

    private async Task LoadSchedulesAsync()
    {
        if (selectedDoctorId == Guid.Empty) return;

        isLoading = true;
        errorMessage = null;
        try
        {
            doctorSchedules = await DoctorScheduleService.GetScheduleAsync(selectedDoctorId, currentTenantId);
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load schedules: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private string FormatTimeSpan(TimeSpan time)
    {
        return DateTime.Today.Add(time).ToString("hh:mm tt");
    }

    private void StartEdit(int dayOfWeek, DoctorSchedule schedule)
    {
        editingDayOfWeek = dayOfWeek;
        editStartTime = DateTime.Today.Add(schedule.StartTime);
        editEndTime = DateTime.Today.Add(schedule.EndTime);
        editSlotDuration = schedule.SlotDurationMinutes;
    }

    private void StartAdd(int dayOfWeek)
    {
        editingDayOfWeek = dayOfWeek;
        editStartTime = DateTime.Today.AddHours(9); // Default 09:00 AM
        editEndTime = DateTime.Today.AddHours(17);   // Default 05:00 PM
        editSlotDuration = 15;
    }

    private void CancelEdit()
    {
        editingDayOfWeek = null;
    }

    private async Task SaveSchedule(int dayOfWeek)
    {
        successMessage = null;
        errorMessage = null;

        try
        {
            var start = editStartTime.TimeOfDay;
            var end = editEndTime.TimeOfDay;

            if (start >= end)
            {
                errorMessage = "Start time must be before End time.";
                return;
            }

            var scheduleObj = new DoctorSchedule
            {
                DoctorId = selectedDoctorId,
                TenantId = currentTenantId,
                DayOfWeek = dayOfWeek,
                StartTime = start,
                EndTime = end,
                SlotDurationMinutes = editSlotDuration,
                IsActive = true
            };

            await DoctorScheduleService.SetScheduleAsync(selectedDoctorId, new List<DoctorSchedule> { scheduleObj }, currentTenantId);
            editingDayOfWeek = null;
            successMessage = "Schedule updated successfully!";
            await LoadSchedulesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to save schedule: " + ex.Message;
        }
    }

    private async Task DeactivateSchedule(DoctorSchedule schedule)
    {
        successMessage = null;
        errorMessage = null;

        try
        {
            schedule.IsActive = false;
            await DoctorScheduleService.SetScheduleAsync(selectedDoctorId, new List<DoctorSchedule> { schedule }, currentTenantId);
            successMessage = "Schedule removed successfully!";
            await LoadSchedulesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to remove schedule: " + ex.Message;
        }
    }
}
