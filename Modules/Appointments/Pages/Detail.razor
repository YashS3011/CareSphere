@page "/appointments/{AppointmentId:guid}"
@attribute [Authorize(Policy = PolicyNames.Permission_Appointments_View)]
@using CareSphere.Data
@using Microsoft.EntityFrameworkCore
@inject IAppointmentService AppointmentService
@inject ApplicationDbContext DbContext
@inject TabIsolatedAuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Appointment Details - CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-calendar2-check-fill text-primary"></i></div>
            <div>
                <h1 class="page-title">Appointment Details</h1>
                <p class="page-subtitle">Detailed check-in status, patient EMR reference, and queue management</p>
            </div>
        </div>
        <div class="page-actions">
            <a href="/appointments" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to List
            </a>
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="loading-state py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading appointment details...</p>
    </div>
}
else if (appointment == null)
{
    <div class="alert alert-danger border-0 shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> Appointment not found or access denied.
    </div>
}
else
{
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Main Details -->
        <div class="col-lg-8">
            <div class="content-card mb-4 p-4 shadow-sm border-0 rounded-4">
                <div class="d-flex justify-content-between align-items-start border-bottom pb-3 mb-4">
                    <div>
                        <h5 class="fw-bold text-dark mb-1">
                            <i class="bi bi-person-fill me-2 text-primary"></i>Patient Information
                        </h5>
                        <p class="text-muted small mb-0">Demographics & contact information</p>
                    </div>
                    <div>
                        @switch (appointment.Status)
                        {
                            case "Scheduled":
                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2 fs-7">Scheduled</span>
                                break;
                            case "Arrived":
                                <span class="badge bg-info-subtle text-info border border-info-subtle px-3 py-2 fs-7">Arrived / In Queue</span>
                                break;
                            case "InProgress":
                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 fs-7">In Consultation</span>
                                break;
                            case "Completed":
                                <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 fs-7">Completed</span>
                                break;
                            case "Cancelled":
                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2 fs-7">Cancelled</span>
                                break;
                            default:
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2 fs-7">@appointment.Status</span>
                                break;
                        }
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <small class="text-muted d-block small text-uppercase fw-bold">Full Name</small>
                        <span class="text-dark fw-bold fs-5">@appointment.Patient.FirstName @appointment.Patient.LastName</span>
                    </div>
                    <div class="col-md-6">
                        <small class="text-muted d-block small text-uppercase fw-bold">Medical Record Number (MRN)</small>
                        <span class="text-dark font-monospace fw-semibold">@appointment.Patient.Mrn</span>
                    </div>
                    <div class="col-md-6">
                        <small class="text-muted d-block small text-uppercase fw-bold">Phone Number</small>
                        <span class="text-dark">@(appointment.Patient.Phone ?? "N/A")</span>
                    </div>
                    <div class="col-md-6">
                        <small class="text-muted d-block small text-uppercase fw-bold">Email Address</small>
                        <span class="text-dark">@(appointment.Patient.Email ?? "N/A")</span>
                    </div>
                </div>

                <h5 class="fw-bold text-dark border-bottom pb-2 mt-5 mb-4">
                    <i class="bi bi-calendar2-event-fill me-2 text-primary"></i>Consultation & Doctor
                </h5>

                <div class="row g-3">
                    <div class="col-md-6">
                        <small class="text-muted d-block small text-uppercase fw-bold">Consulting Physician</small>
                        <span class="text-dark fw-bold">Dr. @appointment.Doctor.FirstName @appointment.Doctor.LastName</span>
                        <span class="text-muted small d-block">@appointment.Doctor.Specialization</span>
                    </div>
                    <div class="col-md-6">
                        <small class="text-muted d-block small text-uppercase fw-bold">Appointment Type</small>
                        <span class="badge bg-light text-dark border mt-1">@appointment.AppointmentType</span>
                    </div>
                    <div class="col-md-6">
                        <small class="text-muted d-block small text-uppercase fw-bold">Scheduled Slot</small>
                        <span class="text-dark fw-semibold">@appointment.SlotStart.ToLocalTime().ToString("dd MMM yyyy")</span>
                        <span class="text-primary d-block fw-bold">@appointment.SlotStart.ToLocalTime().ToString("hh:mm tt") - @appointment.SlotEnd.ToLocalTime().ToString("hh:mm tt")</span>
                    </div>
                    <div class="col-md-6">
                        <small class="text-muted d-block small text-uppercase fw-bold">Booked By User ID</small>
                        <span class="text-dark font-monospace small">@appointment.BookedByUserId</span>
                    </div>
                    <div class="col-12">
                        <small class="text-muted d-block small text-uppercase fw-bold">Booking Notes / Remarks</small>
                        <p class="text-dark mb-0 p-3 bg-light rounded-3 mt-1 small">@(string.IsNullOrWhiteSpace(appointment.Notes) ? "No notes provided at booking." : appointment.Notes)</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions Panel -->
        <div class="col-lg-4">
            <div class="content-card p-4 shadow-sm border-0 rounded-4 bg-white">
                <h5 class="fw-bold text-dark border-bottom pb-2 mb-4">
                    <i class="bi bi-lightning-charge-fill me-2 text-warning"></i>Actions & Queue
                </h5>

                @if (appointment.Status == "Scheduled" || appointment.Status == "Confirmed")
                {
                    <div class="d-grid gap-3">
                        <button type="button" class="btn btn-success btn-lg fs-6 py-2.5 shadow-sm" @onclick="MarkArrived">
                            <i class="bi bi-check-circle-fill me-2"></i> Patient Arrived (Check-In)
                        </button>

                        <button type="button" class="btn btn-outline-primary btn-lg fs-6 py-2.5" @onclick="MarkCompleted">
                            <i class="bi bi-calendar-check me-2"></i> Mark Completed
                        </button>

                        <button type="button" class="btn btn-outline-danger btn-lg fs-6 py-2.5" @onclick="PromptCancel">
                            <i class="bi bi-x-circle me-2"></i> Cancel Appointment
                        </button>
                    </div>
                    <div class="mt-4 p-3 rounded bg-info-subtle border border-info-subtle">
                        <small class="text-info-emphasis d-flex">
                            <i class="bi bi-info-circle-fill me-2 fs-5"></i>
                            <span>Checking in the patient status updates their status to <strong>Arrived</strong> and automatically enqueues them into the doctor's queue.</span>
                        </small>
                    </div>
                }
                else if (appointment.Status == "Arrived")
                {
                    <div class="d-grid gap-3">
                        <button type="button" class="btn btn-primary btn-lg fs-6 py-2.5" @onclick="MarkCompleted">
                            <i class="bi bi-calendar-check me-2"></i> Mark Completed
                        </button>

                        <button type="button" class="btn btn-outline-danger btn-lg fs-6 py-2.5" disabled>
                            <i class="bi bi-x-circle me-2"></i> Cancel (Arrived)
                        </button>
                    </div>
                    <div class="mt-4 text-center">
                        <span class="text-success small fw-bold"><i class="bi bi-check-circle-fill me-1"></i> Patient is checked-in and waiting in consultation queue.</span>
                    </div>
                }
                else
                {
                    <div class="p-3 bg-light rounded text-center text-muted small">
                        <i class="bi bi-lock me-1"></i> No active actions for this appointment state.
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- Modal Dialog for Cancellation -->
@if (showConfirmModal)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" style="background-color: rgba(0, 0, 0, 0.5); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-danger text-white border-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Cancellation</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseCancelPrompt"></button>
                </div>
                <div class="modal-body py-4">
                    <p class="mb-0 fs-6 text-dark">Are you sure you want to cancel this appointment? This action cannot be undone.</p>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" @onclick="CloseCancelPrompt">Close</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmCancel">Yes, Cancel Appointment</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid AppointmentId { get; set; }

    private Appointment? appointment;
    private bool isLoading = true;
    private Guid currentTenantId;

    private string? successMessage;
    private string? errorMessage;
    private bool showConfirmModal = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var tenantIdOpt = CurrentUserHelper.GetTenantId(user);
        if (tenantIdOpt.HasValue)
        {
            currentTenantId = tenantIdOpt.Value;
            await LoadAppointmentAsync();
        }
        else
        {
            isLoading = false;
        }
    }

    private async Task LoadAppointmentAsync()
    {
        isLoading = true;
        try
        {
            appointment = await DbContext.Appointments
                .Include(a => a.Patient)
                .Include(a => a.Doctor)
                .FirstOrDefaultAsync(a => a.Id == AppointmentId && a.TenantId == currentTenantId);
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load appointment: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task MarkArrived()
    {
        successMessage = null;
        errorMessage = null;
        try
        {
            await AppointmentService.MarkArrivedAsync(AppointmentId, currentTenantId);
            successMessage = "Patient has been marked as Arrived and successfully enqueued.";
            await LoadAppointmentAsync();
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to check in: " + ex.Message;
        }
    }

    private async Task MarkCompleted()
    {
        successMessage = null;
        errorMessage = null;
        try
        {
            await AppointmentService.MarkCompletedAsync(AppointmentId, currentTenantId);
            successMessage = "Appointment marked as Completed.";
            await LoadAppointmentAsync();
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to mark completed: " + ex.Message;
        }
    }

    private void PromptCancel()
    {
        showConfirmModal = true;
    }

    private void CloseCancelPrompt()
    {
        showConfirmModal = false;
    }

    private async Task ConfirmCancel()
    {
        successMessage = null;
        errorMessage = null;
        showConfirmModal = false;
        try
        {
            await AppointmentService.CancelAsync(AppointmentId, currentTenantId);
            successMessage = "Appointment has been cancelled.";
            await LoadAppointmentAsync();
        }
        catch (Exception ex)
        {
            errorMessage = "Cancellation failed: " + ex.Message;
        }
    }
}
