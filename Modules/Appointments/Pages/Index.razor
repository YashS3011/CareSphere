@page "/appointments"
@attribute [Authorize(Policy = PolicyNames.Permission_Appointments_View)]
@inject IAppointmentService AppointmentService
@inject IPatientReadModel PatientReadModel
@inject IDoctorReadModel DoctorReadModel
@inject TabIsolatedAuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Appointment Scheduling - CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-calendar-event-fill"></i></div>
            <div>
                <h1 class="page-title">Appointment Scheduling</h1>
                <p class="page-subtitle">Manage doctor schedules, consultation queues, and book patient appointments</p>
            </div>
        </div>
        <div class="page-actions">
            <AuthorizeView Policy="@PolicyNames.Permission_Appointments_Book">
                <Authorized>
                    <a href="/appointments/book" class="btn btn-primary">
                        <i class="bi bi-calendar-plus me-1"></i> Book Appointment
                    </a>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="loading-state py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading appointments...</p>
    </div>
}
else
{
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    <!-- Metrics Row -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="stat-card stat-card-primary">
                <div class="stat-icon"><i class="bi bi-calendar-event"></i></div>
                <div class="stat-value">@todayCount</div>
                <div class="stat-label">Today's Appointments</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card stat-card-success">
                <div class="stat-icon"><i class="bi bi-calendar-range"></i></div>
                <div class="stat-value">@upcomingCount</div>
                <div class="stat-label">Upcoming This Week</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card stat-card-danger">
                <div class="stat-icon"><i class="bi bi-calendar-x"></i></div>
                <div class="stat-value">@cancelledCount</div>
                <div class="stat-label">Cancelled This Week</div>
            </div>
        </div>
    </div>

    <!-- Today's Appointments Table -->
    <div class="content-card mb-4">
        <div class="content-card-header">
            <h5 class="content-card-title"><i class="bi bi-clock-history me-2 text-primary"></i>Today's Schedule</h5>
        </div>
        <div class="content-card-body p-0">
            @if (todayAppointments.Count == 0)
            {
                <div class="loading-state py-5">
                    <i class="bi bi-calendar-check text-muted display-4 mb-3 d-block"></i>
                    <h5 class="fw-bold">No Appointments</h5>
                    <p class="text-muted small">No appointments scheduled for today.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover data-table mb-0 small">
                        <thead>
                            <tr>
                                <th class="ps-4">Time Slot</th>
                                <th>Patient Name</th>
                                <th>Doctor Name</th>
                                <th>Type</th>
                                <th>Status</th>
                                <th class="pe-4 text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var appt in todayAppointments)
                            {
                                var patientName = GetPatientName(appt.PatientId);
                                var doctorName = GetDoctorName(appt.DoctorId);
                                <tr>
                                    <td class="ps-4 fw-semibold text-primary">
                                        @appt.SlotStart.ToString("hh:mm tt") - @appt.SlotEnd.ToString("hh:mm tt")
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar bg-light text-primary rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 28px; height: 28px; font-size: 0.8rem;">
                                                <i class="bi bi-person-fill"></i>
                                            </div>
                                            <span class="fw-semibold text-dark">@patientName</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="text-dark fw-medium">@doctorName</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border">@appt.AppointmentType</span>
                                    </td>
                                    <td>
                                        @switch (appt.Status)
                                        {
                                            case "Scheduled":
                                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle">Scheduled</span>
                                                break;
                                            case "Confirmed":
                                                <span class="badge bg-success-subtle text-success border border-success-subtle">Confirmed</span>
                                                break;
                                            case "Arrived":
                                                <span class="badge bg-info-subtle text-info border border-info-subtle">Arrived</span>
                                                break;
                                            case "Completed":
                                                <span class="badge bg-success-subtle text-success border border-success-subtle">Completed</span>
                                                break;
                                            case "In Consultation":
                                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle">In Consultation</span>
                                                break;
                                            case "Cancelled":
                                            case "No Show":
                                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle">@appt.Status</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">@appt.Status</span>
                                                break;
                                        }
                                    </td>
                                    <td class="pe-4 text-end">
                                        <div class="d-inline-flex gap-1">
                                            <a class="btn btn-xs btn-outline-primary" href="/appointments/@appt.Id">
                                                <i class="bi bi-eye me-1"></i> View
                                            </a>
                                            @if (appt.Status == "Scheduled" || appt.Status == "Confirmed")
                                            {
                                                <button class="btn btn-xs btn-success text-white" @onclick="() => CheckIn(appt)">
                                                    <i class="bi bi-check-circle me-1"></i> Check In
                                                </button>
                                                <button class="btn btn-xs btn-outline-danger" @onclick="() => PromptCancel(appt)">
                                                    <i class="bi bi-x-circle me-1"></i> Cancel
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

<!-- Modal Dialog for Confirmation -->
@if (showConfirmModal && appointmentToCancel != null)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" style="background-color: rgba(0, 0, 0, 0.5); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-danger text-white border-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Cancellation</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseCancelPrompt"></button>
                </div>
                <div class="modal-body py-4">
                    <p class="mb-0 fs-6 text-dark">Are you sure you want to cancel the appointment for <strong>@GetPatientName(appointmentToCancel.PatientId)</strong> with <strong>@GetDoctorName(appointmentToCancel.DoctorId)</strong> scheduled at <strong>@appointmentToCancel.SlotStart.ToString("hh:mm tt")</strong>?</p>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" @onclick="CloseCancelPrompt">Close</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmCancel">Yes, Cancel Appointment</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Appointment> todayAppointments = new();
    private int todayCount;
    private int upcomingCount;
    private int cancelledCount;
    private bool isLoading = true;
    private Guid currentTenantId;

    private Dictionary<Guid, string> patientNames = new();
    private Dictionary<Guid, string> doctorNames = new();

    private Appointment? appointmentToCancel;
    private bool showConfirmModal = false;

    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var tenantIdOpt = CurrentUserHelper.GetTenantId(user);
        if (tenantIdOpt.HasValue)
        {
            currentTenantId = tenantIdOpt.Value;
            await LoadDataAsync();
        }
        else
        {
            isLoading = false;
        }
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            var today = DateTime.UtcNow.Date;
            var startOfWeek = today;
            var endOfWeek = today.AddDays(7);

            var weekAppointments = await AppointmentService.GetAppointmentsForRangeAsync(startOfWeek, endOfWeek, currentTenantId);

            todayAppointments = weekAppointments.Where(a => a.SlotStart.Date == today).ToList();
            todayCount = todayAppointments.Count(a => a.Status != "Cancelled");

            upcomingCount = weekAppointments.Count(a => a.Status != "Cancelled" && a.SlotStart.Date >= today);
            cancelledCount = weekAppointments.Count(a => a.Status == "Cancelled");

            var uniquePatientIds = weekAppointments.Select(a => a.PatientId).Distinct().ToList();
            var uniqueDoctorIds = weekAppointments.Select(a => a.DoctorId).Distinct().ToList();

            foreach (var pid in uniquePatientIds)
            {
                if (!patientNames.ContainsKey(pid))
                {
                    var summary = await PatientReadModel.GetSummaryAsync(pid, currentTenantId);
                    patientNames[pid] = summary?.FullName ?? "Unknown Patient";
                }
            }

            foreach (var did in uniqueDoctorIds)
            {
                if (!doctorNames.ContainsKey(did))
                {
                    var summary = await DoctorReadModel.GetSummaryAsync(did, currentTenantId);
                    doctorNames[did] = summary?.FullName ?? "Unknown Doctor";
                }
            }
        }
        catch (Exception)
        {
            // Silently handle or log
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetPatientName(Guid patientId)
    {
        return patientNames.TryGetValue(patientId, out var name) ? name : "Loading...";
    }

    private string GetDoctorName(Guid doctorId)
    {
        return doctorNames.TryGetValue(doctorId, out var name) ? name : "Loading...";
    }

    private async Task CheckIn(Appointment appt)
    {
        successMessage = null;
        errorMessage = null;
        try
        {
            await AppointmentService.MarkArrivedAsync(appt.Id, currentTenantId);
            successMessage = $"Patient {GetPatientName(appt.PatientId)} checked in successfully.";
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to check in patient: {ex.Message}";
        }
    }

    private void PromptCancel(Appointment appt)
    {
        appointmentToCancel = appt;
        showConfirmModal = true;
    }

    private void CloseCancelPrompt()
    {
        appointmentToCancel = null;
        showConfirmModal = false;
    }

    private async Task ConfirmCancel()
    {
        if (appointmentToCancel != null)
        {
            await AppointmentService.CancelAsync(appointmentToCancel.Id, currentTenantId);
            showConfirmModal = false;
            appointmentToCancel = null;
            await LoadDataAsync();
        }
    }
}
