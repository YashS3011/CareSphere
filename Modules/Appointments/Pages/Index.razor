@page "/appointments"
@attribute [Authorize(Policy = PolicyNames.Permission_Appointments_View)]
@inject IAppointmentService AppointmentService
@inject IPatientReadModel PatientReadModel
@inject IDoctorReadModel DoctorReadModel
@inject TabIsolatedAuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<div class="container-fluid py-4 animate-fade-in">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card bg-dark text-white border-0 shadow">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="h3 mb-1 fw-bold">Appointment Scheduling</h1>
                        <p class="text-light opacity-75 mb-0">Manage doctor schedules and book patient appointments</p>
                    </div>
                    <div>
                        <a href="/appointments/book" class="btn btn-primary btn-lg shadow-sm">
                            <i class="bi bi-calendar-plus me-2"></i>Book Appointment
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <!-- Metrics Row -->
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm bg-gradient bg-primary text-white h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-uppercase text-light opacity-75 mb-2 fw-semibold">Today's Appointments</h6>
                                <span class="h1 fw-bold mb-0">@todayCount</span>
                            </div>
                            <div class="fs-1 text-light opacity-50">
                                <i class="bi bi-calendar-event"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm bg-gradient bg-success text-white h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-uppercase text-light opacity-75 mb-2 fw-semibold">Upcoming This Week</h6>
                                <span class="h1 fw-bold mb-0">@upcomingCount</span>
                            </div>
                            <div class="fs-1 text-light opacity-50">
                                <i class="bi bi-calendar-range"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm bg-gradient bg-danger text-white h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-uppercase text-light opacity-75 mb-2 fw-semibold">Cancelled This Week</h6>
                                <span class="h1 fw-bold mb-0">@cancelledCount</span>
                            </div>
                            <div class="fs-1 text-light opacity-50">
                                <i class="bi bi-calendar-x"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Today's Appointments Table -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 border-0">
                <h5 class="card-title fw-bold text-dark mb-0"><i class="bi bi-clock-history me-2 text-primary"></i>Today's Schedule</h5>
            </div>
            <div class="card-body p-0">
                @if (todayAppointments.Count == 0)
                {
                    <div class="text-center py-5">
                        <i class="bi bi-calendar-check text-muted display-4"></i>
                        <p class="mt-3 text-muted">No appointments scheduled for today.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Time</th>
                                    <th>Patient Name</th>
                                    <th>Doctor Name</th>
                                    <th>Type</th>
                                    <th>Status</th>
                                    <th class="text-end pe-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var appt in todayAppointments)
                                {
                                    var patientName = GetPatientName(appt.PatientId);
                                    var doctorName = GetDoctorName(appt.DoctorId);
                                    <tr>
                                        <td class="ps-4 fw-semibold text-primary">
                                            @appt.SlotStart.ToString("hh:mm tt") - @appt.SlotEnd.ToString("hh:mm tt")
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="avatar bg-light text-primary rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                                    <i class="bi bi-person-fill"></i>
                                                </div>
                                                <span class="fw-medium">@patientName</span>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="text-dark">@doctorName</span>
                                        </td>
                                        <td>
                                            <span class="badge rounded-pill bg-info text-dark">@appt.AppointmentType</span>
                                        </td>
                                        <td>
                                            @switch (appt.Status)
                                            {
                                                case "Scheduled":
                                                    <span class="badge bg-warning text-dark">Scheduled</span>
                                                    break;
                                                case "Confirmed":
                                                    <span class="badge bg-success">Confirmed</span>
                                                    break;
                                                case "Completed":
                                                    <span class="badge bg-primary">Completed</span>
                                                    break;
                                                case "Cancelled":
                                                    <span class="badge bg-danger">Cancelled</span>
                                                    break;
                                                default:
                                                    <span class="badge bg-secondary">@appt.Status</span>
                                                    break;
                                            }
                                        </td>
                                        <td class="text-end pe-4">
                                            @if (appt.Status == "Scheduled" || appt.Status == "Confirmed")
                                            {
                                                <button class="btn btn-outline-danger btn-sm" @onclick="() => PromptCancel(appt)">
                                                    <i class="bi bi-x-circle me-1"></i>Cancel
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Modal Dialog for Confirmation -->
@if (showConfirmModal && appointmentToCancel != null)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" style="background-color: rgba(0, 0, 0, 0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-danger text-white border-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Cancellation</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseCancelPrompt"></button>
                </div>
                <div class="modal-body py-4">
                    <p class="mb-0 fs-5">Are you sure you want to cancel the appointment for <strong>@GetPatientName(appointmentToCancel.PatientId)</strong> with <strong>@GetDoctorName(appointmentToCancel.DoctorId)</strong> scheduled at <strong>@appointmentToCancel.SlotStart.ToString("hh:mm tt")</strong>?</p>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" @onclick="CloseCancelPrompt">Close</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmCancel">Yes, Cancel Appointment</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Appointment> todayAppointments = new();
    private int todayCount;
    private int upcomingCount;
    private int cancelledCount;
    private bool isLoading = true;
    private Guid currentTenantId;

    private Dictionary<Guid, string> patientNames = new();
    private Dictionary<Guid, string> doctorNames = new();

    private Appointment? appointmentToCancel;
    private bool showConfirmModal = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var tenantIdOpt = CurrentUserHelper.GetTenantId(user);
        if (tenantIdOpt.HasValue)
        {
            currentTenantId = tenantIdOpt.Value;
            await LoadDataAsync();
        }
        else
        {
            isLoading = false;
        }
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            var today = DateTime.UtcNow.Date;
            var startOfWeek = today;
            var endOfWeek = today.AddDays(7);

            var weekAppointments = await AppointmentService.GetAppointmentsForRangeAsync(startOfWeek, endOfWeek, currentTenantId);

            todayAppointments = weekAppointments.Where(a => a.SlotStart.Date == today).ToList();
            todayCount = todayAppointments.Count(a => a.Status != "Cancelled");

            upcomingCount = weekAppointments.Count(a => a.Status != "Cancelled" && a.SlotStart.Date >= today);
            cancelledCount = weekAppointments.Count(a => a.Status == "Cancelled");

            var uniquePatientIds = weekAppointments.Select(a => a.PatientId).Distinct().ToList();
            var uniqueDoctorIds = weekAppointments.Select(a => a.DoctorId).Distinct().ToList();

            foreach (var pid in uniquePatientIds)
            {
                if (!patientNames.ContainsKey(pid))
                {
                    var summary = await PatientReadModel.GetSummaryAsync(pid, currentTenantId);
                    patientNames[pid] = summary?.FullName ?? "Unknown Patient";
                }
            }

            foreach (var did in uniqueDoctorIds)
            {
                if (!doctorNames.ContainsKey(did))
                {
                    var summary = await DoctorReadModel.GetSummaryAsync(did, currentTenantId);
                    doctorNames[did] = summary?.FullName ?? "Unknown Doctor";
                }
            }
        }
        catch (Exception)
        {
            // Silently handle or log
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetPatientName(Guid patientId)
    {
        return patientNames.TryGetValue(patientId, out var name) ? name : "Loading...";
    }

    private string GetDoctorName(Guid doctorId)
    {
        return doctorNames.TryGetValue(doctorId, out var name) ? name : "Loading...";
    }

    private void PromptCancel(Appointment appt)
    {
        appointmentToCancel = appt;
        showConfirmModal = true;
    }

    private void CloseCancelPrompt()
    {
        appointmentToCancel = null;
        showConfirmModal = false;
    }

    private async Task ConfirmCancel()
    {
        if (appointmentToCancel != null)
        {
            await AppointmentService.CancelAsync(appointmentToCancel.Id, currentTenantId);
            showConfirmModal = false;
            appointmentToCancel = null;
            await LoadDataAsync();
        }
    }
}
