@page "/nursing"
@rendermode InteractiveServer
@inject CareSphere.Data.ApplicationDbContext DbContext
@inject IBedReadModel BedReadModel
@inject TabIsolatedAuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@using Microsoft.EntityFrameworkCore

<PageTitle>Nursing Dashboard - CareSphere</PageTitle>

<div class="container py-4 animate-fade-in">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card bg-dark text-white border-0 shadow">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="h3 mb-1 fw-bold"><i class="bi bi-heart-pulse-fill me-2 text-danger"></i>Nursing Dashboard</h1>
                        <p class="text-light opacity-75 mb-0">Overview of active patients, daily activity, and critical clinical events</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row g-3 mb-4">
        <!-- Vitals Card -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 p-3 bg-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-secondary small fw-bold d-block mb-1">VITALS RECORDED TODAY</span>
                        <h3 class="fw-bold mb-0 text-dark">@vitalsCount</h3>
                    </div>
                    <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-3">
                        <i class="bi bi-activity fs-3"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="/nursing/vitals" class="small text-primary text-decoration-none fw-semibold">
                        Go to Vitals <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Notes Card -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 p-3 bg-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-secondary small fw-bold d-block mb-1">NOTES LOGGED TODAY</span>
                        <h3 class="fw-bold mb-0 text-dark">@notesCount</h3>
                    </div>
                    <div class="bg-success bg-opacity-10 text-success rounded-3 p-3">
                        <i class="bi bi-clipboard-pulse fs-3"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="/nursing/notes" class="small text-success text-decoration-none fw-semibold">
                        Go to Notes <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- MAR Card -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 p-3 bg-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-secondary small fw-bold d-block mb-1">MEDS ADMINISTERED TODAY</span>
                        <h3 class="fw-bold mb-0 text-dark">@marCount</h3>
                    </div>
                    <div class="bg-info bg-opacity-10 text-info rounded-3 p-3">
                        <i class="bi bi-capsule fs-3"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="/nursing/mar" class="small text-info text-decoration-none fw-semibold">
                        Go to MAR <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Alerts Card -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 p-3 bg-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-secondary small fw-bold d-block mb-1">CRITICAL ALERTS TODAY</span>
                        <h3 class="fw-bold mb-0 @(alertsCount > 0 ? "text-danger" : "text-muted")">@alertsCount</h3>
                    </div>
                    <div class="bg-danger bg-opacity-10 text-danger rounded-3 p-3">
                        <i class="bi bi-exclamation-triangle-fill fs-3"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <span class="small text-muted">Generated from abnormal vitals</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Active Admissions Table -->
    <div class="card border-0 shadow-sm p-4 bg-white">
        <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-people-fill me-2 text-primary"></i>Currently Admitted Patients</h5>
        
        @if (isLoading)
        {
            <div class="d-flex align-items-center py-4">
                <div class="spinner-border text-primary me-3" role="status"></div>
                <span class="text-secondary">Loading active patient admissions...</span>
            </div>
        }
        else if (activeAdmissions.Count == 0)
        {
            <div class="alert alert-info border-0 mb-0">
                <i class="bi bi-info-circle me-2"></i>No patients are currently admitted to the ward.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Patient / MRN</th>
                            <th>Ward & Bed</th>
                            <th>Admission Date</th>
                            <th>Admitting Doctor</th>
                            <th>Quick Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var admission in activeAdmissions)
                        {
                            var patientName = admission.Patient != null ? $"{admission.Patient.FirstName} {admission.Patient.LastName}" : "Unknown";
                            var mrn = admission.Patient?.Mrn ?? "N/A";
                            var bedInfo = bedSummaries.TryGetValue(admission.PatientId, out var bs) ? $"{bs.WardName} - Bed {bs.BedNumber}" : "Loading...";
                            
                            <tr>
                                <td>
                                    <div class="fw-bold text-dark">@patientName</div>
                                    <small class="text-muted">MRN: @mrn</small>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@bedInfo</span>
                                </td>
                                <td>
                                    <div>@admission.AdmissionDate.ToString("dd MMM yyyy")</div>
                                    <small class="text-muted">@admission.AdmissionDate.ToString("hh:mm tt")</small>
                                </td>
                                <td>
                                    <div class="text-dark"><i class="bi bi-person-badge-fill text-muted me-1"></i>@(admission.AdmittingDoctor ?? "Not assigned")</div>
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => RecordVitals(admission.PatientId)">
                                            <i class="bi bi-activity"></i> Record Vitals
                                        </button>
                                        <button class="btn btn-sm btn-outline-success" @onclick="() => AddNote(admission.PatientId)">
                                            <i class="bi bi-clipboard-plus"></i> Add Note
                                        </button>
                                        <button class="btn btn-sm btn-outline-info" @onclick="() => AdministerMed(admission.PatientId)">
                                            <i class="bi bi-capsule"></i> MAR
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private int vitalsCount = 0;
    private int notesCount = 0;
    private int marCount = 0;
    private int alertsCount = 0;
    private bool isLoading = true;
    private Guid currentTenantId = Guid.Empty;

    private List<BedAllotment> activeAdmissions = new();
    private Dictionary<Guid, BedSummary> bedSummaries = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var tenantIdOpt = CurrentUserHelper.GetTenantId(user);

        if (tenantIdOpt.HasValue)
        {
            currentTenantId = tenantIdOpt.Value;
            var todayUtc = DateTime.UtcNow.Date;

            // Load statistics counts
            vitalsCount = await DbContext.VitalSigns
                .Where(v => v.TenantId == currentTenantId && v.RecordedAt >= todayUtc)
                .CountAsync();

            notesCount = await DbContext.NursingNotes
                .Where(n => n.TenantId == currentTenantId && n.NoteDateTime >= todayUtc)
                .CountAsync();

            marCount = await DbContext.MedicationAdministrationRecords
                .Where(m => m.TenantId == currentTenantId && m.AdministeredAt >= todayUtc)
                .CountAsync();

            alertsCount = await DbContext.InAppNotifications
                .Where(n => n.TenantId == currentTenantId && n.ResourceType == "VitalSigns" && n.CreatedAt >= todayUtc)
                .CountAsync();

            // Load active admissions
            activeAdmissions = await DbContext.BedAllotments
                .Include(a => a.Patient)
                .Where(a => a.Status == "Active" && a.TenantId == currentTenantId)
                .OrderByDescending(a => a.AdmissionDate)
                .Take(20)
                .ToListAsync();

            // Load bed info for each patient
            foreach (var adm in activeAdmissions)
            {
                var summary = await BedReadModel.GetCurrentAllotmentAsync(adm.PatientId, currentTenantId);
                if (summary != null)
                {
                    bedSummaries[adm.PatientId] = summary;
                }
            }
        }

        isLoading = false;
    }

    private void RecordVitals(Guid patientId)
    {
        NavigationManager.NavigateTo($"/nursing/vitals?patientId={patientId}");
    }

    private void AddNote(Guid patientId)
    {
        NavigationManager.NavigateTo($"/nursing/notes?patientId={patientId}");
    }

    private void AdministerMed(Guid patientId)
    {
        NavigationManager.NavigateTo($"/nursing/mar?patientId={patientId}");
    }
}
