@page "/nursing"
@rendermode InteractiveServer
@inject CareSphere.Data.ApplicationDbContext DbContext
@inject IBedReadModel BedReadModel
@inject TabIsolatedAuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@using Microsoft.EntityFrameworkCore

<PageTitle>Nursing Dashboard - CareSphere</PageTitle>

<div class="page-header">
    <div class="page-header-content">
        <div class="page-title-group">
            <div class="page-icon"><i class="bi bi-heart-pulse-fill"></i></div>
            <div>
                <h1 class="page-title">Nursing Dashboard</h1>
                <p class="page-subtitle">Overview of active patients, daily clinical activity logs, and critical events</p>
            </div>
        </div>
    </div>
</div>

<!-- Quick Stats -->
<div class="row g-4 mb-4">
    <!-- Vitals Card -->
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card-primary" style="cursor: pointer;" @onclick='() => NavigationManager.NavigateTo("/nursing/vitals")'>
            <div class="stat-icon"><i class="bi bi-activity"></i></div>
            <div class="stat-value">@vitalsCount</div>
            <div class="stat-label">Vitals Recorded Today</div>
        </div>
    </div>

    <!-- Notes Card -->
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card-success" style="cursor: pointer;" @onclick='() => NavigationManager.NavigateTo("/nursing/notes")'>
            <div class="stat-icon"><i class="bi bi-clipboard-pulse"></i></div>
            <div class="stat-value">@notesCount</div>
            <div class="stat-label">Notes Logged Today</div>
        </div>
    </div>

    <!-- MAR Card -->
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card-info" style="cursor: pointer;" @onclick='() => NavigationManager.NavigateTo("/nursing/mar")'>
            <div class="stat-icon"><i class="bi bi-capsule"></i></div>
            <div class="stat-value">@marCount</div>
            <div class="stat-label">Meds Administered Today</div>
        </div>
    </div>

    <!-- Alerts Card -->
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card @(alertsCount > 0 ? "stat-card-danger" : "stat-card-secondary")">
            <div class="stat-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
            <div class="stat-value">@alertsCount</div>
            <div class="stat-label">Critical Alerts Today</div>
        </div>
    </div>
</div>

<!-- Active Admissions Table -->
<div class="content-card mb-4">
    <div class="content-card-header">
        <h5 class="content-card-title"><i class="bi bi-people-fill me-2 text-primary"></i>Currently Admitted Patients</h5>
    </div>
    <div class="content-card-body p-0">
        @if (isLoading)
        {
            <div class="loading-state py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 text-muted">Loading active admissions...</p>
            </div>
        }
        else if (activeAdmissions.Count == 0)
        {
            <div class="loading-state py-5">
                <i class="bi bi-info-circle text-muted display-4 mb-3 d-block"></i>
                <h5 class="fw-bold">No Admitted Patients</h5>
                <p class="text-muted small">No patients are currently admitted to the ward.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover data-table mb-0 small">
                    <thead>
                        <tr>
                            <th class="ps-4">Patient / MRN</th>
                            <th>Ward &amp; Bed</th>
                            <th>Admission Date</th>
                            <th>Admitting Doctor</th>
                            <th class="pe-4 text-end">Quick Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var admission in activeAdmissions)
                        {
                            var patientName = admission.Patient != null ? $"{admission.Patient.FirstName} {admission.Patient.LastName}" : "Unknown";
                            var mrn = admission.Patient?.Mrn ?? "N/A";
                            var bedInfo = bedSummaries.TryGetValue(admission.PatientId, out var bs) ? $"{bs.WardName} - Bed {bs.BedNumber}" : "Loading...";
                            
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-semibold text-dark">@patientName</div>
                                    <small class="text-muted">MRN: @mrn</small>
                                </td>
                                <td>
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">@bedInfo</span>
                                </td>
                                <td>
                                    <div>@admission.AdmissionDate.ToString("dd MMM yyyy")</div>
                                    <small class="text-muted">@admission.AdmissionDate.ToString("hh:mm tt")</small>
                                </td>
                                <td>
                                    <div class="text-dark fw-medium"><i class="bi bi-person-badge-fill text-muted me-1"></i>@(admission.AdmittingDoctor ?? "Not assigned")</div>
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="d-flex justify-content-end gap-1">
                                        <button class="btn btn-xs btn-outline-primary" @onclick="() => RecordVitals(admission.PatientId)">
                                            <i class="bi bi-activity me-1"></i> Vitals
                                        </button>
                                        <button class="btn btn-xs btn-outline-success" @onclick="() => AddNote(admission.PatientId)">
                                            <i class="bi bi-clipboard-plus me-1"></i> Note
                                        </button>
                                        <button class="btn btn-xs btn-outline-info" @onclick="() => AdministerMed(admission.PatientId)">
                                            <i class="bi bi-capsule me-1"></i> MAR
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private int vitalsCount = 0;
    private int notesCount = 0;
    private int marCount = 0;
    private int alertsCount = 0;
    private bool isLoading = true;
    private Guid currentTenantId = Guid.Empty;

    private List<BedAllotment> activeAdmissions = new();
    private Dictionary<Guid, BedSummary> bedSummaries = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var tenantIdOpt = CurrentUserHelper.GetTenantId(user);

        if (tenantIdOpt.HasValue)
        {
            currentTenantId = tenantIdOpt.Value;
            var todayUtc = DateTime.UtcNow.Date;

            // Load statistics counts
            vitalsCount = await DbContext.VitalSigns
                .Where(v => v.TenantId == currentTenantId && v.RecordedAt >= todayUtc)
                .CountAsync();

            notesCount = await DbContext.NursingNotes
                .Where(n => n.TenantId == currentTenantId && n.NoteDateTime >= todayUtc)
                .CountAsync();

            marCount = await DbContext.MedicationAdministrationRecords
                .Where(m => m.TenantId == currentTenantId && m.AdministeredAt >= todayUtc)
                .CountAsync();

            alertsCount = await DbContext.InAppNotifications
                .Where(n => n.TenantId == currentTenantId && n.ResourceType == "VitalSigns" && n.CreatedAt >= todayUtc)
                .CountAsync();

            // Load active admissions
            activeAdmissions = await DbContext.BedAllotments
                .Include(a => a.Patient)
                .Where(a => a.Status == "Active" && a.TenantId == currentTenantId)
                .OrderByDescending(a => a.AdmissionDate)
                .Take(20)
                .ToListAsync();

            // Load bed info for each patient
            foreach (var adm in activeAdmissions)
            {
                var summary = await BedReadModel.GetCurrentAllotmentAsync(adm.PatientId, currentTenantId);
                if (summary != null)
                {
                    bedSummaries[adm.PatientId] = summary;
                }
            }
        }

        isLoading = false;
    }

    private void RecordVitals(Guid patientId)
    {
        NavigationManager.NavigateTo($"/nursing/vitals?patientId={patientId}");
    }

    private void AddNote(Guid patientId)
    {
        NavigationManager.NavigateTo($"/nursing/notes?patientId={patientId}");
    }

    private void VoidAdmission(Guid patientId)
    {
        // Placeholder or unused
    }

    private void AdministerMed(Guid patientId)
    {
        NavigationManager.NavigateTo($"/nursing/mar?patientId={patientId}");
    }
}
