@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Authorization
@using CareSphere.Infrastructure
@using CareSphere.Components
@using CareSphere.Components.Layout
@inject PageTitleService PageTitle
@implements IDisposable

<div class="layout-container">
    <NavMenu />

    <div class="flex-grow-1 d-flex flex-column min-width-0">
        <header class="navbar-top">
            <div class="d-flex align-items-center">
                <button class="btn d-md-none border-0 p-1 me-2 text-dark" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebar" aria-controls="sidebar">
                    <i class="bi bi-list fs-3"></i>
                </button>
                <h4 class="navbar-top-title">@PageTitle.Title</h4>
            </div>
            <div class="d-flex align-items-center gap-3">
                <AuthorizeView>
                    <Authorized>
                        <a href="/" class="btn btn-outline-secondary btn-sm rounded-pill px-3"><i class="bi bi-house-door-fill me-1"></i> Home</a>
                        <a class="btn btn-outline-danger btn-sm rounded-pill px-3" href="/auth/logout"><i class="bi bi-box-arrow-right me-1"></i> Sign Out</a>
                    </Authorized>
                </AuthorizeView>
            </div>
        </header>
        <main class="flex-grow-1 p-4 overflow-auto" style="height: calc(100vh - 64px); background-color: var(--surface-bg);">
            <ImpersonationBanner />
            @Body
        </main>
    </div>
</div>

@code {
    protected override void OnInitialized() => PageTitle.OnTitleChanged += StateHasChanged;
    public void Dispose() => PageTitle.OnTitleChanged -= StateHasChanged;
}
