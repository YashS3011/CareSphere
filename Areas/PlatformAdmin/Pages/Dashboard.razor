@page "/platform-admin"
@layout CareSphere.Areas.PlatformAdmin.Layout.PlatformAdminLayout
@rendermode InteractiveServer
@inject CareSphere.Data.ApplicationDbContext DbContext
@inject AuthenticationStateProvider AuthStateProvider
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims

<PageTitle>Platform Dashboard — CareSphere</PageTitle>

<div class="row mb-4">
    <div class="col-12">
        <h2 class="fw-bold text-dark mb-1">Platform Operations Dashboard</h2>
        <p class="text-muted">Overview of system health, active tenants, and platform administration.</p>
    </div>
</div>

@if (loading)
{
    <div class="d-flex justify-content-center align-items-center py-5">
        <div class="spinner-border text-warning" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Loading dashboard data...</span>
        </div>
    </div>
}
else
{
    <!-- Stat Cards -->
    <div class="row g-4 mb-4">
        <!-- Total Tenants -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 border-start border-primary border-4 h-100 py-2">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase text-muted fw-bold mb-1 small">Total Tenants</h6>
                            <h2 class="mb-0 fw-bold">@totalTenants</h2>
                        </div>
                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3 d-flex align-items-center justify-content-center" style="width: 55px; height: 55px;">
                            <i class="bi bi-building fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Hospitals -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 border-start border-success border-4 h-100 py-2">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase text-muted fw-bold mb-1 small">Total Hospitals</h6>
                            <h2 class="mb-0 fw-bold">@totalHospitals</h2>
                        </div>
                        <div class="bg-success bg-opacity-10 text-success rounded-circle p-3 d-flex align-items-center justify-content-center" style="width: 55px; height: 55px;">
                            <i class="bi bi-hospital fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Active Users -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 border-start border-warning border-4 h-100 py-2">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase text-muted fw-bold mb-1 small">Total Active Users</h6>
                            <h2 class="mb-0 fw-bold">@totalActiveUsers</h2>
                        </div>
                        <div class="bg-warning bg-opacity-10 text-warning rounded-circle p-3 d-flex align-items-center justify-content-center" style="width: 55px; height: 55px;">
                            <i class="bi bi-people-fill fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Admin profile info -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white fw-bold py-3">
                    <i class="bi bi-person-badge-fill me-2 text-warning"></i> Platform Admin Information
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="text-muted small fw-bold text-uppercase d-block mb-1">Full Name</label>
                            <div class="fs-5 fw-semibold">@adminName</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted small fw-bold text-uppercase d-block mb-1">Email Address</label>
                            <div class="fs-5 fw-semibold text-primary">@adminEmail</div>
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-md-6">
                            <label class="text-muted small fw-bold text-uppercase d-block mb-1">Role Claim Value</label>
                            <div><span class="badge bg-danger text-white fs-6 px-3 py-1">platform_super_admin</span></div>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small fw-bold text-uppercase d-block mb-1">Tenant ID scope</label>
                            <div class="font-monospace text-muted">Guid.Empty (Cross-Tenant Scope)</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private int totalTenants;
    private int totalHospitals;
    private int totalActiveUsers;
    private string adminName = "Platform Super Admin";
    private string adminEmail = "platformadmin@caresphere.dev";

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            // Fetch cross-tenant stats ignoring query filters
            totalTenants = await DbContext.TenantSettings.IgnoreQueryFilters().CountAsync();
            totalHospitals = totalTenants;
            totalActiveUsers = await DbContext.Users.IgnoreQueryFilters().Cast<ApplicationUser>().CountAsync(u => u.IsActive);

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                adminName = user.FindFirst(CareSphere.CareSphereClaimTypes.FullName)?.Value ?? user.Identity.Name ?? "Platform Super Admin";
                adminEmail = user.FindFirst(ClaimTypes.Email)?.Value ?? user.Identity.Name ?? "platformadmin@caresphere.dev";
            }
        }
        catch (Exception ex)
        {
            // Log or show errors
        }
        finally
        {
            loading = false;
        }
    }
}
