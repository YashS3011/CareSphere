@page "/platform-admin/tenants"
@layout CareSphere.Areas.PlatformAdmin.Layout.PlatformAdminLayout
@rendermode InteractiveServer
@inject CareSphere.Data.ApplicationDbContext DbContext
@inject IImpersonationService ImpersonationService
@inject NavigationManager NavigationManager
@using Microsoft.EntityFrameworkCore

<PageTitle>Tenant Management — CareSphere</PageTitle>

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h2 class="fw-bold text-dark mb-1">Tenant Management</h2>
        <p class="text-muted">Manage tenant settings, subscription limits, SSO integrations, and impersonate administrators.</p>
    </div>
</div>

@if (!string.IsNullOrEmpty(impersonateError))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-octagon-fill me-2"></i> @impersonateError
        <button type="button" class="btn-close" @onclick="() => impersonateError = null" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-4">
        <!-- Client-side filter input -->
        <div class="row mb-3">
            <div class="col-md-6 col-lg-4">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control border-start-0 ps-0" placeholder="Filter by hospital name..." @bind-value="searchQuery" @bind-value:event="oninput" />
                </div>
            </div>
        </div>

        @if (loading)
        {
            <div class="d-flex justify-content-center align-items-center py-5">
                <div class="spinner-border text-warning" role="status">
                    <span class="visually-hidden">Loading tenants...</span>
                </div>
            </div>
        }
        else if (FilteredTenants.Count == 0)
        {
            <div class="text-center py-5">
                <i class="bi bi-buildings text-muted" style="font-size: 3rem;"></i>
                <p class="mt-3 text-muted">No tenants match the search filter.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle border">
                    <thead class="table-dark">
                        <tr>
                            <th>Hospital Name</th>
                            <th>Subscription Tier</th>
                            <th>Max Users Allowed</th>
                            <th>SSO Enabled</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tenant in FilteredTenants)
                        {
                            <tr>
                                <td class="fw-semibold text-dark">@tenant.HospitalName</td>
                                <td>
                                    <span class="badge @GetTierBadgeClass(tenant.SubscriptionTier) px-3 py-1">
                                        @tenant.SubscriptionTier
                                    </span>
                                </td>
                                <td>@tenant.MaxUsersAllowed</td>
                                <td>
                                    @if (tenant.SsoEnabled)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i> Enabled</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Disabled</span>
                                    }
                                </td>
                                <td>
                                    @if (tenant.IsActive)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-unlock-fill me-1"></i> Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-lock-fill me-1"></i> Frozen</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex justify-content-center gap-2">
                                        <a href="/platform-admin/tenants/edit/@tenant.Id" class="btn btn-sm btn-outline-primary fw-semibold px-3">
                                            <i class="bi bi-pencil-square me-1"></i> Edit
                                        </a>
                                        <button class="btn btn-sm btn-outline-danger fw-semibold px-3" @onclick="() => ImpersonateTenant(tenant.TenantId)">
                                            <i class="bi bi-incognito me-1"></i> Impersonate
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private bool loading = true;
    private List<CareSphere.Models.TenantSettings> tenants = new();
    private string searchQuery = string.Empty;
    private string? impersonateError;

    private List<CareSphere.Models.TenantSettings> FilteredTenants =>
        tenants.Where(t => string.IsNullOrEmpty(searchQuery) ||
                           t.HospitalName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadTenantsAsync();
    }

    private async Task LoadTenantsAsync()
    {
        loading = true;
        try
        {
            tenants = await DbContext.TenantSettings.IgnoreQueryFilters().ToListAsync();
        }
        catch (Exception ex)
        {
            impersonateError = $"Failed to load tenants: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task ImpersonateTenant(Guid tenantId)
    {
        // Find first active user in this tenant to impersonate
        var targetUser = await DbContext.Users
            .IgnoreQueryFilters()
            .Cast<ApplicationUser>()
            .FirstOrDefaultAsync(u => u.TenantId == tenantId && u.IsActive);

        if (targetUser == null)
        {
            impersonateError = "Cannot impersonate this tenant because it has no active users.";
            return;
        }

        try
        {
            impersonateError = null;
            var result = await ImpersonationService.ImpersonateAsync(tenantId, targetUser.Id);
            // Redirect via the Controller to establish cookie authentication and set session tokens
            NavigationManager.NavigateTo($"/auth/impersonate-signin?token={Uri.EscapeDataString(result.ShortLivedToken)}&returnUrl=/dashboard", forceLoad: true);
        }
        catch (Exception ex)
        {
            impersonateError = $"Impersonation failed: {ex.Message}";
        }
    }

    private string GetTierBadgeClass(string tier)
    {
        return tier.ToLower() switch
        {
            "free" => "bg-secondary text-white",
            "basic" => "bg-info text-dark",
            "professional" => "bg-primary text-white",
            "pro" => "bg-primary text-white",
            "enterprise" => "bg-dark text-warning border border-warning",
            _ => "bg-secondary text-white"
        };
    }
}
