@page "/platform-admin/tenants/edit/{id:guid}"
@layout CareSphere.Areas.PlatformAdmin.Layout.PlatformAdminLayout
@rendermode InteractiveServer
@inject CareSphere.Data.ApplicationDbContext DbContext
@inject ITenantService TenantService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims

<PageTitle>Edit Tenant — @(tenantSettings?.HospitalName ?? "Loading...")</PageTitle>

<div class="row mb-4">
    <div class="col-12">
        <a href="/platform-admin/tenants" class="btn btn-outline-secondary btn-sm mb-3">
            <i class="bi bi-arrow-left"></i> Back to Tenants
        </a>
        <h2 class="fw-bold text-dark mb-1">Edit Tenant settings</h2>
        <p class="text-muted">Modify parameters for <strong>@tenantSettings?.HospitalName</strong></p>
    </div>
</div>

@if (loading)
{
    <div class="d-flex justify-content-center align-items-center py-5">
        <div class="spinner-border text-warning" role="status">
            <span class="visually-hidden">Loading tenant settings...</span>
        </div>
    </div>
}
else if (tenantSettings == null)
{
    <div class="alert alert-danger" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> Tenant settings record not found.
    </div>
}
else
{
    <!-- Success Alert -->
    @if (showSuccessAlert)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> Tenant settings updated successfully.
            <button type="button" class="btn-close" @onclick="() => showSuccessAlert = false" aria-label="Close"></button>
        </div>
    }

    <!-- Error Alert -->
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-octagon-fill me-2"></i> @errorMessage
        </div>
    }

    <!-- Locking out warning banner -->
    <div class="alert alert-danger border-start border-danger border-4 d-flex align-items-center mb-4 shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-4 text-danger me-3"></i>
        <div class="fw-semibold text-danger">
            Warning: Disabling IsActive will immediately lock out all users of this hospital.
        </div>
    </div>

    <!-- Edit Form -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <EditForm Model="tenantSettings" OnValidSubmit="SaveSettings">
                <DataAnnotationsValidator />

                <div class="row g-4 mb-4">
                    <!-- Max Users Allowed -->
                    <div class="col-md-6">
                        <label for="maxUsers" class="form-label fw-bold">Max Users Allowed</label>
                        <InputNumber id="maxUsers" class="form-control" @bind-Value="tenantSettings.MaxUsersAllowed" min="1" />
                        <ValidationMessage For="@(() => tenantSettings.MaxUsersAllowed)" class="text-danger small" />
                    </div>

                    <!-- Subscription Tier -->
                    <div class="col-md-6">
                        <label for="subTier" class="form-label fw-bold">Subscription Tier</label>
                        <select id="subTier" class="form-select" @bind="tenantSettings.SubscriptionTier">
                            <option value="Free">Free</option>
                            <option value="Basic">Basic</option>
                            <option value="Professional">Professional</option>
                            <option value="Enterprise">Enterprise</option>
                        </select>
                    </div>
                </div>

                <div class="row g-4 mb-4">
                    <!-- SSO Enabled -->
                    <div class="col-md-6">
                        <div class="form-check form-switch p-3 bg-light rounded border">
                            <input class="form-check-input ms-0 me-3 float-start" type="checkbox" id="ssoEnabled" @bind="tenantSettings.SsoEnabled" style="width: 2.5em; height: 1.25em;" />
                            <label class="form-check-label fw-bold" for="ssoEnabled">Enable SSO Integration</label>
                            <div class="text-muted small ms-5 mt-1">Allows users of this hospital to authenticate via SAML, Google, or Microsoft OIDC.</div>
                        </div>
                    </div>

                    <!-- Tenant Active State -->
                    <div class="col-md-6">
                        <div class="form-check form-switch p-3 bg-light rounded border">
                            <input class="form-check-input ms-0 me-3 float-start" type="checkbox" id="isActive" @bind="tenantSettings.IsActive" style="width: 2.5em; height: 1.25em;" />
                            <label class="form-check-label fw-bold" for="isActive">Tenant Active Status</label>
                            <div class="text-muted small ms-5 mt-1">Freeze or activate this hospital tenant. If frozen, all users will be logged out and locked out.</div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 border-top pt-4">
                    <a href="/platform-admin/tenants" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-warning px-4 fw-bold" disabled="@saving">
                        @if (saving)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>Saving...</span>
                        }
                        else
                        {
                            <i class="bi bi-save me-1"></i>
                            <span>Save Changes</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid id { get; set; }

    private bool loading = true;
    private bool saving = false;
    private bool showSuccessAlert = false;
    private string? errorMessage;
    private CareSphere.Models.TenantSettings? tenantSettings;

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            tenantSettings = await DbContext.TenantSettings
                .IgnoreQueryFilters()
                .FirstOrDefaultAsync(t => t.Id == id);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load tenant: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task SaveSettings()
    {
        if (tenantSettings == null) return;

        saving = true;
        showSuccessAlert = false;
        errorMessage = null;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var platformAdminUserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "platform_admin";

            // Update in the service layer
            await TenantService.UpdateTenantSettingsAsync(tenantSettings, platformAdminUserId);
            showSuccessAlert = true;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to save settings: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }
}
