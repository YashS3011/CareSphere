@inherits LayoutComponentBase

<div class="min-vh-100 d-flex flex-column bg-light">
    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark px-4 shadow-sm py-2">
        <div class="container-fluid p-0">
            <a class="navbar-brand fw-bold text-white d-flex align-items-center" href="/platform-admin">
                <i class="bi bi-shield-lock-fill text-warning me-2 fs-3"></i>
                <span class="fs-4">CareSphere — Platform Admin</span>
            </a>
            
            <div class="ms-auto d-flex align-items-center gap-3">
                <span class="badge bg-warning text-dark fs-6 px-3 py-2 fw-bold rounded-pill">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i> Platform Admin Mode
                </span>
                <AuthorizeView>
                    <Authorized>
                        <a href="/auth/logout" class="btn btn-outline-light btn-sm px-3 rounded-pill fw-semibold">
                            <i class="bi bi-box-arrow-right me-1"></i> Sign Out
                        </a>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
    </nav>

    <!-- Main Content: Left Sidebar + Right Pages -->
    <div class="d-flex flex-grow-1">
        <!-- Sidebar -->
        <div class="bg-dark text-white border-top border-secondary p-3 shadow" style="width: 260px; min-height: calc(100vh - 56px);">
            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item mb-2">
                    <NavLink class="nav-link text-white d-flex align-items-center py-2 px-3 rounded" href="/platform-admin" Match="NavLinkMatch.All">
                        <i class="bi bi-speedometer2 me-3 fs-5"></i>
                        <span>Dashboard</span>
                    </NavLink>
                </li>
                <li class="nav-item mb-2">
                    <NavLink class="nav-link text-white d-flex align-items-center py-2 px-3 rounded" href="/platform-admin/tenants" Match="NavLinkMatch.Prefix">
                        <i class="bi bi-building me-3 fs-5"></i>
                        <span>Tenants</span>
                    </NavLink>
                </li>
            </ul>
        </div>

        <!-- Content Area -->
        <div class="flex-grow-1 p-4 d-flex flex-column justify-content-between">
            <div class="container-fluid p-0">
                @Body
            </div>
            
            <!-- Footer -->
            <footer class="text-center text-muted py-3 mt-5 border-top bg-white rounded shadow-sm">
                <p class="mb-0 fw-semibold text-danger">
                    <i class="bi bi-shield-fill-exclamation me-1"></i> CareSphere Platform Operations — Restricted Access
                </p>
            </footer>
        </div>
    </div>
</div>

<style>
    .nav-link.active {
        background-color: #ffc107 !important; /* bg-warning */
        color: #212529 !important; /* text-dark */
        font-weight: bold;
    }
    .nav-link:hover:not(.active) {
        background-color: rgba(255, 255, 255, 0.1);
    }
</style>
